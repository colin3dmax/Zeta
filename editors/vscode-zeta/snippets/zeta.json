{
  "module": {
    "prefix": "module",
    "body": [
      "module ${1:name};"
    ],
    "description": "Declare a Zeta module"
  },
  "import alias": {
    "prefix": "importas",
    "body": [
      "import ${1:demo.module} as ${2:alias};"
    ],
    "description": "Import a module path with a local alias"
  },
  "function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:param}: ${3:Type}) -> ${4:Result} {",
      "  ${0}",
      "}"
    ],
    "description": "Declare a Zeta function"
  },
  "export function": {
    "prefix": "exportfn",
    "body": [
      "export fn ${1:name}(${2:param}: ${3:Type}) -> ${4:Result} {",
      "  ${0}",
      "}"
    ],
    "description": "Declare an exported Zeta function"
  },
  "struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "  ${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Declare a Zeta struct"
  },
  "enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "  ${2:Variant},",
      "}"
    ],
    "description": "Declare a Zeta enum"
  },
  "let": {
    "prefix": "let",
    "body": [
      "let ${1:name}: ${2:Type} = ${3:value};"
    ],
    "description": "Declare a local binding"
  },
  "let mut": {
    "prefix": "letmut",
    "body": [
      "let mut ${1:name}: ${2:Type} = ${3:value};"
    ],
    "description": "Declare a mutable local binding"
  },
  "while count": {
    "prefix": "whilecmp",
    "body": [
      "while ${1:count} < ${2:limit} {",
      "  ${1:count} = ${1:count} + 1;",
      "}"
    ],
    "description": "Loop with an Int comparison condition"
  },
  "if bool logic": {
    "prefix": "ifbool",
    "body": [
      "if ${1:ready} && !${2:done} {",
      "  ${0}",
      "}"
    ],
    "description": "Branch with a Bool logic condition"
  },
  "read file": {
    "prefix": "readfile",
    "body": [
      "import std.io;",
      "",
      "fn ${1:main}() -> String {",
      "  let result: ResultString = file_read_to_string(${2:\"src/main.zeta\"});",
      "  match result {",
      "    ResultString.Ok(text) -> { return text; },",
      "    ResultString.Err(message) -> { return message; },",
      "  }",
      "  return \"\";",
      "}"
    ],
    "description": "Read a file through std.io ResultString"
  }
}
