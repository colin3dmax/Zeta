MirModule
  fn main -> Int
    block entry
      local value: Int mutability=immutable
      _t0 = const Int 2
      store value, _t0
      _t1 = load value
      match _t1
        arm int:1
          _t2 = const Int 10
          return _t2
        arm int:2
          _t3 = const Int 42
          return _t3
        arm _
          _t4 = const Int 0
          return _t4
      end_match
      _t5 = const Int 0
      return _t5
