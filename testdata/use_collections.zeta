// Uses std.collections without defining HashMap/HashSet/Hash/Eq itself — the
// `import std.collections;` injects them. Note it does not import std.core, yet
// the injected library's string/array builtins still resolve (the prelude
// carries its own `import std.core;`).
import std.collections;

fn main() -> Int {
  let mut h: HashMap<String, Int> = hashmap_new("", 0);
  h = hashmap_insert(h, "one", 1);
  h = hashmap_insert(h, "two", 2);
  h = hashmap_insert(h, "three", 3);
  h = hashmap_remove(h, "one");

  let mut s: HashSet<Int> = hashset_new(0);
  s = hashset_insert(s, 5);
  s = hashset_insert(s, 5);   // duplicate
  s = hashset_insert(s, 7);

  let a: Int = hashmap_get(h, "two", 0 - 1);      // 2
  let b: Int = hashmap_get(h, "one", 0 - 1);      // -1 (removed)
  let g: Int = hashmap_get(h, "three", 0 - 1);    // 3

  let mut cont: Int = 0;
  if hashmap_contains(h, "two") { cont = 1; }     // 1
  let mut setc: Int = 0;
  if hashset_contains(s, 7) { setc = 1; }         // 1

  // 2 + (-1) + 3 + 1 + 1 + size(map=2) + size(set=2) = 10
  return a + b + g + cont + setc + h.size + s.size;
}
