// Recursive factorial + fibonacci: exercises call-frame isolation (each frame
// rebinds `n` without seeing the caller's `n`) and deep self-recursion.
fn fact(n: Int) -> Int {
  if n <= 1 {
    return 1;
  }
  return n * fact(n - 1);
}

fn fib(n: Int) -> Int {
  if n < 2 {
    return n;
  }
  return fib(n - 1) + fib(n - 2);
}

fn main() -> Int {
  // 5! = 120, fib(10) = 55 -> 175
  return fact(5) + fib(10);
}
