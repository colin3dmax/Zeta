// Deep for-c loop wrapping a for-range loop, with a break/continue inside the
// range body. Exercises nested binding scopes (the for-c `k` stays live across
// iterations while each range `i` is freshly scoped per iteration).
fn main() -> Int {
  let mut sum: Int = 0;
  for (let mut k: Int = 0; k < 4; k = k + 1) {
    for i in 0..4 {
      if i == k {
        continue;
      }
      if i == 3 {
        break;
      }
      sum = sum + (k * 10 + i);
    }
  }
  return sum;
}
