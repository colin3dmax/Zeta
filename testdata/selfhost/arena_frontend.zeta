module selfhost.arena_frontend;
import std.core;

// ---------------------------------------------------------------------------
// Self-hosting milestone M2 vertical slice.
//
// Unlike the Stage1 frontend (which concatenates dump text directly while
// scanning tokens), this module builds a *real* AST as an index-based arena and
// then walks that arena to produce the dump. This is the范式 that later stages
// (resolver / typecheck / MIR / interpreter) will reuse, so clarity and
// correctness matter more than speed.
//
// Two cooperating arenas:
//   * Expr arena  — parallel arrays (node_kind / node_a / node_b / node_text).
//                   Built post-order so a parent is allocated only after its
//                   children, letting it reference their already-known indices
//                   without any back-patching.
//   * Item arenas — parallel arrays describing the structural skeleton
//                   (function list + statement arena), each pointing into the
//                   expr arena for its expression children.
//
// Statements form a *tree* (if/while carry nested statement blocks). We keep
// every statement in one flat statement arena (post-order) and record each
// block's children as a contiguous (start, count) slice into a separate
// `block_list` index array. Because statements are pushed post-order, a parent's
// direct children are *not* contiguous in the statement arena itself, so each
// block first gathers its direct child statement indices into a local list and
// only then appends them to `block_list` as one contiguous run.
//
// Pipeline: lex -> recursive descent that *constructs* the arena -> walk the
// arena to emit dump text byte-for-byte identical to the Rust `ast-dump`.
// ---------------------------------------------------------------------------

// Expr node kinds.
fn int_node() -> Int { return 0; }
fn name_node() -> Int { return 1; }
fn binary_node() -> Int { return 2; }
fn bool_node() -> Int { return 3; }
fn unary_node() -> Int { return 4; }
fn string_node() -> Int { return 5; }
fn call_node() -> Int { return 6; }
fn index_node() -> Int { return 7; }
fn field_node() -> Int { return 8; }
fn array_node() -> Int { return 9; }
fn struct_lit_node() -> Int { return 10; }
fn range_node() -> Int { return 11; }

// Top-level item kinds (the item list is dumped in source order).
fn item_import() -> Int { return 0; }
fn item_struct() -> Int { return 1; }
fn item_enum() -> Int { return 2; }
fn item_function() -> Int { return 3; }

// Statement kinds.
fn let_stmt() -> Int { return 0; }
fn return_stmt() -> Int { return 1; }
fn if_stmt() -> Int { return 2; }
fn while_stmt() -> Int { return 3; }
fn assign_stmt() -> Int { return 4; }
fn expr_stmt() -> Int { return 5; }
fn break_stmt() -> Int { return 6; }
fn continue_stmt() -> Int { return 7; }
fn for_in_stmt() -> Int { return 8; }
fn for_c_stmt() -> Int { return 9; }
fn match_stmt() -> Int { return 10; }

// ---------------------------------------------------------------------------
// Arena: a bundle of parallel arrays threaded functionally through the parser.
// Every parse_* helper takes a ParseResult-shaped struct in and returns an
// updated one out (Zeta has no mutable aliasing across calls, so we accumulate
// by value).
// ---------------------------------------------------------------------------
struct Arena {
  // Expr arena.
  node_kind: IntArray,
  node_a: IntArray,
  node_b: IntArray,
  node_text: StringArray,
  // Variable-arity expr children (call args, array elements) sliced via
  // (start, count) recorded in node_a/node_b of the owning node.
  child_list: IntArray,
  // Struct-literal field inits: parallel name/value arrays, sliced via
  // (start, count) in node_a/node_b of the owning StructLiteral node.
  sl_field_name: StringArray,
  sl_field_value: IntArray,
  // Field-name ident token start per struct-literal field, parallel to
  // sl_field_name (single token: end = start + len(name)). TYPE_DUPLICATE_FIELD
  // and TYPE_UNKNOWN_FIELD point at the field name, mirroring Rust's name_span.
  sl_field_name_span_start: IntArray,
  // Module decl: has_module=1 when a `module a.b.c;` was present.
  has_module: Int,
  module_name: String,
  // Unified source-order item list. item_kind picks the per-kind table and
  // item_ref is the row index inside that table.
  item_kind: IntArray,
  item_ref: IntArray,
  // Import table.
  import_path: StringArray,
  import_alias: StringArray,
  import_exported: IntArray,
  // Struct table (fields sliced via field_start/field_count into the field arena).
  struct_name: StringArray,
  struct_exported: IntArray,
  struct_field_start: IntArray,
  struct_field_count: IntArray,
  field_name: StringArray,
  field_type: StringArray,
  // Enum table (variants sliced via variant_start/variant_count).
  enum_name: StringArray,
  enum_exported: IntArray,
  enum_variant_start: IntArray,
  enum_variant_count: IntArray,
  variant_name: StringArray,
  variant_payload: StringArray,
  // Function list.
  fn_name: StringArray,
  fn_exported: IntArray,
  fn_has_ret: IntArray,
  fn_ret: StringArray,
  fn_param_start: IntArray,
  fn_param_count: IntArray,
  fn_body_start: IntArray,
  fn_body_count: IntArray,
  // Parameter list (sliced per function via start/count above).
  param_name: StringArray,
  param_type: StringArray,
  // Statement arena (a flat post-order pool; tree shape lives in block_list).
  stmt_kind: IntArray,
  stmt_name: StringArray,
  stmt_type: StringArray,
  stmt_has_type: IntArray,
  stmt_mut: IntArray,
  stmt_expr: IntArray,
  stmt_then_start: IntArray,
  stmt_then_count: IntArray,
  stmt_else_start: IntArray,
  stmt_else_count: IntArray,
  // Complex assignment target expr (-1 when the Assign uses a simple `name=`).
  stmt_target: IntArray,
  // ForC: statement-arena indices of the init and step statements.
  stmt_init: IntArray,
  stmt_step: IntArray,
  // Flat list of statement indices; blocks reference contiguous slices of it.
  block_list: IntArray,
  // Match arms: parallel pattern-text / body-slice arrays. A Match statement
  // slices these via (then_start, then_count); each arm's body is a contiguous
  // run in block_list referenced by (arm_body_start, arm_body_count).
  arm_pattern: StringArray,
  arm_body_start: IntArray,
  arm_body_count: IntArray,
  // Token byte offsets, parallel to the lexer's kinds/texts arrays. Set by the
  // entry points right after lexing; the parser reads it to record spans.
  token_start: IntArray,
  // Name-reference spans per expr node: Name nodes carry the ident token span,
  // Call nodes the dotted-callee-path span (first ident start .. last ident
  // end), FieldAccess nodes the field ident token span (Rust's field_span),
  // StructLiteral nodes the type-name token span (Rust's ty_span); -1/-1 for
  // every other node kind.
  node_span_start: IntArray,
  node_span_end: IntArray,
  // Full expression spans per expr node, mirroring the Rust Expr::span():
  // every node kind records the byte range of its complete source text
  // (literals: the token; unary: op..operand end; binary/range: left start..
  // right end; call: callee start..")"; index: base..."]"; field: base..field
  // ident end; array: "["..."]"; struct literal: type name..."}"). A
  // parenthesized expression keeps the inner node's span unchanged — the Rust
  // parser does the same (parse_primary returns the inner expr as-is).
  node_full_start: IntArray,
  node_full_end: IntArray,
  // Start offset of the binding ident for let rows and of the target ident for
  // simple-assign rows; -1 for other statement kinds. Single-ident spans store
  // only the start — the end is always start + len(name).
  stmt_name_span_start: IntArray,
  param_name_span_start: IntArray,
  fn_name_span_start: IntArray,
  struct_name_span_start: IntArray,
  enum_name_span_start: IntArray,
  // Declared-type token spans (every type name in the language is a single
  // ident token, so only the start is stored; end = start + len(name)).
  // -1 marks "no type here" (payload-less enum variants / fns without `->` /
  // untyped lets / non-let statement rows).
  field_type_span_start: IntArray,
  variant_payload_span_start: IntArray,
  param_type_span_start: IntArray,
  fn_ret_span_start: IntArray,
  stmt_type_span_start: IntArray,
  // Import path span (multi-token, so start and end are both recorded).
  import_path_span_start: IntArray,
  import_path_span_end: IntArray,
}

fn arena_empty() -> Arena {
  return Arena {
    node_kind: int_array_empty(),
    node_a: int_array_empty(),
    node_b: int_array_empty(),
    node_text: string_array_empty(),
    child_list: int_array_empty(),
    sl_field_name: string_array_empty(),
    sl_field_value: int_array_empty(),
    sl_field_name_span_start: int_array_empty(),
    has_module: 0,
    module_name: "",
    item_kind: int_array_empty(),
    item_ref: int_array_empty(),
    import_path: string_array_empty(),
    import_alias: string_array_empty(),
    import_exported: int_array_empty(),
    struct_name: string_array_empty(),
    struct_exported: int_array_empty(),
    struct_field_start: int_array_empty(),
    struct_field_count: int_array_empty(),
    field_name: string_array_empty(),
    field_type: string_array_empty(),
    enum_name: string_array_empty(),
    enum_exported: int_array_empty(),
    enum_variant_start: int_array_empty(),
    enum_variant_count: int_array_empty(),
    variant_name: string_array_empty(),
    variant_payload: string_array_empty(),
    fn_name: string_array_empty(),
    fn_exported: int_array_empty(),
    fn_has_ret: int_array_empty(),
    fn_ret: string_array_empty(),
    fn_param_start: int_array_empty(),
    fn_param_count: int_array_empty(),
    fn_body_start: int_array_empty(),
    fn_body_count: int_array_empty(),
    param_name: string_array_empty(),
    param_type: string_array_empty(),
    stmt_kind: int_array_empty(),
    stmt_name: string_array_empty(),
    stmt_type: string_array_empty(),
    stmt_has_type: int_array_empty(),
    stmt_mut: int_array_empty(),
    stmt_expr: int_array_empty(),
    stmt_then_start: int_array_empty(),
    stmt_then_count: int_array_empty(),
    stmt_else_start: int_array_empty(),
    stmt_else_count: int_array_empty(),
    stmt_target: int_array_empty(),
    stmt_init: int_array_empty(),
    stmt_step: int_array_empty(),
    block_list: int_array_empty(),
    arm_pattern: string_array_empty(),
    arm_body_start: int_array_empty(),
    arm_body_count: int_array_empty(),
    token_start: int_array_empty(),
    node_span_start: int_array_empty(),
    node_span_end: int_array_empty(),
    node_full_start: int_array_empty(),
    node_full_end: int_array_empty(),
    stmt_name_span_start: int_array_empty(),
    param_name_span_start: int_array_empty(),
    fn_name_span_start: int_array_empty(),
    struct_name_span_start: int_array_empty(),
    enum_name_span_start: int_array_empty(),
    field_type_span_start: int_array_empty(),
    variant_payload_span_start: int_array_empty(),
    param_type_span_start: int_array_empty(),
    fn_ret_span_start: int_array_empty(),
    stmt_type_span_start: int_array_empty(),
    import_path_span_start: int_array_empty(),
    import_path_span_end: int_array_empty(),
  };
}

// ParseResult packs the threaded arena plus the index of the node just built
// and the token cursor consumed so far.
struct ParseResult {
  arena: Arena,
  node: Int,
  pos: Int,
}

// BlockResult is returned by block parsers: it carries the (start, count) slice
// into block_list describing the statements just parsed, plus the cursor.
struct BlockResult {
  arena: Arena,
  start: Int,
  count: Int,
  pos: Int,
}

// ---------------------------------------------------------------------------
// Node allocation (post-order). Each pusher appends to every parallel array so
// the arrays stay the same length and the new node's index is the pre-push len.
// ---------------------------------------------------------------------------
fn push_int_node(arena: Arena, text: String, full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, int_node());
  a.node_a = int_array_push(a.node_a, 0);
  a.node_b = int_array_push(a.node_b, 0);
  a.node_text = string_array_push(a.node_text, text);
  a.node_span_start = int_array_push(a.node_span_start, 0 - 1);
  a.node_span_end = int_array_push(a.node_span_end, 0 - 1);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// Name carries the span of its identifier token (a Name reference diagnostic
// points at exactly that token).
fn push_name_node(arena: Arena, text: String, span_start: Int, span_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, name_node());
  a.node_a = int_array_push(a.node_a, 0);
  a.node_b = int_array_push(a.node_b, 0);
  a.node_text = string_array_push(a.node_text, text);
  a.node_span_start = int_array_push(a.node_span_start, span_start);
  a.node_span_end = int_array_push(a.node_span_end, span_end);
  // A Name's full span IS its ident token span.
  a.node_full_start = int_array_push(a.node_full_start, span_start);
  a.node_full_end = int_array_push(a.node_full_end, span_end);
  return a;
}

fn push_bool_node(arena: Arena, text: String, full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, bool_node());
  a.node_a = int_array_push(a.node_a, 0);
  a.node_b = int_array_push(a.node_b, 0);
  a.node_text = string_array_push(a.node_text, text);
  a.node_span_start = int_array_push(a.node_span_start, 0 - 1);
  a.node_span_end = int_array_push(a.node_span_end, 0 - 1);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

fn push_unary_node(arena: Arena, operand: Int, op: String, full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, unary_node());
  a.node_a = int_array_push(a.node_a, operand);
  a.node_b = int_array_push(a.node_b, 0);
  a.node_text = string_array_push(a.node_text, op);
  a.node_span_start = int_array_push(a.node_span_start, 0 - 1);
  a.node_span_end = int_array_push(a.node_span_end, 0 - 1);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

fn push_binary_node(arena: Arena, left: Int, right: Int, op: String, full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, binary_node());
  a.node_a = int_array_push(a.node_a, left);
  a.node_b = int_array_push(a.node_b, right);
  a.node_text = string_array_push(a.node_text, op);
  a.node_span_start = int_array_push(a.node_span_start, 0 - 1);
  a.node_span_end = int_array_push(a.node_span_end, 0 - 1);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// String literal: text is the raw token slice (quotes included); the dump pass
// normalizes escapes to match Rust's Debug formatting.
fn push_string_node(arena: Arena, text: String, full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, string_node());
  a.node_a = int_array_push(a.node_a, 0);
  a.node_b = int_array_push(a.node_b, 0);
  a.node_text = string_array_push(a.node_text, text);
  a.node_span_start = int_array_push(a.node_span_start, 0 - 1);
  a.node_span_end = int_array_push(a.node_span_end, 0 - 1);
  // Quotes included: the raw token slice length IS the Rust token span length.
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// Call: text is the dotted callee path; (arg_start, arg_count) slice child_list.
// The span covers the callee path only (first ident start .. last ident end),
// matching the Rust parser's callee_span.
fn push_call_node(arena: Arena, callee: String, arg_start: Int, arg_count: Int, span_start: Int, span_end: Int,
                  full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, call_node());
  a.node_a = int_array_push(a.node_a, arg_start);
  a.node_b = int_array_push(a.node_b, arg_count);
  a.node_text = string_array_push(a.node_text, callee);
  a.node_span_start = int_array_push(a.node_span_start, span_start);
  a.node_span_end = int_array_push(a.node_span_end, span_end);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// Index: node_a is the base expr, node_b is the index expr.
fn push_index_node(arena: Arena, base: Int, index: Int, full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, index_node());
  a.node_a = int_array_push(a.node_a, base);
  a.node_b = int_array_push(a.node_b, index);
  a.node_text = string_array_push(a.node_text, "");
  a.node_span_start = int_array_push(a.node_span_start, 0 - 1);
  a.node_span_end = int_array_push(a.node_span_end, 0 - 1);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// FieldAccess: node_a is the base expr, text is the field name. (span_start,
// span_end) is the field ident token span — TYPE_ARRAY_FIELD and
// TYPE_UNKNOWN_FIELD point at the field name, mirroring Rust's field_span.
fn push_field_node(arena: Arena, base: Int, field: String, span_start: Int, span_end: Int,
                   full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, field_node());
  a.node_a = int_array_push(a.node_a, base);
  a.node_b = int_array_push(a.node_b, 0);
  a.node_text = string_array_push(a.node_text, field);
  a.node_span_start = int_array_push(a.node_span_start, span_start);
  a.node_span_end = int_array_push(a.node_span_end, span_end);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// ArrayLiteral: (elem_start, elem_count) slice child_list.
fn push_array_node(arena: Arena, elem_start: Int, elem_count: Int, full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, array_node());
  a.node_a = int_array_push(a.node_a, elem_start);
  a.node_b = int_array_push(a.node_b, elem_count);
  a.node_text = string_array_push(a.node_text, "");
  a.node_span_start = int_array_push(a.node_span_start, 0 - 1);
  a.node_span_end = int_array_push(a.node_span_end, 0 - 1);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// Range: node_a is the start expr, node_b is the end expr.
fn push_range_node(arena: Arena, start: Int, end: Int, full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, range_node());
  a.node_a = int_array_push(a.node_a, start);
  a.node_b = int_array_push(a.node_b, end);
  a.node_text = string_array_push(a.node_text, "");
  a.node_span_start = int_array_push(a.node_span_start, 0 - 1);
  a.node_span_end = int_array_push(a.node_span_end, 0 - 1);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// StructLiteral: text is the type name; (field_start, field_count) slice the
// parallel sl_field_name / sl_field_value arrays. (span_start, span_end) is the
// type-name token span — TYPE_UNKNOWN_STRUCT and TYPE_MISSING_FIELD point at
// the type name, mirroring Rust's ty_span.
fn push_struct_lit_node(arena: Arena, type_name: String, field_start: Int, field_count: Int,
                        span_start: Int, span_end: Int,
                        full_start: Int, full_end: Int) -> Arena {
  let mut a: Arena = arena;
  a.node_kind = int_array_push(a.node_kind, struct_lit_node());
  a.node_a = int_array_push(a.node_a, field_start);
  a.node_b = int_array_push(a.node_b, field_count);
  a.node_text = string_array_push(a.node_text, type_name);
  a.node_span_start = int_array_push(a.node_span_start, span_start);
  a.node_span_end = int_array_push(a.node_span_end, span_end);
  a.node_full_start = int_array_push(a.node_full_start, full_start);
  a.node_full_end = int_array_push(a.node_full_end, full_end);
  return a;
}

// ---------------------------------------------------------------------------
// Recursive-descent parser. Token streams come from the lexer below.
// Grammar (the M2 slice):
//   module    := ("module" path ";")? function+
//   function  := "fn" name "(" params? ")" "->" type "{" stmt* "}"
//   params    := param ("," param)*
//   param     := name ":" type
//   stmt      := "let" "mut"? name ":" type "=" expr ";"
//              | "return" expr ";"
//              | "if" expr block ("else" (ifstmt | block))?
//              | "while" expr block
//              | name "=" expr ";"
//   block     := "{" stmt* "}"
//   expr      := or
//   or        := and ("||" and)*
//   and       := bitor (("&"|"|"|"^") bitor)*
//   bitor     := cmp (("=="|"!="|"<"|"<="|">"|">=") cmp)*
//   cmp       := add (("+"|"-") add)*
//   add       := mul (("*"|"/"|"%") mul)*
//   mul       := unary
//   unary     := ("!"|"-"|"~") unary | primary
//   primary   := INT | "true" | "false" | NAME | "(" expr ")"
// ---------------------------------------------------------------------------

export fn dump_module_via_arena(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut start_arena: Arena = arena_empty();
  start_arena.token_start = lex_starts(source);
  let result: ParseResult = parse_module(start_arena, kinds, texts, 0);
  return dump_from_arena(result.arena);
}

fn parse_module(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  if p < kinds.len && kinds[p] == token_module() {
    p = p + 1;
    let mut name: String = "";
    while p < kinds.len && kinds[p] != token_semicolon() {
      name = string_concat(name, texts[p]);
      p = p + 1;
    }
    if p < kinds.len && kinds[p] == token_semicolon() {
      p = p + 1;
    }
    a.has_module = 1;
    a.module_name = name;
  }
  while p < kinds.len && kinds[p] != token_eof() {
    let r: ParseResult = parse_item(a, kinds, texts, p);
    a = r.arena;
    p = r.pos;
  }
  return ParseResult { arena: a, node: 0, pos: p };
}

// Dispatch one top-level item: import / struct / enum / fn, each optionally
// prefixed with `export`. Registers the item in the source-order item list.
fn parse_item(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut p: Int = pos;
  let mut exported: Int = 0;
  if p < kinds.len && kinds[p] == token_export() {
    exported = 1;
    p = p + 1;
  }
  if p < kinds.len && kinds[p] == token_import() {
    return parse_import(arena, kinds, texts, p, exported);
  }
  if p < kinds.len && kinds[p] == token_struct() {
    return parse_struct(arena, kinds, texts, p, exported);
  }
  if p < kinds.len && kinds[p] == token_enum() {
    return parse_enum(arena, kinds, texts, p, exported);
  }
  return parse_function(arena, kinds, texts, p, exported);
}

// import := "import" path ("as" alias)? ";"   path := name ("." name)*
fn parse_import(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, exported: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "import"
  p = p + 1;
  // Path span: first path token start .. last path token end (the alias and the
  // ";" never join the loop, so `p - 1` after it is always the last path token).
  let path_start_tok: Int = p;
  let mut path: String = "";
  while p < kinds.len && (kinds[p] == token_ident() || kinds[p] == token_dot()) {
    path = string_concat(path, texts[p]);
    p = p + 1;
  }
  let path_end_tok: Int = p - 1;
  let mut alias: String = "";
  if p < kinds.len && kinds[p] == token_as() {
    p = p + 1;
    alias = texts[p];
    p = p + 1;
  }
  if p < kinds.len && kinds[p] == token_semicolon() {
    p = p + 1;
  }
  let ref: Int = a.import_path.len;
  a.import_path = string_array_push(a.import_path, path);
  a.import_alias = string_array_push(a.import_alias, alias);
  a.import_exported = int_array_push(a.import_exported, exported);
  a.import_path_span_start = int_array_push(a.import_path_span_start, a.token_start[path_start_tok]);
  a.import_path_span_end = int_array_push(a.import_path_span_end,
                                          a.token_start[path_end_tok] + string_len(texts[path_end_tok]));
  a.item_kind = int_array_push(a.item_kind, item_import());
  a.item_ref = int_array_push(a.item_ref, ref);
  return ParseResult { arena: a, node: 0, pos: p };
}

// struct := "struct" name "{" (field ("," field)* ","?)? "}"  field := name ":" type
fn parse_struct(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, exported: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "struct"
  p = p + 1;
  let name_tok: Int = p;
  let name: String = texts[p];
  p = p + 1;
  if p < kinds.len && kinds[p] == token_lbrace() {
    p = p + 1;
  }
  let field_start: Int = a.field_name.len;
  let mut field_count: Int = 0;
  while p < kinds.len && kinds[p] != token_rbrace() {
    if kinds[p] == token_comma() {
      p = p + 1;
    } else {
      let fname: String = texts[p];
      p = p + 1;
      if p < kinds.len && kinds[p] == token_colon() {
        p = p + 1;
      }
      let ftype_tok: Int = p;
      let ftype: String = texts[p];
      p = p + 1;
      a.field_name = string_array_push(a.field_name, fname);
      a.field_type = string_array_push(a.field_type, ftype);
      a.field_type_span_start = int_array_push(a.field_type_span_start, a.token_start[ftype_tok]);
      field_count = field_count + 1;
    }
  }
  if p < kinds.len && kinds[p] == token_rbrace() {
    p = p + 1;
  }
  let ref: Int = a.struct_name.len;
  a.struct_name = string_array_push(a.struct_name, name);
  a.struct_name_span_start = int_array_push(a.struct_name_span_start, a.token_start[name_tok]);
  a.struct_exported = int_array_push(a.struct_exported, exported);
  a.struct_field_start = int_array_push(a.struct_field_start, field_start);
  a.struct_field_count = int_array_push(a.struct_field_count, field_count);
  a.item_kind = int_array_push(a.item_kind, item_struct());
  a.item_ref = int_array_push(a.item_ref, ref);
  return ParseResult { arena: a, node: 0, pos: p };
}

// enum := "enum" name "{" (variant ("," variant)* ","?)? "}"
// variant := name ("(" type ")")?
fn parse_enum(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, exported: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "enum"
  p = p + 1;
  let name_tok: Int = p;
  let name: String = texts[p];
  p = p + 1;
  if p < kinds.len && kinds[p] == token_lbrace() {
    p = p + 1;
  }
  let variant_start: Int = a.variant_name.len;
  let mut variant_count: Int = 0;
  while p < kinds.len && kinds[p] != token_rbrace() {
    if kinds[p] == token_comma() {
      p = p + 1;
    } else {
      let vname: String = texts[p];
      p = p + 1;
      let mut payload: String = "";
      // Payload type token start; -1 when the variant carries no payload.
      let mut payload_span: Int = 0 - 1;
      if p < kinds.len && kinds[p] == token_lparen() {
        p = p + 1;
        payload = texts[p];
        payload_span = a.token_start[p];
        p = p + 1;
        if p < kinds.len && kinds[p] == token_rparen() {
          p = p + 1;
        }
      }
      a.variant_name = string_array_push(a.variant_name, vname);
      a.variant_payload = string_array_push(a.variant_payload, payload);
      a.variant_payload_span_start = int_array_push(a.variant_payload_span_start, payload_span);
      variant_count = variant_count + 1;
    }
  }
  if p < kinds.len && kinds[p] == token_rbrace() {
    p = p + 1;
  }
  let ref: Int = a.enum_name.len;
  a.enum_name = string_array_push(a.enum_name, name);
  a.enum_name_span_start = int_array_push(a.enum_name_span_start, a.token_start[name_tok]);
  a.enum_exported = int_array_push(a.enum_exported, exported);
  a.enum_variant_start = int_array_push(a.enum_variant_start, variant_start);
  a.enum_variant_count = int_array_push(a.enum_variant_count, variant_count);
  a.item_kind = int_array_push(a.item_kind, item_enum());
  a.item_ref = int_array_push(a.item_ref, ref);
  return ParseResult { arena: a, node: 0, pos: p };
}

fn parse_function(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, exported: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "fn"
  p = p + 1;
  let name_tok: Int = p;
  let name: String = texts[p];
  p = p + 1;
  // "("
  if p < kinds.len && kinds[p] == token_lparen() {
    p = p + 1;
  }
  // params := param ("," param)*  (param := name ":" type)
  let param_start: Int = a.param_name.len;
  let mut param_count: Int = 0;
  while p < kinds.len && kinds[p] != token_rparen() {
    if kinds[p] == token_comma() {
      p = p + 1;
    }
    let pname_tok: Int = p;
    let pname: String = texts[p];
    p = p + 1;
    if p < kinds.len && kinds[p] == token_colon() {
      p = p + 1;
    }
    let ptype_tok: Int = p;
    let ptype: String = texts[p];
    p = p + 1;
    a.param_name = string_array_push(a.param_name, pname);
    a.param_name_span_start = int_array_push(a.param_name_span_start, a.token_start[pname_tok]);
    a.param_type = string_array_push(a.param_type, ptype);
    a.param_type_span_start = int_array_push(a.param_type_span_start, a.token_start[ptype_tok]);
    param_count = param_count + 1;
  }
  // ")"
  if p < kinds.len && kinds[p] == token_rparen() {
    p = p + 1;
  }
  // "->" type  (optional; when absent the function has no explicit return type
  // and the dump omits the `Return type=` line entirely).
  let mut has_ret: Int = 0;
  let mut ret: String = "";
  // Return type token start; -1 when the function has no `->` clause.
  let mut ret_span: Int = 0 - 1;
  if p < kinds.len && kinds[p] == token_arrow() {
    p = p + 1;
    ret = texts[p];
    ret_span = a.token_start[p];
    p = p + 1;
    has_ret = 1;
  }
  // "{" stmt* "}"
  let body: BlockResult = parse_block(a, kinds, texts, p);
  a = body.arena;
  p = body.pos;
  let ref: Int = a.fn_name.len;
  a.fn_name = string_array_push(a.fn_name, name);
  a.fn_name_span_start = int_array_push(a.fn_name_span_start, a.token_start[name_tok]);
  a.fn_exported = int_array_push(a.fn_exported, exported);
  a.fn_has_ret = int_array_push(a.fn_has_ret, has_ret);
  a.fn_ret = string_array_push(a.fn_ret, ret);
  a.fn_ret_span_start = int_array_push(a.fn_ret_span_start, ret_span);
  a.fn_param_start = int_array_push(a.fn_param_start, param_start);
  a.fn_param_count = int_array_push(a.fn_param_count, param_count);
  a.fn_body_start = int_array_push(a.fn_body_start, body.start);
  a.fn_body_count = int_array_push(a.fn_body_count, body.count);
  a.item_kind = int_array_push(a.item_kind, item_function());
  a.item_ref = int_array_push(a.item_ref, ref);
  return ParseResult { arena: a, node: 0, pos: p };
}

// block := "{" stmt* "}" — gathers direct child statement indices locally then
// commits them to block_list as one contiguous run.
fn parse_block(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> BlockResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  if p < kinds.len && kinds[p] == token_lbrace() {
    p = p + 1;
  }
  let mut items: IntArray = int_array_empty();
  while p < kinds.len && kinds[p] != token_rbrace() {
    let r: ParseResult = parse_stmt(a, kinds, texts, p);
    a = r.arena;
    p = r.pos;
    items = int_array_push(items, r.node);
  }
  if p < kinds.len && kinds[p] == token_rbrace() {
    p = p + 1;
  }
  let start: Int = a.block_list.len;
  let count: Int = items.len;
  let mut i: Int = 0;
  while i < count {
    a.block_list = int_array_push(a.block_list, items[i]);
    i = i + 1;
  }
  return BlockResult { arena: a, start: start, count: count, pos: p };
}

// parse_stmt parses one statement, pushes it onto the statement arena, and
// returns its statement-arena index in ParseResult.node.
fn parse_stmt(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  if kinds[pos] == token_let() {
    return parse_let(arena, kinds, texts, pos);
  }
  if kinds[pos] == token_return() {
    return parse_return(arena, kinds, texts, pos);
  }
  if kinds[pos] == token_if() {
    return parse_if(arena, kinds, texts, pos);
  }
  if kinds[pos] == token_while() {
    return parse_while(arena, kinds, texts, pos);
  }
  if kinds[pos] == token_break() {
    return parse_break(arena, kinds, texts, pos);
  }
  if kinds[pos] == token_continue() {
    return parse_continue(arena, kinds, texts, pos);
  }
  if kinds[pos] == token_for() {
    return parse_for(arena, kinds, texts, pos);
  }
  if kinds[pos] == token_match() {
    return parse_match(arena, kinds, texts, pos);
  }
  return parse_assign(arena, kinds, texts, pos);
}

// Append a fully-described statement to the statement arena, returning its index.
fn push_stmt(arena: Arena, kind: Int, name: String, ty: String, has_type: Int, is_mut: Int, expr: Int,
             then_start: Int, then_count: Int, else_start: Int, else_count: Int) -> Arena {
  return push_stmt_full(arena, kind, name, ty, has_type, is_mut, expr,
                        then_start, then_count, else_start, else_count, 0 - 1, 0 - 1, 0 - 1);
}

// Extended pusher carrying the complex-assign target and ForC init/step indices
// (all -1 for statements that do not use them).
fn push_stmt_full(arena: Arena, kind: Int, name: String, ty: String, has_type: Int, is_mut: Int, expr: Int,
                  then_start: Int, then_count: Int, else_start: Int, else_count: Int,
                  target: Int, init: Int, step: Int) -> Arena {
  let mut a: Arena = arena;
  a.stmt_kind = int_array_push(a.stmt_kind, kind);
  a.stmt_name = string_array_push(a.stmt_name, name);
  a.stmt_type = string_array_push(a.stmt_type, ty);
  a.stmt_has_type = int_array_push(a.stmt_has_type, has_type);
  a.stmt_mut = int_array_push(a.stmt_mut, is_mut);
  a.stmt_expr = int_array_push(a.stmt_expr, expr);
  a.stmt_then_start = int_array_push(a.stmt_then_start, then_start);
  a.stmt_then_count = int_array_push(a.stmt_then_count, then_count);
  a.stmt_else_start = int_array_push(a.stmt_else_start, else_start);
  a.stmt_else_count = int_array_push(a.stmt_else_count, else_count);
  a.stmt_target = int_array_push(a.stmt_target, target);
  a.stmt_init = int_array_push(a.stmt_init, init);
  a.stmt_step = int_array_push(a.stmt_step, step);
  // Binding/target ident start, overwritten in place by parse_let / emit_assign
  // for the rows that have one (-1 keeps the array parallel for the rest).
  a.stmt_name_span_start = int_array_push(a.stmt_name_span_start, 0 - 1);
  // Declared-type token start, overwritten in place by parse_let for typed lets
  // (-1 for untyped lets and every other statement kind).
  a.stmt_type_span_start = int_array_push(a.stmt_type_span_start, 0 - 1);
  return a;
}

fn parse_let(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "let"
  p = p + 1;
  // optional "mut"
  let mut is_mut: Int = 0;
  if p < kinds.len && kinds[p] == token_mut() {
    is_mut = 1;
    p = p + 1;
  }
  let name_tok: Int = p;
  let name: String = texts[p];
  p = p + 1;
  // optional ":" type — an untyped `let` omits the `type=` field in the dump.
  let mut has_type: Int = 0;
  let mut ty: String = "";
  // Declared-type token start; -1 when the let is untyped.
  let mut ty_span: Int = 0 - 1;
  if p < kinds.len && kinds[p] == token_colon() {
    p = p + 1;
    ty = texts[p];
    ty_span = a.token_start[p];
    p = p + 1;
    has_type = 1;
  }
  // "="
  if p < kinds.len && kinds[p] == token_eq() {
    p = p + 1;
  }
  let r: ParseResult = parse_expr(a, kinds, texts, p);
  a = r.arena;
  p = r.pos;
  // ";"
  if p < kinds.len && kinds[p] == token_semicolon() {
    p = p + 1;
  }
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, let_stmt(), name, ty, has_type, is_mut, r.node, 0, 0, 0, 0);
  a.stmt_name_span_start[index] = a.token_start[name_tok];
  a.stmt_type_span_start[index] = ty_span;
  return ParseResult { arena: a, node: index, pos: p };
}

fn parse_return(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "return"
  p = p + 1;
  // Empty return (`return;`) carries no expression; -1 marks the missing child.
  if p < kinds.len && kinds[p] == token_semicolon() {
    p = p + 1;
    let index: Int = a.stmt_kind.len;
    a = push_stmt(a, return_stmt(), "", "", 0, 0, 0 - 1, 0, 0, 0, 0);
    return ParseResult { arena: a, node: index, pos: p };
  }
  let r: ParseResult = parse_expr(a, kinds, texts, p);
  a = r.arena;
  p = r.pos;
  // ";"
  if p < kinds.len && kinds[p] == token_semicolon() {
    p = p + 1;
  }
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, return_stmt(), "", "", 0, 0, r.node, 0, 0, 0, 0);
  return ParseResult { arena: a, node: index, pos: p };
}

// if := "if" expr block ("else" (ifstmt | block))?
// The else-if form is just an `if` statement living inside the else block, so we
// dispatch to parse_stmt for `else if` and let it land as a single block item.
fn parse_if(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "if"
  p = p + 1;
  let cond: ParseResult = parse_expr_with(a, kinds, texts, p, 0);
  a = cond.arena;
  p = cond.pos;
  let then_block: BlockResult = parse_block(a, kinds, texts, p);
  a = then_block.arena;
  p = then_block.pos;
  let mut else_start: Int = 0;
  let mut else_count: Int = 0;
  if p < kinds.len && kinds[p] == token_else() {
    p = p + 1;
    if p < kinds.len && kinds[p] == token_if() {
      // else if: parse the nested if as one statement and wrap it in a 1-item
      // else block.
      let nested: ParseResult = parse_stmt(a, kinds, texts, p);
      a = nested.arena;
      p = nested.pos;
      else_start = a.block_list.len;
      else_count = 1;
      a.block_list = int_array_push(a.block_list, nested.node);
    } else {
      let else_block: BlockResult = parse_block(a, kinds, texts, p);
      a = else_block.arena;
      p = else_block.pos;
      else_start = else_block.start;
      else_count = else_block.count;
    }
  }
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, if_stmt(), "", "", 0, 0, cond.node,
                then_block.start, then_block.count, else_start, else_count);
  return ParseResult { arena: a, node: index, pos: p };
}

// while := "while" expr block
fn parse_while(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "while"
  p = p + 1;
  let cond: ParseResult = parse_expr_with(a, kinds, texts, p, 0);
  a = cond.arena;
  p = cond.pos;
  let body: BlockResult = parse_block(a, kinds, texts, p);
  a = body.arena;
  p = body.pos;
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, while_stmt(), "", "", 0, 0, cond.node,
                body.start, body.count, 0, 0);
  return ParseResult { arena: a, node: index, pos: p };
}

// break := "break" ";"  — a leaf statement carrying no children.
fn parse_break(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos + 1;
  if p < kinds.len && kinds[p] == token_semicolon() {
    p = p + 1;
  }
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, break_stmt(), "", "", 0, 0, 0 - 1, 0, 0, 0, 0);
  // Keyword token start — TYPE_BREAK_OUTSIDE_LOOP points at `break` itself.
  a.stmt_name_span_start[index] = a.token_start[pos];
  return ParseResult { arena: a, node: index, pos: p };
}

// continue := "continue" ";"  — a leaf statement carrying no children.
fn parse_continue(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos + 1;
  if p < kinds.len && kinds[p] == token_semicolon() {
    p = p + 1;
  }
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, continue_stmt(), "", "", 0, 0, 0 - 1, 0, 0, 0, 0);
  // Keyword token start — TYPE_CONTINUE_OUTSIDE_LOOP points at `continue`.
  a.stmt_name_span_start[index] = a.token_start[pos];
  return ParseResult { arena: a, node: index, pos: p };
}

// for := for-in | for-c
//   for-in := "for" NAME "in" expr block   (expr may be a `start..end` Range)
//   for-c  := "for" "(" init ";" cond ";" step ")" block
// A "(" directly after "for" picks the C-style form.
fn parse_for(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  if pos + 1 < kinds.len && kinds[pos + 1] == token_lparen() {
    return parse_for_c(arena, kinds, texts, pos);
  }
  return parse_for_in(arena, kinds, texts, pos);
}

// for-in := "for" NAME "in" iterable block. The iterable's struct-literal flag is
// off (matching the oracle: `Name {` after `in` opens the loop body, not a
// struct literal). A top-level `..` makes the iterable a Range node.
fn parse_for_in(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "for"
  p = p + 1;
  let binding: String = texts[p];
  p = p + 1;
  // "in"
  if p < kinds.len && kinds[p] == token_in() {
    p = p + 1;
  }
  let startr: ParseResult = parse_expr_with(a, kinds, texts, p, 0);
  a = startr.arena;
  p = startr.pos;
  let mut iter: Int = startr.node;
  if p < kinds.len && kinds[p] == token_dotdot() {
    p = p + 1;
    let endr: ParseResult = parse_expr_with(a, kinds, texts, p, 0);
    a = endr.arena;
    p = endr.pos;
    let range_index: Int = a.node_kind.len;
    a = push_range_node(a, startr.node, endr.node,
                        a.node_full_start[startr.node], a.node_full_end[endr.node]);
    iter = range_index;
  }
  let body: BlockResult = parse_block(a, kinds, texts, p);
  a = body.arena;
  p = body.pos;
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, for_in_stmt(), binding, "", 0, 0, iter,
                body.start, body.count, 0, 0);
  return ParseResult { arena: a, node: index, pos: p };
}

// for-c := "for" "(" init ";" cond ";" step ")" block. init is parsed as a full
// statement (typically a `let`, which consumes its own ";"); cond is an
// expression terminated by ";"; step is an assignment without a trailing ";".
fn parse_for_c(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "for"
  p = p + 1;
  // "("
  if p < kinds.len && kinds[p] == token_lparen() {
    p = p + 1;
  }
  // init statement (consumes its own trailing ";").
  let init: ParseResult = parse_stmt(a, kinds, texts, p);
  a = init.arena;
  p = init.pos;
  // cond expr ";"
  let cond: ParseResult = parse_expr(a, kinds, texts, p);
  a = cond.arena;
  p = cond.pos;
  if p < kinds.len && kinds[p] == token_semicolon() {
    p = p + 1;
  }
  // step assignment (no trailing ";"; ends at ")").
  let step: ParseResult = parse_assign_no_semi(a, kinds, texts, p);
  a = step.arena;
  p = step.pos;
  if p < kinds.len && kinds[p] == token_rparen() {
    p = p + 1;
  }
  let body: BlockResult = parse_block(a, kinds, texts, p);
  a = body.arena;
  p = body.pos;
  let index: Int = a.stmt_kind.len;
  a = push_stmt_full(a, for_c_stmt(), "", "", 0, 0, cond.node,
                     body.start, body.count, 0, 0, 0 - 1, init.node, step.node);
  return ParseResult { arena: a, node: index, pos: p };
}

// match := "match" value "{" (arm ("," arm)* ","?)? "}"
//   arm := pattern "->" block
// Patterns are rendered to text up front (see pattern_text); arm bodies are
// ordinary blocks. The value's struct-literal flag is off so `match X {` opens
// the match body rather than parsing `X { ... }` as a struct literal.
fn parse_match(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos;
  // "match"
  p = p + 1;
  let value: ParseResult = parse_expr_with(a, kinds, texts, p, 0);
  a = value.arena;
  p = value.pos;
  if p < kinds.len && kinds[p] == token_lbrace() {
    p = p + 1;
  }
  // Gather each arm's (pattern, body slice) locally, then commit to the arm
  // arrays as one contiguous run so the Match can slice them post-order.
  let mut patterns: StringArray = string_array_empty();
  let mut body_starts: IntArray = int_array_empty();
  let mut body_counts: IntArray = int_array_empty();
  while p < kinds.len && kinds[p] != token_rbrace() {
    if kinds[p] == token_comma() {
      p = p + 1;
    } else {
      // Pattern runs until the top-level "->".
      let pat_start: Int = p;
      let mut paren_depth: Int = 0;
      while p < kinds.len && !(paren_depth == 0 && kinds[p] == token_arrow()) {
        if kinds[p] == token_lparen() {
          paren_depth = paren_depth + 1;
        }
        if kinds[p] == token_rparen() && paren_depth > 0 {
          paren_depth = paren_depth - 1;
        }
        p = p + 1;
      }
      let pat: String = pattern_text(kinds, texts, pat_start, p);
      // "->"
      if p < kinds.len && kinds[p] == token_arrow() {
        p = p + 1;
      }
      let body: BlockResult = parse_block(a, kinds, texts, p);
      a = body.arena;
      p = body.pos;
      patterns = string_array_push(patterns, pat);
      body_starts = int_array_push(body_starts, body.start);
      body_counts = int_array_push(body_counts, body.count);
    }
  }
  if p < kinds.len && kinds[p] == token_rbrace() {
    p = p + 1;
  }
  let arm_start: Int = a.arm_pattern.len;
  let arm_count: Int = patterns.len;
  let mut i: Int = 0;
  while i < arm_count {
    a.arm_pattern = string_array_push(a.arm_pattern, patterns[i]);
    a.arm_body_start = int_array_push(a.arm_body_start, body_starts[i]);
    a.arm_body_count = int_array_push(a.arm_body_count, body_counts[i]);
    i = i + 1;
  }
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, match_stmt(), "", "", 0, 0, value.node,
                arm_start, arm_count, 0, 0);
  return ParseResult { arena: a, node: index, pos: p };
}

// Render a match pattern over tokens [start, end) to its dump text. Mirrors the
// Stage1 frontend's rust_pattern_text:
//   int:N  string:"x"  bool:true  _  name:x  variant:E.V  variant:E.V(b)
fn pattern_text(kinds: IntArray, texts: StringArray, start: Int, end: Int) -> String {
  if start >= end {
    return "";
  }
  if start + 1 == end {
    if kinds[start] == token_int() {
      return string_concat("int:", texts[start]);
    }
    if kinds[start] == token_string() {
      return string_concat("string:", texts[start]);
    }
    if kinds[start] == token_true() || kinds[start] == token_false() {
      return string_concat("bool:", texts[start]);
    }
    if kinds[start] == token_ident() && texts[start] == "_" {
      return "_";
    }
    if kinds[start] == token_ident() {
      return string_concat("name:", texts[start]);
    }
  }
  if start + 3 == end && kinds[start] == token_ident()
      && kinds[start + 1] == token_dot() && kinds[start + 2] == token_ident() {
    let mut out: String = "variant:";
    out = string_concat(out, texts[start]);
    out = string_concat(out, ".");
    out = string_concat(out, texts[start + 2]);
    return out;
  }
  if start + 6 == end && kinds[start] == token_ident()
      && kinds[start + 1] == token_dot() && kinds[start + 2] == token_ident()
      && kinds[start + 3] == token_lparen() && kinds[start + 4] == token_ident()
      && kinds[start + 5] == token_rparen() {
    let mut out: String = "variant:";
    out = string_concat(out, texts[start]);
    out = string_concat(out, ".");
    out = string_concat(out, texts[start + 2]);
    out = string_concat(out, "(");
    out = string_concat(out, texts[start + 4]);
    out = string_concat(out, ")");
    return out;
  }
  return "";
}

// Statement starting with an expression: either a simple-name assignment
//   assign   := NAME "=" expr ";"
// or a bare expression statement (e.g. a call used for its effect)
//   exprstmt := expr ";"
//   assign   := target ("=" | "+=" | "-=" | "*=" | "/=" | "%=") expr ";"
// The target may be a simple NAME, a field/index chain (a.b / a[i] / a.b.c /
// a[i][j]), or any mix. A simple NAME target dumps as `Assign name=N`; richer
// targets dump as `Assign` / `Target` / `Value`. Compound assignment desugars
// `t op= rhs` into `t = (t op rhs)`, sharing the target node between the Assign
// and the Binary's left operand.
fn parse_assign(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  // Parse the leading expression: either the assignment target or a bare expr.
  let lhs: ParseResult = parse_expr(arena, kinds, texts, pos);
  let mut a: Arena = lhs.arena;
  let mut p: Int = lhs.pos;
  if p < kinds.len && kinds[p] == token_eq() {
    p = p + 1;
    let rhs: ParseResult = parse_expr(a, kinds, texts, p);
    a = rhs.arena;
    p = rhs.pos;
    if p < kinds.len && kinds[p] == token_semicolon() {
      p = p + 1;
    }
    let index: Int = a.stmt_kind.len;
    a = emit_assign(a, lhs.node, rhs.node);
    return ParseResult { arena: a, node: index, pos: p };
  }
  if p < kinds.len && is_compound_assign_op(kinds[p]) {
    let op: String = compound_op_name(kinds[p]);
    p = p + 1;
    let rhs: ParseResult = parse_expr(a, kinds, texts, p);
    a = rhs.arena;
    p = rhs.pos;
    if p < kinds.len && kinds[p] == token_semicolon() {
      p = p + 1;
    }
    let bin_index: Int = a.node_kind.len;
    a = push_binary_node(a, lhs.node, rhs.node, op,
                         a.node_full_start[lhs.node], a.node_full_end[rhs.node]);
    let index: Int = a.stmt_kind.len;
    a = emit_assign(a, lhs.node, bin_index);
    return ParseResult { arena: a, node: index, pos: p };
  }
  // Bare expression statement.
  if p < kinds.len && kinds[p] == token_semicolon() {
    p = p + 1;
  }
  let index: Int = a.stmt_kind.len;
  a = push_stmt(a, expr_stmt(), "", "", 0, 0, lhs.node, 0, 0, 0, 0);
  return ParseResult { arena: a, node: index, pos: p };
}

// ForC step: like parse_assign but with no trailing ";" (the step ends at ")").
// Always an assignment (simple or compound); never a bare expression.
fn parse_assign_no_semi(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  let lhs: ParseResult = parse_expr(arena, kinds, texts, pos);
  let mut a: Arena = lhs.arena;
  let mut p: Int = lhs.pos;
  if p < kinds.len && kinds[p] == token_eq() {
    p = p + 1;
    let rhs: ParseResult = parse_expr(a, kinds, texts, p);
    a = rhs.arena;
    p = rhs.pos;
    let index: Int = a.stmt_kind.len;
    a = emit_assign(a, lhs.node, rhs.node);
    return ParseResult { arena: a, node: index, pos: p };
  }
  let op: String = compound_op_name(kinds[p]);
  p = p + 1;
  let rhs: ParseResult = parse_expr(a, kinds, texts, p);
  a = rhs.arena;
  p = rhs.pos;
  let bin_index: Int = a.node_kind.len;
  a = push_binary_node(a, lhs.node, rhs.node, op,
                       a.node_full_start[lhs.node], a.node_full_end[rhs.node]);
  let index: Int = a.stmt_kind.len;
  a = emit_assign(a, lhs.node, bin_index);
  return ParseResult { arena: a, node: index, pos: p };
}

// Push an Assign statement for `target = value`. A bare Name target collapses to
// the `Assign name=N` form (target=-1); any other target keeps the explicit
// Target/Value shape with the target expr stored in stmt_target.
fn emit_assign(arena: Arena, target: Int, value: Int) -> Arena {
  let mut a: Arena = arena;
  if a.node_kind[target] == name_node() {
    let row: Int = a.stmt_kind.len;
    a = push_stmt(a, assign_stmt(), a.node_text[target], "", 0, 0, value, 0, 0, 0, 0);
    // The simple target's span is exactly the Name node's ident token span.
    a.stmt_name_span_start[row] = a.node_span_start[target];
    return a;
  }
  return push_stmt_full(a, assign_stmt(), "", "", 0, 0, value, 0, 0, 0, 0, target, 0 - 1, 0 - 1);
}

fn is_compound_assign_op(kind: Int) -> Bool {
  return kind == token_plus_eq() || kind == token_minus_eq() || kind == token_star_eq()
      || kind == token_slash_eq() || kind == token_percent_eq();
}

// The arithmetic op name a compound-assign desugars to (matching binary_op_name).
fn compound_op_name(kind: Int) -> String {
  if kind == token_plus_eq() { return "add"; }
  if kind == token_minus_eq() { return "sub"; }
  if kind == token_star_eq() { return "mul"; }
  if kind == token_slash_eq() { return "div"; }
  return "mod";
}

// ---------------------------------------------------------------------------
// Expression precedence ladder, lowest to highest:
//   or  := and ("||" and)*
//   and := bit (("&"|"|"|"^") bit)*          [bit ops share one left-assoc tier]
//   bit := cmp (("=="|"!="|"<"|"<="|">"|">=") cmp)*
//   cmp := add (("+"|"-") add)*
//   add := mul (("*"|"/"|"%") mul)*
//   mul := unary
//   unary := ("!"|"-"|"~") unary | primary
//   primary := INT | true | false | NAME | "(" expr ")"
// Every binary tier folds left-associatively by the same post-order pattern as
// the original `+ - * /` slice.
// ---------------------------------------------------------------------------
// allow_struct controls struct-literal recognition: it is 1 in normal value
// positions and 0 throughout an if/while condition (matching the Rust parser's
// no-struct-literal restriction, which — like the oracle — does NOT reset inside
// parens, call args, or index brackets within the condition).
fn parse_expr(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int) -> ParseResult {
  return parse_or(arena, kinds, texts, pos, 1);
}

fn parse_expr_with(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  return parse_or(arena, kinds, texts, pos, allow_struct);
}

fn is_or_op(kind: Int) -> Bool {
  return kind == token_oror();
}

fn is_bit_op(kind: Int) -> Bool {
  return kind == token_amp() || kind == token_pipe() || kind == token_caret();
}

fn is_cmp_op(kind: Int) -> Bool {
  return kind == token_eqeq() || kind == token_ne() || kind == token_lt()
      || kind == token_le() || kind == token_gt() || kind == token_ge();
}

fn is_add_op(kind: Int) -> Bool {
  return kind == token_plus() || kind == token_minus();
}

fn is_mul_op(kind: Int) -> Bool {
  return kind == token_star() || kind == token_slash() || kind == token_percent();
}

fn parse_or(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  let left: ParseResult = parse_and(arena, kinds, texts, pos, allow_struct);
  let mut a: Arena = left.arena;
  let mut node: Int = left.node;
  let mut p: Int = left.pos;
  while p < kinds.len && is_or_op(kinds[p]) {
    let op: String = binary_op_name(kinds[p]);
    let rhs: ParseResult = parse_and(a, kinds, texts, p + 1, allow_struct);
    a = rhs.arena;
    p = rhs.pos;
    let new_index: Int = a.node_kind.len;
    a = push_binary_node(a, node, rhs.node, op,
                         a.node_full_start[node], a.node_full_end[rhs.node]);
    node = new_index;
  }
  return ParseResult { arena: a, node: node, pos: p };
}

fn parse_and(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  let left: ParseResult = parse_bit(arena, kinds, texts, pos, allow_struct);
  let mut a: Arena = left.arena;
  let mut node: Int = left.node;
  let mut p: Int = left.pos;
  while p < kinds.len && kinds[p] == token_andand() {
    let op: String = binary_op_name(kinds[p]);
    let rhs: ParseResult = parse_bit(a, kinds, texts, p + 1, allow_struct);
    a = rhs.arena;
    p = rhs.pos;
    let new_index: Int = a.node_kind.len;
    a = push_binary_node(a, node, rhs.node, op,
                         a.node_full_start[node], a.node_full_end[rhs.node]);
    node = new_index;
  }
  return ParseResult { arena: a, node: node, pos: p };
}

fn parse_bit(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  let left: ParseResult = parse_cmp(arena, kinds, texts, pos, allow_struct);
  let mut a: Arena = left.arena;
  let mut node: Int = left.node;
  let mut p: Int = left.pos;
  while p < kinds.len && is_bit_op(kinds[p]) {
    let op: String = binary_op_name(kinds[p]);
    let rhs: ParseResult = parse_cmp(a, kinds, texts, p + 1, allow_struct);
    a = rhs.arena;
    p = rhs.pos;
    let new_index: Int = a.node_kind.len;
    a = push_binary_node(a, node, rhs.node, op,
                         a.node_full_start[node], a.node_full_end[rhs.node]);
    node = new_index;
  }
  return ParseResult { arena: a, node: node, pos: p };
}

fn parse_cmp(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  let left: ParseResult = parse_add(arena, kinds, texts, pos, allow_struct);
  let mut a: Arena = left.arena;
  let mut node: Int = left.node;
  let mut p: Int = left.pos;
  while p < kinds.len && is_cmp_op(kinds[p]) {
    let op: String = binary_op_name(kinds[p]);
    let rhs: ParseResult = parse_add(a, kinds, texts, p + 1, allow_struct);
    a = rhs.arena;
    p = rhs.pos;
    let new_index: Int = a.node_kind.len;
    a = push_binary_node(a, node, rhs.node, op,
                         a.node_full_start[node], a.node_full_end[rhs.node]);
    node = new_index;
  }
  return ParseResult { arena: a, node: node, pos: p };
}

fn parse_add(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  let left: ParseResult = parse_mul(arena, kinds, texts, pos, allow_struct);
  let mut a: Arena = left.arena;
  let mut node: Int = left.node;
  let mut p: Int = left.pos;
  while p < kinds.len && is_add_op(kinds[p]) {
    let op: String = binary_op_name(kinds[p]);
    let rhs: ParseResult = parse_mul(a, kinds, texts, p + 1, allow_struct);
    a = rhs.arena;
    p = rhs.pos;
    let new_index: Int = a.node_kind.len;
    a = push_binary_node(a, node, rhs.node, op,
                         a.node_full_start[node], a.node_full_end[rhs.node]);
    node = new_index;
  }
  return ParseResult { arena: a, node: node, pos: p };
}

fn parse_mul(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  let left: ParseResult = parse_unary(arena, kinds, texts, pos, allow_struct);
  let mut a: Arena = left.arena;
  let mut node: Int = left.node;
  let mut p: Int = left.pos;
  while p < kinds.len && is_mul_op(kinds[p]) {
    let op: String = binary_op_name(kinds[p]);
    let rhs: ParseResult = parse_unary(a, kinds, texts, p + 1, allow_struct);
    a = rhs.arena;
    p = rhs.pos;
    let new_index: Int = a.node_kind.len;
    a = push_binary_node(a, node, rhs.node, op,
                         a.node_full_start[node], a.node_full_end[rhs.node]);
    node = new_index;
  }
  return ParseResult { arena: a, node: node, pos: p };
}

// unary := ("!"|"-"|"~") unary | postfix  — right-recursive, highest binding.
fn parse_unary(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  if kinds[pos] == token_bang() || kinds[pos] == token_minus() || kinds[pos] == token_tilde() {
    let op: String = unary_op_name(kinds[pos]);
    let operand: ParseResult = parse_unary(arena, kinds, texts, pos + 1, allow_struct);
    let mut a: Arena = operand.arena;
    let new_index: Int = a.node_kind.len;
    // Full span: op token start .. operand end (matching the Rust parser).
    a = push_unary_node(a, operand.node, op,
                        a.token_start[pos], a.node_full_end[operand.node]);
    return ParseResult { arena: a, node: new_index, pos: operand.pos };
  }
  return parse_postfix(arena, kinds, texts, pos, allow_struct);
}

// postfix := primary ( "[" expr "]" | "." NAME )*
// A leading identifier is special-cased into the primary parser: it greedily
// consumes a dotted name path and, if a "(" follows that path, becomes a Call
// whose callee is the joined path. Once any non-call suffix has been applied the
// base is no longer a name path, so a subsequent "(" is not a call (the oracle
// rejects e.g. `f(x)(y)` / `make().m()`); such inputs are out of this slice.
fn parse_postfix(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  let prim: ParseResult = parse_primary(arena, kinds, texts, pos, allow_struct);
  let mut a: Arena = prim.arena;
  let mut node: Int = prim.node;
  let mut p: Int = prim.pos;
  while p < kinds.len && (kinds[p] == token_lbracket() || kinds[p] == token_dot()) {
    if kinds[p] == token_lbracket() {
      p = p + 1;
      let idx: ParseResult = parse_expr_with(a, kinds, texts, p, allow_struct);
      a = idx.arena;
      p = idx.pos;
      if p < kinds.len && kinds[p] == token_rbracket() {
        p = p + 1;
      }
      let new_index: Int = a.node_kind.len;
      // Full span: base start .. "]" end (token p-1 is the consumed "]").
      a = push_index_node(a, node, idx.node,
                          a.node_full_start[node], a.token_start[p - 1] + 1);
      node = new_index;
    } else {
      // "." NAME — field access (calls were already absorbed in parse_primary).
      p = p + 1;
      let field: String = texts[p];
      p = p + 1;
      let new_index: Int = a.node_kind.len;
      // Full span: base start .. field ident end (token p-1 is the field);
      // name span: the field ident token itself.
      a = push_field_node(a, node, field,
                          a.token_start[p - 1], a.token_start[p - 1] + string_len(field),
                          a.node_full_start[node], a.token_start[p - 1] + string_len(field));
      node = new_index;
    }
  }
  return ParseResult { arena: a, node: node, pos: p };
}

// primary := INT | STRING | true | false | "[" array "]"
//          | NAME-path ( "(" args ")" )?      (call when path is followed by "(")
//          | NAME "{" struct-fields "}"        (struct literal, when allowed)
//          | "(" expr ")"
fn parse_primary(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  if kinds[pos] == token_lparen() {
    // A parenthesized expression keeps the inner node (and its full span)
    // unchanged — the Rust parser's LParen branch likewise returns the inner
    // expr without widening its span to the parens.
    let inner: ParseResult = parse_expr_with(arena, kinds, texts, pos + 1, allow_struct);
    let mut p: Int = inner.pos;
    if p < kinds.len && kinds[p] == token_rparen() {
      p = p + 1;
    }
    return ParseResult { arena: inner.arena, node: inner.node, pos: p };
  }
  if kinds[pos] == token_lbracket() {
    return parse_array_literal(arena, kinds, texts, pos, allow_struct);
  }
  if kinds[pos] == token_int() {
    let index: Int = arena.node_kind.len;
    let a: Arena = push_int_node(arena, texts[pos], arena.token_start[pos],
                                 arena.token_start[pos] + string_len(texts[pos]));
    return ParseResult { arena: a, node: index, pos: pos + 1 };
  }
  if kinds[pos] == token_string() {
    // The raw token text keeps its quotes, so its length equals the Rust
    // lexer's String token span length.
    let index: Int = arena.node_kind.len;
    let a: Arena = push_string_node(arena, texts[pos], arena.token_start[pos],
                                    arena.token_start[pos] + string_len(texts[pos]));
    return ParseResult { arena: a, node: index, pos: pos + 1 };
  }
  if kinds[pos] == token_true() || kinds[pos] == token_false() {
    let index: Int = arena.node_kind.len;
    let a: Arena = push_bool_node(arena, texts[pos], arena.token_start[pos],
                                  arena.token_start[pos] + string_len(texts[pos]));
    return ParseResult { arena: a, node: index, pos: pos + 1 };
  }
  // identifier: scan a dotted name path.
  let mut path: String = texts[pos];
  let mut p: Int = pos + 1;
  while p + 1 < kinds.len && kinds[p] == token_dot() && kinds[p + 1] == token_ident() {
    path = string_concat(path, ".");
    path = string_concat(path, texts[p + 1]);
    p = p + 2;
  }
  // "(" → qualified/simple call over the joined path. The callee span runs from
  // the first path ident's start to the last path ident's end (token p - 1),
  // covering any interior whitespace — matching the Rust parser's callee_span.
  if p < kinds.len && kinds[p] == token_lparen() {
    return parse_call(arena, kinds, texts, p, path, allow_struct,
                      arena.token_start[pos],
                      arena.token_start[p - 1] + string_len(texts[p - 1]));
  }
  // NAME "{" → struct literal (only outside if/while condition contexts).
  if allow_struct == 1 && p < kinds.len && kinds[p] == token_lbrace()
      && p == pos + 1 {
    return parse_struct_literal(arena, kinds, texts, p, texts[pos], allow_struct);
  }
  // Otherwise the dotted path is a Name (first segment) wrapped in FieldAccess
  // nodes for each subsequent segment.
  let mut a: Arena = arena;
  let base_index: Int = a.node_kind.len;
  a = push_name_node(a, texts[pos], a.token_start[pos],
                     a.token_start[pos] + string_len(texts[pos]));
  let mut node: Int = base_index;
  let mut q: Int = pos + 1;
  while q + 1 < kinds.len && kinds[q] == token_dot() && kinds[q + 1] == token_ident() {
    let new_index: Int = a.node_kind.len;
    // Full span: chain start .. this segment's ident end; name span: the
    // segment's ident token itself.
    a = push_field_node(a, node, texts[q + 1],
                        a.token_start[q + 1], a.token_start[q + 1] + string_len(texts[q + 1]),
                        a.node_full_start[node],
                        a.token_start[q + 1] + string_len(texts[q + 1]));
    node = new_index;
    q = q + 2;
  }
  return ParseResult { arena: a, node: node, pos: p };
}

// call := "(" (expr ("," expr)*)? ")"  — `pos` points at the "(". The callee
// span computed by parse_primary is threaded through to the Call node.
fn parse_call(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, callee: String, allow_struct: Int,
              callee_span_start: Int, callee_span_end: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos + 1;
  let mut args: IntArray = int_array_empty();
  while p < kinds.len && kinds[p] != token_rparen() {
    if kinds[p] == token_comma() {
      p = p + 1;
    } else {
      let arg: ParseResult = parse_expr_with(a, kinds, texts, p, allow_struct);
      a = arg.arena;
      p = arg.pos;
      args = int_array_push(args, arg.node);
    }
  }
  if p < kinds.len && kinds[p] == token_rparen() {
    p = p + 1;
  }
  let start: Int = a.child_list.len;
  let count: Int = args.len;
  let mut i: Int = 0;
  while i < count {
    a.child_list = int_array_push(a.child_list, args[i]);
    i = i + 1;
  }
  let new_index: Int = a.node_kind.len;
  // Full span: callee path start .. ")" end (token p-1 is the consumed ")").
  a = push_call_node(a, callee, start, count, callee_span_start, callee_span_end,
                     callee_span_start, a.token_start[p - 1] + 1);
  return ParseResult { arena: a, node: new_index, pos: p };
}

// array := "[" (expr ("," expr)*)? "]"  — `pos` points at the "[".
fn parse_array_literal(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, allow_struct: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos + 1;
  let mut elems: IntArray = int_array_empty();
  while p < kinds.len && kinds[p] != token_rbracket() {
    if kinds[p] == token_comma() {
      p = p + 1;
    } else {
      let el: ParseResult = parse_expr_with(a, kinds, texts, p, allow_struct);
      a = el.arena;
      p = el.pos;
      elems = int_array_push(elems, el.node);
    }
  }
  if p < kinds.len && kinds[p] == token_rbracket() {
    p = p + 1;
  }
  let start: Int = a.child_list.len;
  let count: Int = elems.len;
  let mut i: Int = 0;
  while i < count {
    a.child_list = int_array_push(a.child_list, elems[i]);
    i = i + 1;
  }
  let new_index: Int = a.node_kind.len;
  // Full span: "[" start .. "]" end (token p-1 is the consumed "]").
  a = push_array_node(a, start, count,
                      a.token_start[pos], a.token_start[p - 1] + 1);
  return ParseResult { arena: a, node: new_index, pos: p };
}

// struct literal := NAME "{" (field ("," field)* ","?)? "}"   field := NAME ":" expr
// `pos` points at the "{"; `type_name` is the preceding identifier.
fn parse_struct_literal(arena: Arena, kinds: IntArray, texts: StringArray, pos: Int, type_name: String, allow_struct: Int) -> ParseResult {
  let mut a: Arena = arena;
  let mut p: Int = pos + 1;
  let mut names: StringArray = string_array_empty();
  let mut name_spans: IntArray = int_array_empty();
  let mut values: IntArray = int_array_empty();
  while p < kinds.len && kinds[p] != token_rbrace() {
    if kinds[p] == token_comma() {
      p = p + 1;
    } else {
      let fname: String = texts[p];
      name_spans = int_array_push(name_spans, a.token_start[p]);
      p = p + 1;
      if p < kinds.len && kinds[p] == token_colon() {
        p = p + 1;
      }
      let val: ParseResult = parse_expr_with(a, kinds, texts, p, allow_struct);
      a = val.arena;
      p = val.pos;
      names = string_array_push(names, fname);
      values = int_array_push(values, val.node);
    }
  }
  if p < kinds.len && kinds[p] == token_rbrace() {
    p = p + 1;
  }
  let start: Int = a.sl_field_name.len;
  let count: Int = values.len;
  let mut i: Int = 0;
  while i < count {
    a.sl_field_name = string_array_push(a.sl_field_name, names[i]);
    a.sl_field_name_span_start = int_array_push(a.sl_field_name_span_start, name_spans[i]);
    a.sl_field_value = int_array_push(a.sl_field_value, values[i]);
    i = i + 1;
  }
  let new_index: Int = a.node_kind.len;
  // Full span: type-name ident (token pos-1) start .. "}" end (token p-1);
  // name span: the type-name ident token itself.
  a = push_struct_lit_node(a, type_name, start, count,
                           a.token_start[pos - 1],
                           a.token_start[pos - 1] + string_len(type_name),
                           a.token_start[pos - 1], a.token_start[p - 1] + 1);
  return ParseResult { arena: a, node: new_index, pos: p };
}

fn binary_op_name(kind: Int) -> String {
  if kind == token_oror() { return "or"; }
  if kind == token_andand() { return "and"; }
  if kind == token_amp() { return "bit_and"; }
  if kind == token_pipe() { return "bit_or"; }
  if kind == token_caret() { return "bit_xor"; }
  if kind == token_eqeq() { return "eq"; }
  if kind == token_ne() { return "not_eq"; }
  if kind == token_lt() { return "lt"; }
  if kind == token_le() { return "lte"; }
  if kind == token_gt() { return "gt"; }
  if kind == token_ge() { return "gte"; }
  if kind == token_plus() { return "add"; }
  if kind == token_minus() { return "sub"; }
  if kind == token_star() { return "mul"; }
  if kind == token_slash() { return "div"; }
  return "mod";
}

fn unary_op_name(kind: Int) -> String {
  if kind == token_bang() { return "not"; }
  if kind == token_minus() { return "neg"; }
  return "bit_not";
}

// ---------------------------------------------------------------------------
// Dump: walk the arenas and emit text identical to Rust `ast-dump`.
// Indent is 2 spaces per level.
// ---------------------------------------------------------------------------
fn dump_from_arena(arena: Arena) -> String {
  let mut out: String = "Module\n";
  if arena.has_module == 1 {
    out = string_concat(out, "  ModuleDecl name=");
    out = string_concat(out, arena.module_name);
    out = string_concat(out, "\n");
  }
  let mut ii: Int = 0;
  while ii < arena.item_kind.len {
    let kind: Int = arena.item_kind[ii];
    let ref: Int = arena.item_ref[ii];
    if kind == item_import() {
      out = dump_import(out, arena, ref);
    } else {
      if kind == item_struct() {
        out = dump_struct(out, arena, ref);
      } else {
        if kind == item_enum() {
          out = dump_enum(out, arena, ref);
        } else {
          out = dump_function(out, arena, ref);
        }
      }
    }
    ii = ii + 1;
  }
  return out;
}

fn dump_import(out: String, arena: Arena, ref: Int) -> String {
  let mut next: String = string_concat(out, "  Import path=");
  next = string_concat(next, arena.import_path[ref]);
  if arena.import_alias[ref] != "" {
    next = string_concat(next, " alias=");
    next = string_concat(next, arena.import_alias[ref]);
  }
  if arena.import_exported[ref] == 1 {
    next = string_concat(next, " exported=true");
  }
  next = string_concat(next, "\n");
  return next;
}

fn dump_struct(out: String, arena: Arena, ref: Int) -> String {
  let mut next: String = string_concat(out, "  Struct name=");
  next = string_concat(next, arena.struct_name[ref]);
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(arena.struct_exported[ref]));
  next = string_concat(next, "\n");
  let start: Int = arena.struct_field_start[ref];
  let count: Int = arena.struct_field_count[ref];
  let mut i: Int = 0;
  while i < count {
    next = string_concat(next, "    Field name=");
    next = string_concat(next, arena.field_name[start + i]);
    next = string_concat(next, " type=");
    next = string_concat(next, arena.field_type[start + i]);
    next = string_concat(next, "\n");
    i = i + 1;
  }
  return next;
}

fn dump_enum(out: String, arena: Arena, ref: Int) -> String {
  let mut next: String = string_concat(out, "  Enum name=");
  next = string_concat(next, arena.enum_name[ref]);
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(arena.enum_exported[ref]));
  next = string_concat(next, "\n");
  let start: Int = arena.enum_variant_start[ref];
  let count: Int = arena.enum_variant_count[ref];
  let mut i: Int = 0;
  while i < count {
    next = string_concat(next, "    Variant name=");
    next = string_concat(next, arena.variant_name[start + i]);
    if arena.variant_payload[start + i] != "" {
      next = string_concat(next, " payload=");
      next = string_concat(next, arena.variant_payload[start + i]);
    }
    next = string_concat(next, "\n");
    i = i + 1;
  }
  return next;
}

fn dump_function(out: String, arena: Arena, fi: Int) -> String {
  let mut next: String = string_concat(out, "  Function name=");
  next = string_concat(next, arena.fn_name[fi]);
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(arena.fn_exported[fi]));
  next = string_concat(next, "\n");
  let pstart: Int = arena.fn_param_start[fi];
  let pcount: Int = arena.fn_param_count[fi];
  let mut pi: Int = 0;
  while pi < pcount {
    next = string_concat(next, "    Param name=");
    next = string_concat(next, arena.param_name[pstart + pi]);
    next = string_concat(next, " type=");
    next = string_concat(next, arena.param_type[pstart + pi]);
    next = string_concat(next, "\n");
    pi = pi + 1;
  }
  if arena.fn_has_ret[fi] == 1 {
    next = string_concat(next, "    Return type=");
    next = string_concat(next, arena.fn_ret[fi]);
    next = string_concat(next, "\n");
  }
  let start: Int = arena.fn_body_start[fi];
  let count: Int = arena.fn_body_count[fi];
  let mut si: Int = 0;
  while si < count {
    next = dump_stmt(next, arena, arena.block_list[start + si], 2);
    si = si + 1;
  }
  return next;
}

fn bool_text(flag: Int) -> String {
  if flag == 1 {
    return "true";
  }
  return "false";
}

// Walk one statement. `depth` is the indentation level (in 2-space units) at
// which this statement's header line is emitted.
fn dump_stmt(out: String, arena: Arena, index: Int, depth: Int) -> String {
  let pad: String = indent_of(depth);
  let kind: Int = arena.stmt_kind[index];
  if kind == let_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Let name=");
    next = string_concat(next, arena.stmt_name[index]);
    if arena.stmt_has_type[index] == 1 {
      next = string_concat(next, " type=");
      next = string_concat(next, arena.stmt_type[index]);
    }
    if arena.stmt_mut[index] == 1 {
      next = string_concat(next, " mutable=true");
    }
    next = string_concat(next, "\n");
    next = dump_expr(next, arena, arena.stmt_expr[index], depth + 1);
    return next;
  }
  if kind == return_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Return\n");
    if arena.stmt_expr[index] >= 0 {
      next = dump_expr(next, arena, arena.stmt_expr[index], depth + 1);
    }
    return next;
  }
  if kind == assign_stmt() {
    if arena.stmt_target[index] >= 0 {
      // Complex target: explicit Target / Value subtrees.
      let mut next: String = string_concat(out, pad);
      next = string_concat(next, "Assign\n");
      let cpad: String = indent_of(depth + 1);
      next = string_concat(next, cpad);
      next = string_concat(next, "Target\n");
      next = dump_expr(next, arena, arena.stmt_target[index], depth + 2);
      next = string_concat(next, cpad);
      next = string_concat(next, "Value\n");
      next = dump_expr(next, arena, arena.stmt_expr[index], depth + 2);
      return next;
    }
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Assign name=");
    next = string_concat(next, arena.stmt_name[index]);
    next = string_concat(next, "\n");
    next = dump_expr(next, arena, arena.stmt_expr[index], depth + 1);
    return next;
  }
  if kind == break_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Break\n");
    return next;
  }
  if kind == continue_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Continue\n");
    return next;
  }
  if kind == for_in_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "For binding=");
    next = string_concat(next, arena.stmt_name[index]);
    next = string_concat(next, "\n");
    let cpad: String = indent_of(depth + 1);
    next = string_concat(next, cpad);
    next = string_concat(next, "Iterable\n");
    next = dump_expr(next, arena, arena.stmt_expr[index], depth + 2);
    next = string_concat(next, cpad);
    next = string_concat(next, "Body\n");
    next = dump_block(next, arena, arena.stmt_then_start[index],
                      arena.stmt_then_count[index], depth + 2);
    return next;
  }
  if kind == for_c_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "ForC\n");
    let cpad: String = indent_of(depth + 1);
    next = string_concat(next, cpad);
    next = string_concat(next, "Init\n");
    next = dump_stmt(next, arena, arena.stmt_init[index], depth + 2);
    next = string_concat(next, cpad);
    next = string_concat(next, "Condition\n");
    next = dump_expr(next, arena, arena.stmt_expr[index], depth + 2);
    next = string_concat(next, cpad);
    next = string_concat(next, "Step\n");
    next = dump_stmt(next, arena, arena.stmt_step[index], depth + 2);
    next = string_concat(next, cpad);
    next = string_concat(next, "Body\n");
    next = dump_block(next, arena, arena.stmt_then_start[index],
                      arena.stmt_then_count[index], depth + 2);
    return next;
  }
  if kind == match_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Match\n");
    let cpad: String = indent_of(depth + 1);
    next = string_concat(next, cpad);
    next = string_concat(next, "Value\n");
    next = dump_expr(next, arena, arena.stmt_expr[index], depth + 2);
    let astart: Int = arena.stmt_then_start[index];
    let acount: Int = arena.stmt_then_count[index];
    let mut ai: Int = 0;
    while ai < acount {
      next = string_concat(next, cpad);
      next = string_concat(next, "Arm pattern=");
      next = string_concat(next, arena.arm_pattern[astart + ai]);
      next = string_concat(next, "\n");
      next = dump_block(next, arena, arena.arm_body_start[astart + ai],
                        arena.arm_body_count[astart + ai], depth + 2);
      ai = ai + 1;
    }
    return next;
  }
  if kind == expr_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "ExprStmt\n");
    next = dump_expr(next, arena, arena.stmt_expr[index], depth + 1);
    return next;
  }
  if kind == while_stmt() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "While\n");
    let cpad: String = indent_of(depth + 1);
    next = string_concat(next, cpad);
    next = string_concat(next, "Condition\n");
    next = dump_expr(next, arena, arena.stmt_expr[index], depth + 2);
    next = string_concat(next, cpad);
    next = string_concat(next, "Body\n");
    next = dump_block(next, arena, arena.stmt_then_start[index],
                      arena.stmt_then_count[index], depth + 2);
    return next;
  }
  // if
  let mut next: String = string_concat(out, pad);
  next = string_concat(next, "If\n");
  let cpad: String = indent_of(depth + 1);
  next = string_concat(next, cpad);
  next = string_concat(next, "Condition\n");
  next = dump_expr(next, arena, arena.stmt_expr[index], depth + 2);
  next = string_concat(next, cpad);
  next = string_concat(next, "Then\n");
  next = dump_block(next, arena, arena.stmt_then_start[index],
                    arena.stmt_then_count[index], depth + 2);
  if arena.stmt_else_count[index] > 0 {
    next = string_concat(next, cpad);
    next = string_concat(next, "Else\n");
    next = dump_block(next, arena, arena.stmt_else_start[index],
                      arena.stmt_else_count[index], depth + 2);
  }
  return next;
}

fn dump_block(out: String, arena: Arena, start: Int, count: Int, depth: Int) -> String {
  let mut next: String = out;
  let mut i: Int = 0;
  while i < count {
    next = dump_stmt(next, arena, arena.block_list[start + i], depth);
    i = i + 1;
  }
  return next;
}

// Walk an expr node recursively. `depth` is the indentation level (in 2-space
// units) at which this node's header line is emitted.
fn dump_expr(out: String, arena: Arena, node: Int, depth: Int) -> String {
  let pad: String = indent_of(depth);
  let kind: Int = arena.node_kind[node];
  if kind == int_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Int ");
    next = string_concat(next, arena.node_text[node]);
    next = string_concat(next, "\n");
    return next;
  }
  if kind == name_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Name ");
    next = string_concat(next, arena.node_text[node]);
    next = string_concat(next, "\n");
    return next;
  }
  if kind == bool_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Bool ");
    next = string_concat(next, arena.node_text[node]);
    next = string_concat(next, "\n");
    return next;
  }
  if kind == string_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "String ");
    next = string_concat(next, normalize_string_escapes(arena.node_text[node]));
    next = string_concat(next, "\n");
    return next;
  }
  if kind == unary_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Unary op=");
    next = string_concat(next, arena.node_text[node]);
    next = string_concat(next, "\n");
    next = dump_expr(next, arena, arena.node_a[node], depth + 1);
    return next;
  }
  if kind == call_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Call callee=");
    next = string_concat(next, arena.node_text[node]);
    next = string_concat(next, "\n");
    let start: Int = arena.node_a[node];
    let count: Int = arena.node_b[node];
    let mut i: Int = 0;
    while i < count {
      next = dump_expr(next, arena, arena.child_list[start + i], depth + 1);
      i = i + 1;
    }
    return next;
  }
  if kind == index_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Index\n");
    let cpad: String = indent_of(depth + 1);
    next = string_concat(next, cpad);
    next = string_concat(next, "Base\n");
    next = dump_expr(next, arena, arena.node_a[node], depth + 2);
    next = string_concat(next, cpad);
    next = string_concat(next, "Index\n");
    next = dump_expr(next, arena, arena.node_b[node], depth + 2);
    return next;
  }
  if kind == field_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "FieldAccess field=");
    next = string_concat(next, arena.node_text[node]);
    next = string_concat(next, "\n");
    next = dump_expr(next, arena, arena.node_a[node], depth + 1);
    return next;
  }
  if kind == array_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "ArrayLiteral\n");
    let start: Int = arena.node_a[node];
    let count: Int = arena.node_b[node];
    let mut i: Int = 0;
    while i < count {
      next = dump_expr(next, arena, arena.child_list[start + i], depth + 1);
      i = i + 1;
    }
    return next;
  }
  if kind == struct_lit_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "StructLiteral type=");
    next = string_concat(next, arena.node_text[node]);
    next = string_concat(next, "\n");
    let cpad: String = indent_of(depth + 1);
    let start: Int = arena.node_a[node];
    let count: Int = arena.node_b[node];
    let mut i: Int = 0;
    while i < count {
      next = string_concat(next, cpad);
      next = string_concat(next, "FieldInit name=");
      next = string_concat(next, arena.sl_field_name[start + i]);
      next = string_concat(next, "\n");
      next = dump_expr(next, arena, arena.sl_field_value[start + i], depth + 2);
      i = i + 1;
    }
    return next;
  }
  if kind == range_node() {
    let mut next: String = string_concat(out, pad);
    next = string_concat(next, "Range\n");
    next = dump_expr(next, arena, arena.node_a[node], depth + 1);
    next = dump_expr(next, arena, arena.node_b[node], depth + 1);
    return next;
  }
  // binary
  let mut next: String = string_concat(out, pad);
  next = string_concat(next, "Binary op=");
  next = string_concat(next, arena.node_text[node]);
  next = string_concat(next, "\n");
  next = dump_expr(next, arena, arena.node_a[node], depth + 1);
  next = dump_expr(next, arena, arena.node_b[node], depth + 1);
  return next;
}

fn indent_of(depth: Int) -> String {
  let mut out: String = "";
  let mut i: Int = 0;
  while i < depth {
    out = string_concat(out, "  ");
    i = i + 1;
  }
  return out;
}

// Replicate the Rust lexer's string-escape contract: `\"`, `\n`, `\\` keep their
// backslash (re-emitted by Rust's Debug formatting); every other `\<x>` drops the
// backslash and keeps x; real TAB/CR/LF bytes render as `\t`/`\r`/`\n`. The input
// `text` is the raw token slice including its surrounding quotes.
fn normalize_string_escapes(text: String) -> String {
  let len: Int = string_len(text);
  let mut out: String = "";
  let mut i: Int = 0;
  while i < len {
    let byte: Int = string_byte_at(text, i);
    if byte == 92 && i + 1 < len {
      let nextb: Int = string_byte_at(text, i + 1);
      if nextb == 110 || nextb == 92 || nextb == 34 {
        out = string_concat(out, string_byte_slice(text, i, 2));
      } else {
        out = string_concat(out, string_byte_slice(text, i + 1, 1));
      }
      i = i + 2;
    } else {
      if byte == 9 {
        out = string_concat(out, "\\t");
      } else {
        if byte == 13 {
          out = string_concat(out, "\\r");
        } else {
          if byte == 10 {
            out = string_concat(out, "\\n");
          } else {
            out = string_concat(out, string_byte_slice(text, i, 1));
          }
        }
      }
      i = i + 1;
    }
  }
  return out;
}

// ---------------------------------------------------------------------------
// Lexer — copied from the Stage1 frontend and trimmed to this slice's needs.
// Produces a parallel kinds / texts pair (each ending with an EOF / "" entry).
// ---------------------------------------------------------------------------
fn lex_kinds(source: String) -> IntArray {
  let mut kinds: IntArray = int_array_empty();
  let mut index: Int = 0;
  let len: Int = string_len(source);
  while index < len {
    let byte: Int = string_byte_at(source, index);
    let mut handled: Bool = false;
    if !handled && ascii_is_whitespace(byte) {
      index = index + 1;
      handled = true;
    }
    if !handled && byte == 47 && index + 1 < len && string_byte_at(source, index + 1) == 47 {
      index = index + 2;
      while index < len && string_byte_at(source, index) != 10 {
        index = index + 1;
      }
      handled = true;
    }
    if !handled && is_ident_start(byte) {
      let start: Int = index;
      index = index + 1;
      while index < len && is_ident_continue(string_byte_at(source, index)) {
        index = index + 1;
      }
      let text: String = string_byte_slice(source, start, index - start);
      kinds = int_array_push(kinds, keyword_or_ident(text));
      handled = true;
    }
    if !handled && ascii_is_digit(byte) {
      index = index + 1;
      while index < len && ascii_is_digit(string_byte_at(source, index)) {
        index = index + 1;
      }
      kinds = int_array_push(kinds, token_int());
      handled = true;
    }
    if !handled && byte == 34 {
      index = index + 1;
      while index < len && string_byte_at(source, index) != 34 {
        if string_byte_at(source, index) == 92 && index + 1 < len {
          index = index + 2;
        } else {
          index = index + 1;
        }
      }
      if index < len {
        index = index + 1;
      }
      kinds = int_array_push(kinds, token_string());
      handled = true;
    }
    if !handled {
      kinds = int_array_push(kinds, symbol_kind(source, index));
      index = index + symbol_width(source, index);
    }
  }
  return int_array_push(kinds, token_eof());
}

fn lex_texts(source: String) -> StringArray {
  let mut texts: StringArray = string_array_empty();
  let mut index: Int = 0;
  let len: Int = string_len(source);
  while index < len {
    let byte: Int = string_byte_at(source, index);
    let mut handled: Bool = false;
    if !handled && ascii_is_whitespace(byte) {
      index = index + 1;
      handled = true;
    }
    if !handled && byte == 47 && index + 1 < len && string_byte_at(source, index + 1) == 47 {
      index = index + 2;
      while index < len && string_byte_at(source, index) != 10 {
        index = index + 1;
      }
      handled = true;
    }
    if !handled && is_ident_start(byte) {
      let start: Int = index;
      index = index + 1;
      while index < len && is_ident_continue(string_byte_at(source, index)) {
        index = index + 1;
      }
      texts = string_array_push(texts, string_byte_slice(source, start, index - start));
      handled = true;
    }
    if !handled && ascii_is_digit(byte) {
      let start: Int = index;
      index = index + 1;
      while index < len && ascii_is_digit(string_byte_at(source, index)) {
        index = index + 1;
      }
      texts = string_array_push(texts, string_byte_slice(source, start, index - start));
      handled = true;
    }
    if !handled && byte == 34 {
      let start: Int = index;
      index = index + 1;
      while index < len && string_byte_at(source, index) != 34 {
        if string_byte_at(source, index) == 92 && index + 1 < len {
          index = index + 2;
        } else {
          index = index + 1;
        }
      }
      if index < len {
        index = index + 1;
      }
      texts = string_array_push(texts, string_byte_slice(source, start, index - start));
      handled = true;
    }
    if !handled {
      let width: Int = symbol_width(source, index);
      texts = string_array_push(texts, string_byte_slice(source, index, width));
      index = index + width;
    }
  }
  return string_array_push(texts, "");
}

// Third parallel lexer pass: each token's starting byte offset (the EOF sentinel
// carries the source length). Mirrors lex_kinds / lex_texts branch for branch so
// the three arrays always stay index-aligned.
fn lex_starts(source: String) -> IntArray {
  let mut starts: IntArray = int_array_empty();
  let mut index: Int = 0;
  let len: Int = string_len(source);
  while index < len {
    let byte: Int = string_byte_at(source, index);
    let mut handled: Bool = false;
    if !handled && ascii_is_whitespace(byte) {
      index = index + 1;
      handled = true;
    }
    if !handled && byte == 47 && index + 1 < len && string_byte_at(source, index + 1) == 47 {
      index = index + 2;
      while index < len && string_byte_at(source, index) != 10 {
        index = index + 1;
      }
      handled = true;
    }
    if !handled && is_ident_start(byte) {
      let start: Int = index;
      index = index + 1;
      while index < len && is_ident_continue(string_byte_at(source, index)) {
        index = index + 1;
      }
      starts = int_array_push(starts, start);
      handled = true;
    }
    if !handled && ascii_is_digit(byte) {
      let start: Int = index;
      index = index + 1;
      while index < len && ascii_is_digit(string_byte_at(source, index)) {
        index = index + 1;
      }
      starts = int_array_push(starts, start);
      handled = true;
    }
    if !handled && byte == 34 {
      let start: Int = index;
      index = index + 1;
      while index < len && string_byte_at(source, index) != 34 {
        if string_byte_at(source, index) == 92 && index + 1 < len {
          index = index + 2;
        } else {
          index = index + 1;
        }
      }
      if index < len {
        index = index + 1;
      }
      starts = int_array_push(starts, start);
      handled = true;
    }
    if !handled {
      starts = int_array_push(starts, index);
      index = index + symbol_width(source, index);
    }
  }
  return int_array_push(starts, len);
}

// Multi-byte operators: "->", "&&", "||", "==", "!=", "<=", ">=".
fn symbol_width(source: String, index: Int) -> Int {
  let byte: Int = string_byte_at(source, index);
  let len: Int = string_len(source);
  if byte == 45 && index + 1 < len && string_byte_at(source, index + 1) == 62 {
    return 2;
  }
  if byte == 38 && index + 1 < len && string_byte_at(source, index + 1) == 38 {
    return 2;
  }
  if byte == 124 && index + 1 < len && string_byte_at(source, index + 1) == 124 {
    return 2;
  }
  if byte == 61 && index + 1 < len && string_byte_at(source, index + 1) == 61 {
    return 2;
  }
  if byte == 33 && index + 1 < len && string_byte_at(source, index + 1) == 61 {
    return 2;
  }
  if byte == 60 && index + 1 < len && string_byte_at(source, index + 1) == 61 {
    return 2;
  }
  if byte == 62 && index + 1 < len && string_byte_at(source, index + 1) == 61 {
    return 2;
  }
  // ".." range operator.
  if byte == 46 && index + 1 < len && string_byte_at(source, index + 1) == 46 {
    return 2;
  }
  // Compound assignment operators "+=" "-=" "*=" "/=" "%=".
  if (byte == 43 || byte == 45 || byte == 42 || byte == 47 || byte == 37)
      && index + 1 < len && string_byte_at(source, index + 1) == 61 {
    return 2;
  }
  return 1;
}

fn is_ident_start(byte: Int) -> Bool {
  return ascii_is_alpha(byte) || byte == 95;
}

fn is_ident_continue(byte: Int) -> Bool {
  return is_ident_start(byte) || ascii_is_digit(byte);
}

fn keyword_or_ident(text: String) -> Int {
  if text == "module" {
    return token_module();
  }
  if text == "import" {
    return token_import();
  }
  if text == "export" {
    return token_export();
  }
  if text == "as" {
    return token_as();
  }
  if text == "struct" {
    return token_struct();
  }
  if text == "enum" {
    return token_enum();
  }
  if text == "fn" {
    return token_fn();
  }
  if text == "let" {
    return token_let();
  }
  if text == "mut" {
    return token_mut();
  }
  if text == "return" {
    return token_return();
  }
  if text == "if" {
    return token_if();
  }
  if text == "else" {
    return token_else();
  }
  if text == "while" {
    return token_while();
  }
  if text == "for" {
    return token_for();
  }
  if text == "in" {
    return token_in();
  }
  if text == "match" {
    return token_match();
  }
  if text == "break" {
    return token_break();
  }
  if text == "continue" {
    return token_continue();
  }
  if text == "true" {
    return token_true();
  }
  if text == "false" {
    return token_false();
  }
  return token_ident();
}

fn symbol_kind(source: String, index: Int) -> Int {
  let byte: Int = string_byte_at(source, index);
  let len: Int = string_len(source);
  if byte == 40 {
    return token_lparen();
  }
  if byte == 41 {
    return token_rparen();
  }
  if byte == 123 {
    return token_lbrace();
  }
  if byte == 125 {
    return token_rbrace();
  }
  if byte == 91 {
    return token_lbracket();
  }
  if byte == 93 {
    return token_rbracket();
  }
  if byte == 58 {
    return token_colon();
  }
  if byte == 59 {
    return token_semicolon();
  }
  if byte == 44 {
    return token_comma();
  }
  if byte == 46 {
    if index + 1 < len && string_byte_at(source, index + 1) == 46 {
      return token_dotdot();
    }
    return token_dot();
  }
  if byte == 45 {
    if index + 1 < len && string_byte_at(source, index + 1) == 62 {
      return token_arrow();
    }
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_minus_eq();
    }
    return token_minus();
  }
  if byte == 61 {
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_eqeq();
    }
    return token_eq();
  }
  if byte == 33 {
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_ne();
    }
    return token_bang();
  }
  if byte == 60 {
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_le();
    }
    return token_lt();
  }
  if byte == 62 {
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_ge();
    }
    return token_gt();
  }
  if byte == 38 {
    if index + 1 < len && string_byte_at(source, index + 1) == 38 {
      return token_andand();
    }
    return token_amp();
  }
  if byte == 124 {
    if index + 1 < len && string_byte_at(source, index + 1) == 124 {
      return token_oror();
    }
    return token_pipe();
  }
  if byte == 94 {
    return token_caret();
  }
  if byte == 126 {
    return token_tilde();
  }
  if byte == 43 {
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_plus_eq();
    }
    return token_plus();
  }
  if byte == 42 {
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_star_eq();
    }
    return token_star();
  }
  if byte == 47 {
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_slash_eq();
    }
    return token_slash();
  }
  if byte == 37 {
    if index + 1 < len && string_byte_at(source, index + 1) == 61 {
      return token_percent_eq();
    }
    return token_percent();
  }
  return token_unknown();
}

// ---------------------------------------------------------------------------
// Token ids (subset of the Stage1 set; values kept identical for familiarity).
// ---------------------------------------------------------------------------
fn token_eof() -> Int { return 0; }
fn token_ident() -> Int { return 1; }
fn token_int() -> Int { return 2; }
fn token_string() -> Int { return 3; }
fn token_module() -> Int { return 10; }
fn token_import() -> Int { return 11; }
fn token_export() -> Int { return 12; }
fn token_as() -> Int { return 13; }
fn token_struct() -> Int { return 23; }
fn token_enum() -> Int { return 24; }
fn token_fn() -> Int { return 14; }
fn token_let() -> Int { return 15; }
fn token_mut() -> Int { return 16; }
fn token_return() -> Int { return 17; }
fn token_if() -> Int { return 18; }
fn token_else() -> Int { return 19; }
fn token_while() -> Int { return 20; }
fn token_true() -> Int { return 21; }
fn token_false() -> Int { return 22; }
fn token_lparen() -> Int { return 30; }
fn token_rparen() -> Int { return 31; }
fn token_lbrace() -> Int { return 32; }
fn token_rbrace() -> Int { return 33; }
fn token_lbracket() -> Int { return 34; }
fn token_rbracket() -> Int { return 35; }
fn token_colon() -> Int { return 36; }
fn token_semicolon() -> Int { return 37; }
fn token_comma() -> Int { return 38; }
fn token_dot() -> Int { return 39; }
fn token_arrow() -> Int { return 40; }
fn token_eq() -> Int { return 41; }
fn token_eqeq() -> Int { return 42; }
fn token_ne() -> Int { return 43; }
fn token_lt() -> Int { return 44; }
fn token_le() -> Int { return 45; }
fn token_gt() -> Int { return 46; }
fn token_ge() -> Int { return 47; }
fn token_bang() -> Int { return 48; }
fn token_amp() -> Int { return 49; }
fn token_pipe() -> Int { return 50; }
fn token_plus() -> Int { return 51; }
fn token_minus() -> Int { return 52; }
fn token_star() -> Int { return 53; }
fn token_slash() -> Int { return 54; }
fn token_percent() -> Int { return 55; }
fn token_caret() -> Int { return 56; }
fn token_tilde() -> Int { return 57; }
fn token_andand() -> Int { return 58; }
fn token_oror() -> Int { return 59; }
fn token_break() -> Int { return 60; }
fn token_continue() -> Int { return 61; }
fn token_for() -> Int { return 62; }
fn token_in() -> Int { return 63; }
fn token_match() -> Int { return 64; }
fn token_dotdot() -> Int { return 65; }
fn token_plus_eq() -> Int { return 66; }
fn token_minus_eq() -> Int { return 67; }
fn token_star_eq() -> Int { return 68; }
fn token_slash_eq() -> Int { return 69; }
fn token_percent_eq() -> Int { return 70; }
fn token_unknown() -> Int { return 99; }

// ---------------------------------------------------------------------------
// M3 vertical slice #1: a minimal name resolver consuming the arena AST.
//
// This walks the *already-built* arena (the same one `dump_module_via_arena`
// produces) and reports every "unknown name reference" — a Name expression (or
// a simple-name assignment target) that is not bound by any param / let / for /
// match binding and is not a top-level item name (fn / struct / enum).
//
// Mirrors src/resolver.rs's RESOLVE_UNKNOWN_NAME behaviour ONLY:
//   * Calls (`Call callee=...`) do NOT produce unknown-name diagnostics here
//     (the Rust resolver classifies an unknown callee as RESOLVE_UNKNOWN_FUNCTION,
//     a different code), so we skip the callee root entirely and only resolve the
//     call arguments. Likewise struct-literal type names and field names are not
//     local references and are never reported.
//   * A bare `Name` is unknown when it is in neither `locals` nor
//     `top_level_names`. A simple-name assignment target is unknown when it is
//     not in `locals` (top-level names are NOT consulted for assign targets,
//     matching the Rust resolver).
//
// Scope stack: Zeta has no map, so `locals` is a StringArray used as a stack of
// bound names, paired with a logical `count`. Entering a block records the
// current `count`; bindings inside the block append to the array and bump
// `count`; on leaving, the parent simply reuses its own saved `count`, so the
// appended entries past that length are invisible to later lookups. Lookups only
// ever scan `locals[0 .. count]`, giving exact block scoping without truncation.
// ---------------------------------------------------------------------------

// Threaded resolver state. `top` holds the top-level item names (fn/struct/enum)
// gathered once up front; `locals`/`count` are the lexical scope stack described
// above; `report` accumulates the diagnostic text in AST-visit order; `fn_name`
// is the enclosing function (kept for parity with the Rust message, though the
// report format only needs the name).
struct ResolveState {
  arena: Arena,
  top: StringArray,
  top_count: Int,
  // Top-level function names only (a subset of `top`). A call callee is "known"
  // when it is in this set; otherwise it is RESOLVE_UNKNOWN_FUNCTION unless it is
  // an enum-variant call (see is_enum_variant_call).
  fns: StringArray,
  fn_count: Int,
  // Enum-variant pairs contributed by the standard imports (parallel arrays:
  // std_enums[i].std_variants[i] is a legal variant call). Populated only when
  // the module imports std.core / std.io — mirrors the Rust resolver extending
  // enum_variants with standard_enum_variants. Exact-length (no logical count).
  std_enums: StringArray,
  std_variants: StringArray,
  locals: StringArray,
  count: Int,
  report: String,
  fn_name: String,
}

export fn resolve_report(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut start_arena: Arena = arena_empty();
  start_arena.token_start = lex_starts(source);
  let parsed: ParseResult = parse_module(start_arena, kinds, texts, 0);
  let arena: Arena = parsed.arena;
  // Gather top-level names (function / struct / enum) — these shadow nothing but
  // make a bare reference to them legal. The same pass detects top-level
  // duplicates (RESOLVE_DUPLICATE_ITEM): the Rust resolver's check_top_level
  // runs BEFORE any function body is resolved, so all duplicate-item reports
  // come first in the report, in item order. `top` doubles as the "names seen
  // so far" set — a named item whose name is already in top[0..top_count] is a
  // duplicate (imports and module decls have no item name and never count).
  let mut report: String = "";
  // Import boundary: the only legal imports in a single-file resolve are the
  // standard `std.core` / `std.io` (mirroring the Rust resolver with empty
  // local_imports); anything else reports RESOLVE_UNKNOWN_IMPORT. Whether the
  // standard modules are imported ANYWHERE in the module is computed up front
  // (the Rust resolver builds standard_top_level_names before its item loop),
  // so an item conflicting with a std name reports even when it precedes the
  // import in the source.
  let mut has_std_core: Bool = false;
  let mut has_std_io: Bool = false;
  let mut si: Int = 0;
  while si < arena.item_kind.len {
    if arena.item_kind[si] == item_import() {
      let path: String = arena.import_path[arena.item_ref[si]];
      if path == "std.core" {
        has_std_core = true;
      }
      if path == "std.io" {
        has_std_io = true;
      }
    }
    si = si + 1;
  }
  // Top-level names contributed by the standard imports (enum names only —
  // std function names are callable but are NOT legal bare references).
  let mut std_top: StringArray = string_array_empty();
  if has_std_core {
    std_top = string_array_push(std_top, "OptionInt");
    std_top = string_array_push(std_top, "ResultInt");
  }
  if has_std_io {
    std_top = string_array_push(std_top, "ResultString");
  }
  let mut top: StringArray = string_array_empty();
  let mut top_count: Int = 0;
  // Function names only — the callee set consulted for RESOLVE_UNKNOWN_FUNCTION.
  let mut fns: StringArray = string_array_empty();
  let mut fn_count: Int = 0;
  let mut ii: Int = 0;
  while ii < arena.item_kind.len {
    let kind: Int = arena.item_kind[ii];
    let ref: Int = arena.item_ref[ii];
    if kind == item_import() {
      let path: String = arena.import_path[ref];
      if path != "std.core" && path != "std.io" {
        report = string_concat(report, "RESOLVE_UNKNOWN_IMPORT name=");
        report = string_concat(report, path);
        report = string_concat(report, span_suffix(arena.import_path_span_start[ref],
                                                   arena.import_path_span_end[ref]));
        report = string_concat(report, "\n");
      }
    }
    let mut name: String = "";
    let mut named: Bool = false;
    // Item-name ident start (the duplicate-item diagnostics point at it).
    let mut name_span_start: Int = 0 - 1;
    if kind == item_struct() {
      name = arena.struct_name[ref];
      name_span_start = arena.struct_name_span_start[ref];
      named = true;
    }
    if kind == item_enum() {
      name = arena.enum_name[ref];
      name_span_start = arena.enum_name_span_start[ref];
      named = true;
    }
    if kind == item_function() {
      name = arena.fn_name[ref];
      name_span_start = arena.fn_name_span_start[ref];
      named = true;
      fns = string_array_push(fns, name);
      fn_count = fn_count + 1;
    }
    if named {
      if name_in_list(top, top_count, name) {
        report = string_concat(report, "RESOLVE_DUPLICATE_ITEM name=");
        report = string_concat(report, name);
        report = string_concat(report, span_suffix(name_span_start, name_span_start + string_len(name)));
        report = string_concat(report, "\n");
      }
      top = string_array_push(top, name);
      top_count = top_count + 1;
      // A user item may ALSO clash with a std-import name (a second
      // RESOLVE_DUPLICATE_ITEM line for the same item, after the user-level
      // duplicate — matching the Rust resolver's two checks in that order).
      if name_in_list(std_top, std_top.len, name) {
        report = string_concat(report, "RESOLVE_DUPLICATE_ITEM name=");
        report = string_concat(report, name);
        report = string_concat(report, span_suffix(name_span_start, name_span_start + string_len(name)));
        report = string_concat(report, "\n");
      }
    }
    ii = ii + 1;
  }
  // Standard items join the lookup sets only AFTER duplicate detection (the
  // Rust resolver builds top_level_names / functions independently of
  // check_top_level's seen-set): std enum names become legal bare references,
  // std functions become known callees.
  let mut k: Int = 0;
  while k < std_top.len {
    top = string_array_push(top, std_top[k]);
    k = k + 1;
  }
  top_count = top.len;
  if has_std_core {
    fns = push_std_core_function_names(fns);
  }
  if has_std_io {
    fns = push_std_io_function_names(fns);
  }
  fn_count = fns.len;
  // Enum-variant pairs from the standard imports (legal `Enum.Variant(...)`
  // callees alongside the user enums in the arena's enum table).
  let mut std_enums: StringArray = string_array_empty();
  let mut std_variants: StringArray = string_array_empty();
  if has_std_core {
    std_enums = string_array_push(std_enums, "OptionInt");
    std_variants = string_array_push(std_variants, "Some");
    std_enums = string_array_push(std_enums, "OptionInt");
    std_variants = string_array_push(std_variants, "None");
    std_enums = string_array_push(std_enums, "ResultInt");
    std_variants = string_array_push(std_variants, "Ok");
    std_enums = string_array_push(std_enums, "ResultInt");
    std_variants = string_array_push(std_variants, "Err");
  }
  if has_std_io {
    std_enums = string_array_push(std_enums, "ResultString");
    std_variants = string_array_push(std_variants, "Ok");
    std_enums = string_array_push(std_enums, "ResultString");
    std_variants = string_array_push(std_variants, "Err");
  }
  // Build the shared resolver state once; per-function resolution resets the
  // scope stack but threads the report (and locals array growth) forward.
  let mut state: ResolveState = ResolveState {
    arena: arena,
    top: top,
    top_count: top_count,
    fns: fns,
    fn_count: fn_count,
    std_enums: std_enums,
    std_variants: std_variants,
    locals: string_array_empty(),
    count: 0,
    report: report,
    fn_name: "",
  };
  // Resolve each function body in source order.
  let mut fi: Int = 0;
  while fi < arena.item_kind.len {
    if arena.item_kind[fi] == item_function() {
      state = resolve_function(state, arena.item_ref[fi]);
    }
    fi = fi + 1;
  }
  return state.report;
}

// The std.core / std.io function name sets (mirror src/std_api.rs
// STD_CORE_FUNCTIONS / STD_IO_FUNCTIONS — the oracle differential will catch
// any drift between these lists and the Rust tables).
fn push_std_core_function_names(fns: StringArray) -> StringArray {
  let mut out: StringArray = fns;
  out = string_array_push(out, "string_len");
  out = string_array_push(out, "string_byte_at");
  out = string_array_push(out, "string_byte_slice");
  out = string_array_push(out, "string_concat");
  out = string_array_push(out, "int_to_string");
  out = string_array_push(out, "ascii_is_digit");
  out = string_array_push(out, "ascii_is_alpha");
  out = string_array_push(out, "ascii_is_alnum");
  out = string_array_push(out, "ascii_is_whitespace");
  out = string_array_push(out, "int_array_empty");
  out = string_array_push(out, "int_array_push");
  out = string_array_push(out, "string_array_empty");
  out = string_array_push(out, "string_array_push");
  out = string_array_push(out, "bool_array_empty");
  out = string_array_push(out, "bool_array_push");
  return out;
}

fn push_std_io_function_names(fns: StringArray) -> StringArray {
  let mut out: StringArray = fns;
  out = string_array_push(out, "file_read_to_string");
  out = string_array_push(out, "path_join");
  out = string_array_push(out, "path_basename");
  out = string_array_push(out, "diagnostic_format");
  return out;
}

// Resolve one function: reset the scope stack, seed it with the parameters,
// then walk the body. The report accumulated so far rides along in `state`.
fn resolve_function(state: ResolveState, ref: Int) -> ResolveState {
  let mut s: ResolveState = state;
  let arena: Arena = s.arena;
  s.count = 0;
  s.fn_name = arena.fn_name[ref];
  // Bind parameters through bind_local so a repeated parameter name reports
  // RESOLVE_DUPLICATE_LOCAL, exactly like the Rust resolver's param loop.
  let pstart: Int = arena.fn_param_start[ref];
  let pcount: Int = arena.fn_param_count[ref];
  let mut pi: Int = 0;
  while pi < pcount {
    let pspan: Int = arena.param_name_span_start[pstart + pi];
    s = bind_local(s, arena.param_name[pstart + pi],
                   pspan, pspan + string_len(arena.param_name[pstart + pi]));
    pi = pi + 1;
  }
  return resolve_block(s, arena.fn_body_start[ref], arena.fn_body_count[ref]);
}

// Is `name` currently in lexical scope (params + lets declared so far + loop /
// match bindings)? Only the first `count` stack entries are visible.
fn local_in_scope(state: ResolveState, name: String) -> Bool {
  let mut i: Int = 0;
  while i < state.count {
    if state.locals[i] == name {
      return true;
    }
    i = i + 1;
  }
  return false;
}

// Is `name` a top-level item (function / struct / enum)?
fn top_in_scope(state: ResolveState, name: String) -> Bool {
  let mut i: Int = 0;
  while i < state.top_count {
    if state.top[i] == name {
      return true;
    }
    i = i + 1;
  }
  return false;
}

// Is `name` among the first `count` entries of `list`? Plain prefix scan used
// for the top-level duplicate-item check (before ResolveState exists).
fn name_in_list(list: StringArray, count: Int, name: String) -> Bool {
  let mut i: Int = 0;
  while i < count {
    if list[i] == name {
      return true;
    }
    i = i + 1;
  }
  return false;
}

// Push a binding onto the scope stack, bumping the logical length.
//
// Duplicate-local semantics (RESOLVE_DUPLICATE_LOCAL): the Rust resolver keeps a
// single per-function `locals` map that is *cloned* on entry to every nested
// block. A `let`/param binding reports a duplicate when `insert` finds the name
// already present in that (possibly inherited) map. Our logical stack reproduces
// this exactly: a name is "already present" iff it is visible in the current
// scope (params + enclosing-block lets/bindings + earlier lets in this block) —
// i.e. iff `local_in_scope` is true at the moment of binding. Consequences,
// verified against the oracle:
//   * two `let x` in one block -> duplicate (second sees the first).
//   * param + `let` same name -> duplicate.
//   * inner-block `let x` shadowing an outer `let x` -> duplicate (the clone
//     carries the outer binding; this is the counterintuitive case).
//   * sibling blocks each with `let x` -> NOT a duplicate (the first block's
//     binding sits past the restored `count`, invisible to the second).
//   * for/match binding then same-name `let` in the body -> duplicate (caught
//     when the body's `let` runs, not when the loop/arm binding is introduced).
// for/match bindings themselves NEVER report — the Rust resolver inserts them
// unconditionally (a for/match binding shadowing an outer local is fine). Those
// callers use bind_local_silent below; only `let` and parameters use bind_local.
// (The C-for init is a `let` statement and so DOES go through bind_local, which
// is why `for (let mut i ...)` shadowing an outer `i` reports while `for i`
// shadowing it does not — matching the oracle exactly.)
fn bind_local(state: ResolveState, name: String, span_start: Int, span_end: Int) -> ResolveState {
  let mut s: ResolveState = state;
  if local_in_scope(s, name) {
    s = report_duplicate_local(s, name, span_start, span_end);
  }
  return bind_local_silent(s, name);
}

// Push a binding without ever reporting a duplicate. Used for for/match bindings
// (Rust inserts these unconditionally). Same logical-stack write as bind_local.
fn bind_local_silent(state: ResolveState, name: String) -> ResolveState {
  let mut s: ResolveState = state;
  // locals 是逻辑栈:写到逻辑位置 count(覆盖上一个块退出后残留、当前不可见的条目),
  // 仅当逻辑长度已达物理末尾时才真正扩展数组。否则残留条目会落在 count 之后,
  // 使 local_in_scope(只查 [0..count])看不到这个新绑定 —— 这正是嵌套块后
  // 兄弟块的循环/match 绑定被误报 unknown 的根因。
  if s.count < s.locals.len {
    s.locals[s.count] = name;
  } else {
    s.locals = string_array_push(s.locals, name);
  }
  s.count = s.count + 1;
  return s;
}

// Render the trailing ` span=S..E` suffix every diagnostic line carries,
// mirroring the byte offsets of the Rust Diagnostic.span.
fn span_suffix(start: Int, end: Int) -> String {
  let mut out: String = " span=";
  out = string_concat(out, int_to_string(start));
  out = string_concat(out, "..");
  out = string_concat(out, int_to_string(end));
  return out;
}

// Append one unknown-name diagnostic line.
fn report_unknown(state: ResolveState, name: String, span_start: Int, span_end: Int) -> ResolveState {
  let mut s: ResolveState = state;
  s.report = string_concat(s.report, "RESOLVE_UNKNOWN_NAME name=");
  s.report = string_concat(s.report, name);
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// Append one unknown-function diagnostic line (callee = the dotted path string).
fn report_unknown_function(state: ResolveState, callee: String, span_start: Int, span_end: Int) -> ResolveState {
  let mut s: ResolveState = state;
  s.report = string_concat(s.report, "RESOLVE_UNKNOWN_FUNCTION name=");
  s.report = string_concat(s.report, callee);
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// Append one duplicate-local diagnostic line (span = the NEW binding's ident).
fn report_duplicate_local(state: ResolveState, name: String, span_start: Int, span_end: Int) -> ResolveState {
  let mut s: ResolveState = state;
  s.report = string_concat(s.report, "RESOLVE_DUPLICATE_LOCAL name=");
  s.report = string_concat(s.report, name);
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// Is `callee` an enum-variant call, i.e. `Enum.Variant` where `Enum` is a
// user-defined enum (arena enum table) or a std-import enum (state.std_enums
// pairs) and `Variant` is one of its variants? Mirrors the Rust resolver's
// is_enum_variant_call: split at the LAST '.', then check the tables.
fn is_enum_variant_call(state: ResolveState, callee: String) -> Bool {
  let arena: Arena = state.arena;
  let len: Int = string_len(callee);
  // find the last '.' (byte 46)
  let mut dot: Int = 0 - 1;
  let mut i: Int = len - 1;
  while i >= 0 {
    if string_byte_at(callee, i) == 46 {
      dot = i;
      i = 0 - 1;
    } else {
      i = i - 1;
    }
  }
  if dot < 0 {
    return false;
  }
  let enum_name: String = string_byte_slice(callee, 0, dot);
  let variant: String = string_byte_slice(callee, dot + 1, len - 1 - dot);
  // Scan the enum table for a matching enum name + variant.
  let mut e: Int = 0;
  while e < arena.enum_name.len {
    if arena.enum_name[e] == enum_name {
      let vstart: Int = arena.enum_variant_start[e];
      let vcount: Int = arena.enum_variant_count[e];
      let mut v: Int = 0;
      while v < vcount {
        if arena.variant_name[vstart + v] == variant {
          return true;
        }
        v = v + 1;
      }
    }
    e = e + 1;
  }
  // Standard-import enum variants (exact-length parallel pairs).
  let mut p: Int = 0;
  while p < state.std_enums.len {
    if state.std_enums[p] == enum_name && state.std_variants[p] == variant {
      return true;
    }
    p = p + 1;
  }
  return false;
}

// Is `callee` a known top-level function name?
fn fn_in_scope(state: ResolveState, name: String) -> Bool {
  let mut i: Int = 0;
  while i < state.fn_count {
    if state.fns[i] == name {
      return true;
    }
    i = i + 1;
  }
  return false;
}

// Resolve a contiguous run of statements (a block). Bindings introduced by the
// block live only until `resolve_block` returns, because we restore the caller's
// `count` on the way out (the appended entries stay in the array but become
// unreachable). `locals` and `report` are threaded forward so later sibling
// statements and outer scopes see accumulated diagnostics and any array growth.
fn resolve_block(state: ResolveState, start: Int, count: Int) -> ResolveState {
  let mut s: ResolveState = state;
  let saved: Int = s.count;
  let arena: Arena = s.arena;
  let mut i: Int = 0;
  while i < count {
    let stmt_index: Int = arena.block_list[start + i];
    s = resolve_stmt(s, stmt_index);
    i = i + 1;
  }
  // Leave the block: forget bindings introduced inside it. The underlying array
  // may have grown (and that growth is preserved for the caller via `s.locals`),
  // but only the first `saved` entries are in scope again.
  s.count = saved;
  return s;
}

// Resolve one statement, mutating scope (for let bindings) and threading state.
fn resolve_stmt(state: ResolveState, index: Int) -> ResolveState {
  let arena: Arena = state.arena;
  let kind: Int = arena.stmt_kind[index];
  let mut s: ResolveState = state;
  if kind == let_stmt() {
    // The initializer is resolved in the *pre-binding* scope (so a let cannot
    // see itself), then the name becomes visible to following statements.
    s = resolve_expr(s, arena.stmt_expr[index]);
    let lspan: Int = arena.stmt_name_span_start[index];
    s = bind_local(s, arena.stmt_name[index],
                   lspan, lspan + string_len(arena.stmt_name[index]));
    return s;
  }
  if kind == return_stmt() {
    if arena.stmt_expr[index] >= 0 {
      s = resolve_expr(s, arena.stmt_expr[index]);
    }
    return s;
  }
  if kind == expr_stmt() {
    s = resolve_expr(s, arena.stmt_expr[index]);
    return s;
  }
  if kind == assign_stmt() {
    // value first (matches Rust ordering), then the target.
    s = resolve_expr(s, arena.stmt_expr[index]);
    if arena.stmt_target[index] >= 0 {
      // Complex target (field / index chain): resolve it as an expression — its
      // Name root is reported as unknown only if absent from BOTH scopes, just
      // like any other Name expression.
      s = resolve_expr(s, arena.stmt_target[index]);
    } else {
      // Simple `name = ...`: unknown when not a local (top-level names are NOT
      // consulted for assignment targets, mirroring the Rust resolver).
      let target_name: String = arena.stmt_name[index];
      if !local_in_scope(s, target_name) {
        let tspan: Int = arena.stmt_name_span_start[index];
        s = report_unknown(s, target_name, tspan, tspan + string_len(target_name));
      }
    }
    return s;
  }
  if kind == if_stmt() {
    s = resolve_expr(s, arena.stmt_expr[index]);
    // then / else each get a fresh nested scope (block bindings don't leak).
    s = resolve_block(s, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    s = resolve_block(s, arena.stmt_else_start[index], arena.stmt_else_count[index]);
    return s;
  }
  if kind == while_stmt() {
    s = resolve_expr(s, arena.stmt_expr[index]);
    s = resolve_block(s, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    return s;
  }
  if kind == for_in_stmt() {
    s = resolve_expr(s, arena.stmt_expr[index]);
    // The loop binding is visible only inside the body. It is inserted
    // unconditionally (no duplicate report even if it shadows an outer local).
    let saved: Int = s.count;
    s = bind_local_silent(s, arena.stmt_name[index]);
    s = resolve_block(s, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    s.count = saved;
    return s;
  }
  if kind == for_c_stmt() {
    // init / condition / step / body all share one loop scope (init's binding is
    // visible to condition, step, and body).
    let saved: Int = s.count;
    s = resolve_stmt(s, arena.stmt_init[index]);
    s = resolve_expr(s, arena.stmt_expr[index]);
    s = resolve_stmt(s, arena.stmt_step[index]);
    s = resolve_block(s, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    s.count = saved;
    return s;
  }
  if kind == match_stmt() {
    s = resolve_expr(s, arena.stmt_expr[index]);
    let astart: Int = arena.stmt_then_start[index];
    let acount: Int = arena.stmt_then_count[index];
    let mut ai: Int = 0;
    while ai < acount {
      // Each arm binds its pattern variable (if any) only within that arm body.
      let saved: Int = s.count;
      let binding: String = pattern_binding(arena.arm_pattern[astart + ai]);
      if binding != "" {
        s = bind_local_silent(s, binding);
      }
      s = resolve_block(s, arena.arm_body_start[astart + ai], arena.arm_body_count[astart + ai]);
      s.count = saved;
      ai = ai + 1;
    }
    return s;
  }
  // break / continue: no names to resolve.
  return s;
}

// Extract the variable bound by a match-arm pattern, if any. Patterns were
// rendered to text by pattern_text:
//   name:x            -> binds x
//   variant:E.V(b)    -> binds b (the payload)
//   variant:E.V       -> binds nothing
//   int:/string:/bool:/_  -> bind nothing
// Returns "" when the arm introduces no binding.
fn pattern_binding(pattern: String) -> String {
  if string_starts_with(pattern, "name:") {
    return string_byte_slice(pattern, 5, string_len(pattern) - 5);
  }
  if string_starts_with(pattern, "variant:") {
    // A payload binding appears as `...(b)` at the end.
    let len: Int = string_len(pattern);
    if len > 0 && string_byte_at(pattern, len - 1) == 41 {
      // find the matching '('
      let mut i: Int = len - 2;
      let mut open: Int = 0 - 1;
      while i >= 0 {
        if string_byte_at(pattern, i) == 40 {
          open = i;
          i = 0 - 1;
        } else {
          i = i - 1;
        }
      }
      if open >= 0 {
        return string_byte_slice(pattern, open + 1, len - 1 - (open + 1));
      }
    }
    return "";
  }
  return "";
}

// The enum name inside a `variant:E.V` / `variant:E.V(b)` pattern text: the
// bytes between the 8-byte "variant:" prefix and the '.' (byte 46).
fn pattern_variant_enum(pattern: String) -> String {
  let len: Int = string_len(pattern);
  let mut i: Int = 8;
  while i < len {
    if string_byte_at(pattern, i) == 46 {
      return string_byte_slice(pattern, 8, i - 8);
    }
    i = i + 1;
  }
  return "";
}

// The variant name inside a `variant:E.V` / `variant:E.V(b)` pattern text:
// the bytes between the '.' and the '(' (byte 40) or the end.
fn pattern_variant_name(pattern: String) -> String {
  let len: Int = string_len(pattern);
  let mut dot: Int = 0 - 1;
  let mut i: Int = 8;
  while i < len {
    if string_byte_at(pattern, i) == 46 && dot < 0 {
      dot = i;
    }
    i = i + 1;
  }
  if dot < 0 {
    return "";
  }
  let mut end: Int = dot + 1;
  while end < len && string_byte_at(pattern, end) != 40 {
    end = end + 1;
  }
  return string_byte_slice(pattern, dot + 1, end - dot - 1);
}

// Does `text` begin with `prefix`?
fn string_starts_with(text: String, prefix: String) -> Bool {
  let plen: Int = string_len(prefix);
  if string_len(text) < plen {
    return false;
  }
  let mut i: Int = 0;
  while i < plen {
    if string_byte_at(text, i) != string_byte_at(prefix, i) {
      return false;
    }
    i = i + 1;
  }
  return true;
}

// Resolve one expression node, reporting unknown Name references in visit order.
fn resolve_expr(state: ResolveState, node: Int) -> ResolveState {
  let arena: Arena = state.arena;
  let kind: Int = arena.node_kind[node];
  let mut s: ResolveState = state;
  if kind == name_node() {
    let name: String = arena.node_text[node];
    if !local_in_scope(s, name) && !top_in_scope(s, name) {
      s = report_unknown(s, name, arena.node_span_start[node], arena.node_span_end[node]);
    }
    return s;
  }
  if kind == int_node() || kind == bool_node() || kind == string_node() {
    return s;
  }
  if kind == unary_node() {
    s = resolve_expr(s, arena.node_a[node]);
    return s;
  }
  if kind == binary_node() {
    s = resolve_expr(s, arena.node_a[node]);
    s = resolve_expr(s, arena.node_b[node]);
    return s;
  }
  if kind == call_node() {
    // The callee is NOT a local name reference. It is RESOLVE_UNKNOWN_FUNCTION
    // when it is neither a known top-level function nor an enum-variant call —
    // mirroring the Rust resolver, which consults only the function set and the
    // enum tables (locals are NOT considered, so a local used as a callee is
    // still reported as an unknown function). The callee is checked BEFORE the
    // arguments so the diagnostic order matches the oracle.
    let callee: String = arena.node_text[node];
    if !fn_in_scope(s, callee) && !is_enum_variant_call(s, callee) {
      s = report_unknown_function(s, callee,
                                  arena.node_span_start[node], arena.node_span_end[node]);
    }
    let start: Int = arena.node_a[node];
    let count: Int = arena.node_b[node];
    let mut i: Int = 0;
    while i < count {
      s = resolve_expr(s, arena.child_list[start + i]);
      i = i + 1;
    }
    return s;
  }
  if kind == index_node() {
    s = resolve_expr(s, arena.node_a[node]);
    s = resolve_expr(s, arena.node_b[node]);
    return s;
  }
  if kind == field_node() {
    // Only the base is a name reference; the field name is not.
    s = resolve_expr(s, arena.node_a[node]);
    return s;
  }
  if kind == array_node() {
    let start: Int = arena.node_a[node];
    let count: Int = arena.node_b[node];
    let mut i: Int = 0;
    while i < count {
      s = resolve_expr(s, arena.child_list[start + i]);
      i = i + 1;
    }
    return s;
  }
  if kind == struct_lit_node() {
    // The type name and field names are not local references; resolve only the
    // field value expressions.
    let start: Int = arena.node_a[node];
    let count: Int = arena.node_b[node];
    let mut i: Int = 0;
    while i < count {
      s = resolve_expr(s, arena.sl_field_value[start + i]);
      i = i + 1;
    }
    return s;
  }
  // range
  s = resolve_expr(s, arena.node_a[node]);
  s = resolve_expr(s, arena.node_b[node]);
  return s;
}

// ---------------------------------------------------------------------------
// M4 vertical slice #1: declared-type validation consuming the arena AST.
//
// Mirrors src/typecheck.rs's validate_declared_types, which runs BEFORE any
// function-body type checking and reports TYPE_UNKNOWN_TYPE for every declared
// type name that is neither a builtin, a user struct/enum (whole-module
// prescan, so forward references are legal), nor a std-import enum
// (`import std.core` grants OptionInt/ResultInt, `import std.io` grants
// ResultString — the import may appear anywhere in the module).
//
// Visit order, matching the oracle exactly: items in source order; struct
// fields in field order; enum variant payloads in variant order (payload-less
// variants are skipped); fn params in order, then the return type (only when
// `->` is present), then the body statements recursively — typed lets report
// their declared type; If recurses then before else; While/ForIn recurse the
// body; ForC recurses init, then step, then body (the condition is an
// expression and carries no declared type); Match recurses each arm body in
// arm order. Untyped lets and Assign/Return/Break/Continue/Expr report nothing.
// ---------------------------------------------------------------------------

export fn typecheck_report(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut start_arena: Arena = arena_empty();
  start_arena.token_start = lex_starts(source);
  let parsed: ParseResult = parse_module(start_arena, kinds, texts, 0);
  let arena: Arena = parsed.arena;
  // Whether the std modules are imported ANYWHERE in the module is computed up
  // front (the Rust typechecker builds standard_external_enums from the whole
  // module before validating).
  let mut has_std_core: Bool = false;
  let mut has_std_io: Bool = false;
  let mut si: Int = 0;
  while si < arena.item_kind.len {
    if arena.item_kind[si] == item_import() {
      let path: String = arena.import_path[arena.item_ref[si]];
      if path == "std.core" {
        has_std_core = true;
      }
      if path == "std.io" {
        has_std_io = true;
      }
    }
    si = si + 1;
  }
  // The legal type-name set: builtins + every user struct/enum name (prescanned
  // from the whole module, so forward references resolve) + std enums by import.
  let mut types: StringArray = string_array_empty();
  types = string_array_push(types, "Int");
  types = string_array_push(types, "String");
  types = string_array_push(types, "Bool");
  types = string_array_push(types, "Unit");
  types = string_array_push(types, "IntArray");
  types = string_array_push(types, "StringArray");
  types = string_array_push(types, "BoolArray");
  let mut ti: Int = 0;
  while ti < arena.struct_name.len {
    types = string_array_push(types, arena.struct_name[ti]);
    ti = ti + 1;
  }
  ti = 0;
  while ti < arena.enum_name.len {
    types = string_array_push(types, arena.enum_name[ti]);
    ti = ti + 1;
  }
  if has_std_core {
    types = string_array_push(types, "OptionInt");
    types = string_array_push(types, "ResultInt");
  }
  if has_std_io {
    types = string_array_push(types, "ResultString");
  }
  // Validate every declared type in item order.
  let mut report: String = "";
  let mut ii: Int = 0;
  while ii < arena.item_kind.len {
    let kind: Int = arena.item_kind[ii];
    let ref: Int = arena.item_ref[ii];
    if kind == item_struct() {
      let fstart: Int = arena.struct_field_start[ref];
      let fcount: Int = arena.struct_field_count[ref];
      let mut fi: Int = 0;
      while fi < fcount {
        report = check_type_name(report, types, arena.field_type[fstart + fi],
                                 arena.field_type_span_start[fstart + fi]);
        fi = fi + 1;
      }
    }
    if kind == item_enum() {
      let vstart: Int = arena.enum_variant_start[ref];
      let vcount: Int = arena.enum_variant_count[ref];
      let mut vi: Int = 0;
      while vi < vcount {
        // Only variants with a payload declare a type.
        if arena.variant_payload[vstart + vi] != "" {
          report = check_type_name(report, types, arena.variant_payload[vstart + vi],
                                   arena.variant_payload_span_start[vstart + vi]);
        }
        vi = vi + 1;
      }
    }
    if kind == item_function() {
      let pstart: Int = arena.fn_param_start[ref];
      let pcount: Int = arena.fn_param_count[ref];
      let mut pi: Int = 0;
      while pi < pcount {
        report = check_type_name(report, types, arena.param_type[pstart + pi],
                                 arena.param_type_span_start[pstart + pi]);
        pi = pi + 1;
      }
      if arena.fn_has_ret[ref] == 1 {
        report = check_type_name(report, types, arena.fn_ret[ref], arena.fn_ret_span_start[ref]);
      }
      report = validate_block(report, arena, types, arena.fn_body_start[ref], arena.fn_body_count[ref]);
    }
    ii = ii + 1;
  }
  // M4 slice #3: the callable-signature table. Std signatures first (gated on
  // the imports, mirroring standard_external_functions), user functions last —
  // tc_sig_index's reverse scan then reproduces the Rust map's precedence.
  let mut sigs: SigTable = SigTable {
    names: string_array_empty(),
    rets: string_array_empty(),
    param_start: int_array_empty(),
    param_count: int_array_empty(),
    params: string_array_empty(),
  };
  if has_std_core {
    sigs = sig_std_core(sigs);
  }
  if has_std_io {
    sigs = sig_std_io(sigs);
  }
  sigs = sig_user_functions(sigs, arena, types);
  // M4 slice #4: the enum-variant table (std rows first, user enums last —
  // tc_variant_index's reverse scan reproduces the Rust map's precedence).
  let enums: EnumTable = enum_table_build(arena, has_std_core, has_std_io);
  // M4 slice #2: after declared-type validation (whose diagnostics all come
  // first, mirroring the Rust check()), run expression type inference over
  // every function body in item order.
  let mut tc: TcState = TcState {
    arena: arena,
    types: types,
    sigs: sigs,
    enums: enums,
    local_names: string_array_empty(),
    local_types: string_array_empty(),
    local_muts: int_array_empty(),
    count: 0,
    report: report,
    ret: "",
    loop_depth: 0,
  };
  let mut tci: Int = 0;
  while tci < arena.item_kind.len {
    if arena.item_kind[tci] == item_function() {
      tc = tc_function(tc, arena.item_ref[tci]);
    }
    tci = tci + 1;
  }
  return tc.report;
}

// Append one TYPE_UNKNOWN_TYPE line when `name` is not in the legal type set.
// Every type name is a single ident token: span end = start + len(name).
fn check_type_name(report: String, types: StringArray, name: String, span_start: Int) -> String {
  if name_in_list(types, types.len, name) {
    return report;
  }
  let mut out: String = report;
  out = string_concat(out, "TYPE_UNKNOWN_TYPE name=");
  out = string_concat(out, name);
  out = string_concat(out, span_suffix(span_start, span_start + string_len(name)));
  out = string_concat(out, "\n");
  return out;
}

// Validate the declared types in a contiguous run of statements (a block).
fn validate_block(report: String, arena: Arena, types: StringArray, start: Int, count: Int) -> String {
  let mut out: String = report;
  let mut i: Int = 0;
  while i < count {
    out = validate_stmt(out, arena, types, arena.block_list[start + i]);
    i = i + 1;
  }
  return out;
}

// Validate one statement's declared types, recursing into nested blocks in the
// oracle's order (see the section comment above).
fn validate_stmt(report: String, arena: Arena, types: StringArray, index: Int) -> String {
  let kind: Int = arena.stmt_kind[index];
  let mut out: String = report;
  if kind == let_stmt() {
    // Only typed lets declare a type; untyped lets are not validated.
    if arena.stmt_has_type[index] == 1 {
      out = check_type_name(out, types, arena.stmt_type[index], arena.stmt_type_span_start[index]);
    }
    return out;
  }
  if kind == if_stmt() {
    out = validate_block(out, arena, types, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    out = validate_block(out, arena, types, arena.stmt_else_start[index], arena.stmt_else_count[index]);
    return out;
  }
  if kind == while_stmt() {
    return validate_block(out, arena, types, arena.stmt_then_start[index], arena.stmt_then_count[index]);
  }
  if kind == for_in_stmt() {
    return validate_block(out, arena, types, arena.stmt_then_start[index], arena.stmt_then_count[index]);
  }
  if kind == for_c_stmt() {
    // Oracle order: init, then step, then body (the condition is an expression).
    out = validate_stmt(out, arena, types, arena.stmt_init[index]);
    out = validate_stmt(out, arena, types, arena.stmt_step[index]);
    out = validate_block(out, arena, types, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    return out;
  }
  if kind == match_stmt() {
    let astart: Int = arena.stmt_then_start[index];
    let acount: Int = arena.stmt_then_count[index];
    let mut ai: Int = 0;
    while ai < acount {
      out = validate_block(out, arena, types,
                           arena.arm_body_start[astart + ai], arena.arm_body_count[astart + ai]);
      ai = ai + 1;
    }
    return out;
  }
  // assign / return / break / continue / expr: no declared types.
  return out;
}

// ---------------------------------------------------------------------------
// M4 vertical slices #2 + #3: expression type inference, mirroring
// src/typecheck.rs's check_function / check_stmts / infer_expr / expect_type.
//
// Types are represented by their Rust display strings: "Int" / "String" /
// "Bool" / "Unit" / "Range" / user struct & enum names verbatim / "<error>"
// for Type::Error / element+"Array" for Type::Array (so "IntArray",
// "StringArray", "PointArray", ...). Equality is plain string equality,
// exactly matching the oracle's Type comparison for every type this slice can
// produce — PROVIDED no user struct/enum name ends in "Array" (a Named type
// ending in "Array" would collide with an Array display; the corpus forbids
// such names).
//
// Slice 3 covers Call / StructLiteral / ArrayLiteral / Index / FieldAccess
// inference plus Assign-target checking. Slice 4 (the last) adds enum-variant
// CALLS (`E.V(x)`, TYPE_ENUM_VARIANT_ARITY/_PAYLOAD), enum VALUES (`E.V`,
// TYPE_ENUM_VARIANT_ARITY kind=uncalled / TYPE_UNKNOWN_VARIANT), match-pattern
// checking (TYPE_MATCH_PATTERN / TYPE_UNKNOWN_ENUM / TYPE_UNKNOWN_VARIANT /
// TYPE_ENUM_PATTERN_ARITY) and match exhaustiveness
// (TYPE_MATCH_NON_EXHAUSTIVE). Remaining corpus restrictions:
//   * TYPE_MISSING_FIELD iterates Rust's HashMap in RANDOM order — every
//     struct literal in the corpus must miss at most ONE field.
//   * Two user enums sharing one NAME: the flat EnumTable keeps both variant
//     row sets, while Rust's HashMap overwrite keeps only the later — the
//     corpus never declares duplicate enums.
// ---------------------------------------------------------------------------

// Threaded typecheck state. `local_names`/`local_types` form the same logical
// scope stack as the resolver's (write at `count`, save/restore `count` per
// block); lookups scan BACKWARDS so the newest visible binding wins, matching
// the Rust HashMap's insert-overwrite semantics under per-block clones. `ret`
// is the enclosing function's return type string; `loop_depth` gates
// break/continue.
struct TcState {
  arena: Arena,
  types: StringArray,
  sigs: SigTable,
  enums: EnumTable,
  local_names: StringArray,
  local_types: StringArray,
  local_muts: IntArray,
  count: Int,
  report: String,
  ret: String,
  loop_depth: Int,
}

// Callable signatures, mirroring the Rust `functions` map (function_signatures
// + or_insert of the std externals). Parallel arrays: per signature a name, a
// return-type display string, and a (param_start, param_count) slice into the
// flat `params` array. Std signatures are pushed FIRST and user functions
// LAST; tc_sig_index scans in REVERSE so a user fn shadows a std name (Rust's
// or_insert keeps the user entry) and a later duplicate user fn shadows an
// earlier one (HashMap collect overwrites).
struct SigTable {
  names: StringArray,
  rets: StringArray,
  param_start: IntArray,
  param_count: IntArray,
  params: StringArray,
}

// Zeta multi-return: infer hands back the threaded state plus the type string.
struct InferResult {
  st: TcState,
  ty: String,
}

// Mirror of the Rust parse_declared_type: a declared type name resolves to
// itself when legal (builtin / user struct / user enum / std-import enum — the
// slice-1 `types` set is exactly that) and to "<error>" otherwise.
fn tc_declared_type(types: StringArray, name: String) -> String {
  if name_in_list(types, types.len, name) {
    return name;
  }
  return "<error>";
}

// Append one signature to the table (flattening the param types).
fn sig_push(table: SigTable, name: String, ret: String, ptypes: StringArray) -> SigTable {
  let mut t: SigTable = table;
  t.names = string_array_push(t.names, name);
  t.rets = string_array_push(t.rets, ret);
  t.param_start = int_array_push(t.param_start, t.params.len);
  t.param_count = int_array_push(t.param_count, ptypes.len);
  let mut i: Int = 0;
  while i < ptypes.len {
    t.params = string_array_push(t.params, ptypes[i]);
    i = i + 1;
  }
  return t;
}

// The std.core signatures, mirroring src/std_api.rs STD_CORE_FUNCTIONS exactly
// (parameter types AND order). Type strings are stored raw: every std type is
// either a builtin or an enum granted by the SAME import, so Rust's
// parse_declared_type maps each one to itself in display-string space.
fn sig_std_core(table: SigTable) -> SigTable {
  let mut t: SigTable = table;
  t = sig_push(t, "string_len", "Int", ["String"]);
  t = sig_push(t, "string_byte_at", "Int", ["String", "Int"]);
  t = sig_push(t, "string_byte_slice", "String", ["String", "Int", "Int"]);
  t = sig_push(t, "string_concat", "String", ["String", "String"]);
  t = sig_push(t, "int_to_string", "String", ["Int"]);
  t = sig_push(t, "ascii_is_digit", "Bool", ["Int"]);
  t = sig_push(t, "ascii_is_alpha", "Bool", ["Int"]);
  t = sig_push(t, "ascii_is_alnum", "Bool", ["Int"]);
  t = sig_push(t, "ascii_is_whitespace", "Bool", ["Int"]);
  t = sig_push(t, "int_array_empty", "IntArray", string_array_empty());
  t = sig_push(t, "int_array_push", "IntArray", ["IntArray", "Int"]);
  t = sig_push(t, "string_array_empty", "StringArray", string_array_empty());
  t = sig_push(t, "string_array_push", "StringArray", ["StringArray", "String"]);
  t = sig_push(t, "bool_array_empty", "BoolArray", string_array_empty());
  t = sig_push(t, "bool_array_push", "BoolArray", ["BoolArray", "Bool"]);
  return t;
}

// The std.io signatures, mirroring src/std_api.rs STD_IO_FUNCTIONS exactly.
fn sig_std_io(table: SigTable) -> SigTable {
  let mut t: SigTable = table;
  t = sig_push(t, "file_read_to_string", "ResultString", ["String"]);
  t = sig_push(t, "path_join", "String", ["String", "String"]);
  t = sig_push(t, "path_basename", "String", ["String"]);
  t = sig_push(t, "diagnostic_format", "String", ["String", "Int", "Int", "String"]);
  return t;
}

// Append every user function's signature in item order. Param and return types
// go through tc_declared_type (the Rust parse_declared_type: unknown names
// degrade to "<error>"); a missing `->` clause means "Unit".
fn sig_user_functions(table: SigTable, arena: Arena, types: StringArray) -> SigTable {
  let mut t: SigTable = table;
  let mut i: Int = 0;
  while i < arena.fn_name.len {
    t.names = string_array_push(t.names, arena.fn_name[i]);
    if arena.fn_has_ret[i] == 1 {
      t.rets = string_array_push(t.rets, tc_declared_type(types, arena.fn_ret[i]));
    } else {
      t.rets = string_array_push(t.rets, "Unit");
    }
    t.param_start = int_array_push(t.param_start, t.params.len);
    t.param_count = int_array_push(t.param_count, arena.fn_param_count[i]);
    let pstart: Int = arena.fn_param_start[i];
    let mut pi: Int = 0;
    while pi < arena.fn_param_count[i] {
      t.params = string_array_push(t.params,
                                   tc_declared_type(types, arena.param_type[pstart + pi]));
      pi = pi + 1;
    }
    i = i + 1;
  }
  return t;
}

// Find `name` in the signature table; -1 on miss. REVERSE scan — see the
// SigTable comment for why this reproduces the Rust map's precedence.
fn tc_sig_index(sigs: SigTable, name: String) -> Int {
  let mut i: Int = sigs.names.len - 1;
  while i >= 0 {
    if sigs.names[i] == name {
      return i;
    }
    i = i - 1;
  }
  return 0 - 1;
}

// Find the struct-table row for `name`; -1 on miss. REVERSE scan so a later
// duplicate struct shadows an earlier one (HashMap collect overwrites).
fn tc_struct_index(arena: Arena, name: String) -> Int {
  let mut i: Int = arena.struct_name.len - 1;
  while i >= 0 {
    if arena.struct_name[i] == name {
      return i;
    }
    i = i - 1;
  }
  return 0 - 1;
}

// The declared type of `field` on struct row `sindex`, or "" when the struct
// has no such field. The declared text is returned VERBATIM — Rust builds the
// struct table with parse_type, which maps every name (even an unknown one
// like `Mystery`) to a type displaying as the name itself. This is the quirk
// that makes `b.m` type "Mystery" (NOT "<error>") when `struct B { m: Mystery }`.
fn tc_struct_field_type(arena: Arena, sindex: Int, field: String) -> String {
  let start: Int = arena.struct_field_start[sindex];
  let count: Int = arena.struct_field_count[sindex];
  let mut i: Int = count - 1;
  while i >= 0 {
    if arena.field_name[start + i] == field {
      return arena.field_type[start + i];
    }
    i = i - 1;
  }
  return "";
}

// Enum variants, mirroring the Rust `enums` map (enum_types + or_insert of the
// std-import enums). `enum_names` answers existence (user + std); the parallel
// v_enums/v_names/v_payloads triples hold one row per declared variant — a ""
// payload means the variant carries none, and payload TEXT is stored verbatim:
// Rust runs it through parse_type, which is the identity in display-string
// space (even an unknown name like `Ghost` displays as itself). Std rows are
// pushed FIRST and user enums LAST; tc_variant_index scans in REVERSE so a
// user enum shadows a std enum of the same name (Rust's or_insert keeps the
// user entry) and a later duplicate variant shadows an earlier one.
struct EnumTable {
  enum_names: StringArray,
  v_enums: StringArray,
  v_names: StringArray,
  v_payloads: StringArray,
}

// Append one variant row to the table.
fn enum_row_push(table: EnumTable, ename: String, vname: String, payload: String) -> EnumTable {
  let mut t: EnumTable = table;
  t.v_enums = string_array_push(t.v_enums, ename);
  t.v_names = string_array_push(t.v_names, vname);
  t.v_payloads = string_array_push(t.v_payloads, payload);
  return t;
}

// Build the whole enum table: std enums first (gated on the imports, mirroring
// standard_external_enums — std.core grants OptionInt{Some(Int),None} and
// ResultInt{Ok(Int),Err(String)}, std.io grants ResultString{Ok(String),
// Err(String)}), then every user enum in item order.
fn enum_table_build(arena: Arena, has_std_core: Bool, has_std_io: Bool) -> EnumTable {
  let mut t: EnumTable = EnumTable {
    enum_names: string_array_empty(),
    v_enums: string_array_empty(),
    v_names: string_array_empty(),
    v_payloads: string_array_empty(),
  };
  if has_std_core {
    t.enum_names = string_array_push(t.enum_names, "OptionInt");
    t = enum_row_push(t, "OptionInt", "Some", "Int");
    t = enum_row_push(t, "OptionInt", "None", "");
    t.enum_names = string_array_push(t.enum_names, "ResultInt");
    t = enum_row_push(t, "ResultInt", "Ok", "Int");
    t = enum_row_push(t, "ResultInt", "Err", "String");
  }
  if has_std_io {
    t.enum_names = string_array_push(t.enum_names, "ResultString");
    t = enum_row_push(t, "ResultString", "Ok", "String");
    t = enum_row_push(t, "ResultString", "Err", "String");
  }
  let mut e: Int = 0;
  while e < arena.enum_name.len {
    t.enum_names = string_array_push(t.enum_names, arena.enum_name[e]);
    let vstart: Int = arena.enum_variant_start[e];
    let vcount: Int = arena.enum_variant_count[e];
    let mut v: Int = 0;
    while v < vcount {
      t = enum_row_push(t, arena.enum_name[e],
                        arena.variant_name[vstart + v], arena.variant_payload[vstart + v]);
      v = v + 1;
    }
    e = e + 1;
  }
  return t;
}

// Is `name` an enum (user-defined or granted by a std import)?
fn tc_enum_exists(table: EnumTable, name: String) -> Bool {
  let mut i: Int = 0;
  while i < table.enum_names.len {
    if table.enum_names[i] == name {
      return true;
    }
    i = i + 1;
  }
  return false;
}

// Find the variant row for (ename, vname); -1 on miss. REVERSE scan — see the
// EnumTable comment for why this reproduces the Rust map's precedence.
fn tc_variant_index(table: EnumTable, ename: String, vname: String) -> Int {
  let mut i: Int = table.v_enums.len - 1;
  while i >= 0 {
    if table.v_enums[i] == ename && table.v_names[i] == vname {
      return i;
    }
    i = i - 1;
  }
  return 0 - 1;
}

// Does `text` end with `suffix`? Used to recognize Array display strings.
fn string_ends_with(text: String, suffix: String) -> Bool {
  let tlen: Int = string_len(text);
  let slen: Int = string_len(suffix);
  if tlen < slen {
    return false;
  }
  let mut i: Int = 0;
  while i < slen {
    if string_byte_at(text, tlen - slen + i) != string_byte_at(suffix, i) {
      return false;
    }
    i = i + 1;
  }
  return true;
}

// Index of the LAST '.' (byte 46) in `text`, or -1 — Rust rsplits a dotted
// callee at the last dot to extract a candidate (enum, variant) pair.
fn string_last_dot(text: String) -> Int {
  let mut i: Int = string_len(text) - 1;
  while i >= 0 {
    if string_byte_at(text, i) == 46 {
      return i;
    }
    i = i - 1;
  }
  return 0 - 1;
}

// Mirror of expect_type: equal types pass; an "<error>" on EITHER side is
// silently suppressed (error recovery never cascades); otherwise report one
// line `CODE expected=E found=F span=S..E`.
fn tc_expect(state: TcState, found: String, expected: String, code: String,
             span_start: Int, span_end: Int) -> TcState {
  if found == expected {
    return state;
  }
  if found == "<error>" || expected == "<error>" {
    return state;
  }
  let mut s: TcState = state;
  s.report = string_concat(s.report, code);
  s.report = string_concat(s.report, " expected=");
  s.report = string_concat(s.report, expected);
  s.report = string_concat(s.report, " found=");
  s.report = string_concat(s.report, found);
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// Fixed-message diagnostics (TYPE_FOR_ITERABLE / TYPE_BREAK_OUTSIDE_LOOP /
// TYPE_CONTINUE_OUTSIDE_LOOP) carry no expected/found pair.
fn tc_report_fixed(state: TcState, code: String, span_start: Int, span_end: Int) -> TcState {
  let mut s: TcState = state;
  s.report = string_concat(s.report, code);
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// Name-carrying diagnostics (TYPE_UNKNOWN_STRUCT / TYPE_DUPLICATE_FIELD /
// TYPE_UNKNOWN_FIELD / TYPE_MISSING_FIELD / TYPE_ARRAY_FIELD /
// TYPE_ASSIGN_IMMUTABLE / TYPE_UNKNOWN_NAME): one line `CODE name=N span=S..E`.
fn tc_report_name(state: TcState, code: String, name: String,
                  span_start: Int, span_end: Int) -> TcState {
  let mut s: TcState = state;
  s.report = string_concat(s.report, code);
  s.report = string_concat(s.report, " name=");
  s.report = string_concat(s.report, name);
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// TYPE_CALL_ARITY carries the callee plus two argument COUNTS:
// `TYPE_CALL_ARITY name=F expected=N found=M span=S..E`.
fn tc_report_arity(state: TcState, callee: String, expected: Int, found: Int,
                   span_start: Int, span_end: Int) -> TcState {
  let mut s: TcState = state;
  s.report = string_concat(s.report, "TYPE_CALL_ARITY name=");
  s.report = string_concat(s.report, callee);
  s.report = string_concat(s.report, " expected=");
  s.report = string_concat(s.report, int_to_string(expected));
  s.report = string_concat(s.report, " found=");
  s.report = string_concat(s.report, int_to_string(found));
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// TYPE_ENUM_VARIANT_ARITY in its CALL forms carries the dotted variant path
// plus the expected/found argument counts (expected is 1 for a payload variant
// and 0 for a bare one): `TYPE_ENUM_VARIANT_ARITY name=E.V expected=N found=M
// span=S..E`.
fn tc_report_variant_arity(state: TcState, ename: String, vname: String,
                           expected: Int, found: Int,
                           span_start: Int, span_end: Int) -> TcState {
  let mut s: TcState = state;
  s.report = string_concat(s.report, "TYPE_ENUM_VARIANT_ARITY name=");
  s.report = string_concat(s.report, ename);
  s.report = string_concat(s.report, ".");
  s.report = string_concat(s.report, vname);
  s.report = string_concat(s.report, " expected=");
  s.report = string_concat(s.report, int_to_string(expected));
  s.report = string_concat(s.report, " found=");
  s.report = string_concat(s.report, int_to_string(found));
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// Kind-carrying variant diagnostics: TYPE_ENUM_VARIANT_ARITY kind=uncalled
// (a payload variant used as a bare value) and TYPE_ENUM_PATTERN_ARITY
// kind=unbound / kind=spurious (a payload pattern without a binding / a bare
// pattern with one): `CODE name=E.V kind=K span=S..E`.
fn tc_report_variant_kind(state: TcState, code: String, ename: String, vname: String,
                          kind: String, span_start: Int, span_end: Int) -> TcState {
  let mut s: TcState = state;
  s.report = string_concat(s.report, code);
  s.report = string_concat(s.report, " name=");
  s.report = string_concat(s.report, ename);
  s.report = string_concat(s.report, ".");
  s.report = string_concat(s.report, vname);
  s.report = string_concat(s.report, " kind=");
  s.report = string_concat(s.report, kind);
  s.report = string_concat(s.report, span_suffix(span_start, span_end));
  s.report = string_concat(s.report, "\n");
  return s;
}

// Push a (name, type, mutability) binding onto the logical scope stack — same
// overwrite-at-count discipline as bind_local_silent, kept in lockstep across
// all THREE parallel arrays. is_mut is 1 only for `let mut` (params and
// for-in/match bindings are immutable in the oracle).
fn tc_bind(state: TcState, name: String, ty: String, is_mut: Int) -> TcState {
  let mut s: TcState = state;
  if s.count < s.local_names.len {
    s.local_names[s.count] = name;
    s.local_types[s.count] = ty;
    s.local_muts[s.count] = is_mut;
  } else {
    s.local_names = string_array_push(s.local_names, name);
    s.local_types = string_array_push(s.local_types, ty);
    s.local_muts = int_array_push(s.local_muts, is_mut);
  }
  s.count = s.count + 1;
  return s;
}

// Find a name's scope-stack slot, NEWEST binding first (reverse scan) — an
// inner shadowing `let` must win over the outer binding, exactly like the
// Rust HashMap clone where the inner insert overwrote the entry. -1 on miss.
fn tc_lookup_slot(state: TcState, name: String) -> Int {
  let mut i: Int = state.count - 1;
  while i >= 0 {
    if state.local_names[i] == name {
      return i;
    }
    i = i - 1;
  }
  return 0 - 1;
}

// A name's bound type; a miss is "<error>" WITHOUT a diagnostic (unknown names
// are the resolver's job).
fn tc_lookup(state: TcState, name: String) -> String {
  let slot: Int = tc_lookup_slot(state, name);
  if slot >= 0 {
    return state.local_types[slot];
  }
  return "<error>";
}

// The Binary ops that demand Int on both sides (TYPE_BINARY_OPERAND); the op
// names are the arena's node_text strings produced by binary_op_name.
fn tc_is_arith_op(op: String) -> Bool {
  return op == "add" || op == "sub" || op == "mul" || op == "div" || op == "mod"
      || op == "bit_and" || op == "bit_or" || op == "bit_xor";
}

// Typecheck one function: reset the scope stack, seed it with the parameters
// (typed via parse_declared_type, so an unknown param type binds "<error>"),
// set the return type ("Unit" when there is no `->` clause), then walk the
// body with loop_depth 0.
fn tc_function(state: TcState, ref: Int) -> TcState {
  let mut s: TcState = state;
  let arena: Arena = s.arena;
  s.count = 0;
  s.loop_depth = 0;
  if arena.fn_has_ret[ref] == 1 {
    s.ret = tc_declared_type(s.types, arena.fn_ret[ref]);
  } else {
    s.ret = "Unit";
  }
  let pstart: Int = arena.fn_param_start[ref];
  let pcount: Int = arena.fn_param_count[ref];
  let mut pi: Int = 0;
  while pi < pcount {
    // Parameters are immutable (Rust binds them with mutable: false).
    s = tc_bind(s, arena.param_name[pstart + pi],
                tc_declared_type(s.types, arena.param_type[pstart + pi]), 0);
    pi = pi + 1;
  }
  return tc_block(s, arena.fn_body_start[ref], arena.fn_body_count[ref]);
}

// Typecheck a contiguous run of statements with block scoping: save the
// logical count on entry, restore it on exit (the Rust check_stmts callers
// clone `locals` per nested block — saving/restoring the count is the same
// observable behaviour under reverse lookup).
fn tc_block(state: TcState, start: Int, count: Int) -> TcState {
  let mut s: TcState = state;
  let saved: Int = s.count;
  let arena: Arena = s.arena;
  let mut i: Int = 0;
  while i < count {
    s = tc_stmt(s, arena.block_list[start + i]);
    i = i + 1;
  }
  s.count = saved;
  return s;
}

// Typecheck one statement, mirroring the Rust check_stmts arm for arm.
fn tc_stmt(state: TcState, index: Int) -> TcState {
  let arena: Arena = state.arena;
  let kind: Int = arena.stmt_kind[index];
  let mut s: TcState = state;
  if kind == let_stmt() {
    let value: InferResult = tc_infer(s, arena.stmt_expr[index]);
    s = value.st;
    if arena.stmt_has_type[index] == 1 {
      // Annotated let: the value must match the declared type (span = the
      // value expression), and the binding carries the DECLARED type even on
      // mismatch — later uses follow the annotation, like the oracle.
      let declared: String = tc_declared_type(s.types, arena.stmt_type[index]);
      s = tc_expect(s, value.ty, declared, "TYPE_LET_MISMATCH",
                    arena.node_full_start[arena.stmt_expr[index]],
                    arena.node_full_end[arena.stmt_expr[index]]);
      return tc_bind(s, arena.stmt_name[index], declared, arena.stmt_mut[index]);
    }
    // Untyped let: the binding takes the inferred type.
    return tc_bind(s, arena.stmt_name[index], value.ty, arena.stmt_mut[index]);
  }
  if kind == return_stmt() {
    if arena.stmt_expr[index] >= 0 {
      let value: InferResult = tc_infer(s, arena.stmt_expr[index]);
      s = value.st;
      return tc_expect(s, value.ty, s.ret, "TYPE_RETURN_MISMATCH",
                       arena.node_full_start[arena.stmt_expr[index]],
                       arena.node_full_end[arena.stmt_expr[index]]);
    }
    // Bare `return;` returns Unit — the oracle reports the mismatch (against a
    // non-Unit return type) at the fixed span 0..0.
    return tc_expect(s, "Unit", s.ret, "TYPE_RETURN_MISMATCH", 0, 0);
  }
  if kind == expr_stmt() {
    let value: InferResult = tc_infer(s, arena.stmt_expr[index]);
    return value.st;
  }
  if kind == assign_stmt() {
    // Value first (Rust infers it before any target handling), then the target.
    let value: InferResult = tc_infer(s, arena.stmt_expr[index]);
    s = value.st;
    let vs: Int = arena.node_full_start[arena.stmt_expr[index]];
    let ve: Int = arena.node_full_end[arena.stmt_expr[index]];
    let target: Int = arena.stmt_target[index];
    if target < 0 {
      // Simple `name = value` (the Rust Expr::Name arm): mutable binding ->
      // value must match the BINDING type; immutable -> TYPE_ASSIGN_IMMUTABLE
      // at the target ident; unbound -> TYPE_UNKNOWN_NAME at the target ident.
      let name: String = arena.stmt_name[index];
      let slot: Int = tc_lookup_slot(s, name);
      let nspan: Int = arena.stmt_name_span_start[index];
      if slot >= 0 {
        if s.local_muts[slot] == 1 {
          return tc_expect(s, value.ty, s.local_types[slot], "TYPE_ASSIGN_MISMATCH", vs, ve);
        }
        return tc_report_name(s, "TYPE_ASSIGN_IMMUTABLE", name,
                              nspan, nspan + string_len(name));
      }
      return tc_report_name(s, "TYPE_UNKNOWN_NAME", name,
                            nspan, nspan + string_len(name));
    }
    let tkind: Int = arena.node_kind[target];
    if tkind == field_node() || tkind == index_node() {
      // Field/index target: infer the WHOLE target expression (its inner
      // diagnostics — e.g. an unknown field — still report), then walk the
      // node_a chain to the root (Rust's assign_root). A Name root is checked
      // for mutability; an UNBOUND root is silent (unlike the simple-name
      // case), and so is a broken chain (assign_root returned None).
      let tres: InferResult = tc_infer(s, target);
      s = tres.st;
      let mut root: Int = target;
      while arena.node_kind[root] == field_node() || arena.node_kind[root] == index_node() {
        root = arena.node_a[root];
      }
      if arena.node_kind[root] == name_node() {
        let rname: String = arena.node_text[root];
        let slot: Int = tc_lookup_slot(s, rname);
        if slot >= 0 {
          if s.local_muts[slot] == 1 {
            return tc_expect(s, value.ty, tres.ty, "TYPE_ASSIGN_MISMATCH", vs, ve);
          }
          return tc_report_name(s, "TYPE_ASSIGN_IMMUTABLE", rname,
                                arena.node_span_start[root], arena.node_span_end[root]);
        }
      }
      return s;
    }
    // Any other target shape is not an lvalue: fixed message at the target
    // span. (The corpus never reaches this — our parser collapses every Name
    // target, parenthesized or not, into the simple form, just like Rust.)
    return tc_report_fixed(s, "TYPE_ASSIGN_TARGET",
                           arena.node_full_start[target], arena.node_full_end[target]);
  }
  if kind == if_stmt() {
    let cond: InferResult = tc_infer(s, arena.stmt_expr[index]);
    s = tc_expect(cond.st, cond.ty, "Bool", "TYPE_IF_CONDITION",
                  arena.node_full_start[arena.stmt_expr[index]],
                  arena.node_full_end[arena.stmt_expr[index]]);
    s = tc_block(s, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    s = tc_block(s, arena.stmt_else_start[index], arena.stmt_else_count[index]);
    return s;
  }
  if kind == while_stmt() {
    let cond: InferResult = tc_infer(s, arena.stmt_expr[index]);
    s = tc_expect(cond.st, cond.ty, "Bool", "TYPE_WHILE_CONDITION",
                  arena.node_full_start[arena.stmt_expr[index]],
                  arena.node_full_end[arena.stmt_expr[index]]);
    s.loop_depth = s.loop_depth + 1;
    s = tc_block(s, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    s.loop_depth = s.loop_depth - 1;
    return s;
  }
  if kind == for_in_stmt() {
    let iter: InferResult = tc_infer(s, arena.stmt_expr[index]);
    s = iter.st;
    // Element type per the oracle: ANY array (display string ending in
    // "Array", e.g. "IntArray" or "PointArray") -> the element prefix,
    // Range -> Int, "<error>" stays silent, anything else reports
    // TYPE_FOR_ITERABLE (fixed message, span = the iterable) and degrades to
    // "<error>".
    let mut elem: String = "";
    let mut matched: Bool = false;
    if string_ends_with(iter.ty, "Array") {
      elem = string_byte_slice(iter.ty, 0, string_len(iter.ty) - 5);
      matched = true;
    }
    if iter.ty == "Range" {
      elem = "Int";
      matched = true;
    }
    if iter.ty == "<error>" {
      elem = "<error>";
      matched = true;
    }
    if !matched {
      s = tc_report_fixed(s, "TYPE_FOR_ITERABLE",
                          arena.node_full_start[arena.stmt_expr[index]],
                          arena.node_full_end[arena.stmt_expr[index]]);
      elem = "<error>";
    }
    let saved: Int = s.count;
    s = tc_bind(s, arena.stmt_name[index], elem, 0);
    s.loop_depth = s.loop_depth + 1;
    s = tc_block(s, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    s.loop_depth = s.loop_depth - 1;
    s.count = saved;
    return s;
  }
  if kind == for_c_stmt() {
    // One loop scope shared by init/cond/step/body. The oracle checks init at
    // the CURRENT loop_depth, then cond, then step and body at depth + 1.
    let saved: Int = s.count;
    s = tc_stmt(s, arena.stmt_init[index]);
    let cond: InferResult = tc_infer(s, arena.stmt_expr[index]);
    s = tc_expect(cond.st, cond.ty, "Bool", "TYPE_FORC_CONDITION",
                  arena.node_full_start[arena.stmt_expr[index]],
                  arena.node_full_end[arena.stmt_expr[index]]);
    s.loop_depth = s.loop_depth + 1;
    s = tc_stmt(s, arena.stmt_step[index]);
    s = tc_block(s, arena.stmt_then_start[index], arena.stmt_then_count[index]);
    s.loop_depth = s.loop_depth - 1;
    s.count = saved;
    return s;
  }
  if kind == match_stmt() {
    let value: InferResult = tc_infer(s, arena.stmt_expr[index]);
    s = value.st;
    // EVERY pattern diagnostic (and the exhaustiveness one) points at the
    // match VALUE expression, mirroring the Rust value.span() everywhere.
    let vs: Int = arena.node_full_start[arena.stmt_expr[index]];
    let ve: Int = arena.node_full_end[arena.stmt_expr[index]];
    let astart: Int = arena.stmt_then_start[index];
    let acount: Int = arena.stmt_then_count[index];
    let mut ai: Int = 0;
    while ai < acount {
      // Each arm gets a child scope: pattern check + bindings first (Rust's
      // check_pattern), then the body. The arm_pattern text was rendered by
      // pattern_text: int:N / string:"x" / bool:true / _ / name:x /
      // variant:E.V / variant:E.V(b).
      let saved: Int = s.count;
      let pattern: String = arena.arm_pattern[astart + ai];
      if string_starts_with(pattern, "variant:") {
        let ename: String = pattern_variant_enum(pattern);
        let vname: String = pattern_variant_name(pattern);
        let binding: String = pattern_binding(pattern);
        // The value must match the pattern's enum FIRST; then the enum and
        // variant lookups, then the payload/binding arity. A payload binding
        // carries the payload's declared text (parse_type identity); a
        // SPURIOUS binding (kind=spurious) binds nothing.
        s = tc_expect(s, value.ty, ename, "TYPE_MATCH_PATTERN", vs, ve);
        if !tc_enum_exists(s.enums, ename) {
          s = tc_report_name(s, "TYPE_UNKNOWN_ENUM", ename, vs, ve);
        } else {
          let vrow: Int = tc_variant_index(s.enums, ename, vname);
          if vrow < 0 {
            s = tc_report_name(s, "TYPE_UNKNOWN_VARIANT", vname, vs, ve);
          } else {
            let payload: String = s.enums.v_payloads[vrow];
            if payload != "" && binding != "" {
              s = tc_bind(s, binding, payload, 0);
            }
            if payload != "" && binding == "" {
              s = tc_report_variant_kind(s, "TYPE_ENUM_PATTERN_ARITY",
                                         ename, vname, "unbound", vs, ve);
            }
            if payload == "" && binding != "" {
              s = tc_report_variant_kind(s, "TYPE_ENUM_PATTERN_ARITY",
                                         ename, vname, "spurious", vs, ve);
            }
          }
        }
      }
      if string_starts_with(pattern, "int:") {
        s = tc_expect(s, value.ty, "Int", "TYPE_MATCH_PATTERN", vs, ve);
      }
      if string_starts_with(pattern, "string:") {
        s = tc_expect(s, value.ty, "String", "TYPE_MATCH_PATTERN", vs, ve);
      }
      if string_starts_with(pattern, "bool:") {
        s = tc_expect(s, value.ty, "Bool", "TYPE_MATCH_PATTERN", vs, ve);
      }
      if string_starts_with(pattern, "name:") {
        s = tc_bind(s, pattern_binding(pattern), value.ty, 0);
      }
      // `_`: no check, no binding.
      s = tc_block(s, arena.arm_body_start[astart + ai], arena.arm_body_count[astart + ai]);
      s.count = saved;
      ai = ai + 1;
    }
    return tc_match_exhaustiveness(s, value.ty, vs, ve, astart, acount);
  }
  if kind == break_stmt() {
    if s.loop_depth == 0 {
      let bspan: Int = arena.stmt_name_span_start[index];
      s = tc_report_fixed(s, "TYPE_BREAK_OUTSIDE_LOOP", bspan, bspan + 5);
    }
    return s;
  }
  // continue
  if s.loop_depth == 0 {
    let cspan: Int = arena.stmt_name_span_start[index];
    s = tc_report_fixed(s, "TYPE_CONTINUE_OUTSIDE_LOOP", cspan, cspan + 8);
  }
  return s;
}

// Infer one expression's type, reporting operand diagnostics in the oracle's
// visit order (children are fully inferred BEFORE the parent's expects run).
fn tc_infer(state: TcState, node: Int) -> InferResult {
  let arena: Arena = state.arena;
  let kind: Int = arena.node_kind[node];
  let mut s: TcState = state;
  if kind == name_node() {
    // A miss is "<error>" with no report — unknown names belong to the
    // resolver, and "<error>" then suppresses every downstream expect.
    return InferResult { st: s, ty: tc_lookup(s, arena.node_text[node]) };
  }
  if kind == int_node() {
    return InferResult { st: s, ty: "Int" };
  }
  if kind == string_node() {
    return InferResult { st: s, ty: "String" };
  }
  if kind == bool_node() {
    return InferResult { st: s, ty: "Bool" };
  }
  if kind == binary_node() {
    let left: InferResult = tc_infer(s, arena.node_a[node]);
    let right: InferResult = tc_infer(left.st, arena.node_b[node]);
    s = right.st;
    let op: String = arena.node_text[node];
    let ls: Int = arena.node_full_start[arena.node_a[node]];
    let le: Int = arena.node_full_end[arena.node_a[node]];
    let rs: Int = arena.node_full_start[arena.node_b[node]];
    let re: Int = arena.node_full_end[arena.node_b[node]];
    if tc_is_arith_op(op) {
      s = tc_expect(s, left.ty, "Int", "TYPE_BINARY_OPERAND", ls, le);
      s = tc_expect(s, right.ty, "Int", "TYPE_BINARY_OPERAND", rs, re);
      return InferResult { st: s, ty: "Int" };
    }
    if op == "and" || op == "or" {
      s = tc_expect(s, left.ty, "Bool", "TYPE_LOGICAL_OPERAND", ls, le);
      s = tc_expect(s, right.ty, "Bool", "TYPE_LOGICAL_OPERAND", rs, re);
      return InferResult { st: s, ty: "Bool" };
    }
    if op == "eq" || op == "not_eq" {
      // Equality only demands that the RIGHT side match the left's type.
      s = tc_expect(s, right.ty, left.ty, "TYPE_EQUALITY_OPERAND", rs, re);
      return InferResult { st: s, ty: "Bool" };
    }
    // lt / lte / gt / gte: ordering demands Int on both sides.
    s = tc_expect(s, left.ty, "Int", "TYPE_ORDERING_OPERAND", ls, le);
    s = tc_expect(s, right.ty, "Int", "TYPE_ORDERING_OPERAND", rs, re);
    return InferResult { st: s, ty: "Bool" };
  }
  if kind == unary_node() {
    let operand: InferResult = tc_infer(s, arena.node_a[node]);
    s = operand.st;
    let os: Int = arena.node_full_start[arena.node_a[node]];
    let oe: Int = arena.node_full_end[arena.node_a[node]];
    if arena.node_text[node] == "not" {
      s = tc_expect(s, operand.ty, "Bool", "TYPE_UNARY_OPERAND", os, oe);
      return InferResult { st: s, ty: "Bool" };
    }
    // neg / bit_not
    s = tc_expect(s, operand.ty, "Int", "TYPE_UNARY_OPERAND", os, oe);
    return InferResult { st: s, ty: "Int" };
  }
  if kind == range_node() {
    // Oracle order: infer + expect the start bound, THEN infer + expect the
    // end bound (each expect points at its own bound expression).
    let startr: InferResult = tc_infer(s, arena.node_a[node]);
    s = tc_expect(startr.st, startr.ty, "Int", "TYPE_RANGE_BOUND",
                  arena.node_full_start[arena.node_a[node]],
                  arena.node_full_end[arena.node_a[node]]);
    let endr: InferResult = tc_infer(s, arena.node_b[node]);
    s = tc_expect(endr.st, endr.ty, "Int", "TYPE_RANGE_BOUND",
                  arena.node_full_start[arena.node_b[node]],
                  arena.node_full_end[arena.node_b[node]]);
    return InferResult { st: s, ty: "Range" };
  }
  if kind == call_node() {
    let callee: String = arena.node_text[node];
    // Rust rsplits the callee at the LAST '.': an enum prefix takes the
    // infer_enum_variant_call path; any OTHER dotted path misses the function
    // map (its keys are plain idents) and returns Error silently, arguments
    // unvisited.
    let dot: Int = string_last_dot(callee);
    if dot >= 0 {
      let ename: String = string_byte_slice(callee, 0, dot);
      if tc_enum_exists(s.enums, ename) {
        let vname: String = string_byte_slice(callee, dot + 1,
                                              string_len(callee) - 1 - dot);
        return tc_infer_variant_call(s, node, ename, vname);
      }
      return InferResult { st: s, ty: "<error>" };
    }
    let sig: Int = tc_sig_index(s.sigs, callee);
    if sig < 0 {
      // Unknown callee: silent "<error>", arguments NOT visited (the Rust
      // `let else` returns before the argument loop).
      return InferResult { st: s, ty: "<error>" };
    }
    let pcount: Int = s.sigs.param_count[sig];
    let acount: Int = arena.node_b[node];
    if acount != pcount {
      // Arity mismatch reports at the callee path and returns the signature's
      // return type IMMEDIATELY — the arguments are never visited.
      s = tc_report_arity(s, callee, pcount, acount,
                          arena.node_span_start[node], arena.node_span_end[node]);
      return InferResult { st: s, ty: s.sigs.rets[sig] };
    }
    let astart: Int = arena.node_a[node];
    let pstart: Int = s.sigs.param_start[sig];
    let mut ai: Int = 0;
    while ai < pcount {
      // Interleaved like the Rust zip loop: infer argument i, expect it
      // against parameter i (span = the argument), then move on.
      let argn: Int = arena.child_list[astart + ai];
      let arg: InferResult = tc_infer(s, argn);
      s = tc_expect(arg.st, arg.ty, s.sigs.params[pstart + ai], "TYPE_CALL_ARGUMENT",
                    arena.node_full_start[argn], arena.node_full_end[argn]);
      ai = ai + 1;
    }
    return InferResult { st: s, ty: s.sigs.rets[sig] };
  }
  if kind == struct_lit_node() {
    let ty: String = arena.node_text[node];
    let fstart: Int = arena.node_a[node];
    let fcount: Int = arena.node_b[node];
    let sidx: Int = tc_struct_index(arena, ty);
    if sidx < 0 {
      // Unknown struct: report at the type-name token, still infer every
      // field value (their inner diagnostics report), and return the name
      // VERBATIM — Rust recovers with Named(ty), not Error.
      s = tc_report_name(s, "TYPE_UNKNOWN_STRUCT", ty,
                         arena.node_span_start[node], arena.node_span_end[node]);
      let mut ui: Int = 0;
      while ui < fcount {
        let uv: InferResult = tc_infer(s, arena.sl_field_value[fstart + ui]);
        s = uv.st;
        ui = ui + 1;
      }
      return InferResult { st: s, ty: ty };
    }
    // Literal fields in source order: duplicate check (against the already-
    // seen list, reporting the SECOND occurrence at ITS name token), then the
    // value's inference, then the declared-field check.
    let mut seen: StringArray = string_array_empty();
    let mut fi: Int = 0;
    while fi < fcount {
      let fname: String = arena.sl_field_name[fstart + fi];
      let nspan: Int = arena.sl_field_name_span_start[fstart + fi];
      if name_in_list(seen, seen.len, fname) {
        s = tc_report_name(s, "TYPE_DUPLICATE_FIELD", fname,
                           nspan, nspan + string_len(fname));
      }
      seen = string_array_push(seen, fname);
      let vnode: Int = arena.sl_field_value[fstart + fi];
      let v: InferResult = tc_infer(s, vnode);
      s = v.st;
      let decl: String = tc_struct_field_type(arena, sidx, fname);
      if decl != "" {
        s = tc_expect(s, v.ty, decl, "TYPE_STRUCT_FIELD",
                      arena.node_full_start[vnode], arena.node_full_end[vnode]);
      } else {
        s = tc_report_name(s, "TYPE_UNKNOWN_FIELD", fname,
                           nspan, nspan + string_len(fname));
      }
      fi = fi + 1;
    }
    // Declared fields absent from the literal, each at the type-name token.
    // CAUTION: Rust iterates fields.keys() in HashMap RANDOM order here while
    // we iterate declaration order — the corpus keeps at most ONE missing
    // field per literal so the orders cannot diverge.
    let dstart: Int = arena.struct_field_start[sidx];
    let dcount: Int = arena.struct_field_count[sidx];
    let mut di: Int = 0;
    while di < dcount {
      if !name_in_list(seen, seen.len, arena.field_name[dstart + di]) {
        s = tc_report_name(s, "TYPE_MISSING_FIELD", arena.field_name[dstart + di],
                           arena.node_span_start[node], arena.node_span_end[node]);
      }
      di = di + 1;
    }
    return InferResult { st: s, ty: ty };
  }
  if kind == array_node() {
    let estart: Int = arena.node_a[node];
    let ecount: Int = arena.node_b[node];
    if ecount == 0 {
      // Stage 0 cannot type an empty literal: fixed message over the whole
      // `[]`, then "<error>".
      s = tc_report_fixed(s, "TYPE_ARRAY_EMPTY",
                          arena.node_full_start[node], arena.node_full_end[node]);
      return InferResult { st: s, ty: "<error>" };
    }
    // The FIRST element fixes the element type; every later element is
    // expected against it (span = that element).
    let first: InferResult = tc_infer(s, arena.child_list[estart]);
    s = first.st;
    let elem: String = first.ty;
    let mut ei: Int = 1;
    while ei < ecount {
      let enode: Int = arena.child_list[estart + ei];
      let el: InferResult = tc_infer(s, enode);
      s = tc_expect(el.st, el.ty, elem, "TYPE_ARRAY_ELEMENT",
                    arena.node_full_start[enode], arena.node_full_end[enode]);
      ei = ei + 1;
    }
    if elem == "<error>" {
      return InferResult { st: s, ty: "<error>" };
    }
    // The general display rule: Array(T) renders as T's display + "Array"
    // ("Int" -> "IntArray", "Point" -> "PointArray").
    return InferResult { st: s, ty: string_concat(elem, "Array") };
  }
  if kind == index_node() {
    // Oracle order: infer base, infer index, expect the index to be Int.
    let base: InferResult = tc_infer(s, arena.node_a[node]);
    let idx: InferResult = tc_infer(base.st, arena.node_b[node]);
    s = tc_expect(idx.st, idx.ty, "Int", "TYPE_INDEX",
                  arena.node_full_start[arena.node_b[node]],
                  arena.node_full_end[arena.node_b[node]]);
    if string_ends_with(base.ty, "Array") {
      // Strip the 5-byte "Array" suffix to recover the element display.
      return InferResult {
        st: s,
        ty: string_byte_slice(base.ty, 0, string_len(base.ty) - 5),
      };
    }
    if base.ty == "<error>" {
      return InferResult { st: s, ty: "<error>" };
    }
    s = tc_report_fixed(s, "TYPE_INDEX_BASE",
                        arena.node_full_start[arena.node_a[node]],
                        arena.node_full_end[arena.node_a[node]]);
    return InferResult { st: s, ty: "<error>" };
  }
  if kind == field_node() {
    let field: String = arena.node_text[node];
    let bnode: Int = arena.node_a[node];
    // Enum VALUE access (`E.V` where E is a Name that is no local but IS an
    // enum — a local named E shadows the enum and falls through to the normal
    // field path). The base is never inferred. All three outcomes recover with
    // Named(E): a payload variant must be CALLED (TYPE_ENUM_VARIANT_ARITY
    // kind=uncalled at the field ident), a bare variant is silent, a missing
    // variant is TYPE_UNKNOWN_VARIANT at the field ident.
    if arena.node_kind[bnode] == name_node()
        && tc_lookup_slot(s, arena.node_text[bnode]) < 0
        && tc_enum_exists(s.enums, arena.node_text[bnode]) {
      let ename: String = arena.node_text[bnode];
      let vrow: Int = tc_variant_index(s.enums, ename, field);
      if vrow >= 0 {
        if s.enums.v_payloads[vrow] != "" {
          s = tc_report_variant_kind(s, "TYPE_ENUM_VARIANT_ARITY", ename, field,
                                     "uncalled",
                                     arena.node_span_start[node], arena.node_span_end[node]);
        }
        return InferResult { st: s, ty: ename };
      }
      s = tc_report_name(s, "TYPE_UNKNOWN_VARIANT", field,
                         arena.node_span_start[node], arena.node_span_end[node]);
      return InferResult { st: s, ty: ename };
    }
    let base: InferResult = tc_infer(s, bnode);
    s = base.st;
    if string_ends_with(base.ty, "Array") {
      // Arrays expose exactly one field: `len`.
      if field == "len" {
        return InferResult { st: s, ty: "Int" };
      }
      s = tc_report_name(s, "TYPE_ARRAY_FIELD", field,
                         arena.node_span_start[node], arena.node_span_end[node]);
      return InferResult { st: s, ty: "<error>" };
    }
    if base.ty == "Int" || base.ty == "String" || base.ty == "Bool"
        || base.ty == "Unit" || base.ty == "Range" || base.ty == "<error>" {
      // QUIRK: Rust's `let Type::Named(..) = base_type else` catches Error
      // too — an "<error>" base is NOT suppressed here. It reports
      // TYPE_FIELD_BASE at the base expression and recovers with
      // Named(field): the FIELD NAME becomes the result type.
      s = tc_report_fixed(s, "TYPE_FIELD_BASE",
                          arena.node_full_start[bnode], arena.node_full_end[bnode]);
      return InferResult { st: s, ty: field };
    }
    // Named base: a struct gives the field's declared type verbatim (see
    // tc_struct_field_type for the parse_type identity quirk); a non-struct
    // name (e.g. an enum) is TYPE_UNKNOWN_STRUCT at the base expression; a
    // missing field is TYPE_UNKNOWN_FIELD at the field ident. Both recover
    // with Named(field).
    let sidx: Int = tc_struct_index(arena, base.ty);
    if sidx < 0 {
      s = tc_report_name(s, "TYPE_UNKNOWN_STRUCT", base.ty,
                         arena.node_full_start[bnode], arena.node_full_end[bnode]);
      return InferResult { st: s, ty: field };
    }
    let decl: String = tc_struct_field_type(arena, sidx, field);
    if decl != "" {
      return InferResult { st: s, ty: decl };
    }
    s = tc_report_name(s, "TYPE_UNKNOWN_FIELD", field,
                       arena.node_span_start[node], arena.node_span_end[node]);
    return InferResult { st: s, ty: field };
  }
  // Unreachable: every node kind is handled above. Keep the "<error>" fallback
  // so the function always returns.
  return InferResult { st: s, ty: "<error>" };
}

// Mirror of infer_enum_variant_call: a call whose dotted callee names a known
// enum. ALL paths recover with Named(E). A payload variant demands exactly one
// argument (TYPE_ENUM_VARIANT_ARITY at the callee span) and — arity right or
// WRONG — every argument is inferred and expected against the payload type
// (TYPE_ENUM_VARIANT_PAYLOAD at the argument). A bare variant demands zero
// (same arity code) and its arguments are inferred but their types DISCARDED.
// An unknown variant reports TYPE_UNKNOWN_VARIANT at the callee span and
// never visits the arguments.
fn tc_infer_variant_call(state: TcState, node: Int, ename: String, vname: String) -> InferResult {
  let arena: Arena = state.arena;
  let mut s: TcState = state;
  let vrow: Int = tc_variant_index(s.enums, ename, vname);
  if vrow < 0 {
    s = tc_report_name(s, "TYPE_UNKNOWN_VARIANT", vname,
                       arena.node_span_start[node], arena.node_span_end[node]);
    return InferResult { st: s, ty: ename };
  }
  let astart: Int = arena.node_a[node];
  let acount: Int = arena.node_b[node];
  let payload: String = s.enums.v_payloads[vrow];
  if payload != "" {
    if acount != 1 {
      s = tc_report_variant_arity(s, ename, vname, 1, acount,
                                  arena.node_span_start[node], arena.node_span_end[node]);
    }
    let mut ai: Int = 0;
    while ai < acount {
      let argn: Int = arena.child_list[astart + ai];
      let arg: InferResult = tc_infer(s, argn);
      s = tc_expect(arg.st, arg.ty, payload, "TYPE_ENUM_VARIANT_PAYLOAD",
                    arena.node_full_start[argn], arena.node_full_end[argn]);
      ai = ai + 1;
    }
    return InferResult { st: s, ty: ename };
  }
  if acount != 0 {
    s = tc_report_variant_arity(s, ename, vname, 0, acount,
                                arena.node_span_start[node], arena.node_span_end[node]);
  }
  let mut ai: Int = 0;
  while ai < acount {
    let arg: InferResult = tc_infer(s, arena.child_list[astart + ai]);
    s = arg.st;
    ai = ai + 1;
  }
  return InferResult { st: s, ty: ename };
}

// Mirror of check_match_exhaustiveness, run AFTER every arm. A `_` or `name:`
// arm covers everything. A Bool value needs both `bool:true` and `bool:false`
// (fixed-message TYPE_MATCH_NON_EXHAUSTIVE). An enum value needs every
// declared variant covered by a variant pattern whose ENUM is the value's
// (a wrong-enum pattern contributes nothing); the report carries the enum
// name. Every other type (Int / String / arrays / Range / Unit / "<error>" /
// non-enum named) is never checked.
fn tc_match_exhaustiveness(state: TcState, value_ty: String, vs: Int, ve: Int,
                           astart: Int, acount: Int) -> TcState {
  let arena: Arena = state.arena;
  let mut s: TcState = state;
  let mut ai: Int = 0;
  while ai < acount {
    let pattern: String = arena.arm_pattern[astart + ai];
    if pattern == "_" || string_starts_with(pattern, "name:") {
      return s;
    }
    ai = ai + 1;
  }
  if value_ty == "Bool" {
    let mut has_true: Bool = false;
    let mut has_false: Bool = false;
    ai = 0;
    while ai < acount {
      if arena.arm_pattern[astart + ai] == "bool:true" {
        has_true = true;
      }
      if arena.arm_pattern[astart + ai] == "bool:false" {
        has_false = true;
      }
      ai = ai + 1;
    }
    if !has_true || !has_false {
      s = tc_report_fixed(s, "TYPE_MATCH_NON_EXHAUSTIVE", vs, ve);
    }
    return s;
  }
  if tc_enum_exists(s.enums, value_ty) {
    let mut covered: Bool = true;
    let mut vi: Int = 0;
    while vi < s.enums.v_enums.len {
      if s.enums.v_enums[vi] == value_ty {
        if !tc_arms_cover_variant(arena, astart, acount, value_ty, s.enums.v_names[vi]) {
          covered = false;
        }
      }
      vi = vi + 1;
    }
    if !covered {
      s = tc_report_name(s, "TYPE_MATCH_NON_EXHAUSTIVE", value_ty, vs, ve);
    }
    return s;
  }
  return s;
}

// Does any arm's pattern name exactly the (ename, vname) variant? (Binding or
// not is irrelevant — even a mis-bound pattern still covers its variant.)
fn tc_arms_cover_variant(arena: Arena, astart: Int, acount: Int,
                         ename: String, vname: String) -> Bool {
  let mut ai: Int = 0;
  while ai < acount {
    let pattern: String = arena.arm_pattern[astart + ai];
    if string_starts_with(pattern, "variant:")
        && pattern_variant_enum(pattern) == ename
        && pattern_variant_name(pattern) == vname {
      return true;
    }
    ai = ai + 1;
  }
  return false;
}

// ---------------------------------------------------------------------------
// M5 self-hosting milestone: AST arena -> MIR arena lowering + mir-dump.
//
// Mirrors src/mir.rs `lower` / `lower_with_external_enum_variants` /
// `dump_program` exactly. The lowering is structural (1:1 statement mapping)
// with three desugars:
//   * an expression statement becomes Drop;
//   * a for-in whose iterable is a Range node becomes ForRange (the Range node
//     itself is never lowered);
//   * a Call whose dotted callee rsplits at the last '.' into a known
//     (enum, variant) pair becomes EnumVariant — only the FIRST argument
//     becomes the payload, extra arguments are silently dropped (Rust uses
//     `args.first()`); a FieldAccess whose base is a Name node naming a known
//     (enum, variant) pair becomes a payload-less EnumVariant (table-driven
//     only — locals are NOT consulted, unlike the typechecker).
//
// The MIR lives in its own arena (parallel arrays, post-order construction)
// so the M6 interpreter can execute it without re-walking the AST.
// ---------------------------------------------------------------------------

// MIR statement kinds.
fn mir_local_stmt() -> Int { return 0; }
fn mir_store_stmt() -> Int { return 1; }
fn mir_if_stmt() -> Int { return 2; }
fn mir_while_stmt() -> Int { return 3; }
fn mir_for_in_stmt() -> Int { return 4; }
fn mir_for_range_stmt() -> Int { return 5; }
fn mir_for_c_stmt() -> Int { return 6; }
fn mir_match_stmt() -> Int { return 7; }
fn mir_return_stmt() -> Int { return 8; }
fn mir_break_stmt() -> Int { return 9; }
fn mir_continue_stmt() -> Int { return 10; }
fn mir_drop_stmt() -> Int { return 11; }

// MIR expression kinds.
fn mir_load_expr() -> Int { return 0; }
fn mir_int_expr() -> Int { return 1; }
fn mir_string_expr() -> Int { return 2; }
fn mir_bool_expr() -> Int { return 3; }
fn mir_binary_expr() -> Int { return 4; }
fn mir_unary_expr() -> Int { return 5; }
fn mir_call_expr() -> Int { return 6; }
fn mir_enum_expr() -> Int { return 7; }
fn mir_struct_expr() -> Int { return 8; }
fn mir_field_expr() -> Int { return 9; }
fn mir_array_expr() -> Int { return 10; }
fn mir_index_expr() -> Int { return 11; }

// MIR place kinds (assignment left-values).
fn mir_place_local() -> Int { return 0; }
fn mir_place_field() -> Int { return 1; }
fn mir_place_index() -> Int { return 2; }

// The MIR arena. Same parallel-array discipline as the AST Arena: every
// pusher appends to all arrays of its family so indices stay aligned.
struct Mir {
  // Enum dump table: user enums in declaration order, then external (std)
  // enums sorted by name with variants sorted by name. mev_payload "" = none.
  men_name: StringArray,
  men_variant_start: IntArray,
  men_variant_count: IntArray,
  mev_name: StringArray,
  mev_payload: StringArray,
  // Function table. mf_has_ret=0 dumps as `-> Unit`.
  mf_name: StringArray,
  mf_has_ret: IntArray,
  mf_ret: StringArray,
  mf_param_start: IntArray,
  mf_param_count: IntArray,
  mf_body_start: IntArray,
  mf_body_count: IntArray,
  mp_name: StringArray,
  mp_type: StringArray,
  // Statement arena (flat post-order pool; block shape lives in mblock_list).
  // ms_name: local name / for binding. ms_expr: value / condition / iterable /
  // range start (-1 = none). ms_expr2: range end. ms_place: Store place row.
  // ms_then_*: then body / loop body / match arm slice. ms_else_*: else body.
  // ms_init / ms_step: ForC init and step statement rows.
  ms_kind: IntArray,
  ms_name: StringArray,
  ms_type: StringArray,
  ms_has_type: IntArray,
  ms_mut: IntArray,
  ms_expr: IntArray,
  ms_expr2: IntArray,
  ms_place: IntArray,
  ms_then_start: IntArray,
  ms_then_count: IntArray,
  ms_else_start: IntArray,
  ms_else_count: IntArray,
  ms_init: IntArray,
  ms_step: IntArray,
  mblock_list: IntArray,
  // Match arms: pattern text is already in MIR form (string patterns carry
  // their Rust Debug escaping).
  marm_pattern: StringArray,
  marm_body_start: IntArray,
  marm_body_count: IntArray,
  // Place arena: local (mpl_name) / field (mpl_base + mpl_name) /
  // index (mpl_base + mpl_index expr row).
  mpl_kind: IntArray,
  mpl_base: IntArray,
  mpl_name: StringArray,
  mpl_index: IntArray,
  // Expression arena. me_text: load name / int text / RAW string token
  // (normalized at dump time) / bool text / binary-unary op name / callee /
  // "Enum.Variant" full path / struct type name / field name. me_a/me_b:
  // children or (start, count) slices of mchild_list. EnumVariant payload is
  // me_a (-1 = none).
  me_kind: IntArray,
  me_a: IntArray,
  me_b: IntArray,
  me_text: StringArray,
  mchild_list: IntArray,
  // Struct-literal fields, sliced via (me_a, me_b) of the owning struct expr.
  msl_field_name: StringArray,
  msl_field_value: IntArray,
}

fn mir_empty() -> Mir {
  return Mir {
    men_name: string_array_empty(),
    men_variant_start: int_array_empty(),
    men_variant_count: int_array_empty(),
    mev_name: string_array_empty(),
    mev_payload: string_array_empty(),
    mf_name: string_array_empty(),
    mf_has_ret: int_array_empty(),
    mf_ret: string_array_empty(),
    mf_param_start: int_array_empty(),
    mf_param_count: int_array_empty(),
    mf_body_start: int_array_empty(),
    mf_body_count: int_array_empty(),
    mp_name: string_array_empty(),
    mp_type: string_array_empty(),
    ms_kind: int_array_empty(),
    ms_name: string_array_empty(),
    ms_type: string_array_empty(),
    ms_has_type: int_array_empty(),
    ms_mut: int_array_empty(),
    ms_expr: int_array_empty(),
    ms_expr2: int_array_empty(),
    ms_place: int_array_empty(),
    ms_then_start: int_array_empty(),
    ms_then_count: int_array_empty(),
    ms_else_start: int_array_empty(),
    ms_else_count: int_array_empty(),
    ms_init: int_array_empty(),
    ms_step: int_array_empty(),
    mblock_list: int_array_empty(),
    marm_pattern: string_array_empty(),
    marm_body_start: int_array_empty(),
    marm_body_count: int_array_empty(),
    mpl_kind: int_array_empty(),
    mpl_base: int_array_empty(),
    mpl_name: string_array_empty(),
    mpl_index: int_array_empty(),
    me_kind: int_array_empty(),
    me_a: int_array_empty(),
    me_b: int_array_empty(),
    me_text: string_array_empty(),
    mchild_list: int_array_empty(),
    msl_field_name: string_array_empty(),
    msl_field_value: int_array_empty(),
  };
}

// MirResult / MirBlockResult thread the Mir arena through the lowering the
// same way ParseResult / BlockResult thread the AST arena through the parser.
struct MirResult {
  mir: Mir,
  node: Int,
}

struct MirBlockResult {
  mir: Mir,
  start: Int,
  count: Int,
}

fn push_mir_expr(mir: Mir, kind: Int, a: Int, b: Int, text: String) -> Mir {
  let mut m: Mir = mir;
  m.me_kind = int_array_push(m.me_kind, kind);
  m.me_a = int_array_push(m.me_a, a);
  m.me_b = int_array_push(m.me_b, b);
  m.me_text = string_array_push(m.me_text, text);
  return m;
}

fn push_mir_place(mir: Mir, kind: Int, base: Int, name: String, index: Int) -> Mir {
  let mut m: Mir = mir;
  m.mpl_kind = int_array_push(m.mpl_kind, kind);
  m.mpl_base = int_array_push(m.mpl_base, base);
  m.mpl_name = string_array_push(m.mpl_name, name);
  m.mpl_index = int_array_push(m.mpl_index, index);
  return m;
}

fn push_mir_stmt(mir: Mir, kind: Int, name: String, ty: String, has_type: Int, is_mut: Int,
                 expr: Int, expr2: Int, place: Int,
                 then_start: Int, then_count: Int, else_start: Int, else_count: Int,
                 init: Int, step: Int) -> Mir {
  let mut m: Mir = mir;
  m.ms_kind = int_array_push(m.ms_kind, kind);
  m.ms_name = string_array_push(m.ms_name, name);
  m.ms_type = string_array_push(m.ms_type, ty);
  m.ms_has_type = int_array_push(m.ms_has_type, has_type);
  m.ms_mut = int_array_push(m.ms_mut, is_mut);
  m.ms_expr = int_array_push(m.ms_expr, expr);
  m.ms_expr2 = int_array_push(m.ms_expr2, expr2);
  m.ms_place = int_array_push(m.ms_place, place);
  m.ms_then_start = int_array_push(m.ms_then_start, then_start);
  m.ms_then_count = int_array_push(m.ms_then_count, then_count);
  m.ms_else_start = int_array_push(m.ms_else_start, else_start);
  m.ms_else_count = int_array_push(m.ms_else_count, else_count);
  m.ms_init = int_array_push(m.ms_init, init);
  m.ms_step = int_array_push(m.ms_step, step);
  return m;
}

// ---------------------------------------------------------------------------
// Lowering: AST arena -> MIR arena, post-order. `enums` is the variant lookup
// table (user enums plus the entry point's external std enums merged in, the
// union Rust builds by extending enum_variants with the external map).
// ---------------------------------------------------------------------------

fn lower_expr(arena: Arena, enums: EnumTable, mir: Mir, node: Int) -> MirResult {
  let kind: Int = arena.node_kind[node];
  if kind == name_node() {
    let index: Int = mir.me_kind.len;
    let m: Mir = push_mir_expr(mir, mir_load_expr(), 0 - 1, 0 - 1, arena.node_text[node]);
    return MirResult { mir: m, node: index };
  }
  if kind == int_node() {
    let index: Int = mir.me_kind.len;
    let m: Mir = push_mir_expr(mir, mir_int_expr(), 0 - 1, 0 - 1, arena.node_text[node]);
    return MirResult { mir: m, node: index };
  }
  if kind == string_node() {
    // Keep the raw quoted token; the dump pass normalizes the escapes.
    let index: Int = mir.me_kind.len;
    let m: Mir = push_mir_expr(mir, mir_string_expr(), 0 - 1, 0 - 1, arena.node_text[node]);
    return MirResult { mir: m, node: index };
  }
  if kind == bool_node() {
    let index: Int = mir.me_kind.len;
    let m: Mir = push_mir_expr(mir, mir_bool_expr(), 0 - 1, 0 - 1, arena.node_text[node]);
    return MirResult { mir: m, node: index };
  }
  if kind == unary_node() {
    let operand: MirResult = lower_expr(arena, enums, mir, arena.node_a[node]);
    let index: Int = operand.mir.me_kind.len;
    let m: Mir = push_mir_expr(operand.mir, mir_unary_expr(), operand.node, 0 - 1,
                               arena.node_text[node]);
    return MirResult { mir: m, node: index };
  }
  if kind == binary_node() {
    let left: MirResult = lower_expr(arena, enums, mir, arena.node_a[node]);
    let right: MirResult = lower_expr(arena, enums, left.mir, arena.node_b[node]);
    let index: Int = right.mir.me_kind.len;
    let m: Mir = push_mir_expr(right.mir, mir_binary_expr(), left.node, right.node,
                               arena.node_text[node]);
    return MirResult { mir: m, node: index };
  }
  if kind == call_node() {
    let callee: String = arena.node_text[node];
    let arg_start: Int = arena.node_a[node];
    let arg_count: Int = arena.node_b[node];
    let dot: Int = string_last_dot(callee);
    if dot >= 0 {
      let ename: String = string_byte_slice(callee, 0, dot);
      let vname: String = string_byte_slice(callee, dot + 1, string_len(callee) - dot - 1);
      if tc_variant_index(enums, ename, vname) >= 0 {
        // Enum-variant construction. Only the first argument is lowered as
        // the payload; extra arguments never reach the MIR (Rust quirk).
        if arg_count > 0 {
          let payload: MirResult = lower_expr(arena, enums, mir, arena.child_list[arg_start]);
          let pindex: Int = payload.mir.me_kind.len;
          let pm: Mir = push_mir_expr(payload.mir, mir_enum_expr(), payload.node, 0 - 1, callee);
          return MirResult { mir: pm, node: pindex };
        }
        let index: Int = mir.me_kind.len;
        let m: Mir = push_mir_expr(mir, mir_enum_expr(), 0 - 1, 0 - 1, callee);
        return MirResult { mir: m, node: index };
      }
    }
    // Plain call: lower the args in order, then commit their MIR rows to
    // mchild_list as one contiguous run.
    let mut mm: Mir = mir;
    let mut args: IntArray = int_array_empty();
    let mut i: Int = 0;
    while i < arg_count {
      let r: MirResult = lower_expr(arena, enums, mm, arena.child_list[arg_start + i]);
      mm = r.mir;
      args = int_array_push(args, r.node);
      i = i + 1;
    }
    let cstart: Int = mm.mchild_list.len;
    let mut j: Int = 0;
    while j < args.len {
      mm.mchild_list = int_array_push(mm.mchild_list, args[j]);
      j = j + 1;
    }
    let index: Int = mm.me_kind.len;
    mm = push_mir_expr(mm, mir_call_expr(), cstart, arg_count, callee);
    return MirResult { mir: mm, node: index };
  }
  if kind == field_node() {
    let base: Int = arena.node_a[node];
    let field: String = arena.node_text[node];
    if arena.node_kind[base] == name_node() {
      if tc_variant_index(enums, arena.node_text[base], field) >= 0 {
        // Payload-less enum-variant reference. Purely table-driven: a local
        // shadowing the enum name does NOT suppress this (unlike typecheck).
        let mut path: String = arena.node_text[base];
        path = string_concat(path, ".");
        path = string_concat(path, field);
        let index: Int = mir.me_kind.len;
        let m: Mir = push_mir_expr(mir, mir_enum_expr(), 0 - 1, 0 - 1, path);
        return MirResult { mir: m, node: index };
      }
    }
    let br: MirResult = lower_expr(arena, enums, mir, base);
    let index: Int = br.mir.me_kind.len;
    let m: Mir = push_mir_expr(br.mir, mir_field_expr(), br.node, 0 - 1, field);
    return MirResult { mir: m, node: index };
  }
  if kind == array_node() {
    let elem_start: Int = arena.node_a[node];
    let elem_count: Int = arena.node_b[node];
    let mut mm: Mir = mir;
    let mut elems: IntArray = int_array_empty();
    let mut i: Int = 0;
    while i < elem_count {
      let r: MirResult = lower_expr(arena, enums, mm, arena.child_list[elem_start + i]);
      mm = r.mir;
      elems = int_array_push(elems, r.node);
      i = i + 1;
    }
    let cstart: Int = mm.mchild_list.len;
    let mut j: Int = 0;
    while j < elems.len {
      mm.mchild_list = int_array_push(mm.mchild_list, elems[j]);
      j = j + 1;
    }
    let index: Int = mm.me_kind.len;
    mm = push_mir_expr(mm, mir_array_expr(), cstart, elem_count, "");
    return MirResult { mir: mm, node: index };
  }
  if kind == struct_lit_node() {
    let fstart: Int = arena.node_a[node];
    let fcount: Int = arena.node_b[node];
    let mut mm: Mir = mir;
    let mut values: IntArray = int_array_empty();
    let mut i: Int = 0;
    while i < fcount {
      let r: MirResult = lower_expr(arena, enums, mm, arena.sl_field_value[fstart + i]);
      mm = r.mir;
      values = int_array_push(values, r.node);
      i = i + 1;
    }
    let mstart: Int = mm.msl_field_name.len;
    let mut j: Int = 0;
    while j < fcount {
      mm.msl_field_name = string_array_push(mm.msl_field_name, arena.sl_field_name[fstart + j]);
      mm.msl_field_value = int_array_push(mm.msl_field_value, values[j]);
      j = j + 1;
    }
    let index: Int = mm.me_kind.len;
    mm = push_mir_expr(mm, mir_struct_expr(), mstart, fcount, arena.node_text[node]);
    return MirResult { mir: mm, node: index };
  }
  if kind == index_node() {
    let base: MirResult = lower_expr(arena, enums, mir, arena.node_a[node]);
    let idx: MirResult = lower_expr(arena, enums, base.mir, arena.node_b[node]);
    let index: Int = idx.mir.me_kind.len;
    let m: Mir = push_mir_expr(idx.mir, mir_index_expr(), base.node, idx.node, "");
    return MirResult { mir: m, node: index };
  }
  // range_node: only reachable as a for-in iterable, which lower_stmt splits
  // into ForRange start/end before ever lowering the Range itself (the Rust
  // arm is unreachable!()). Emit a dummy load to keep the arena consistent.
  let index: Int = mir.me_kind.len;
  let m: Mir = push_mir_expr(mir, mir_load_expr(), 0 - 1, 0 - 1, "");
  return MirResult { mir: m, node: index };
}

// Lower an assignment target expression into a place row.
fn lower_place(arena: Arena, enums: EnumTable, mir: Mir, node: Int) -> MirResult {
  let kind: Int = arena.node_kind[node];
  if kind == name_node() {
    let index: Int = mir.mpl_kind.len;
    let m: Mir = push_mir_place(mir, mir_place_local(), 0 - 1, arena.node_text[node], 0 - 1);
    return MirResult { mir: m, node: index };
  }
  if kind == field_node() {
    let base: MirResult = lower_place(arena, enums, mir, arena.node_a[node]);
    let index: Int = base.mir.mpl_kind.len;
    let m: Mir = push_mir_place(base.mir, mir_place_field(), base.node,
                                arena.node_text[node], 0 - 1);
    return MirResult { mir: m, node: index };
  }
  if kind == index_node() {
    let base: MirResult = lower_place(arena, enums, mir, arena.node_a[node]);
    let idx: MirResult = lower_expr(arena, enums, base.mir, arena.node_b[node]);
    let index: Int = idx.mir.mpl_kind.len;
    let m: Mir = push_mir_place(idx.mir, mir_place_index(), base.node, "", idx.node);
    return MirResult { mir: m, node: index };
  }
  // Non-lvalue target: Rust lowers it to Local("") (typecheck rejects such
  // programs before MIR in valid pipelines).
  let index: Int = mir.mpl_kind.len;
  let m: Mir = push_mir_place(mir, mir_place_local(), 0 - 1, "", 0 - 1);
  return MirResult { mir: m, node: index };
}

// AST arm-pattern text -> MIR arm-pattern text. Identical except string
// patterns: the arena stores the raw quoted token after "string:", while the
// MIR dump shows the Rust Debug escaping (normalize_string_escapes handles
// both the quotes and the escape contract).
fn mir_pattern_text(pattern: String) -> String {
  if string_starts_with(pattern, "string:") {
    let raw: String = string_byte_slice(pattern, 7, string_len(pattern) - 7);
    return string_concat("string:", normalize_string_escapes(raw));
  }
  return pattern;
}

fn lower_block(arena: Arena, enums: EnumTable, mir: Mir, start: Int, count: Int) -> MirBlockResult {
  // Same gather-then-commit pattern as parse_block: lowered child rows are
  // collected locally, then appended to mblock_list as one contiguous run.
  let mut m: Mir = mir;
  let mut items: IntArray = int_array_empty();
  let mut i: Int = 0;
  while i < count {
    let r: MirResult = lower_stmt(arena, enums, m, arena.block_list[start + i]);
    m = r.mir;
    items = int_array_push(items, r.node);
    i = i + 1;
  }
  let bstart: Int = m.mblock_list.len;
  let mut j: Int = 0;
  while j < count {
    m.mblock_list = int_array_push(m.mblock_list, items[j]);
    j = j + 1;
  }
  return MirBlockResult { mir: m, start: bstart, count: count };
}

fn lower_stmt(arena: Arena, enums: EnumTable, mir: Mir, index: Int) -> MirResult {
  let kind: Int = arena.stmt_kind[index];
  if kind == let_stmt() {
    let value: MirResult = lower_expr(arena, enums, mir, arena.stmt_expr[index]);
    let row: Int = value.mir.ms_kind.len;
    let m: Mir = push_mir_stmt(value.mir, mir_local_stmt(), arena.stmt_name[index],
                               arena.stmt_type[index], arena.stmt_has_type[index],
                               arena.stmt_mut[index], value.node, 0 - 1, 0 - 1,
                               0, 0, 0, 0, 0 - 1, 0 - 1);
    return MirResult { mir: m, node: row };
  }
  if kind == return_stmt() {
    if arena.stmt_expr[index] >= 0 {
      let value: MirResult = lower_expr(arena, enums, mir, arena.stmt_expr[index]);
      let row: Int = value.mir.ms_kind.len;
      let m: Mir = push_mir_stmt(value.mir, mir_return_stmt(), "", "", 0, 0,
                                 value.node, 0 - 1, 0 - 1, 0, 0, 0, 0, 0 - 1, 0 - 1);
      return MirResult { mir: m, node: row };
    }
    let row: Int = mir.ms_kind.len;
    let m: Mir = push_mir_stmt(mir, mir_return_stmt(), "", "", 0, 0,
                               0 - 1, 0 - 1, 0 - 1, 0, 0, 0, 0, 0 - 1, 0 - 1);
    return MirResult { mir: m, node: row };
  }
  if kind == assign_stmt() {
    // Store. A simple-name assign (target -1) becomes a Local place directly;
    // a complex target lowers through lower_place.
    let mut m: Mir = mir;
    let mut place: Int = 0 - 1;
    if arena.stmt_target[index] >= 0 {
      let pr: MirResult = lower_place(arena, enums, m, arena.stmt_target[index]);
      m = pr.mir;
      place = pr.node;
    } else {
      place = m.mpl_kind.len;
      m = push_mir_place(m, mir_place_local(), 0 - 1, arena.stmt_name[index], 0 - 1);
    }
    let value: MirResult = lower_expr(arena, enums, m, arena.stmt_expr[index]);
    let row: Int = value.mir.ms_kind.len;
    let mm: Mir = push_mir_stmt(value.mir, mir_store_stmt(), "", "", 0, 0,
                                value.node, 0 - 1, place, 0, 0, 0, 0, 0 - 1, 0 - 1);
    return MirResult { mir: mm, node: row };
  }
  if kind == if_stmt() {
    let cond: MirResult = lower_expr(arena, enums, mir, arena.stmt_expr[index]);
    let thenb: MirBlockResult = lower_block(arena, enums, cond.mir,
                                            arena.stmt_then_start[index],
                                            arena.stmt_then_count[index]);
    let elseb: MirBlockResult = lower_block(arena, enums, thenb.mir,
                                            arena.stmt_else_start[index],
                                            arena.stmt_else_count[index]);
    let row: Int = elseb.mir.ms_kind.len;
    let m: Mir = push_mir_stmt(elseb.mir, mir_if_stmt(), "", "", 0, 0,
                               cond.node, 0 - 1, 0 - 1,
                               thenb.start, thenb.count, elseb.start, elseb.count,
                               0 - 1, 0 - 1);
    return MirResult { mir: m, node: row };
  }
  if kind == while_stmt() {
    let cond: MirResult = lower_expr(arena, enums, mir, arena.stmt_expr[index]);
    let body: MirBlockResult = lower_block(arena, enums, cond.mir,
                                           arena.stmt_then_start[index],
                                           arena.stmt_then_count[index]);
    let row: Int = body.mir.ms_kind.len;
    let m: Mir = push_mir_stmt(body.mir, mir_while_stmt(), "", "", 0, 0,
                               cond.node, 0 - 1, 0 - 1,
                               body.start, body.count, 0, 0, 0 - 1, 0 - 1);
    return MirResult { mir: m, node: row };
  }
  if kind == for_in_stmt() {
    let iter: Int = arena.stmt_expr[index];
    if arena.node_kind[iter] == range_node() {
      // for-in over a Range desugars to ForRange; the Range node itself is
      // never lowered (only its start/end children are).
      let startr: MirResult = lower_expr(arena, enums, mir, arena.node_a[iter]);
      let endr: MirResult = lower_expr(arena, enums, startr.mir, arena.node_b[iter]);
      let body: MirBlockResult = lower_block(arena, enums, endr.mir,
                                             arena.stmt_then_start[index],
                                             arena.stmt_then_count[index]);
      let row: Int = body.mir.ms_kind.len;
      let m: Mir = push_mir_stmt(body.mir, mir_for_range_stmt(), arena.stmt_name[index],
                                 "", 0, 0, startr.node, endr.node, 0 - 1,
                                 body.start, body.count, 0, 0, 0 - 1, 0 - 1);
      return MirResult { mir: m, node: row };
    }
    let iterable: MirResult = lower_expr(arena, enums, mir, iter);
    let body: MirBlockResult = lower_block(arena, enums, iterable.mir,
                                           arena.stmt_then_start[index],
                                           arena.stmt_then_count[index]);
    let row: Int = body.mir.ms_kind.len;
    let m: Mir = push_mir_stmt(body.mir, mir_for_in_stmt(), arena.stmt_name[index],
                               "", 0, 0, iterable.node, 0 - 1, 0 - 1,
                               body.start, body.count, 0, 0, 0 - 1, 0 - 1);
    return MirResult { mir: m, node: row };
  }
  if kind == for_c_stmt() {
    let init: MirResult = lower_stmt(arena, enums, mir, arena.stmt_init[index]);
    let cond: MirResult = lower_expr(arena, enums, init.mir, arena.stmt_expr[index]);
    let step: MirResult = lower_stmt(arena, enums, cond.mir, arena.stmt_step[index]);
    let body: MirBlockResult = lower_block(arena, enums, step.mir,
                                           arena.stmt_then_start[index],
                                           arena.stmt_then_count[index]);
    let row: Int = body.mir.ms_kind.len;
    let m: Mir = push_mir_stmt(body.mir, mir_for_c_stmt(), "", "", 0, 0,
                               cond.node, 0 - 1, 0 - 1,
                               body.start, body.count, 0, 0, init.node, step.node);
    return MirResult { mir: m, node: row };
  }
  if kind == match_stmt() {
    let value: MirResult = lower_expr(arena, enums, mir, arena.stmt_expr[index]);
    // Gather each arm locally, then commit one contiguous run (same pattern
    // as parse_match).
    let mut m: Mir = value.mir;
    let mut patterns: StringArray = string_array_empty();
    let mut bstarts: IntArray = int_array_empty();
    let mut bcounts: IntArray = int_array_empty();
    let astart: Int = arena.stmt_then_start[index];
    let acount: Int = arena.stmt_then_count[index];
    let mut ai: Int = 0;
    while ai < acount {
      let body: MirBlockResult = lower_block(arena, enums, m,
                                             arena.arm_body_start[astart + ai],
                                             arena.arm_body_count[astart + ai]);
      m = body.mir;
      patterns = string_array_push(patterns, mir_pattern_text(arena.arm_pattern[astart + ai]));
      bstarts = int_array_push(bstarts, body.start);
      bcounts = int_array_push(bcounts, body.count);
      ai = ai + 1;
    }
    let marm_start: Int = m.marm_pattern.len;
    let mut k: Int = 0;
    while k < acount {
      m.marm_pattern = string_array_push(m.marm_pattern, patterns[k]);
      m.marm_body_start = int_array_push(m.marm_body_start, bstarts[k]);
      m.marm_body_count = int_array_push(m.marm_body_count, bcounts[k]);
      k = k + 1;
    }
    let row: Int = m.ms_kind.len;
    m = push_mir_stmt(m, mir_match_stmt(), "", "", 0, 0,
                      value.node, 0 - 1, 0 - 1,
                      marm_start, acount, 0, 0, 0 - 1, 0 - 1);
    return MirResult { mir: m, node: row };
  }
  if kind == break_stmt() {
    let row: Int = mir.ms_kind.len;
    let m: Mir = push_mir_stmt(mir, mir_break_stmt(), "", "", 0, 0,
                               0 - 1, 0 - 1, 0 - 1, 0, 0, 0, 0, 0 - 1, 0 - 1);
    return MirResult { mir: m, node: row };
  }
  if kind == continue_stmt() {
    let row: Int = mir.ms_kind.len;
    let m: Mir = push_mir_stmt(mir, mir_continue_stmt(), "", "", 0, 0,
                               0 - 1, 0 - 1, 0 - 1, 0, 0, 0, 0, 0 - 1, 0 - 1);
    return MirResult { mir: m, node: row };
  }
  // Expression statement -> Drop.
  let value: MirResult = lower_expr(arena, enums, mir, arena.stmt_expr[index]);
  let row: Int = value.mir.ms_kind.len;
  let m: Mir = push_mir_stmt(value.mir, mir_drop_stmt(), "", "", 0, 0,
                             value.node, 0 - 1, 0 - 1, 0, 0, 0, 0, 0 - 1, 0 - 1);
  return MirResult { mir: m, node: row };
}

fn lower_function(arena: Arena, enums: EnumTable, mir: Mir, fi: Int) -> Mir {
  let mut m: Mir = mir;
  let pstart: Int = m.mp_name.len;
  let apstart: Int = arena.fn_param_start[fi];
  let pcount: Int = arena.fn_param_count[fi];
  let mut pi: Int = 0;
  while pi < pcount {
    m.mp_name = string_array_push(m.mp_name, arena.param_name[apstart + pi]);
    m.mp_type = string_array_push(m.mp_type, arena.param_type[apstart + pi]);
    pi = pi + 1;
  }
  let body: MirBlockResult = lower_block(arena, enums, m,
                                         arena.fn_body_start[fi], arena.fn_body_count[fi]);
  m = body.mir;
  m.mf_name = string_array_push(m.mf_name, arena.fn_name[fi]);
  m.mf_has_ret = int_array_push(m.mf_has_ret, arena.fn_has_ret[fi]);
  m.mf_ret = string_array_push(m.mf_ret, arena.fn_ret[fi]);
  m.mf_param_start = int_array_push(m.mf_param_start, pstart);
  m.mf_param_count = int_array_push(m.mf_param_count, pcount);
  m.mf_body_start = int_array_push(m.mf_body_start, body.start);
  m.mf_body_count = int_array_push(m.mf_body_count, body.count);
  return m;
}

fn lower_module(arena: Arena, enums: EnumTable, mir: Mir) -> Mir {
  // Functions in item (source) order, mirroring the Rust items filter.
  let mut m: Mir = mir;
  let mut ii: Int = 0;
  while ii < arena.item_kind.len {
    if arena.item_kind[ii] == item_function() {
      m = lower_function(arena, enums, m, arena.item_ref[ii]);
    }
    ii = ii + 1;
  }
  return m;
}

// Is `name` declared as a user enum in this module? (Used to suppress dumping
// an external std enum shadowed by a same-named user enum.)
fn user_enum_declared(arena: Arena, name: String) -> Bool {
  let mut i: Int = 0;
  while i < arena.enum_name.len {
    if arena.enum_name[i] == name {
      return true;
    }
    i = i + 1;
  }
  return false;
}

// Append one external std enum (always exactly two variants, pre-sorted by
// variant name to match Rust's sort_by_key).
fn push_mir_external_enum(mir: Mir, name: String, v1: String, p1: String,
                          v2: String, p2: String) -> Mir {
  let mut m: Mir = mir;
  m.men_name = string_array_push(m.men_name, name);
  m.men_variant_start = int_array_push(m.men_variant_start, m.mev_name.len);
  m.men_variant_count = int_array_push(m.men_variant_count, 2);
  m.mev_name = string_array_push(m.mev_name, v1);
  m.mev_payload = string_array_push(m.mev_payload, p1);
  m.mev_name = string_array_push(m.mev_name, v2);
  m.mev_payload = string_array_push(m.mev_payload, p2);
  return m;
}

// Build the enum dump table: user enums in declaration order first, then the
// external std enums sorted by enum name (OptionInt < ResultInt < ResultString,
// so pushing the std.core pair before the std.io one preserves the sort) with
// variants sorted by name. An external enum shadowed by a same-named user enum
// is not dumped — but its variants still join the lowering lookup table.
fn mir_enum_dump_table(arena: Arena, mir: Mir, has_std_core: Bool, has_std_io: Bool) -> Mir {
  let mut m: Mir = mir;
  let mut e: Int = 0;
  while e < arena.enum_name.len {
    m.men_name = string_array_push(m.men_name, arena.enum_name[e]);
    m.men_variant_start = int_array_push(m.men_variant_start, m.mev_name.len);
    m.men_variant_count = int_array_push(m.men_variant_count, arena.enum_variant_count[e]);
    let vstart: Int = arena.enum_variant_start[e];
    let vcount: Int = arena.enum_variant_count[e];
    let mut v: Int = 0;
    while v < vcount {
      m.mev_name = string_array_push(m.mev_name, arena.variant_name[vstart + v]);
      m.mev_payload = string_array_push(m.mev_payload, arena.variant_payload[vstart + v]);
      v = v + 1;
    }
    e = e + 1;
  }
  if has_std_core {
    if !user_enum_declared(arena, "OptionInt") {
      m = push_mir_external_enum(m, "OptionInt", "None", "", "Some", "Int");
    }
    if !user_enum_declared(arena, "ResultInt") {
      m = push_mir_external_enum(m, "ResultInt", "Err", "String", "Ok", "Int");
    }
  }
  if has_std_io {
    if !user_enum_declared(arena, "ResultString") {
      m = push_mir_external_enum(m, "ResultString", "Err", "String", "Ok", "String");
    }
  }
  return m;
}

// ---------------------------------------------------------------------------
// MIR dump: walk the MIR arena and emit text identical to Rust dump_program.
// Temps `_tN` restart at 0 per function; every expression dumps its children
// first (post-order) and returns its own temp name.
// ---------------------------------------------------------------------------

// Threaded dump results: `out` is the accumulated text, `next` the next temp id.
struct MirDumpStmt {
  out: String,
  next: Int,
}

struct MirDumpExpr {
  out: String,
  next: Int,
  temp: String,
}

struct MirDumpPlace {
  out: String,
  next: Int,
  text: String,
}

fn mir_temp_name(n: Int) -> String {
  return string_concat("_t", int_to_string(n));
}

fn mir_dump_expr(mir: Mir, node: Int, depth: Int, out: String, next: Int) -> MirDumpExpr {
  let pad: String = indent_of(depth);
  let kind: Int = mir.me_kind[node];
  if kind == mir_load_expr() {
    let temp: String = mir_temp_name(next);
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = load ");
    o = string_concat(o, mir.me_text[node]);
    o = string_concat(o, "\n");
    return MirDumpExpr { out: o, next: next + 1, temp: temp };
  }
  if kind == mir_int_expr() {
    let temp: String = mir_temp_name(next);
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = const Int ");
    o = string_concat(o, mir.me_text[node]);
    o = string_concat(o, "\n");
    return MirDumpExpr { out: o, next: next + 1, temp: temp };
  }
  if kind == mir_string_expr() {
    let temp: String = mir_temp_name(next);
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = const String ");
    o = string_concat(o, normalize_string_escapes(mir.me_text[node]));
    o = string_concat(o, "\n");
    return MirDumpExpr { out: o, next: next + 1, temp: temp };
  }
  if kind == mir_bool_expr() {
    let temp: String = mir_temp_name(next);
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = const Bool ");
    o = string_concat(o, mir.me_text[node]);
    o = string_concat(o, "\n");
    return MirDumpExpr { out: o, next: next + 1, temp: temp };
  }
  if kind == mir_binary_expr() {
    let left: MirDumpExpr = mir_dump_expr(mir, mir.me_a[node], depth, out, next);
    let right: MirDumpExpr = mir_dump_expr(mir, mir.me_b[node], depth, left.out, left.next);
    let temp: String = mir_temp_name(right.next);
    let mut o: String = string_concat(right.out, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = binary ");
    o = string_concat(o, mir.me_text[node]);
    o = string_concat(o, " ");
    o = string_concat(o, left.temp);
    o = string_concat(o, ", ");
    o = string_concat(o, right.temp);
    o = string_concat(o, "\n");
    return MirDumpExpr { out: o, next: right.next + 1, temp: temp };
  }
  if kind == mir_unary_expr() {
    let operand: MirDumpExpr = mir_dump_expr(mir, mir.me_a[node], depth, out, next);
    let temp: String = mir_temp_name(operand.next);
    let mut o: String = string_concat(operand.out, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = unary ");
    o = string_concat(o, mir.me_text[node]);
    o = string_concat(o, " ");
    o = string_concat(o, operand.temp);
    o = string_concat(o, "\n");
    return MirDumpExpr { out: o, next: operand.next + 1, temp: temp };
  }
  if kind == mir_call_expr() {
    let astart: Int = mir.me_a[node];
    let acount: Int = mir.me_b[node];
    let mut o: String = out;
    let mut n: Int = next;
    let mut joined: String = "";
    let mut i: Int = 0;
    while i < acount {
      let r: MirDumpExpr = mir_dump_expr(mir, mir.mchild_list[astart + i], depth, o, n);
      o = r.out;
      n = r.next;
      if i > 0 {
        joined = string_concat(joined, ", ");
      }
      joined = string_concat(joined, r.temp);
      i = i + 1;
    }
    let temp: String = mir_temp_name(n);
    o = string_concat(o, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = call ");
    o = string_concat(o, mir.me_text[node]);
    o = string_concat(o, "(");
    o = string_concat(o, joined);
    o = string_concat(o, ")\n");
    return MirDumpExpr { out: o, next: n + 1, temp: temp };
  }
  if kind == mir_enum_expr() {
    if mir.me_a[node] >= 0 {
      let payload: MirDumpExpr = mir_dump_expr(mir, mir.me_a[node], depth, out, next);
      let temp: String = mir_temp_name(payload.next);
      let mut o: String = string_concat(payload.out, pad);
      o = string_concat(o, temp);
      o = string_concat(o, " = enum ");
      o = string_concat(o, mir.me_text[node]);
      o = string_concat(o, "(");
      o = string_concat(o, payload.temp);
      o = string_concat(o, ")\n");
      return MirDumpExpr { out: o, next: payload.next + 1, temp: temp };
    }
    let temp: String = mir_temp_name(next);
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = enum ");
    o = string_concat(o, mir.me_text[node]);
    o = string_concat(o, "\n");
    return MirDumpExpr { out: o, next: next + 1, temp: temp };
  }
  if kind == mir_struct_expr() {
    let fstart: Int = mir.me_a[node];
    let fcount: Int = mir.me_b[node];
    let mut o: String = out;
    let mut n: Int = next;
    let mut joined: String = "";
    let mut i: Int = 0;
    while i < fcount {
      let r: MirDumpExpr = mir_dump_expr(mir, mir.msl_field_value[fstart + i], depth, o, n);
      o = r.out;
      n = r.next;
      if i > 0 {
        joined = string_concat(joined, ", ");
      }
      joined = string_concat(joined, mir.msl_field_name[fstart + i]);
      joined = string_concat(joined, ": ");
      joined = string_concat(joined, r.temp);
      i = i + 1;
    }
    let temp: String = mir_temp_name(n);
    o = string_concat(o, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = struct ");
    o = string_concat(o, mir.me_text[node]);
    // Rust formats `{{ {} }}`: an empty field list still keeps both spaces.
    o = string_concat(o, " { ");
    o = string_concat(o, joined);
    o = string_concat(o, " }\n");
    return MirDumpExpr { out: o, next: n + 1, temp: temp };
  }
  if kind == mir_field_expr() {
    let base: MirDumpExpr = mir_dump_expr(mir, mir.me_a[node], depth, out, next);
    let temp: String = mir_temp_name(base.next);
    let mut o: String = string_concat(base.out, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = field ");
    o = string_concat(o, base.temp);
    o = string_concat(o, ".");
    o = string_concat(o, mir.me_text[node]);
    o = string_concat(o, "\n");
    return MirDumpExpr { out: o, next: base.next + 1, temp: temp };
  }
  if kind == mir_array_expr() {
    let estart: Int = mir.me_a[node];
    let ecount: Int = mir.me_b[node];
    let mut o: String = out;
    let mut n: Int = next;
    let mut joined: String = "";
    let mut i: Int = 0;
    while i < ecount {
      let r: MirDumpExpr = mir_dump_expr(mir, mir.mchild_list[estart + i], depth, o, n);
      o = r.out;
      n = r.next;
      if i > 0 {
        joined = string_concat(joined, ", ");
      }
      joined = string_concat(joined, r.temp);
      i = i + 1;
    }
    let temp: String = mir_temp_name(n);
    o = string_concat(o, pad);
    o = string_concat(o, temp);
    o = string_concat(o, " = array [");
    o = string_concat(o, joined);
    o = string_concat(o, "]\n");
    return MirDumpExpr { out: o, next: n + 1, temp: temp };
  }
  // index
  let base: MirDumpExpr = mir_dump_expr(mir, mir.me_a[node], depth, out, next);
  let idx: MirDumpExpr = mir_dump_expr(mir, mir.me_b[node], depth, base.out, base.next);
  let temp: String = mir_temp_name(idx.next);
  let mut o: String = string_concat(idx.out, pad);
  o = string_concat(o, temp);
  o = string_concat(o, " = index ");
  o = string_concat(o, base.temp);
  o = string_concat(o, "[");
  o = string_concat(o, idx.temp);
  o = string_concat(o, "]\n");
  return MirDumpExpr { out: o, next: idx.next + 1, temp: temp };
}

// Render a place to its text, dumping any index expressions along the way
// (base text first, then the index expr — matching Rust dump_place).
fn mir_dump_place(mir: Mir, place: Int, depth: Int, out: String, next: Int) -> MirDumpPlace {
  let kind: Int = mir.mpl_kind[place];
  if kind == mir_place_local() {
    return MirDumpPlace { out: out, next: next, text: mir.mpl_name[place] };
  }
  if kind == mir_place_field() {
    let base: MirDumpPlace = mir_dump_place(mir, mir.mpl_base[place], depth, out, next);
    let mut text: String = string_concat(base.text, ".");
    text = string_concat(text, mir.mpl_name[place]);
    return MirDumpPlace { out: base.out, next: base.next, text: text };
  }
  // index place
  let base: MirDumpPlace = mir_dump_place(mir, mir.mpl_base[place], depth, out, next);
  let idx: MirDumpExpr = mir_dump_expr(mir, mir.mpl_index[place], depth, base.out, base.next);
  let mut text: String = string_concat(base.text, "[");
  text = string_concat(text, idx.temp);
  text = string_concat(text, "]");
  return MirDumpPlace { out: idx.out, next: idx.next, text: text };
}

fn mir_dump_block(mir: Mir, start: Int, count: Int, depth: Int, out: String, next: Int) -> MirDumpStmt {
  let mut o: String = out;
  let mut n: Int = next;
  let mut i: Int = 0;
  while i < count {
    let r: MirDumpStmt = mir_dump_stmt(mir, mir.mblock_list[start + i], depth, o, n);
    o = r.out;
    n = r.next;
    i = i + 1;
  }
  return MirDumpStmt { out: o, next: n };
}

fn mir_dump_stmt(mir: Mir, index: Int, depth: Int, out: String, next: Int) -> MirDumpStmt {
  let pad: String = indent_of(depth);
  let kind: Int = mir.ms_kind[index];
  if kind == mir_local_stmt() {
    // Header line first, then the value expression, then the store.
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, "local ");
    o = string_concat(o, mir.ms_name[index]);
    o = string_concat(o, ": ");
    if mir.ms_has_type[index] == 1 {
      o = string_concat(o, mir.ms_type[index]);
    } else {
      o = string_concat(o, "<inferred>");
    }
    o = string_concat(o, " mutability=");
    if mir.ms_mut[index] == 1 {
      o = string_concat(o, "mutable");
    } else {
      o = string_concat(o, "immutable");
    }
    o = string_concat(o, "\n");
    let value: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth, o, next);
    let mut o2: String = string_concat(value.out, pad);
    o2 = string_concat(o2, "store ");
    o2 = string_concat(o2, mir.ms_name[index]);
    o2 = string_concat(o2, ", ");
    o2 = string_concat(o2, value.temp);
    o2 = string_concat(o2, "\n");
    return MirDumpStmt { out: o2, next: value.next };
  }
  if kind == mir_store_stmt() {
    // Value expression first, then the place (whose index exprs dump here).
    let value: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth, out, next);
    let place: MirDumpPlace = mir_dump_place(mir, mir.ms_place[index], depth,
                                             value.out, value.next);
    let mut o: String = string_concat(place.out, pad);
    o = string_concat(o, "store ");
    o = string_concat(o, place.text);
    o = string_concat(o, ", ");
    o = string_concat(o, value.temp);
    o = string_concat(o, "\n");
    return MirDumpStmt { out: o, next: place.next };
  }
  if kind == mir_if_stmt() {
    let cond: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth, out, next);
    let mut o: String = string_concat(cond.out, pad);
    o = string_concat(o, "if ");
    o = string_concat(o, cond.temp);
    o = string_concat(o, "\n");
    o = string_concat(o, pad);
    o = string_concat(o, "  then\n");
    let thenb: MirDumpStmt = mir_dump_block(mir, mir.ms_then_start[index],
                                            mir.ms_then_count[index], depth + 2, o, cond.next);
    let mut o2: String = thenb.out;
    let mut n2: Int = thenb.next;
    if mir.ms_else_count[index] > 0 {
      o2 = string_concat(o2, pad);
      o2 = string_concat(o2, "  else\n");
      let elseb: MirDumpStmt = mir_dump_block(mir, mir.ms_else_start[index],
                                              mir.ms_else_count[index], depth + 2, o2, n2);
      o2 = elseb.out;
      n2 = elseb.next;
    }
    o2 = string_concat(o2, pad);
    o2 = string_concat(o2, "end_if\n");
    return MirDumpStmt { out: o2, next: n2 };
  }
  if kind == mir_while_stmt() {
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, "loop\n");
    // The condition dumps one level deeper than the loop header.
    let cond: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth + 1, o, next);
    let mut o2: String = string_concat(cond.out, pad);
    o2 = string_concat(o2, "  break_unless ");
    o2 = string_concat(o2, cond.temp);
    o2 = string_concat(o2, "\n");
    let body: MirDumpStmt = mir_dump_block(mir, mir.ms_then_start[index],
                                           mir.ms_then_count[index], depth + 1, o2, cond.next);
    let mut o3: String = string_concat(body.out, pad);
    o3 = string_concat(o3, "end_loop\n");
    return MirDumpStmt { out: o3, next: body.next };
  }
  if kind == mir_for_in_stmt() {
    let iterable: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth, out, next);
    let mut o: String = string_concat(iterable.out, pad);
    o = string_concat(o, "for ");
    o = string_concat(o, mir.ms_name[index]);
    o = string_concat(o, " in ");
    o = string_concat(o, iterable.temp);
    o = string_concat(o, "\n");
    let body: MirDumpStmt = mir_dump_block(mir, mir.ms_then_start[index],
                                           mir.ms_then_count[index], depth + 1, o, iterable.next);
    let mut o2: String = string_concat(body.out, pad);
    o2 = string_concat(o2, "end_for\n");
    return MirDumpStmt { out: o2, next: body.next };
  }
  if kind == mir_for_range_stmt() {
    let startr: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth, out, next);
    let endr: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr2[index], depth,
                                          startr.out, startr.next);
    let mut o: String = string_concat(endr.out, pad);
    o = string_concat(o, "for ");
    o = string_concat(o, mir.ms_name[index]);
    o = string_concat(o, " in ");
    o = string_concat(o, startr.temp);
    o = string_concat(o, "..");
    o = string_concat(o, endr.temp);
    o = string_concat(o, "\n");
    let body: MirDumpStmt = mir_dump_block(mir, mir.ms_then_start[index],
                                           mir.ms_then_count[index], depth + 1, o, endr.next);
    let mut o2: String = string_concat(body.out, pad);
    o2 = string_concat(o2, "end_for\n");
    return MirDumpStmt { out: o2, next: body.next };
  }
  if kind == mir_for_c_stmt() {
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, "for_c\n");
    o = string_concat(o, pad);
    o = string_concat(o, "  init\n");
    let init: MirDumpStmt = mir_dump_stmt(mir, mir.ms_init[index], depth + 2, o, next);
    // The condition dumps one level deeper than the for_c header.
    let cond: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth + 1,
                                          init.out, init.next);
    let mut o2: String = string_concat(cond.out, pad);
    o2 = string_concat(o2, "  break_unless ");
    o2 = string_concat(o2, cond.temp);
    o2 = string_concat(o2, "\n");
    o2 = string_concat(o2, pad);
    o2 = string_concat(o2, "  body\n");
    let body: MirDumpStmt = mir_dump_block(mir, mir.ms_then_start[index],
                                           mir.ms_then_count[index], depth + 2, o2, cond.next);
    let mut o3: String = string_concat(body.out, pad);
    o3 = string_concat(o3, "  step\n");
    let step: MirDumpStmt = mir_dump_stmt(mir, mir.ms_step[index], depth + 2, o3, body.next);
    let mut o4: String = string_concat(step.out, pad);
    o4 = string_concat(o4, "end_for_c\n");
    return MirDumpStmt { out: o4, next: step.next };
  }
  if kind == mir_match_stmt() {
    let value: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth, out, next);
    let mut o: String = string_concat(value.out, pad);
    o = string_concat(o, "match ");
    o = string_concat(o, value.temp);
    o = string_concat(o, "\n");
    let mut n: Int = value.next;
    let astart: Int = mir.ms_then_start[index];
    let acount: Int = mir.ms_then_count[index];
    let mut ai: Int = 0;
    while ai < acount {
      o = string_concat(o, pad);
      o = string_concat(o, "  arm ");
      o = string_concat(o, mir.marm_pattern[astart + ai]);
      o = string_concat(o, "\n");
      let body: MirDumpStmt = mir_dump_block(mir, mir.marm_body_start[astart + ai],
                                             mir.marm_body_count[astart + ai],
                                             depth + 2, o, n);
      o = body.out;
      n = body.next;
      ai = ai + 1;
    }
    o = string_concat(o, pad);
    o = string_concat(o, "end_match\n");
    return MirDumpStmt { out: o, next: n };
  }
  if kind == mir_return_stmt() {
    if mir.ms_expr[index] >= 0 {
      let value: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth, out, next);
      let mut o: String = string_concat(value.out, pad);
      o = string_concat(o, "return ");
      o = string_concat(o, value.temp);
      o = string_concat(o, "\n");
      return MirDumpStmt { out: o, next: value.next };
    }
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, "return Unit\n");
    return MirDumpStmt { out: o, next: next };
  }
  if kind == mir_break_stmt() {
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, "break\n");
    return MirDumpStmt { out: o, next: next };
  }
  if kind == mir_continue_stmt() {
    let mut o: String = string_concat(out, pad);
    o = string_concat(o, "continue\n");
    return MirDumpStmt { out: o, next: next };
  }
  // drop
  let value: MirDumpExpr = mir_dump_expr(mir, mir.ms_expr[index], depth, out, next);
  let mut o: String = string_concat(value.out, pad);
  o = string_concat(o, "drop ");
  o = string_concat(o, value.temp);
  o = string_concat(o, "\n");
  return MirDumpStmt { out: o, next: value.next };
}

fn mir_dump_function_text(out: String, mir: Mir, fi: Int) -> String {
  let mut o: String = string_concat(out, "  fn ");
  o = string_concat(o, mir.mf_name[fi]);
  o = string_concat(o, " -> ");
  if mir.mf_has_ret[fi] == 1 {
    o = string_concat(o, mir.mf_ret[fi]);
  } else {
    o = string_concat(o, "Unit");
  }
  o = string_concat(o, "\n");
  let pstart: Int = mir.mf_param_start[fi];
  let pcount: Int = mir.mf_param_count[fi];
  let mut pi: Int = 0;
  while pi < pcount {
    o = string_concat(o, "    param ");
    o = string_concat(o, mir.mp_name[pstart + pi]);
    o = string_concat(o, ": ");
    o = string_concat(o, mir.mp_type[pstart + pi]);
    o = string_concat(o, "\n");
    pi = pi + 1;
  }
  o = string_concat(o, "    block entry\n");
  // Temps restart at _t0 for every function.
  let body: MirDumpStmt = mir_dump_block(mir, mir.mf_body_start[fi],
                                         mir.mf_body_count[fi], 3, o, 0);
  return body.out;
}

fn mir_dump_text(mir: Mir) -> String {
  let mut out: String = "MirModule\n";
  let mut e: Int = 0;
  while e < mir.men_name.len {
    out = string_concat(out, "  enum ");
    out = string_concat(out, mir.men_name[e]);
    out = string_concat(out, " variants=");
    let vstart: Int = mir.men_variant_start[e];
    let vcount: Int = mir.men_variant_count[e];
    let mut v: Int = 0;
    while v < vcount {
      if v > 0 {
        out = string_concat(out, ",");
      }
      out = string_concat(out, mir.mev_name[vstart + v]);
      if mir.mev_payload[vstart + v] != "" {
        out = string_concat(out, "(");
        out = string_concat(out, mir.mev_payload[vstart + v]);
        out = string_concat(out, ")");
      }
      v = v + 1;
    }
    out = string_concat(out, "\n");
    e = e + 1;
  }
  let mut f: Int = 0;
  while f < mir.mf_name.len {
    out = mir_dump_function_text(out, mir, f);
    f = f + 1;
  }
  return out;
}

// Shared driver for both entry points: lex + parse, build the variant lookup
// table (user enums plus std enums when granted), build the enum dump table,
// lower, dump.
fn mir_dump_with_std(arena: Arena, has_std_core: Bool, has_std_io: Bool) -> String {
  let enums: EnumTable = enum_table_build(arena, has_std_core, has_std_io);
  let mut mir: Mir = mir_empty();
  mir = mir_enum_dump_table(arena, mir, has_std_core, has_std_io);
  mir = lower_module(arena, enums, mir);
  return mir_dump_text(mir);
}

// Mirror of `zeta::mir::dump`: lowering with NO external enums (parse-only
// oracle; the variant table holds just the user enums).
export fn mir_dump_via_arena(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut start_arena: Arena = arena_empty();
  start_arena.token_start = lex_starts(source);
  let parsed: ParseResult = parse_module(start_arena, kinds, texts, 0);
  return mir_dump_with_std(parsed.arena, false, false);
}

// Mirror of `zeta::dump_mir`'s lowering: std imports inject external enums
// (`import std.core` grants OptionInt/ResultInt, `import std.io` grants
// ResultString), which join the variant lookup table and are dumped after the
// user enums (sorted by name, variants sorted by name, shadowed names skipped).
export fn mir_dump_pipeline_via_arena(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut start_arena: Arena = arena_empty();
  start_arena.token_start = lex_starts(source);
  let parsed: ParseResult = parse_module(start_arena, kinds, texts, 0);
  let arena: Arena = parsed.arena;
  let mut has_std_core: Bool = false;
  let mut has_std_io: Bool = false;
  let mut si: Int = 0;
  while si < arena.item_kind.len {
    if arena.item_kind[si] == item_import() {
      let path: String = arena.import_path[arena.item_ref[si]];
      if path == "std.core" {
        has_std_core = true;
      }
      if path == "std.io" {
        has_std_io = true;
      }
    }
    si = si + 1;
  }
  return mir_dump_with_std(arena, has_std_core, has_std_io);
}

// ===========================================================================
// M6 slice 1: MIR-arena evaluator.
//
// Walks the MIR arena built above and evaluates `main()` exactly the way
// `zeta::runtime::MirRuntime` does, returning the byte-for-byte same result
// string as `zeta::run_source(source).to_string()`. This slice covers
// scalars (Int / Bool / Unit), arithmetic / bitwise / comparison / boolean
// (with short-circuit), control flow (if / while / for-range / for-c), and
// user-function calls with an isolated call frame. String / Struct / Enum /
// Array values and the std builtins are reserved for slice 2/3; the schema
// below already carries the fields those slices need.
// ===========================================================================

// Value arena: append-only parallel arrays, threaded copy-on-write through the
// evaluator. A value is a handle (index) into these arrays.
struct Values {
  kind: IntArray,        // 0 Int, 1 String, 2 Bool, 3 Struct, 4 Enum, 5 Array, 6 Unit
  intval: IntArray,      // Int value; Bool stores 0/1; otherwise 0
  text: StringArray,     // String value / Struct type name / Enum ty; otherwise ""
  variant: StringArray,  // Enum variant; otherwise ""
  a: IntArray,           // Enum payload handle (-1 none); Array/Struct child slice start
  b: IntArray,           // Array element count; Struct field count
  elems: IntArray,       // flat array-element handle pool (Array slices via a/b)
  fnames: StringArray,   // flat struct field-name pool (Struct slices via a/b, sorted)
  fvals: IntArray,       // flat struct field-value handle pool (parallel to fnames)
}

fn values_empty() -> Values {
  return Values {
    kind: int_array_empty(),
    intval: int_array_empty(),
    text: string_array_empty(),
    variant: string_array_empty(),
    a: int_array_empty(),
    b: int_array_empty(),
    elems: int_array_empty(),
    fnames: string_array_empty(),
    fvals: int_array_empty(),
  };
}

// Packed (Values arena + handle) return so constructors can thread the arena.
struct ValuesH {
  vals: Values,
  h: Int,
}

fn vpush(vals: Values, kind: Int, intval: Int, text: String, variant: String,
         a: Int, b: Int) -> ValuesH {
  let mut v: Values = vals;
  let h: Int = v.kind.len;
  v.kind = int_array_push(v.kind, kind);
  v.intval = int_array_push(v.intval, intval);
  v.text = string_array_push(v.text, text);
  v.variant = string_array_push(v.variant, variant);
  v.a = int_array_push(v.a, a);
  v.b = int_array_push(v.b, b);
  return ValuesH { vals: v, h: h };
}

fn vmake_int(vals: Values, n: Int) -> ValuesH {
  return vpush(vals, 0, n, "", "", 0, 0);
}

fn vmake_bool(vals: Values, flag: Int) -> ValuesH {
  return vpush(vals, 2, flag, "", "", 0, 0);
}

fn vmake_unit(vals: Values) -> ValuesH {
  return vpush(vals, 6, 0, "", "", 0, 0);
}

fn vmake_string(vals: Values, text: String) -> ValuesH {
  return vpush(vals, 1, 0, text, "", 0, 0);
}

// Build an Array value: push each element handle into the flat `elems` pool,
// recording the slice (a=start, b=count) on the new value row.
fn vmake_array(vals: Values, elem_handles: IntArray) -> ValuesH {
  let mut v: Values = vals;
  let start: Int = v.elems.len;
  let count: Int = elem_handles.len;
  let mut i: Int = 0;
  while i < count {
    v.elems = int_array_push(v.elems, elem_handles[i]);
    i = i + 1;
  }
  return vpush(v, 5, 0, "", "", start, count);
}

// Build an Enum value: kind 4, text=ty, variant=variant, a=payload handle
// (-1 = payload-less variant).
fn vmake_enum(vals: Values, ty: String, variant: String, payload_h: Int) -> ValuesH {
  return vpush(vals, 4, 0, ty, variant, payload_h, 0);
}

// Decode a raw double-quoted string token into its String value. The corpus
// uses no escapes, but we still honor the lexer's escape contract for `\"`,
// `\\` and a permissive `\<other>` (the backslash is dropped, the next byte is
// emitted literally). KNOWN GAP: `\n`/`\t` would produce a literal `n`/`t`
// here rather than a newline/tab — there is no byte->string primitive to emit
// a control byte, and the run corpus never exercises these escapes.
fn unquote_string(raw: String) -> String {
  let len: Int = string_len(raw);
  let mut out: String = "";
  // Scan the interior bytes [1, len-1), skipping the surrounding quotes.
  let mut i: Int = 1;
  while i < len - 1 {
    let c: Int = string_byte_at(raw, i);
    if c == 92 {
      // Backslash: emit the following byte literally (\" -> ", \\ -> \,
      // \<other> -> <other>).
      out = string_concat(out, string_byte_slice(raw, i + 1, 1));
      i = i + 2;
    } else {
      out = string_concat(out, string_byte_slice(raw, i, 1));
      i = i + 1;
    }
  }
  return out;
}

// Lexicographic byte comparison: returns true iff `a` sorts strictly before
// `b`. A shorter string that is a prefix of the longer sorts first.
fn string_less(a: String, b: String) -> Bool {
  let la: Int = string_len(a);
  let lb: Int = string_len(b);
  let mut i: Int = 0;
  while i < la {
    if i >= lb {
      return false;
    }
    let ca: Int = string_byte_at(a, i);
    let cb: Int = string_byte_at(b, i);
    if ca < cb {
      return true;
    }
    if ca > cb {
      return false;
    }
    i = i + 1;
  }
  // `a` is a (possibly equal) prefix of `b`: smaller iff strictly shorter.
  return la < lb;
}

// Build a Struct value. Fields arrive in source order; the Rust runtime keeps
// them in a BTreeMap, so Display and equality observe field-name sorted order.
// We insertion-sort (name, handle) pairs by name into the flat fnames/fvals
// pools and record the slice (a=start, b=n) on the new row.
fn vmake_struct(vals: Values, type_name: String, names: StringArray,
                handles: IntArray, n: Int) -> ValuesH {
  // Insertion sort into local sorted arrays.
  let mut snames: StringArray = string_array_empty();
  let mut shandles: IntArray = int_array_empty();
  let mut i: Int = 0;
  while i < n {
    let nm: String = names[i];
    let hd: Int = handles[i];
    // Find insertion point: first j whose name is greater than nm.
    let mut j: Int = 0;
    let mut placed: Int = 0;
    while placed == 0 {
      if j >= snames.len {
        snames = string_array_push(snames, nm);
        shandles = int_array_push(shandles, hd);
        placed = 1;
      } else {
        if string_less(nm, snames[j]) {
          // Shift everything from j right by one by rebuilding the tail.
          let mut nn: StringArray = string_array_empty();
          let mut nh: IntArray = int_array_empty();
          let mut k: Int = 0;
          while k < j {
            nn = string_array_push(nn, snames[k]);
            nh = int_array_push(nh, shandles[k]);
            k = k + 1;
          }
          nn = string_array_push(nn, nm);
          nh = int_array_push(nh, hd);
          while k < snames.len {
            nn = string_array_push(nn, snames[k]);
            nh = int_array_push(nh, shandles[k]);
            k = k + 1;
          }
          snames = nn;
          shandles = nh;
          placed = 1;
        } else {
          j = j + 1;
        }
      }
    }
    i = i + 1;
  }
  // Append the sorted pairs to the flat pools.
  let mut v: Values = vals;
  let start: Int = v.fnames.len;
  let mut p: Int = 0;
  while p < n {
    v.fnames = string_array_push(v.fnames, snames[p]);
    v.fvals = int_array_push(v.fvals, shandles[p]);
    p = p + 1;
  }
  return vpush(v, 3, 0, type_name, "", start, n);
}

// Structural equality on values. Int/Bool compare via kind+intval. String
// compares text. Struct/Array recurse (fields already sorted, so positional
// comparison is order-stable). Enum is reserved for slice 3.
fn value_equal(vals: Values, h1: Int, h2: Int) -> Bool {
  if vals.kind[h1] != vals.kind[h2] {
    return false;
  }
  let kind: Int = vals.kind[h1];
  if kind == 1 {
    return vals.text[h1] == vals.text[h2];
  }
  if kind == 3 {
    if vals.text[h1] != vals.text[h2] {
      return false;
    }
    if vals.b[h1] != vals.b[h2] {
      return false;
    }
    let a1: Int = vals.a[h1];
    let a2: Int = vals.a[h2];
    let n: Int = vals.b[h1];
    let mut i: Int = 0;
    while i < n {
      if vals.fnames[a1 + i] != vals.fnames[a2 + i] {
        return false;
      }
      if !value_equal(vals, vals.fvals[a1 + i], vals.fvals[a2 + i]) {
        return false;
      }
      i = i + 1;
    }
    return true;
  }
  if kind == 5 {
    if vals.b[h1] != vals.b[h2] {
      return false;
    }
    let a1: Int = vals.a[h1];
    let a2: Int = vals.a[h2];
    let n: Int = vals.b[h1];
    let mut i: Int = 0;
    while i < n {
      if !value_equal(vals, vals.elems[a1 + i], vals.elems[a2 + i]) {
        return false;
      }
      i = i + 1;
    }
    return true;
  }
  if kind == 4 {
    // Enum: same ty + variant, and payloads both absent or both equal.
    if vals.text[h1] != vals.text[h2] {
      return false;
    }
    if vals.variant[h1] != vals.variant[h2] {
      return false;
    }
    let p1: Int = vals.a[h1];
    let p2: Int = vals.a[h2];
    if p1 < 0 && p2 < 0 {
      return true;
    }
    if p1 < 0 || p2 < 0 {
      return false;
    }
    return value_equal(vals, p1, p2);
  }
  return vals.intval[h1] == vals.intval[h2];
}

fn value_to_string(vals: Values, h: Int) -> String {
  let kind: Int = vals.kind[h];
  if kind == 0 {
    return int_to_string(vals.intval[h]);
  }
  if kind == 2 {
    if vals.intval[h] == 1 {
      return "true";
    }
    return "false";
  }
  if kind == 6 {
    return "()";
  }
  if kind == 1 {
    return vals.text[h];
  }
  if kind == 3 {
    // `{ty} {{ {fields} }}` with fields = "name: value" joined by ", ".
    let start: Int = vals.a[h];
    let n: Int = vals.b[h];
    let mut fields: String = "";
    let mut i: Int = 0;
    while i < n {
      if i > 0 {
        fields = string_concat(fields, ", ");
      }
      fields = string_concat(fields, vals.fnames[start + i]);
      fields = string_concat(fields, ": ");
      fields = string_concat(fields, value_to_string(vals, vals.fvals[start + i]));
      i = i + 1;
    }
    let mut out: String = vals.text[h];
    out = string_concat(out, " { ");
    out = string_concat(out, fields);
    out = string_concat(out, " }");
    return out;
  }
  if kind == 5 {
    // `[elem, elem, ...]`.
    let start: Int = vals.a[h];
    let n: Int = vals.b[h];
    let mut out: String = "[";
    let mut i: Int = 0;
    while i < n {
      if i > 0 {
        out = string_concat(out, ", ");
      }
      out = string_concat(out, value_to_string(vals, vals.elems[start + i]));
      i = i + 1;
    }
    out = string_concat(out, "]");
    return out;
  }
  if kind == 4 {
    // `{ty}.{variant}` with an optional `({payload})` suffix.
    let mut out: String = vals.text[h];
    out = string_concat(out, ".");
    out = string_concat(out, vals.variant[h]);
    let payload: Int = vals.a[h];
    if payload >= 0 {
      out = string_concat(out, "(");
      out = string_concat(out, value_to_string(vals, payload));
      out = string_concat(out, ")");
    }
    return out;
  }
  return "";
}

// Parse a non-negative decimal literal token (negatives arrive as unary neg).
fn decimal_to_int(text: String) -> Int {
  let len: Int = string_len(text);
  let mut acc: Int = 0;
  let mut i: Int = 0;
  while i < len {
    let c: Int = string_byte_at(text, i);
    acc = acc * 10 + (c - 48);
    i = i + 1;
  }
  return acc;
}

// Execution state. The locals stack is two parallel arrays; `base` is the
// current frame's floor (lookups never cross below it) and `count` is the
// logical stack height (block-scoped lets pop back to a saved count).
struct Exec {
  mir: Mir,
  vals: Values,
  lnames: StringArray,
  lhandles: IntArray,
  base: Int,
  count: Int,
  signal: Int,    // 0 normal, 1 break, 2 continue, 3 return
  retval: Int,    // handle when signal==3, else -1
}

struct EvalResult {
  ex: Exec,
  h: Int,
}

// Outcome of testing one match arm against a scrutinee. `matched` says the arm
// applies; `ex` carries any binding pushed onto the locals stack; `bound` is 1
// when the arm pushed a binding (so the caller restores the stack height).
struct MatchTest {
  matched: Bool,
  ex: Exec,
  bound: Int,
}

// Find the slot of `name`, scanning the current frame top-down to `base`.
// Returns -1 on miss (typecheck guarantees valid programs never miss).
fn local_slot(ex: Exec, name: String) -> Int {
  let mut i: Int = ex.count - 1;
  while i >= ex.base {
    if ex.lnames[i] == name {
      return i;
    }
    i = i - 1;
  }
  return 0 - 1;
}

// Push (name, handle) at the logical top of the stack, extending the parallel
// arrays only when the stack has actually grown past their physical length.
fn local_push(ex: Exec, name: String, handle: Int) -> Exec {
  let mut e: Exec = ex;
  if e.count < e.lnames.len {
    let mut names: StringArray = e.lnames;
    let mut handles: IntArray = e.lhandles;
    names[e.count] = name;
    handles[e.count] = handle;
    e.lnames = names;
    e.lhandles = handles;
  } else {
    e.lnames = string_array_push(e.lnames, name);
    e.lhandles = int_array_push(e.lhandles, handle);
  }
  e.count = e.count + 1;
  return e;
}

// Overwrite the handle stored in an existing slot (Store to a Local place).
fn local_set(ex: Exec, slot: Int, handle: Int) -> Exec {
  let mut e: Exec = ex;
  let mut handles: IntArray = e.lhandles;
  handles[slot] = handle;
  e.lhandles = handles;
  return e;
}

// Find the function row whose name matches (mf_name).
fn fn_row(mir: Mir, name: String) -> Int {
  let mut i: Int = 0;
  while i < mir.mf_name.len {
    if mir.mf_name[i] == name {
      return i;
    }
    i = i + 1;
  }
  return 0 - 1;
}

// Is `s` one of the 18 std builtin function names? (No file_read_to_string —
// the run corpus never touches file IO.) Std builtins are dispatched in the
// Call expr arm before falling through to user-function lookup.
fn is_std_builtin_name(s: String) -> Bool {
  if s == "string_len" { return true; }
  if s == "string_byte_at" { return true; }
  if s == "string_byte_slice" { return true; }
  if s == "string_concat" { return true; }
  if s == "int_to_string" { return true; }
  if s == "ascii_is_digit" { return true; }
  if s == "ascii_is_alpha" { return true; }
  if s == "ascii_is_alnum" { return true; }
  if s == "ascii_is_whitespace" { return true; }
  if s == "int_array_empty" { return true; }
  if s == "int_array_push" { return true; }
  if s == "string_array_empty" { return true; }
  if s == "string_array_push" { return true; }
  if s == "bool_array_empty" { return true; }
  if s == "bool_array_push" { return true; }
  if s == "path_join" { return true; }
  if s == "path_basename" { return true; }
  if s == "diagnostic_format" { return true; }
  return false;
}

// path_join, mirroring src/runtime.rs join_path: empty operands pass through;
// an absolute right (leading '/' or '\\') wins; otherwise join with a single
// '/' unless `left` already ends in a separator.
fn builtin_path_join(left: String, right: String) -> String {
  if string_len(left) == 0 {
    return right;
  }
  if string_len(right) == 0 {
    return left;
  }
  let r0: Int = string_byte_at(right, 0);
  if r0 == 47 || r0 == 92 {
    return right;
  }
  let llast: Int = string_byte_at(left, string_len(left) - 1);
  if llast == 47 || llast == 92 {
    return string_concat(left, right);
  }
  return string_concat(string_concat(left, "/"), right);
}

// path_basename, mirroring src/runtime.rs: drop trailing separators, then
// return the suffix after the last remaining separator (whole string if none,
// "" if the path was all separators).
fn builtin_path_basename(path: String) -> String {
  // Drop trailing separators.
  let mut end: Int = string_len(path);
  let mut trimming: Int = 1;
  while trimming == 1 {
    if end == 0 {
      trimming = 0;
    } else {
      let c: Int = string_byte_at(path, end - 1);
      if c == 47 || c == 92 {
        end = end - 1;
      } else {
        trimming = 0;
      }
    }
  }
  if end == 0 {
    return "";
  }
  // Scan back to the separator before [0, end).
  let mut start: Int = end;
  let mut scanning: Int = 1;
  while scanning == 1 {
    if start == 0 {
      scanning = 0;
    } else {
      let c: Int = string_byte_at(path, start - 1);
      if c == 47 || c == 92 {
        scanning = 0;
      } else {
        start = start - 1;
      }
    }
  }
  return string_byte_slice(path, start, end - start);
}

// Evaluate one std builtin given already-evaluated argument value handles.
// Each case mirrors eval_std_builtin in src/runtime.rs.
fn eval_builtin(vals: Values, callee: String, argh: IntArray, argn: Int) -> ValuesH {
  if callee == "string_len" {
    return vmake_int(vals, string_len(vals.text[argh[0]]));
  }
  if callee == "string_byte_at" {
    return vmake_int(vals, string_byte_at(vals.text[argh[0]], vals.intval[argh[1]]));
  }
  if callee == "string_byte_slice" {
    return vmake_string(vals, string_byte_slice(vals.text[argh[0]],
                                                vals.intval[argh[1]],
                                                vals.intval[argh[2]]));
  }
  if callee == "string_concat" {
    return vmake_string(vals, string_concat(vals.text[argh[0]], vals.text[argh[1]]));
  }
  if callee == "int_to_string" {
    return vmake_string(vals, int_to_string(vals.intval[argh[0]]));
  }
  // ASCII predicates. Rust returns false for bytes outside 0..=255; guard the
  // range explicitly so the Zeta builtin never sees an out-of-range value.
  if callee == "ascii_is_digit" {
    let n: Int = vals.intval[argh[0]];
    let mut flag: Int = 0;
    if n >= 0 && n <= 255 && ascii_is_digit(n) { flag = 1; }
    return vmake_bool(vals, flag);
  }
  if callee == "ascii_is_alpha" {
    let n: Int = vals.intval[argh[0]];
    let mut flag: Int = 0;
    if n >= 0 && n <= 255 && ascii_is_alpha(n) { flag = 1; }
    return vmake_bool(vals, flag);
  }
  if callee == "ascii_is_alnum" {
    let n: Int = vals.intval[argh[0]];
    let mut flag: Int = 0;
    if n >= 0 && n <= 255 && ascii_is_alnum(n) { flag = 1; }
    return vmake_bool(vals, flag);
  }
  if callee == "ascii_is_whitespace" {
    let n: Int = vals.intval[argh[0]];
    let mut flag: Int = 0;
    if n >= 0 && n <= 255 && ascii_is_whitespace(n) { flag = 1; }
    return vmake_bool(vals, flag);
  }
  if callee == "int_array_empty" || callee == "string_array_empty"
     || callee == "bool_array_empty" {
    return vmake_array(vals, int_array_empty());
  }
  if callee == "int_array_push" || callee == "string_array_push"
     || callee == "bool_array_push" {
    // COW: copy the source array's element handles, append the new value's
    // handle, and build a fresh Array.
    let arr: Int = argh[0];
    let abase: Int = vals.a[arr];
    let count: Int = vals.b[arr];
    let mut handles: IntArray = int_array_empty();
    let mut i: Int = 0;
    while i < count {
      handles = int_array_push(handles, vals.elems[abase + i]);
      i = i + 1;
    }
    handles = int_array_push(handles, argh[1]);
    return vmake_array(vals, handles);
  }
  if callee == "path_join" {
    return vmake_string(vals, builtin_path_join(vals.text[argh[0]], vals.text[argh[1]]));
  }
  if callee == "path_basename" {
    return vmake_string(vals, builtin_path_basename(vals.text[argh[0]]));
  }
  // diagnostic_format(code, line, col, msg) -> "{code} at {line}:{col}: {msg}".
  let mut out: String = vals.text[argh[0]];
  out = string_concat(out, " at ");
  out = string_concat(out, int_to_string(vals.intval[argh[1]]));
  out = string_concat(out, ":");
  out = string_concat(out, int_to_string(vals.intval[argh[2]]));
  out = string_concat(out, ": ");
  out = string_concat(out, vals.text[argh[3]]);
  return vmake_string(vals, out);
}

fn ev_expr(ex: Exec, node: Int) -> EvalResult {
  let kind: Int = ex.mir.me_kind[node];
  if kind == mir_load_expr() {
    let slot: Int = local_slot(ex, ex.mir.me_text[node]);
    return EvalResult { ex: ex, h: ex.lhandles[slot] };
  }
  if kind == mir_int_expr() {
    let n: Int = decimal_to_int(ex.mir.me_text[node]);
    let r: ValuesH = vmake_int(ex.vals, n);
    let mut e: Exec = ex;
    e.vals = r.vals;
    return EvalResult { ex: e, h: r.h };
  }
  if kind == mir_bool_expr() {
    let mut flag: Int = 0;
    if ex.mir.me_text[node] == "true" {
      flag = 1;
    }
    let r: ValuesH = vmake_bool(ex.vals, flag);
    let mut e: Exec = ex;
    e.vals = r.vals;
    return EvalResult { ex: e, h: r.h };
  }
  if kind == mir_string_expr() {
    // me_text is the raw quoted token; decode it to a String value.
    let r: ValuesH = vmake_string(ex.vals, unquote_string(ex.mir.me_text[node]));
    let mut e: Exec = ex;
    e.vals = r.vals;
    return EvalResult { ex: e, h: r.h };
  }
  if kind == mir_enum_expr() {
    // me_text = "E.V"; me_a = payload expr (-1 = payload-less).
    let path: String = ex.mir.me_text[node];
    let dot: Int = string_last_dot(path);
    let ty: String = string_byte_slice(path, 0, dot);
    let variant: String = string_byte_slice(path, dot + 1, string_len(path) - dot - 1);
    let mut e: Exec = ex;
    let mut payload_h: Int = 0 - 1;
    if ex.mir.me_a[node] >= 0 {
      let pr: EvalResult = ev_expr(e, ex.mir.me_a[node]);
      e = pr.ex;
      payload_h = pr.h;
    }
    let r: ValuesH = vmake_enum(e.vals, ty, variant, payload_h);
    e.vals = r.vals;
    return EvalResult { ex: e, h: r.h };
  }
  if kind == mir_unary_expr() {
    let op: String = ex.mir.me_text[node];
    let operand: EvalResult = ev_expr(ex, ex.mir.me_a[node]);
    let mut e: Exec = operand.ex;
    if op == "not" {
      let mut flag: Int = 1;
      if e.vals.intval[operand.h] == 1 {
        flag = 0;
      }
      let r: ValuesH = vmake_bool(e.vals, flag);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    if op == "neg" {
      let r: ValuesH = vmake_int(e.vals, 0 - e.vals.intval[operand.h]);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    // bit_not
    let r: ValuesH = vmake_int(e.vals, ~e.vals.intval[operand.h]);
    e.vals = r.vals;
    return EvalResult { ex: e, h: r.h };
  }
  if kind == mir_binary_expr() {
    let op: String = ex.mir.me_text[node];
    // Short-circuit boolean operators: only the left operand is guaranteed to
    // be evaluated.
    if op == "and" {
      let left: EvalResult = ev_expr(ex, ex.mir.me_a[node]);
      let mut e: Exec = left.ex;
      if e.vals.intval[left.h] == 0 {
        let r: ValuesH = vmake_bool(e.vals, 0);
        e.vals = r.vals;
        return EvalResult { ex: e, h: r.h };
      }
      let right: EvalResult = ev_expr(e, ex.mir.me_b[node]);
      let mut e2: Exec = right.ex;
      let r2: ValuesH = vmake_bool(e2.vals, e2.vals.intval[right.h]);
      e2.vals = r2.vals;
      return EvalResult { ex: e2, h: r2.h };
    }
    if op == "or" {
      let left: EvalResult = ev_expr(ex, ex.mir.me_a[node]);
      let mut e: Exec = left.ex;
      if e.vals.intval[left.h] == 1 {
        let r: ValuesH = vmake_bool(e.vals, 1);
        e.vals = r.vals;
        return EvalResult { ex: e, h: r.h };
      }
      let right: EvalResult = ev_expr(e, ex.mir.me_b[node]);
      let mut e2: Exec = right.ex;
      let r2: ValuesH = vmake_bool(e2.vals, e2.vals.intval[right.h]);
      e2.vals = r2.vals;
      return EvalResult { ex: e2, h: r2.h };
    }
    // All remaining operators evaluate left then right.
    let left: EvalResult = ev_expr(ex, ex.mir.me_a[node]);
    let right: EvalResult = ev_expr(left.ex, ex.mir.me_b[node]);
    let mut e: Exec = right.ex;
    let lh: Int = left.h;
    let rh: Int = right.h;
    if op == "eq" {
      let mut flag: Int = 0;
      if value_equal(e.vals, lh, rh) {
        flag = 1;
      }
      let r: ValuesH = vmake_bool(e.vals, flag);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    if op == "not_eq" {
      let mut flag: Int = 1;
      if value_equal(e.vals, lh, rh) {
        flag = 0;
      }
      let r: ValuesH = vmake_bool(e.vals, flag);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    let lv: Int = e.vals.intval[lh];
    let rv: Int = e.vals.intval[rh];
    // Integer comparisons -> Bool.
    if op == "lt" {
      let mut flag: Int = 0;
      if lv < rv { flag = 1; }
      let r: ValuesH = vmake_bool(e.vals, flag);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    if op == "lte" {
      let mut flag: Int = 0;
      if lv <= rv { flag = 1; }
      let r: ValuesH = vmake_bool(e.vals, flag);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    if op == "gt" {
      let mut flag: Int = 0;
      if lv > rv { flag = 1; }
      let r: ValuesH = vmake_bool(e.vals, flag);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    if op == "gte" {
      let mut flag: Int = 0;
      if lv >= rv { flag = 1; }
      let r: ValuesH = vmake_bool(e.vals, flag);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    // Integer arithmetic / bitwise -> Int.
    let mut out: Int = 0;
    if op == "add" { out = lv + rv; }
    if op == "sub" { out = lv - rv; }
    if op == "mul" { out = lv * rv; }
    if op == "div" { out = lv / rv; }
    if op == "mod" { out = lv % rv; }
    if op == "bit_and" { out = lv & rv; }
    if op == "bit_or" { out = lv | rv; }
    if op == "bit_xor" { out = lv ^ rv; }
    let r: ValuesH = vmake_int(e.vals, out);
    e.vals = r.vals;
    return EvalResult { ex: e, h: r.h };
  }
  if kind == mir_call_expr() {
    let callee: String = ex.mir.me_text[node];
    let arg_start: Int = ex.mir.me_a[node];
    let arg_count: Int = ex.mir.me_b[node];
    // Evaluate the arguments in the CALLER frame first.
    let mut e: Exec = ex;
    let mut argh: IntArray = int_array_empty();
    let mut i: Int = 0;
    while i < arg_count {
      let r: EvalResult = ev_expr(e, e.mir.mchild_list[arg_start + i]);
      e = r.ex;
      argh = int_array_push(argh, r.h);
      i = i + 1;
    }
    // Std builtins are dispatched directly on the evaluated argument handles —
    // there is no user-function frame to enter.
    if is_std_builtin_name(callee) {
      let r: ValuesH = eval_builtin(e.vals, callee, argh, arg_count);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    // Switch into a fresh frame: save the caller's base/count, set base to the
    // current top so the callee can never see caller locals.
    let row: Int = fn_row(e.mir, callee);
    let pstart: Int = e.mir.mf_param_start[row];
    let pcount: Int = e.mir.mf_param_count[row];
    let base0: Int = e.base;
    let count0: Int = e.count;
    e.base = e.count;
    let mut pi: Int = 0;
    while pi < pcount {
      e = local_push(e, e.mir.mp_name[pstart + pi], argh[pi]);
      pi = pi + 1;
    }
    e = ev_block(e, e.mir.mf_body_start[row], e.mir.mf_body_count[row]);
    let mut result: Int = 0 - 1;
    if e.signal == 3 {
      result = e.retval;
    } else {
      let u: ValuesH = vmake_unit(e.vals);
      e.vals = u.vals;
      result = u.h;
    }
    // Restore the caller frame.
    e.base = base0;
    e.count = count0;
    e.signal = 0;
    e.retval = 0 - 1;
    return EvalResult { ex: e, h: result };
  }
  if kind == mir_array_expr() {
    // me_a=start, me_b=count slice of mchild_list; evaluate each element.
    let start: Int = ex.mir.me_a[node];
    let count: Int = ex.mir.me_b[node];
    let mut e: Exec = ex;
    let mut handles: IntArray = int_array_empty();
    let mut i: Int = 0;
    while i < count {
      let r: EvalResult = ev_expr(e, e.mir.mchild_list[start + i]);
      e = r.ex;
      handles = int_array_push(handles, r.h);
      i = i + 1;
    }
    let arr: ValuesH = vmake_array(e.vals, handles);
    e.vals = arr.vals;
    return EvalResult { ex: e, h: arr.h };
  }
  if kind == mir_index_expr() {
    // me_a=base (Array), me_b=index (Int). Corpus never indexes out of range.
    let baser: EvalResult = ev_expr(ex, ex.mir.me_a[node]);
    let idxr: EvalResult = ev_expr(baser.ex, ex.mir.me_b[node]);
    let e: Exec = idxr.ex;
    let abase: Int = e.vals.a[baser.h];
    let i: Int = e.vals.intval[idxr.h];
    return EvalResult { ex: e, h: e.vals.elems[abase + i] };
  }
  if kind == mir_struct_expr() {
    // me_text=type name; me_a=start, me_b=count of msl_field_name/value.
    let type_name: String = ex.mir.me_text[node];
    let start: Int = ex.mir.me_a[node];
    let count: Int = ex.mir.me_b[node];
    let mut e: Exec = ex;
    let mut names: StringArray = string_array_empty();
    let mut handles: IntArray = int_array_empty();
    let mut i: Int = 0;
    while i < count {
      let r: EvalResult = ev_expr(e, e.mir.msl_field_value[start + i]);
      e = r.ex;
      names = string_array_push(names, e.mir.msl_field_name[start + i]);
      handles = int_array_push(handles, r.h);
      i = i + 1;
    }
    let st: ValuesH = vmake_struct(e.vals, type_name, names, handles, count);
    e.vals = st.vals;
    return EvalResult { ex: e, h: st.h };
  }
  if kind == mir_field_expr() {
    // me_a=base, me_text=field name. Enum FieldAccess is already lowered to
    // EnumVariant, so the base is always an Array (.len) or a Struct here.
    let baser: EvalResult = ev_expr(ex, ex.mir.me_a[node]);
    let mut e: Exec = baser.ex;
    let field: String = e.mir.me_text[node];
    let bkind: Int = e.vals.kind[baser.h];
    if bkind == 5 {
      // Array: only `.len` is valid (typecheck guarantees this).
      let r: ValuesH = vmake_int(e.vals, e.vals.b[baser.h]);
      e.vals = r.vals;
      return EvalResult { ex: e, h: r.h };
    }
    // Struct: locate the field by name in the sorted fnames slice.
    let abase: Int = e.vals.a[baser.h];
    let n: Int = e.vals.b[baser.h];
    let mut found: Int = 0 - 1;
    let mut j: Int = 0;
    while j < n {
      if e.vals.fnames[abase + j] == field {
        found = abase + j;
        j = n;
      } else {
        j = j + 1;
      }
    }
    return EvalResult { ex: e, h: e.vals.fvals[found] };
  }
  // string / enum reserved for slice 3.
  let u: ValuesH = vmake_unit(ex.vals);
  let mut e: Exec = ex;
  e.vals = u.vals;
  return EvalResult { ex: e, h: u.h };
}

// A place flattened from leaf->root into a root name plus an ordered list of
// steps (root->leaf). step_kind: 0 = field, 1 = index. step_field holds the
// field name for field steps; step_index holds the already-evaluated index for
// index steps. `ex` carries any value-arena growth from evaluating index exprs.
struct FlatPlace {
  ex: Exec,
  root_name: String,
  step_kind: IntArray,
  step_field: StringArray,
  step_index: IntArray,
  n: Int,
}

// Walk a place row chain (mpl_base links leaf->root), evaluating index
// expressions in the current scope, then reverse to root->leaf order.
fn flatten_place(ex: Exec, place_row: Int) -> FlatPlace {
  let mut e: Exec = ex;
  // Collect leaf->root.
  let mut rkind: IntArray = int_array_empty();
  let mut rfield: StringArray = string_array_empty();
  let mut rindex: IntArray = int_array_empty();
  let mut root: String = "";
  let mut row: Int = place_row;
  let mut walking: Int = 1;
  while walking == 1 {
    let pk: Int = e.mir.mpl_kind[row];
    if pk == mir_place_local() {
      root = e.mir.mpl_name[row];
      walking = 0;
    } else {
      if pk == mir_place_field() {
        rkind = int_array_push(rkind, 0);
        rfield = string_array_push(rfield, e.mir.mpl_name[row]);
        rindex = int_array_push(rindex, 0 - 1);
      } else {
        // index place: evaluate the index expr in the current scope.
        let r: EvalResult = ev_expr(e, e.mir.mpl_index[row]);
        e = r.ex;
        rkind = int_array_push(rkind, 1);
        rfield = string_array_push(rfield, "");
        rindex = int_array_push(rindex, e.vals.intval[r.h]);
      }
      row = e.mir.mpl_base[row];
    }
  }
  // Reverse into root->leaf order.
  let n: Int = rkind.len;
  let mut sk: IntArray = int_array_empty();
  let mut sf: StringArray = string_array_empty();
  let mut si: IntArray = int_array_empty();
  let mut i: Int = n - 1;
  while i >= 0 {
    sk = int_array_push(sk, rkind[i]);
    sf = string_array_push(sf, rfield[i]);
    si = int_array_push(si, rindex[i]);
    i = i - 1;
  }
  return FlatPlace { ex: e, root_name: root, step_kind: sk, step_field: sf,
                     step_index: si, n: n };
}

// Copy-on-write write-through: rebuild the value at handle `h` so that the
// path sk/sf/si[depth..n] is replaced by `newval`, returning the new root
// handle. Each struct/array node along the path is reconstructed (old nodes
// become garbage).
fn store_through(vals: Values, h: Int, sk: IntArray, sf: StringArray,
                 si: IntArray, depth: Int, n: Int, newval: Int) -> ValuesH {
  if depth == n {
    return ValuesH { vals: vals, h: newval };
  }
  if sk[depth] == 0 {
    // field step: h is a Struct.
    let abase: Int = vals.a[h];
    let count: Int = vals.b[h];
    let type_name: String = vals.text[h];
    // Recurse into the matching child first.
    let mut j: Int = 0;
    let mut target: Int = 0 - 1;
    while j < count {
      if vals.fnames[abase + j] == sf[depth] {
        target = abase + j;
        j = count;
      } else {
        j = j + 1;
      }
    }
    let child: ValuesH = store_through(vals, vals.fvals[target], sk, sf, si,
                                       depth + 1, n, newval);
    // Rebuild the struct with the child handle replaced (fields stay sorted,
    // so reuse the stored order rather than re-sorting).
    let mut v: Values = child.vals;
    let start: Int = v.fnames.len;
    let mut k: Int = 0;
    while k < count {
      v.fnames = string_array_push(v.fnames, v.fnames[abase + k]);
      if k == target - abase {
        v.fvals = int_array_push(v.fvals, child.h);
      } else {
        v.fvals = int_array_push(v.fvals, v.fvals[abase + k]);
      }
      k = k + 1;
    }
    return vpush(v, 3, 0, type_name, "", start, count);
  }
  // index step: h is an Array.
  let abase: Int = vals.a[h];
  let count: Int = vals.b[h];
  let idx: Int = si[depth];
  let child: ValuesH = store_through(vals, vals.elems[abase + idx], sk, sf, si,
                                     depth + 1, n, newval);
  let mut v: Values = child.vals;
  let start: Int = v.elems.len;
  let mut k: Int = 0;
  while k < count {
    if k == idx {
      v.elems = int_array_push(v.elems, child.h);
    } else {
      v.elems = int_array_push(v.elems, v.elems[abase + k]);
    }
    k = k + 1;
  }
  return vpush(v, 5, 0, "", "", start, count);
}

fn ev_block(ex: Exec, start: Int, count: Int) -> Exec {
  let mut e: Exec = ex;
  let saved: Int = e.count;
  let mut i: Int = 0;
  while i < count {
    if e.signal != 0 {
      i = count;
    } else {
      e = ev_stmt(e, e.mir.mblock_list[start + i]);
      i = i + 1;
    }
  }
  // Block-scoped lets fall out of scope when the block exits (short-circuit or
  // not). The slots stay physically allocated; only the logical height resets.
  e.count = saved;
  return e;
}

// Test one match arm `pat` against the scrutinee value handle `vh`. On a match
// that introduces a binding, the binding is pushed onto `ex`'s locals stack and
// `bound` is set to 1. Pattern texts mirror the MIR contract:
//   `_`              wildcard
//   `name:x`         binds the whole value to x
//   `variant:E.V`    matches an Enum (ty E, variant V), payload ignored
//   `variant:E.V(b)` like above, binds the payload to b
//   `int:N`          matches an Int equal to N
//   `bool:true|false`matches a Bool
//   `string:"..."`   matches a String (raw quoted token after the prefix)
fn match_arm(ex: Exec, vh: Int, pat: String) -> MatchTest {
  if pat == "_" {
    return MatchTest { matched: true, ex: ex, bound: 0 };
  }
  if string_starts_with(pat, "name:") {
    let name: String = pattern_binding(pat);
    let e: Exec = local_push(ex, name, vh);
    return MatchTest { matched: true, ex: e, bound: 1 };
  }
  if string_starts_with(pat, "variant:") {
    if ex.vals.kind[vh] != 4 {
      return MatchTest { matched: false, ex: ex, bound: 0 };
    }
    let ename: String = pattern_variant_enum(pat);
    let vname: String = pattern_variant_name(pat);
    if ex.vals.text[vh] != ename {
      return MatchTest { matched: false, ex: ex, bound: 0 };
    }
    if ex.vals.variant[vh] != vname {
      return MatchTest { matched: false, ex: ex, bound: 0 };
    }
    let binding: String = pattern_binding(pat);
    if string_len(binding) > 0 {
      let payload: Int = ex.vals.a[vh];
      let e: Exec = local_push(ex, binding, payload);
      return MatchTest { matched: true, ex: e, bound: 1 };
    }
    return MatchTest { matched: true, ex: ex, bound: 0 };
  }
  if string_starts_with(pat, "int:") {
    if ex.vals.kind[vh] != 0 {
      return MatchTest { matched: false, ex: ex, bound: 0 };
    }
    let n: Int = decimal_to_int(string_byte_slice(pat, 4, string_len(pat) - 4));
    let mut ok: Bool = false;
    if ex.vals.intval[vh] == n { ok = true; }
    return MatchTest { matched: ok, ex: ex, bound: 0 };
  }
  if string_starts_with(pat, "bool:") {
    if ex.vals.kind[vh] != 2 {
      return MatchTest { matched: false, ex: ex, bound: 0 };
    }
    let mut want: Int = 0;
    if string_byte_slice(pat, 5, string_len(pat) - 5) == "true" { want = 1; }
    let mut ok: Bool = false;
    if ex.vals.intval[vh] == want { ok = true; }
    return MatchTest { matched: ok, ex: ex, bound: 0 };
  }
  if string_starts_with(pat, "string:") {
    if ex.vals.kind[vh] != 1 {
      return MatchTest { matched: false, ex: ex, bound: 0 };
    }
    // The remainder after "string:" is the raw quoted token (Rust Debug
    // escaping); decode it the same way string literals are decoded. KNOWN GAP:
    // escapes like `\n` round-trip as literal `n` (see unquote_string).
    let want: String = unquote_string(string_byte_slice(pat, 7, string_len(pat) - 7));
    let mut ok: Bool = false;
    if ex.vals.text[vh] == want { ok = true; }
    return MatchTest { matched: ok, ex: ex, bound: 0 };
  }
  return MatchTest { matched: false, ex: ex, bound: 0 };
}

fn ev_stmt(ex: Exec, index: Int) -> Exec {
  let kind: Int = ex.mir.ms_kind[index];
  if kind == mir_local_stmt() {
    let r: EvalResult = ev_expr(ex, ex.mir.ms_expr[index]);
    let mut e: Exec = r.ex;
    e = local_push(e, e.mir.ms_name[index], r.h);
    e.signal = 0;
    return e;
  }
  if kind == mir_store_stmt() {
    // Evaluate the RHS first, then flatten the place (which may evaluate index
    // expressions in the current scope), matching the Rust runtime order.
    let r: EvalResult = ev_expr(ex, ex.mir.ms_expr[index]);
    let mut e: Exec = r.ex;
    let place: Int = e.mir.ms_place[index];
    if e.mir.mpl_kind[place] == mir_place_local() {
      // Fast path: plain local assignment, no write-through.
      let root: String = e.mir.mpl_name[place];
      let slot: Int = local_slot(e, root);
      e = local_set(e, slot, r.h);
      e.signal = 0;
      return e;
    }
    // Nested place: flatten root->leaf, then COW write-through from the root.
    let flat: FlatPlace = flatten_place(e, place);
    e = flat.ex;
    let slot: Int = local_slot(e, flat.root_name);
    let rooth: Int = e.lhandles[slot];
    let built: ValuesH = store_through(e.vals, rooth, flat.step_kind,
                                       flat.step_field, flat.step_index, 0,
                                       flat.n, r.h);
    e.vals = built.vals;
    e = local_set(e, slot, built.h);
    e.signal = 0;
    return e;
  }
  if kind == mir_if_stmt() {
    let cond: EvalResult = ev_expr(ex, ex.mir.ms_expr[index]);
    let mut e: Exec = cond.ex;
    if e.vals.intval[cond.h] == 1 {
      e = ev_block(e, e.mir.ms_then_start[index], e.mir.ms_then_count[index]);
    } else {
      e = ev_block(e, e.mir.ms_else_start[index], e.mir.ms_else_count[index]);
    }
    return e;
  }
  if kind == mir_while_stmt() {
    let mut e: Exec = ex;
    let mut looping: Int = 1;
    while looping == 1 {
      let cond: EvalResult = ev_expr(e, e.mir.ms_expr[index]);
      e = cond.ex;
      if e.vals.intval[cond.h] == 0 {
        looping = 0;
      } else {
        e = ev_block(e, e.mir.ms_then_start[index], e.mir.ms_then_count[index]);
        if e.signal == 1 {
          e.signal = 0;
          looping = 0;
        } else {
          if e.signal == 2 {
            e.signal = 0;
          } else {
            if e.signal == 3 {
              looping = 0;
            }
          }
        }
      }
    }
    return e;
  }
  if kind == mir_for_range_stmt() {
    let startr: EvalResult = ev_expr(ex, ex.mir.ms_expr[index]);
    let mut e: Exec = startr.ex;
    let endr: EvalResult = ev_expr(e, e.mir.ms_expr2[index]);
    e = endr.ex;
    let lo: Int = e.vals.intval[startr.h];
    let hi: Int = e.vals.intval[endr.h];
    let binding: String = e.mir.ms_name[index];
    let mut i: Int = lo;
    let mut looping: Int = 1;
    while looping == 1 {
      if i >= hi {
        looping = 0;
      } else {
        let saved: Int = e.count;
        let iv: ValuesH = vmake_int(e.vals, i);
        e.vals = iv.vals;
        e = local_push(e, binding, iv.h);
        e = ev_block(e, e.mir.ms_then_start[index], e.mir.ms_then_count[index]);
        e.count = saved;
        if e.signal == 1 {
          e.signal = 0;
          looping = 0;
        } else {
          if e.signal == 2 {
            e.signal = 0;
          } else {
            if e.signal == 3 {
              looping = 0;
            }
          }
        }
        i = i + 1;
      }
    }
    return e;
  }
  if kind == mir_for_c_stmt() {
    let mut e: Exec = ex;
    let saved: Int = e.count;
    // The init binding stays live on the stack across all iterations.
    e = ev_stmt(e, e.mir.ms_init[index]);
    e.signal = 0;
    let mut looping: Int = 1;
    while looping == 1 {
      let cond: EvalResult = ev_expr(e, e.mir.ms_expr[index]);
      e = cond.ex;
      if e.vals.intval[cond.h] == 0 {
        looping = 0;
      } else {
        e = ev_block(e, e.mir.ms_then_start[index], e.mir.ms_then_count[index]);
        if e.signal == 1 {
          e.signal = 0;
          looping = 0;
        } else {
          if e.signal == 3 {
            looping = 0;
          } else {
            // normal or continue: both fall through to the step.
            e.signal = 0;
            e = ev_stmt(e, e.mir.ms_step[index]);
            e.signal = 0;
          }
        }
      }
    }
    e.count = saved;
    return e;
  }
  if kind == mir_return_stmt() {
    let mut e: Exec = ex;
    if e.mir.ms_expr[index] >= 0 {
      let r: EvalResult = ev_expr(e, e.mir.ms_expr[index]);
      e = r.ex;
      e.retval = r.h;
    } else {
      let u: ValuesH = vmake_unit(e.vals);
      e.vals = u.vals;
      e.retval = u.h;
    }
    e.signal = 3;
    return e;
  }
  if kind == mir_break_stmt() {
    let mut e: Exec = ex;
    e.signal = 1;
    return e;
  }
  if kind == mir_continue_stmt() {
    let mut e: Exec = ex;
    e.signal = 2;
    return e;
  }
  if kind == mir_drop_stmt() {
    let r: EvalResult = ev_expr(ex, ex.mir.ms_expr[index]);
    let mut e: Exec = r.ex;
    e.signal = 0;
    return e;
  }
  if kind == mir_for_in_stmt() {
    // ms_expr=iterable (Array), ms_name=binding, ms_then_*=body. Iterate the
    // array's element handles, mirroring for_range's stack discipline.
    let iterr: EvalResult = ev_expr(ex, ex.mir.ms_expr[index]);
    let mut e: Exec = iterr.ex;
    let abase: Int = e.vals.a[iterr.h];
    let n: Int = e.vals.b[iterr.h];
    let binding: String = e.mir.ms_name[index];
    let mut i: Int = 0;
    let mut looping: Int = 1;
    while looping == 1 {
      if i >= n {
        looping = 0;
      } else {
        let saved: Int = e.count;
        e = local_push(e, binding, e.vals.elems[abase + i]);
        e = ev_block(e, e.mir.ms_then_start[index], e.mir.ms_then_count[index]);
        e.count = saved;
        if e.signal == 1 {
          e.signal = 0;
          looping = 0;
        } else {
          if e.signal == 2 {
            e.signal = 0;
          } else {
            if e.signal == 3 {
              looping = 0;
            }
          }
        }
        i = i + 1;
      }
    }
    return e;
  }
  if kind == mir_match_stmt() {
    // Evaluate the scrutinee, then test each arm in order. The FIRST matching
    // arm runs and ends the match (its body's signal becomes the match result);
    // later arms are never tried. This mirrors the Rust runtime's semantics.
    let scrut: EvalResult = ev_expr(ex, ex.mir.ms_expr[index]);
    let mut e: Exec = scrut.ex;
    let vh: Int = scrut.h;
    let arm_start: Int = e.mir.ms_then_start[index];
    let arm_count: Int = e.mir.ms_then_count[index];
    let mut ai: Int = 0;
    let mut done: Int = 0;
    while ai < arm_count && done == 0 {
      let pat: String = e.mir.marm_pattern[arm_start + ai];
      let saved: Int = e.count;
      let test: MatchTest = match_arm(e, vh, pat);
      e = test.ex;
      if test.matched {
        e = ev_block(e, e.mir.marm_body_start[arm_start + ai],
                     e.mir.marm_body_count[arm_start + ai]);
        e.count = saved;
        done = 1;
      } else {
        // No binding survives a failed arm (match_arm only pushes on a match).
        e.count = saved;
        ai = ai + 1;
      }
    }
    return e;
  }
  // Unreachable in valid programs (typecheck rejects non-exhaustive matches and
  // every other statement kind is handled above).
  let mut e: Exec = ex;
  e.signal = 0;
  return e;
}

// Build the MIR (including std external enums, matching run_source's pipeline)
// and evaluate `main()`, returning the result value's string.
export fn run_main_via_arena(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut start_arena: Arena = arena_empty();
  start_arena.token_start = lex_starts(source);
  let parsed: ParseResult = parse_module(start_arena, kinds, texts, 0);
  let arena: Arena = parsed.arena;
  let mut has_std_core: Bool = false;
  let mut has_std_io: Bool = false;
  let mut si: Int = 0;
  while si < arena.item_kind.len {
    if arena.item_kind[si] == item_import() {
      let path: String = arena.import_path[arena.item_ref[si]];
      if path == "std.core" {
        has_std_core = true;
      }
      if path == "std.io" {
        has_std_io = true;
      }
    }
    si = si + 1;
  }
  let enums: EnumTable = enum_table_build(arena, has_std_core, has_std_io);
  let mut mir: Mir = mir_empty();
  mir = mir_enum_dump_table(arena, mir, has_std_core, has_std_io);
  mir = lower_module(arena, enums, mir);

  let main_row: Int = fn_row(mir, "main");
  let mut ex: Exec = Exec {
    mir: mir,
    vals: values_empty(),
    lnames: string_array_empty(),
    lhandles: int_array_empty(),
    base: 0,
    count: 0,
    signal: 0,
    retval: 0 - 1,
  };
  ex = ev_block(ex, ex.mir.mf_body_start[main_row], ex.mir.mf_body_count[main_row]);
  let mut result: Int = 0 - 1;
  if ex.signal == 3 {
    result = ex.retval;
  } else {
    let u: ValuesH = vmake_unit(ex.vals);
    ex.vals = u.vals;
    result = u.h;
  }
  return value_to_string(ex.vals, result);
}

// M7 slice 2: the unified compiler driver. Turns the seven per-stage exports
// above into a single `zetac`-style front door that dispatches on `mode`.
// Mode strings mirror the Stage0 CLI subcommands (`zeta ast-dump`, `zeta run`,
// ...): "ast-dump" / "resolve" / "typecheck" / "mir-dump" / "run". An unknown
// mode returns a `ZETAC_UNKNOWN_MODE <mode>` marker rather than crashing, so a
// caller can probe the driver without knowing the mode set up front.
//
// This is the integration step that makes the Zeta side "one compiler" instead
// of a handful of loose functions; the whole-program self-application proof
// lives in tests/selfhost_fixpoint.rs, and driver dispatch is gated by
// tests/selfhost_driver.rs.
// ===========================================================================
// Stage2: MIR arena -> LLVM IR text (slice 1 scalar + 2 struct + 3 IntArray
// + 4 String + 5 enum/match). String = `%zstr = { i64 len, ptr i8 }`,
// IMMUTABLE so binding points share the buffer (no deep copy); literals become
// private global constants (accumulated across functions via Emit.globals /
// FnResult), and string_len / byte_at / concat / byte_slice / int_to_string
// (snprintf) / ascii_is_* lower inline, with == / != via memcmp (branch-free).
// Enums are `%zenum = { i64 tag, i64 p0, ptr p1 }` (Int/Bool in p0, String
// split across p0/p1, no payload zero/null); `match` lowers to an LLVM `switch`
// on the tag (enum) or the value itself (Int/Bool), arms binding their payload.
// for-range / for-in / for-c lower to explicit control flow, with continue
// advancing the counter/step so it still progresses. Arrays are generalized
// over element type: IntArray / BoolArray (i64, 8-byte stride) and StringArray
// (%zstr, 16-byte stride), driven by `array_elem_type` / `elem_stride`.
//
// Emits textual LLVM IR. Int / Bool unify as i64; structs map to named `%S`
// aggregate types (insertvalue literals, extractvalue field reads, GEP field
// writes; pass / return by value); IntArray is `%zarr = { i64 len, ptr data }`
// with a heap (malloc) element buffer, VALUE SEMANTICS via a deep copy at
// binding points (let / assign / call arg) unless the source is already fresh
// (an array literal or `int_array_*` builtin). Covered: Int / Bool / struct /
// IntArray params and returns, let / assign (local / field / index place) /
// return, arithmetic / bitwise / comparison / unary (neg / not / bit_not) /
// logical and-or, if / else / while / break / continue, user calls including
// recursion, array literals, `arr[i]` read / write, `arr.len`, and the
// `int_array_empty` / `int_array_push` builtins (inline malloc + memcpy). Every
// alloca is hoisted to the entry block. Each user function is emitted as
// `@z_<name>` so the linked C driver can call `@z_main` without clashing with
// C's own `main`. A read-only `Tcx` rides inside `Emit` to type every value
// (struct decls from the AST arena, function return types from the MIR table,
// per-function local scope). The Rust gate (tests/selfhost_llvm.rs) compiles
// this IR with clang, links a tiny C driver, runs it, and asserts the printed
// result equals the Stage0 interpreter oracle (run_mir). Short-circuit is not
// observable in this pure subset, so and / or lower to value-equivalent
// normalized bitwise ops; true short-circuit and the String / Bool-StringArray
// / Enum / match / for families come in later slices.
// ===========================================================================

// Read-only type context threaded (inside Emit) through the emitter so it can
// type each value: struct decls (from the AST arena), function return types
// (from the MIR table), and the current function's local scope (name -> type,
// rebuilt per function). Types are the same display strings the typechecker
// uses ("Int" / "Bool" / struct name / ...).
struct Tcx {
  struct_name: StringArray,
  struct_field_start: IntArray,
  struct_field_count: IntArray,
  field_name: StringArray,
  field_type: StringArray,
  efn_name: StringArray,
  efn_has_ret: IntArray,
  efn_ret: StringArray,
  men_name: StringArray,
  men_variant_start: IntArray,
  men_variant_count: IntArray,
  mev_name: StringArray,
  mev_payload: StringArray,
  loc_name: StringArray,
  loc_type: StringArray,
}

// Threaded emitter state: accumulated IR text, next %tN register id, next
// basic-block label id, whether the current block already has a terminator, the
// read-only type context, and the module-level accumulator for string-literal
// global constants (`gcount` = next id, `globals` = their definitions text).
struct Emit {
  out: String,
  reg: Int,
  block: Int,
  term: Int,
  tcx: Tcx,
  gcount: Int,
  globals: String,
}

// What a function emission yields: its `define` body plus the updated
// string-literal global accumulator threaded on to the next function.
struct FnResult {
  body: String,
  gcount: Int,
  globals: String,
}

// An emitted expression: the threaded state plus the value reference (an "%tN"
// register or an i64 immediate like "42").
struct EmitVal {
  em: Emit,
  vref: String,
}

// A resolved assignment place: the threaded state, the pointer register holding
// the address, and the Zeta type stored there.
struct PlaceRef {
  em: Emit,
  ptr: String,
  ty: String,
}

// Index of `name` in the struct table, or `len` when absent (so the caller can
// test `< struct_name.len` for "is a struct type").
fn find_struct(tcx: Tcx, name: String) -> Int {
  let mut i: Int = 0;
  while i < tcx.struct_name.len {
    if tcx.struct_name[i] == name {
      return i;
    }
    i = i + 1;
  }
  return tcx.struct_name.len;
}

fn find_fn(tcx: Tcx, name: String) -> Int {
  let mut i: Int = 0;
  while i < tcx.efn_name.len {
    if tcx.efn_name[i] == name {
      return i;
    }
    i = i + 1;
  }
  return tcx.efn_name.len;
}

// Declaration index (0-based) of field `fname` within struct `si`.
fn struct_field_index(tcx: Tcx, si: Int, fname: String) -> Int {
  let start: Int = tcx.struct_field_start[si];
  let count: Int = tcx.struct_field_count[si];
  let mut i: Int = 0;
  while i < count {
    if tcx.field_name[start + i] == fname {
      return i;
    }
    i = i + 1;
  }
  return 0;
}

fn struct_field_type_at(tcx: Tcx, si: Int, idx: Int) -> String {
  return tcx.field_type[tcx.struct_field_start[si] + idx];
}

// Index of `name` in the enum table, or `len` when absent.
fn find_enum(tcx: Tcx, name: String) -> Int {
  let mut i: Int = 0;
  while i < tcx.men_name.len {
    if tcx.men_name[i] == name {
      return i;
    }
    i = i + 1;
  }
  return tcx.men_name.len;
}

// Runtime tag (declaration index) of `vname` within enum `ename`.
fn variant_tag(tcx: Tcx, ename: String, vname: String) -> Int {
  let ei: Int = find_enum(tcx, ename);
  if ei >= tcx.men_name.len {
    return 0;
  }
  let start: Int = tcx.men_variant_start[ei];
  let count: Int = tcx.men_variant_count[ei];
  let mut j: Int = 0;
  while j < count {
    if tcx.mev_name[start + j] == vname {
      return j;
    }
    j = j + 1;
  }
  return 0;
}

// Payload type of `ename.vname` ("" = no payload).
fn variant_payload_type(tcx: Tcx, ename: String, vname: String) -> String {
  let ei: Int = find_enum(tcx, ename);
  if ei >= tcx.men_name.len {
    return "";
  }
  let start: Int = tcx.men_variant_start[ei];
  let count: Int = tcx.men_variant_count[ei];
  let mut j: Int = 0;
  while j < count {
    if tcx.mev_name[start + j] == vname {
      return tcx.mev_payload[start + j];
    }
    j = j + 1;
  }
  return "";
}

// Split an "Enum.Variant" path on its dot.
fn enum_path_enum(s: String) -> String {
  let len: Int = string_len(s);
  let mut i: Int = 0;
  while i < len {
    if string_byte_at(s, i) == 46 {
      return string_byte_slice(s, 0, i);
    }
    i = i + 1;
  }
  return s;
}

fn enum_path_variant(s: String) -> String {
  let len: Int = string_len(s);
  let mut i: Int = 0;
  while i < len {
    if string_byte_at(s, i) == 46 {
      return string_byte_slice(s, i + 1, len - i - 1);
    }
    i = i + 1;
  }
  return "";
}

// Type of local / param `name`, searched newest-first for shadowing.
fn scope_type(tcx: Tcx, name: String) -> String {
  let mut i: Int = tcx.loc_name.len;
  while i > 0 {
    i = i - 1;
    if tcx.loc_name[i] == name {
      return tcx.loc_type[i];
    }
  }
  return "Int";
}

// Whether `ty` is a dynamic array. Arrays are the `%zarr = { i64 len, ptr data }`
// value with a heap element buffer (Int/Bool elements are i64 = 8 bytes, String
// elements are %zstr = 16 bytes).
fn is_array_type(ty: String) -> Bool {
  return ty == "IntArray" || ty == "BoolArray" || ty == "StringArray";
}

// The element Zeta type of an array type, and the reverse.
fn array_elem_type(arr_ty: String) -> String {
  if arr_ty == "StringArray" {
    return "String";
  }
  if arr_ty == "BoolArray" {
    return "Bool";
  }
  return "Int";
}

fn elem_to_array_type(elem: String) -> String {
  if elem == "String" {
    return "StringArray";
  }
  if elem == "Bool" {
    return "BoolArray";
  }
  return "IntArray";
}

// Byte stride of one array element (String = 16, Int/Bool = 8).
fn elem_stride(elem: String) -> Int {
  if elem == "String" {
    return 16;
  }
  return 8;
}

// Array builtins lowered inline (not user `@z_` calls).
fn is_array_builtin(name: String) -> Bool {
  return name == "int_array_empty" || name == "int_array_push"
      || name == "bool_array_empty" || name == "bool_array_push"
      || name == "string_array_empty" || name == "string_array_push";
}

fn array_builtin_elem(name: String) -> String {
  if string_starts_with(name, "string_array") {
    return "String";
  }
  if string_starts_with(name, "bool_array") {
    return "Bool";
  }
  return "Int";
}

fn array_builtin_is_push(name: String) -> Bool {
  let l: Int = string_len(name);
  return string_byte_slice(name, l - 5, 5) == "_push";
}

// String builtins lowered inline.
fn is_string_builtin(name: String) -> Bool {
  return name == "string_len" || name == "string_byte_at"
      || name == "string_concat" || name == "string_byte_slice"
      || name == "int_to_string"
      || name == "ascii_is_digit" || name == "ascii_is_alpha"
      || name == "ascii_is_alnum" || name == "ascii_is_whitespace";
}

fn string_builtin_ret(name: String) -> String {
  if name == "string_concat" {
    return "String";
  }
  if name == "string_byte_slice" {
    return "String";
  }
  if name == "int_to_string" {
    return "String";
  }
  if name == "string_len" {
    return "Int";
  }
  if name == "string_byte_at" {
    return "Int";
  }
  return "Bool";
}

fn hex_digit(d: Int) -> String {
  return string_byte_slice("0123456789ABCDEF", d, 1);
}

// One byte as an LLVM `\HH` escape.
fn byte_to_hex2(n: Int) -> String {
  return string_concat("\\", string_concat(hex_digit(n / 16), hex_digit(n % 16)));
}

// Escape a byte string for an LLVM `c"..."` constant: `"`, `\`, and any
// non-printable byte become `\HH`; other printable ASCII passes through.
fn llvm_str_escape(content: String) -> String {
  let len: Int = string_len(content);
  let mut out: String = "";
  let mut i: Int = 0;
  while i < len {
    let b: Int = string_byte_at(content, i);
    if b == 34 || b == 92 || b < 32 || b > 126 {
      out = string_concat(out, byte_to_hex2(b));
    } else {
      out = string_concat(out, string_byte_slice(content, i, 1));
    }
    i = i + 1;
  }
  return out;
}

// The LLVM type for a Zeta type string. Int / Bool unify as i64; an array is
// `%zarr`; a struct maps to its named `%Name` type. (String / enum: later.)
fn llvm_ty(tcx: Tcx, ty: String) -> String {
  if ty == "Int" {
    return "i64";
  }
  if ty == "Bool" {
    return "i64";
  }
  if ty == "String" {
    return "%zstr";
  }
  if is_array_type(ty) {
    return "%zarr";
  }
  if find_enum(tcx, ty) < tcx.men_name.len {
    return "%zenum";
  }
  if find_struct(tcx, ty) < tcx.struct_name.len {
    return string_concat("%", ty);
  }
  return "i64";
}

// Static type of an expression node (scalar + struct subset).
fn type_of_expr(tcx: Tcx, mir: Mir, node: Int) -> String {
  let kind: Int = mir.me_kind[node];
  if kind == mir_int_expr() {
    return "Int";
  }
  if kind == mir_bool_expr() {
    return "Bool";
  }
  if kind == mir_string_expr() {
    return "String";
  }
  if kind == mir_load_expr() {
    return scope_type(tcx, mir.me_text[node]);
  }
  if kind == mir_unary_expr() {
    if mir.me_text[node] == "not" {
      return "Bool";
    }
    return "Int";
  }
  if kind == mir_binary_expr() {
    let op: String = mir.me_text[node];
    if llvm_is_arith(op) {
      return "Int";
    }
    return "Bool";
  }
  if kind == mir_call_expr() {
    if is_array_builtin(mir.me_text[node]) {
      return elem_to_array_type(array_builtin_elem(mir.me_text[node]));
    }
    if is_string_builtin(mir.me_text[node]) {
      return string_builtin_ret(mir.me_text[node]);
    }
    let ci: Int = find_fn(tcx, mir.me_text[node]);
    if ci < tcx.efn_name.len {
      if tcx.efn_has_ret[ci] == 1 {
        return tcx.efn_ret[ci];
      }
      return "Unit";
    }
    return "Int";
  }
  if kind == mir_array_expr() {
    if mir.me_b[node] > 0 {
      return elem_to_array_type(type_of_expr(tcx, mir, mir.mchild_list[mir.me_a[node]]));
    }
    return "IntArray";
  }
  if kind == mir_index_expr() {
    return array_elem_type(type_of_expr(tcx, mir, mir.me_a[node]));
  }
  if kind == mir_enum_expr() {
    return enum_path_enum(mir.me_text[node]);
  }
  if kind == mir_struct_expr() {
    return mir.me_text[node];
  }
  if kind == mir_field_expr() {
    let bty: String = type_of_expr(tcx, mir, mir.me_a[node]);
    let si: Int = find_struct(tcx, bty);
    if si < tcx.struct_name.len {
      let fidx: Int = struct_field_index(tcx, si, mir.me_text[node]);
      return struct_field_type_at(tcx, si, fidx);
    }
    return "Int";
  }
  return "Int";
}

// `%Name = type { ... }` for every struct, fields in declaration order.
fn llvm_emit_struct_defs(out: String, tcx: Tcx) -> String {
  let mut o: String = out;
  let mut si: Int = 0;
  while si < tcx.struct_name.len {
    o = string_concat(o, "%");
    o = string_concat(o, tcx.struct_name[si]);
    o = string_concat(o, " = type { ");
    let start: Int = tcx.struct_field_start[si];
    let count: Int = tcx.struct_field_count[si];
    let mut fi: Int = 0;
    while fi < count {
      if fi > 0 {
        o = string_concat(o, ", ");
      }
      o = string_concat(o, llvm_ty(tcx, tcx.field_type[start + fi]));
      fi = fi + 1;
    }
    o = string_concat(o, " }\n");
    si = si + 1;
  }
  if tcx.struct_name.len > 0 {
    o = string_concat(o, "\n");
  }
  return o;
}

// Build the module-global type context (struct decls + function return types).
fn tcx_global(arena: Arena, mir: Mir) -> Tcx {
  return Tcx {
    struct_name: arena.struct_name,
    struct_field_start: arena.struct_field_start,
    struct_field_count: arena.struct_field_count,
    field_name: arena.field_name,
    field_type: arena.field_type,
    efn_name: mir.mf_name,
    efn_has_ret: mir.mf_has_ret,
    efn_ret: mir.mf_ret,
    men_name: mir.men_name,
    men_variant_start: mir.men_variant_start,
    men_variant_count: mir.men_variant_count,
    mev_name: mir.mev_name,
    mev_payload: mir.mev_payload,
    loc_name: string_array_empty(),
    loc_type: string_array_empty(),
  };
}

// Record local types declared in a block (recursing into if / while bodies);
// each let's type is its annotation, else the inferred type of its initializer.
fn tcx_scan_lets(tcx: Tcx, mir: Mir, start: Int, count: Int) -> Tcx {
  let mut acc: Tcx = tcx;
  let mut i: Int = 0;
  while i < count {
    let s: Int = mir.mblock_list[start + i];
    let k: Int = mir.ms_kind[s];
    if k == mir_local_stmt() {
      let mut ty: String = "Int";
      if mir.ms_has_type[s] == 1 {
        ty = mir.ms_type[s];
      } else {
        ty = type_of_expr(acc, mir, mir.ms_expr[s]);
      }
      acc.loc_name = string_array_push(acc.loc_name, mir.ms_name[s]);
      acc.loc_type = string_array_push(acc.loc_type, ty);
    }
    if k == mir_if_stmt() {
      acc = tcx_scan_lets(acc, mir, mir.ms_then_start[s], mir.ms_then_count[s]);
      acc = tcx_scan_lets(acc, mir, mir.ms_else_start[s], mir.ms_else_count[s]);
    }
    if k == mir_while_stmt() {
      acc = tcx_scan_lets(acc, mir, mir.ms_then_start[s], mir.ms_then_count[s]);
    }
    if k == mir_match_stmt() {
      let astart: Int = mir.ms_then_start[s];
      let acount: Int = mir.ms_then_count[s];
      let mvty: String = type_of_expr(acc, mir, mir.ms_expr[s]);
      let mut ai: Int = 0;
      while ai < acount {
        let pat: String = mir.marm_pattern[astart + ai];
        if string_starts_with(pat, "name:") {
          acc.loc_name = string_array_push(acc.loc_name, pattern_binding(pat));
          acc.loc_type = string_array_push(acc.loc_type, mvty);
        }
        if string_starts_with(pat, "variant:") {
          let bnd: String = pattern_binding(pat);
          if string_len(bnd) > 0 {
            acc.loc_name = string_array_push(acc.loc_name, bnd);
            acc.loc_type = string_array_push(acc.loc_type,
              variant_payload_type(acc, pattern_variant_enum(pat), pattern_variant_name(pat)));
          }
        }
        acc = tcx_scan_lets(acc, mir, mir.marm_body_start[astart + ai], mir.marm_body_count[astart + ai]);
        ai = ai + 1;
      }
    }
    if k == mir_for_range_stmt() {
      acc.loc_name = string_array_push(acc.loc_name, mir.ms_name[s]);
      acc.loc_type = string_array_push(acc.loc_type, "Int");
      acc = tcx_scan_lets(acc, mir, mir.ms_then_start[s], mir.ms_then_count[s]);
    }
    if k == mir_for_in_stmt() {
      acc.loc_name = string_array_push(acc.loc_name, mir.ms_name[s]);
      acc.loc_type = string_array_push(acc.loc_type,
        array_elem_type(type_of_expr(acc, mir, mir.ms_expr[s])));
      acc = tcx_scan_lets(acc, mir, mir.ms_then_start[s], mir.ms_then_count[s]);
    }
    if k == mir_for_c_stmt() {
      let init: Int = mir.ms_init[s];
      if mir.ms_kind[init] == mir_local_stmt() {
        let mut ity: String = "Int";
        if mir.ms_has_type[init] == 1 {
          ity = mir.ms_type[init];
        } else {
          ity = type_of_expr(acc, mir, mir.ms_expr[init]);
        }
        acc.loc_name = string_array_push(acc.loc_name, mir.ms_name[init]);
        acc.loc_type = string_array_push(acc.loc_type, ity);
      }
      acc = tcx_scan_lets(acc, mir, mir.ms_then_start[s], mir.ms_then_count[s]);
    }
    i = i + 1;
  }
  return acc;
}

// Per-function context: params first, then every let, layered on the globals.
fn tcx_with_scope(g: Tcx, mir: Mir, fi: Int) -> Tcx {
  let mut t: Tcx = g;
  t.loc_name = string_array_empty();
  t.loc_type = string_array_empty();
  let pstart: Int = mir.mf_param_start[fi];
  let pcount: Int = mir.mf_param_count[fi];
  let mut pi: Int = 0;
  while pi < pcount {
    t.loc_name = string_array_push(t.loc_name, mir.mp_name[pstart + pi]);
    t.loc_type = string_array_push(t.loc_type, mir.mp_type[pstart + pi]);
    pi = pi + 1;
  }
  t = tcx_scan_lets(t, mir, mir.mf_body_start[fi], mir.mf_body_count[fi]);
  return t;
}

fn llvm_reg_name(n: Int) -> String {
  return string_concat("%t", int_to_string(n));
}

fn llvm_label_name(n: Int) -> String {
  return string_concat("b", int_to_string(n));
}

// The alloca pointer for a local / param: `%<name>.slot`.
fn llvm_slot_ref(name: String) -> String {
  return string_concat(string_concat("%", name), ".slot");
}

fn llvm_arith_op(op: String) -> String {
  if op == "add" { return "add"; }
  if op == "sub" { return "sub"; }
  if op == "mul" { return "mul"; }
  if op == "div" { return "sdiv"; }
  if op == "mod" { return "srem"; }
  if op == "bit_and" { return "and"; }
  if op == "bit_or" { return "or"; }
  if op == "bit_xor" { return "xor"; }
  return "add";
}

fn llvm_is_arith(op: String) -> Bool {
  return op == "add" || op == "sub" || op == "mul" || op == "div" || op == "mod"
      || op == "bit_and" || op == "bit_or" || op == "bit_xor";
}

fn llvm_cmp_pred(op: String) -> String {
  if op == "eq" { return "eq"; }
  if op == "not_eq" { return "ne"; }
  if op == "lt" { return "slt"; }
  if op == "lte" { return "sle"; }
  if op == "gt" { return "sgt"; }
  if op == "gte" { return "sge"; }
  return "eq";
}

fn llvm_is_cmp(op: String) -> Bool {
  return op == "eq" || op == "not_eq" || op == "lt" || op == "lte"
      || op == "gt" || op == "gte";
}

// Emit `<reg> = icmp ne i64 <vref>, 0` then `<reg2> = zext i1 <reg> to i64`,
// returning the i64 0/1 normalization of `vref`.
fn llvm_normalize_bool(em: Emit, vref: String) -> EmitVal {
  let mut e: Emit = em;
  let r: Int = e.reg;
  e.reg = e.reg + 1;
  let rn: String = llvm_reg_name(r);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, rn);
  e.out = string_concat(e.out, " = icmp ne i64 ");
  e.out = string_concat(e.out, vref);
  e.out = string_concat(e.out, ", 0\n");
  let r2: Int = e.reg;
  e.reg = e.reg + 1;
  let rn2: String = llvm_reg_name(r2);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, rn2);
  e.out = string_concat(e.out, " = zext i1 ");
  e.out = string_concat(e.out, rn);
  e.out = string_concat(e.out, " to i64\n");
  return EmitVal { em: e, vref: rn2 };
}

fn llvm_expr(em: Emit, mir: Mir, node: Int) -> EmitVal {
  let kind: Int = mir.me_kind[node];
  if kind == mir_int_expr() {
    return EmitVal { em: em, vref: mir.me_text[node] };
  }
  if kind == mir_bool_expr() {
    let mut v: String = "0";
    if mir.me_text[node] == "true" {
      v = "1";
    }
    return EmitVal { em: em, vref: v };
  }
  if kind == mir_string_expr() {
    // Decode the raw token to its bytes (reusing the interpreter's unquote),
    // emit a private global constant, and build the {len, ptr} value.
    let content: String = unquote_string(mir.me_text[node]);
    let n: Int = string_len(content);
    let mut e: Emit = em;
    let gname: String = string_concat("@.str.", int_to_string(e.gcount));
    e.globals = string_concat(e.globals, gname);
    e.globals = string_concat(e.globals, " = private constant [");
    e.globals = string_concat(e.globals, int_to_string(n));
    e.globals = string_concat(e.globals, " x i8] c\"");
    e.globals = string_concat(e.globals, llvm_str_escape(content));
    e.globals = string_concat(e.globals, "\"\n");
    e.gcount = e.gcount + 1;
    let r0: Int = e.reg;
    e.reg = e.reg + 1;
    let agg0: String = llvm_reg_name(r0);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, agg0);
    e.out = string_concat(e.out, " = insertvalue %zstr undef, i64 ");
    e.out = string_concat(e.out, int_to_string(n));
    e.out = string_concat(e.out, ", 0\n");
    let r1: Int = e.reg;
    e.reg = e.reg + 1;
    let agg1: String = llvm_reg_name(r1);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, agg1);
    e.out = string_concat(e.out, " = insertvalue %zstr ");
    e.out = string_concat(e.out, agg0);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, gname);
    e.out = string_concat(e.out, ", 1\n");
    return EmitVal { em: e, vref: agg1 };
  }
  if kind == mir_load_expr() {
    let mut e: Emit = em;
    let llty: String = llvm_ty(e.tcx, scope_type(e.tcx, mir.me_text[node]));
    let r: Int = e.reg;
    e.reg = e.reg + 1;
    let rn: String = llvm_reg_name(r);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, rn);
    e.out = string_concat(e.out, " = load ");
    e.out = string_concat(e.out, llty);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, llvm_slot_ref(mir.me_text[node]));
    e.out = string_concat(e.out, "\n");
    return EmitVal { em: e, vref: rn };
  }
  if kind == mir_unary_expr() {
    let operand: EmitVal = llvm_expr(em, mir, mir.me_a[node]);
    let mut e: Emit = operand.em;
    let op: String = mir.me_text[node];
    if op == "neg" {
      let r: Int = e.reg;
      e.reg = e.reg + 1;
      let rn: String = llvm_reg_name(r);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, rn);
      e.out = string_concat(e.out, " = sub i64 0, ");
      e.out = string_concat(e.out, operand.vref);
      e.out = string_concat(e.out, "\n");
      return EmitVal { em: e, vref: rn };
    }
    if op == "bit_not" {
      let r: Int = e.reg;
      e.reg = e.reg + 1;
      let rn: String = llvm_reg_name(r);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, rn);
      e.out = string_concat(e.out, " = xor i64 ");
      e.out = string_concat(e.out, operand.vref);
      e.out = string_concat(e.out, ", -1\n");
      return EmitVal { em: e, vref: rn };
    }
    // not: logical not on a Bool → (x == 0) widened to i64.
    let r: Int = e.reg;
    e.reg = e.reg + 1;
    let rn: String = llvm_reg_name(r);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, rn);
    e.out = string_concat(e.out, " = icmp eq i64 ");
    e.out = string_concat(e.out, operand.vref);
    e.out = string_concat(e.out, ", 0\n");
    let r2: Int = e.reg;
    e.reg = e.reg + 1;
    let rn2: String = llvm_reg_name(r2);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, rn2);
    e.out = string_concat(e.out, " = zext i1 ");
    e.out = string_concat(e.out, rn);
    e.out = string_concat(e.out, " to i64\n");
    return EmitVal { em: e, vref: rn2 };
  }
  if kind == mir_binary_expr() {
    let op: String = mir.me_text[node];
    let left: EmitVal = llvm_expr(em, mir, mir.me_a[node]);
    let right: EmitVal = llvm_expr(left.em, mir, mir.me_b[node]);
    let mut e: Emit = right.em;
    if type_of_expr(e.tcx, mir, mir.me_a[node]) == "String" {
      // String == / != : len equal AND memcmp(min(la,lb)) == 0 (min avoids an
      // over-read; the length guard supplies correctness). Branch-free.
      let la: EmitVal = emit_extract_zstr(e, left.vref, 0);
      let pa: EmitVal = emit_extract_zstr(la.em, left.vref, 1);
      let lb: EmitVal = emit_extract_zstr(pa.em, right.vref, 0);
      let pb: EmitVal = emit_extract_zstr(lb.em, right.vref, 1);
      let le: EmitBit = emit_icmp_i64(pb.em, "eq", la.vref, lb.vref);
      let lt: EmitBit = emit_icmp_i64(le.em, "ult", la.vref, lb.vref);
      let mut e3: Emit = lt.em;
      let rm: Int = e3.reg;
      e3.reg = e3.reg + 1;
      let minr: String = llvm_reg_name(rm);
      e3.out = string_concat(e3.out, "  ");
      e3.out = string_concat(e3.out, minr);
      e3.out = string_concat(e3.out, " = select i1 ");
      e3.out = string_concat(e3.out, lt.bit);
      e3.out = string_concat(e3.out, ", i64 ");
      e3.out = string_concat(e3.out, la.vref);
      e3.out = string_concat(e3.out, ", i64 ");
      e3.out = string_concat(e3.out, lb.vref);
      e3.out = string_concat(e3.out, "\n");
      let rc: Int = e3.reg;
      e3.reg = e3.reg + 1;
      let cmpr: String = llvm_reg_name(rc);
      e3.out = string_concat(e3.out, "  ");
      e3.out = string_concat(e3.out, cmpr);
      e3.out = string_concat(e3.out, " = call i32 @memcmp(ptr ");
      e3.out = string_concat(e3.out, pa.vref);
      e3.out = string_concat(e3.out, ", ptr ");
      e3.out = string_concat(e3.out, pb.vref);
      e3.out = string_concat(e3.out, ", i64 ");
      e3.out = string_concat(e3.out, minr);
      e3.out = string_concat(e3.out, ")\n");
      let rce: Int = e3.reg;
      e3.reg = e3.reg + 1;
      let ceq: String = llvm_reg_name(rce);
      e3.out = string_concat(e3.out, "  ");
      e3.out = string_concat(e3.out, ceq);
      e3.out = string_concat(e3.out, " = icmp eq i32 ");
      e3.out = string_concat(e3.out, cmpr);
      e3.out = string_concat(e3.out, ", 0\n");
      let andbit: EmitBit = emit_i1_binop(e3, "and", le.bit, ceq);
      if op == "not_eq" {
        let mut e4: Emit = andbit.em;
        let rn: Int = e4.reg;
        e4.reg = e4.reg + 1;
        let nb: String = llvm_reg_name(rn);
        e4.out = string_concat(e4.out, "  ");
        e4.out = string_concat(e4.out, nb);
        e4.out = string_concat(e4.out, " = xor i1 ");
        e4.out = string_concat(e4.out, andbit.bit);
        e4.out = string_concat(e4.out, ", true\n");
        return emit_zext_i1(e4, nb);
      }
      return emit_zext_i1(andbit.em, andbit.bit);
    }
    if llvm_is_arith(op) {
      let r: Int = e.reg;
      e.reg = e.reg + 1;
      let rn: String = llvm_reg_name(r);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, rn);
      e.out = string_concat(e.out, " = ");
      e.out = string_concat(e.out, llvm_arith_op(op));
      e.out = string_concat(e.out, " i64 ");
      e.out = string_concat(e.out, left.vref);
      e.out = string_concat(e.out, ", ");
      e.out = string_concat(e.out, right.vref);
      e.out = string_concat(e.out, "\n");
      return EmitVal { em: e, vref: rn };
    }
    if llvm_is_cmp(op) {
      let r: Int = e.reg;
      e.reg = e.reg + 1;
      let rn: String = llvm_reg_name(r);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, rn);
      e.out = string_concat(e.out, " = icmp ");
      e.out = string_concat(e.out, llvm_cmp_pred(op));
      e.out = string_concat(e.out, " i64 ");
      e.out = string_concat(e.out, left.vref);
      e.out = string_concat(e.out, ", ");
      e.out = string_concat(e.out, right.vref);
      e.out = string_concat(e.out, "\n");
      let r2: Int = e.reg;
      e.reg = e.reg + 1;
      let rn2: String = llvm_reg_name(r2);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, rn2);
      e.out = string_concat(e.out, " = zext i1 ");
      e.out = string_concat(e.out, rn);
      e.out = string_concat(e.out, " to i64\n");
      return EmitVal { em: e, vref: rn2 };
    }
    // Logical and / or: normalize both operands to 0/1, then bitwise.
    let ln: EmitVal = llvm_normalize_bool(e, left.vref);
    let rnv: EmitVal = llvm_normalize_bool(ln.em, right.vref);
    let mut e2: Emit = rnv.em;
    let mut opc: String = "and";
    if op == "or" {
      opc = "or";
    }
    let r: Int = e2.reg;
    e2.reg = e2.reg + 1;
    let rn: String = llvm_reg_name(r);
    e2.out = string_concat(e2.out, "  ");
    e2.out = string_concat(e2.out, rn);
    e2.out = string_concat(e2.out, " = ");
    e2.out = string_concat(e2.out, opc);
    e2.out = string_concat(e2.out, " i64 ");
    e2.out = string_concat(e2.out, ln.vref);
    e2.out = string_concat(e2.out, ", ");
    e2.out = string_concat(e2.out, rnv.vref);
    e2.out = string_concat(e2.out, "\n");
    return EmitVal { em: e2, vref: rn };
  }
  if kind == mir_call_expr() {
    if is_array_builtin(mir.me_text[node]) {
      return llvm_array_builtin(em, mir, node);
    }
    if is_string_builtin(mir.me_text[node]) {
      return llvm_string_builtin(em, mir, node);
    }
    let astart: Int = mir.me_a[node];
    let acount: Int = mir.me_b[node];
    let mut e: Emit = em;
    let mut args: String = "";
    let mut i: Int = 0;
    while i < acount {
      let argnode: Int = mir.mchild_list[astart + i];
      let argty: String = llvm_ty(e.tcx, type_of_expr(e.tcx, mir, argnode));
      // User-call array args get an independent deep copy (value semantics).
      let a: EmitVal = emit_bind(e, mir, argnode);
      e = a.em;
      if i > 0 {
        args = string_concat(args, ", ");
      }
      args = string_concat(args, argty);
      args = string_concat(args, " ");
      args = string_concat(args, a.vref);
      i = i + 1;
    }
    let callee: String = mir.me_text[node];
    let ci: Int = find_fn(e.tcx, callee);
    let mut retllty: String = "i64";
    let mut has_ret: Int = 1;
    if ci < e.tcx.efn_name.len {
      has_ret = e.tcx.efn_has_ret[ci];
      if has_ret == 1 {
        retllty = llvm_ty(e.tcx, e.tcx.efn_ret[ci]);
      } else {
        retllty = "void";
      }
    }
    if has_ret == 0 {
      e.out = string_concat(e.out, "  call void @z_");
      e.out = string_concat(e.out, callee);
      e.out = string_concat(e.out, "(");
      e.out = string_concat(e.out, args);
      e.out = string_concat(e.out, ")\n");
      return EmitVal { em: e, vref: "0" };
    }
    let r: Int = e.reg;
    e.reg = e.reg + 1;
    let rn: String = llvm_reg_name(r);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, rn);
    e.out = string_concat(e.out, " = call ");
    e.out = string_concat(e.out, retllty);
    e.out = string_concat(e.out, " @z_");
    e.out = string_concat(e.out, callee);
    e.out = string_concat(e.out, "(");
    e.out = string_concat(e.out, args);
    e.out = string_concat(e.out, ")\n");
    return EmitVal { em: e, vref: rn };
  }
  if kind == mir_array_expr() {
    // [e0, e1, ...] → malloc(count*stride), store each, build {count, buf}.
    let estart: Int = mir.me_a[node];
    let ecount: Int = mir.me_b[node];
    let mut elem: String = "Int";
    if ecount > 0 {
      elem = type_of_expr(em.tcx, mir, mir.mchild_list[estart]);
    }
    let elemll: String = llvm_ty(em.tcx, elem);
    let stride: Int = elem_stride(elem);
    let mut e: Emit = em;
    let rb: Int = e.reg;
    e.reg = e.reg + 1;
    let buf: String = llvm_reg_name(rb);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, " = call ptr @malloc(i64 ");
    e.out = string_concat(e.out, int_to_string(ecount * stride));
    e.out = string_concat(e.out, ")\n");
    let mut i: Int = 0;
    while i < ecount {
      let v: EmitVal = llvm_expr(e, mir, mir.mchild_list[estart + i]);
      e = v.em;
      let rp: Int = e.reg;
      e.reg = e.reg + 1;
      let p: String = llvm_reg_name(rp);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, p);
      e.out = string_concat(e.out, " = getelementptr ");
      e.out = string_concat(e.out, elemll);
      e.out = string_concat(e.out, ", ptr ");
      e.out = string_concat(e.out, buf);
      e.out = string_concat(e.out, ", i64 ");
      e.out = string_concat(e.out, int_to_string(i));
      e.out = string_concat(e.out, "\n  store ");
      e.out = string_concat(e.out, elemll);
      e.out = string_concat(e.out, " ");
      e.out = string_concat(e.out, v.vref);
      e.out = string_concat(e.out, ", ptr ");
      e.out = string_concat(e.out, p);
      e.out = string_concat(e.out, "\n");
      i = i + 1;
    }
    let ra: Int = e.reg;
    e.reg = e.reg + 1;
    let agg0: String = llvm_reg_name(ra);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, agg0);
    e.out = string_concat(e.out, " = insertvalue %zarr undef, i64 ");
    e.out = string_concat(e.out, int_to_string(ecount));
    e.out = string_concat(e.out, ", 0\n");
    let rc: Int = e.reg;
    e.reg = e.reg + 1;
    let agg1: String = llvm_reg_name(rc);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, agg1);
    e.out = string_concat(e.out, " = insertvalue %zarr ");
    e.out = string_concat(e.out, agg0);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, ", 1\n");
    return EmitVal { em: e, vref: agg1 };
  }
  if kind == mir_index_expr() {
    // arr[i] → extract data ptr, GEP element, load.
    let elemll: String = llvm_ty(em.tcx, array_elem_type(type_of_expr(em.tcx, mir, mir.me_a[node])));
    let base: EmitVal = llvm_expr(em, mir, mir.me_a[node]);
    let mut e: Emit = base.em;
    let rd: Int = e.reg;
    e.reg = e.reg + 1;
    let data: String = llvm_reg_name(rd);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, data);
    e.out = string_concat(e.out, " = extractvalue %zarr ");
    e.out = string_concat(e.out, base.vref);
    e.out = string_concat(e.out, ", 1\n");
    let idx: EmitVal = llvm_expr(e, mir, mir.me_b[node]);
    e = idx.em;
    let rp: Int = e.reg;
    e.reg = e.reg + 1;
    let p: String = llvm_reg_name(rp);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, p);
    e.out = string_concat(e.out, " = getelementptr ");
    e.out = string_concat(e.out, elemll);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, data);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, idx.vref);
    e.out = string_concat(e.out, "\n");
    let rv: Int = e.reg;
    e.reg = e.reg + 1;
    let rn: String = llvm_reg_name(rv);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, rn);
    e.out = string_concat(e.out, " = load ");
    e.out = string_concat(e.out, elemll);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, p);
    e.out = string_concat(e.out, "\n");
    return EmitVal { em: e, vref: rn };
  }
  if kind == mir_enum_expr() {
    // {tag, p0, p1}: tag = variant index; payload Int/Bool in p0, String split
    // as (p0=len, p1=data); no payload leaves them 0/null.
    let ename: String = enum_path_enum(mir.me_text[node]);
    let vname: String = enum_path_variant(mir.me_text[node]);
    let tag: Int = variant_tag(em.tcx, ename, vname);
    let pty: String = variant_payload_type(em.tcx, ename, vname);
    let mut e: Emit = em;
    let mut p0: String = "0";
    let mut p1: String = "null";
    if mir.me_a[node] >= 0 {
      let pv: EmitVal = llvm_expr(e, mir, mir.me_a[node]);
      e = pv.em;
      if pty == "String" {
        let l: EmitVal = emit_extract_zstr(e, pv.vref, 0);
        let d: EmitVal = emit_extract_zstr(l.em, pv.vref, 1);
        e = d.em;
        p0 = l.vref;
        p1 = d.vref;
      } else {
        p0 = pv.vref;
      }
    }
    let r0: Int = e.reg;
    e.reg = e.reg + 1;
    let a0: String = llvm_reg_name(r0);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, a0);
    e.out = string_concat(e.out, " = insertvalue %zenum undef, i64 ");
    e.out = string_concat(e.out, int_to_string(tag));
    e.out = string_concat(e.out, ", 0\n");
    let r1: Int = e.reg;
    e.reg = e.reg + 1;
    let a1: String = llvm_reg_name(r1);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, a1);
    e.out = string_concat(e.out, " = insertvalue %zenum ");
    e.out = string_concat(e.out, a0);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, p0);
    e.out = string_concat(e.out, ", 1\n");
    let r2: Int = e.reg;
    e.reg = e.reg + 1;
    let a2: String = llvm_reg_name(r2);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, a2);
    e.out = string_concat(e.out, " = insertvalue %zenum ");
    e.out = string_concat(e.out, a1);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, p1);
    e.out = string_concat(e.out, ", 2\n");
    return EmitVal { em: e, vref: a2 };
  }
  if kind == mir_struct_expr() {
    let sname: String = mir.me_text[node];
    let si: Int = find_struct(em.tcx, sname);
    let llty: String = string_concat("%", sname);
    let fstart: Int = mir.me_a[node];
    let fcount: Int = mir.me_b[node];
    let mut e: Emit = em;
    let mut agg: String = "undef";
    let mut i: Int = 0;
    while i < fcount {
      let fidx: Int = struct_field_index(e.tcx, si, mir.msl_field_name[fstart + i]);
      let fllty: String = llvm_ty(e.tcx, struct_field_type_at(e.tcx, si, fidx));
      let v: EmitVal = llvm_expr(e, mir, mir.msl_field_value[fstart + i]);
      e = v.em;
      let r: Int = e.reg;
      e.reg = e.reg + 1;
      let rn: String = llvm_reg_name(r);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, rn);
      e.out = string_concat(e.out, " = insertvalue ");
      e.out = string_concat(e.out, llty);
      e.out = string_concat(e.out, " ");
      e.out = string_concat(e.out, agg);
      e.out = string_concat(e.out, ", ");
      e.out = string_concat(e.out, fllty);
      e.out = string_concat(e.out, " ");
      e.out = string_concat(e.out, v.vref);
      e.out = string_concat(e.out, ", ");
      e.out = string_concat(e.out, int_to_string(fidx));
      e.out = string_concat(e.out, "\n");
      agg = rn;
      i = i + 1;
    }
    return EmitVal { em: e, vref: agg };
  }
  if kind == mir_field_expr() {
    let bty: String = type_of_expr(em.tcx, mir, mir.me_a[node]);
    if is_array_type(bty) {
      // arr.len → field 0 of %zarr.
      let base: EmitVal = llvm_expr(em, mir, mir.me_a[node]);
      let mut e: Emit = base.em;
      let r: Int = e.reg;
      e.reg = e.reg + 1;
      let rn: String = llvm_reg_name(r);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, rn);
      e.out = string_concat(e.out, " = extractvalue %zarr ");
      e.out = string_concat(e.out, base.vref);
      e.out = string_concat(e.out, ", 0\n");
      return EmitVal { em: e, vref: rn };
    }
    let si: Int = find_struct(em.tcx, bty);
    let fidx: Int = struct_field_index(em.tcx, si, mir.me_text[node]);
    let base: EmitVal = llvm_expr(em, mir, mir.me_a[node]);
    let mut e: Emit = base.em;
    let r: Int = e.reg;
    e.reg = e.reg + 1;
    let rn: String = llvm_reg_name(r);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, rn);
    e.out = string_concat(e.out, " = extractvalue %");
    e.out = string_concat(e.out, bty);
    e.out = string_concat(e.out, " ");
    e.out = string_concat(e.out, base.vref);
    e.out = string_concat(e.out, ", ");
    e.out = string_concat(e.out, int_to_string(fidx));
    e.out = string_concat(e.out, "\n");
    return EmitVal { em: e, vref: rn };
  }
  // Unsupported in this slice (string / enum / array / index): the gate corpus
  // avoids these; emit a sentinel so any accidental use is a 0.
  return EmitVal { em: em, vref: "0" };
}

// `<reg> = icmp <pred> i64 <lhs>, <rhs>`, returning the i1 register.
fn emit_icmp_i64(em: Emit, pred: String, lhs: String, rhs: String) -> EmitBit {
  let mut e: Emit = em;
  let r: Int = e.reg;
  e.reg = e.reg + 1;
  let rn: String = llvm_reg_name(r);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, rn);
  e.out = string_concat(e.out, " = icmp ");
  e.out = string_concat(e.out, pred);
  e.out = string_concat(e.out, " i64 ");
  e.out = string_concat(e.out, lhs);
  e.out = string_concat(e.out, ", ");
  e.out = string_concat(e.out, rhs);
  e.out = string_concat(e.out, "\n");
  return EmitBit { em: e, bit: rn };
}

// `<reg> = <op> i1 <a>, <b>` (op = and / or), returning the i1 register.
fn emit_i1_binop(em: Emit, op: String, a: String, b: String) -> EmitBit {
  let mut e: Emit = em;
  let r: Int = e.reg;
  e.reg = e.reg + 1;
  let rn: String = llvm_reg_name(r);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, rn);
  e.out = string_concat(e.out, " = ");
  e.out = string_concat(e.out, op);
  e.out = string_concat(e.out, " i1 ");
  e.out = string_concat(e.out, a);
  e.out = string_concat(e.out, ", ");
  e.out = string_concat(e.out, b);
  e.out = string_concat(e.out, "\n");
  return EmitBit { em: e, bit: rn };
}

// `<reg> = zext i1 <bit> to i64` — widen a predicate to the Bool i64.
fn emit_zext_i1(em: Emit, bit: String) -> EmitVal {
  let mut e: Emit = em;
  let r: Int = e.reg;
  e.reg = e.reg + 1;
  let rn: String = llvm_reg_name(r);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, rn);
  e.out = string_concat(e.out, " = zext i1 ");
  e.out = string_concat(e.out, bit);
  e.out = string_concat(e.out, " to i64\n");
  return EmitVal { em: e, vref: rn };
}

// `<reg> = extractvalue %zstr <v>, <idx>` → the field register.
fn emit_extract_zstr(em: Emit, v: String, idx: Int) -> EmitVal {
  let mut e: Emit = em;
  let r: Int = e.reg;
  e.reg = e.reg + 1;
  let rn: String = llvm_reg_name(r);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, rn);
  e.out = string_concat(e.out, " = extractvalue %zstr ");
  e.out = string_concat(e.out, v);
  e.out = string_concat(e.out, ", ");
  e.out = string_concat(e.out, int_to_string(idx));
  e.out = string_concat(e.out, "\n");
  return EmitVal { em: e, vref: rn };
}

// Build a {len, ptr} %zstr value from a length register and a buffer register.
fn emit_make_zstr(em: Emit, lenref: String, bufref: String) -> EmitVal {
  let mut e: Emit = em;
  let r0: Int = e.reg;
  e.reg = e.reg + 1;
  let agg0: String = llvm_reg_name(r0);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, agg0);
  e.out = string_concat(e.out, " = insertvalue %zstr undef, i64 ");
  e.out = string_concat(e.out, lenref);
  e.out = string_concat(e.out, ", 0\n");
  let r1: Int = e.reg;
  e.reg = e.reg + 1;
  let agg1: String = llvm_reg_name(r1);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, agg1);
  e.out = string_concat(e.out, " = insertvalue %zstr ");
  e.out = string_concat(e.out, agg0);
  e.out = string_concat(e.out, ", ptr ");
  e.out = string_concat(e.out, bufref);
  e.out = string_concat(e.out, ", 1\n");
  return EmitVal { em: e, vref: agg1 };
}

// ASCII predicate: c in [lo, hi] → i1, ANDed onto an optional running i1 via or.
fn emit_range_bit(em: Emit, c: String, lo: String, hi: String) -> EmitBit {
  let a: EmitBit = emit_icmp_i64(em, "sge", c, lo);
  let b: EmitBit = emit_icmp_i64(a.em, "sle", c, hi);
  return emit_i1_binop(b.em, "and", a.bit, b.bit);
}

// Lower a string builtin to inline IR (string_len / byte_at / concat /
// byte_slice / int_to_string / ascii_is_*).
fn llvm_string_builtin(em: Emit, mir: Mir, node: Int) -> EmitVal {
  let callee: String = mir.me_text[node];
  let astart: Int = mir.me_a[node];
  if callee == "string_len" {
    let s: EmitVal = llvm_expr(em, mir, mir.mchild_list[astart]);
    return emit_extract_zstr(s.em, s.vref, 0);
  }
  if callee == "string_byte_at" {
    let s: EmitVal = llvm_expr(em, mir, mir.mchild_list[astart]);
    let iv: EmitVal = llvm_expr(s.em, mir, mir.mchild_list[astart + 1]);
    let data: EmitVal = emit_extract_zstr(iv.em, s.vref, 1);
    let mut e: Emit = data.em;
    let rp: Int = e.reg;
    e.reg = e.reg + 1;
    let p: String = llvm_reg_name(rp);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, p);
    e.out = string_concat(e.out, " = getelementptr i8, ptr ");
    e.out = string_concat(e.out, data.vref);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, iv.vref);
    e.out = string_concat(e.out, "\n");
    let rb: Int = e.reg;
    e.reg = e.reg + 1;
    let bv: String = llvm_reg_name(rb);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, bv);
    e.out = string_concat(e.out, " = load i8, ptr ");
    e.out = string_concat(e.out, p);
    e.out = string_concat(e.out, "\n");
    let rz: Int = e.reg;
    e.reg = e.reg + 1;
    let zn: String = llvm_reg_name(rz);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, zn);
    e.out = string_concat(e.out, " = zext i8 ");
    e.out = string_concat(e.out, bv);
    e.out = string_concat(e.out, " to i64\n");
    return EmitVal { em: e, vref: zn };
  }
  if callee == "string_concat" {
    let a: EmitVal = llvm_expr(em, mir, mir.mchild_list[astart]);
    let b: EmitVal = llvm_expr(a.em, mir, mir.mchild_list[astart + 1]);
    let la: EmitVal = emit_extract_zstr(b.em, a.vref, 0);
    let pa: EmitVal = emit_extract_zstr(la.em, a.vref, 1);
    let lb: EmitVal = emit_extract_zstr(pa.em, b.vref, 0);
    let pb: EmitVal = emit_extract_zstr(lb.em, b.vref, 1);
    let mut e: Emit = pb.em;
    let rt: Int = e.reg;
    e.reg = e.reg + 1;
    let tot: String = llvm_reg_name(rt);
    let rbuf: Int = e.reg;
    e.reg = e.reg + 1;
    let buf: String = llvm_reg_name(rbuf);
    let rtail: Int = e.reg;
    e.reg = e.reg + 1;
    let tail: String = llvm_reg_name(rtail);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, tot);
    e.out = string_concat(e.out, " = add i64 ");
    e.out = string_concat(e.out, la.vref);
    e.out = string_concat(e.out, ", ");
    e.out = string_concat(e.out, lb.vref);
    e.out = string_concat(e.out, "\n  ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, " = call ptr @malloc(i64 ");
    e.out = string_concat(e.out, tot);
    e.out = string_concat(e.out, ")\n  call ptr @memcpy(ptr ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, pa.vref);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, la.vref);
    e.out = string_concat(e.out, ")\n  ");
    e.out = string_concat(e.out, tail);
    e.out = string_concat(e.out, " = getelementptr i8, ptr ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, la.vref);
    e.out = string_concat(e.out, "\n  call ptr @memcpy(ptr ");
    e.out = string_concat(e.out, tail);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, pb.vref);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, lb.vref);
    e.out = string_concat(e.out, ")\n");
    return emit_make_zstr(e, tot, buf);
  }
  if callee == "string_byte_slice" {
    let s: EmitVal = llvm_expr(em, mir, mir.mchild_list[astart]);
    let start: EmitVal = llvm_expr(s.em, mir, mir.mchild_list[astart + 1]);
    let len: EmitVal = llvm_expr(start.em, mir, mir.mchild_list[astart + 2]);
    let pd: EmitVal = emit_extract_zstr(len.em, s.vref, 1);
    let mut e: Emit = pd.em;
    let rbuf: Int = e.reg;
    e.reg = e.reg + 1;
    let buf: String = llvm_reg_name(rbuf);
    let rsrc: Int = e.reg;
    e.reg = e.reg + 1;
    let src: String = llvm_reg_name(rsrc);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, " = call ptr @malloc(i64 ");
    e.out = string_concat(e.out, len.vref);
    e.out = string_concat(e.out, ")\n  ");
    e.out = string_concat(e.out, src);
    e.out = string_concat(e.out, " = getelementptr i8, ptr ");
    e.out = string_concat(e.out, pd.vref);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, start.vref);
    e.out = string_concat(e.out, "\n  call ptr @memcpy(ptr ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, src);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, len.vref);
    e.out = string_concat(e.out, ")\n");
    return emit_make_zstr(e, len.vref, buf);
  }
  if callee == "int_to_string" {
    let nv: EmitVal = llvm_expr(em, mir, mir.mchild_list[astart]);
    let mut e: Emit = nv.em;
    let rbuf: Int = e.reg;
    e.reg = e.reg + 1;
    let buf: String = llvm_reg_name(rbuf);
    let rn: Int = e.reg;
    e.reg = e.reg + 1;
    let cnt: String = llvm_reg_name(rn);
    let rl: Int = e.reg;
    e.reg = e.reg + 1;
    let len: String = llvm_reg_name(rl);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, " = call ptr @malloc(i64 24)\n  ");
    e.out = string_concat(e.out, cnt);
    e.out = string_concat(e.out, " = call i32 (ptr, i64, ptr, ...) @snprintf(ptr ");
    e.out = string_concat(e.out, buf);
    e.out = string_concat(e.out, ", i64 24, ptr @.fmt.lld, i64 ");
    e.out = string_concat(e.out, nv.vref);
    e.out = string_concat(e.out, ")\n  ");
    e.out = string_concat(e.out, len);
    e.out = string_concat(e.out, " = sext i32 ");
    e.out = string_concat(e.out, cnt);
    e.out = string_concat(e.out, " to i64\n");
    return emit_make_zstr(e, len, buf);
  }
  // ascii_is_* predicates take an Int and return a Bool.
  let c: EmitVal = llvm_expr(em, mir, mir.mchild_list[astart]);
  if callee == "ascii_is_digit" {
    let d: EmitBit = emit_range_bit(c.em, c.vref, "48", "57");
    return emit_zext_i1(d.em, d.bit);
  }
  if callee == "ascii_is_alpha" {
    let up: EmitBit = emit_range_bit(c.em, c.vref, "65", "90");
    let lo: EmitBit = emit_range_bit(up.em, c.vref, "97", "122");
    let both: EmitBit = emit_i1_binop(lo.em, "or", up.bit, lo.bit);
    return emit_zext_i1(both.em, both.bit);
  }
  if callee == "ascii_is_alnum" {
    let dig: EmitBit = emit_range_bit(c.em, c.vref, "48", "57");
    let up: EmitBit = emit_range_bit(dig.em, c.vref, "65", "90");
    let lo: EmitBit = emit_range_bit(up.em, c.vref, "97", "122");
    let alpha: EmitBit = emit_i1_binop(lo.em, "or", up.bit, lo.bit);
    let any: EmitBit = emit_i1_binop(alpha.em, "or", dig.bit, alpha.bit);
    return emit_zext_i1(any.em, any.bit);
  }
  // ascii_is_whitespace: c == 32 / 9 / 10 / 12 / 13.
  let w1: EmitBit = emit_icmp_i64(c.em, "eq", c.vref, "32");
  let w2: EmitBit = emit_icmp_i64(w1.em, "eq", c.vref, "9");
  let w3: EmitBit = emit_icmp_i64(w2.em, "eq", c.vref, "10");
  let w4: EmitBit = emit_icmp_i64(w3.em, "eq", c.vref, "12");
  let w5: EmitBit = emit_icmp_i64(w4.em, "eq", c.vref, "13");
  let o1: EmitBit = emit_i1_binop(w5.em, "or", w1.bit, w2.bit);
  let o2: EmitBit = emit_i1_binop(o1.em, "or", o1.bit, w3.bit);
  let o3: EmitBit = emit_i1_binop(o2.em, "or", o2.bit, w4.bit);
  let o4: EmitBit = emit_i1_binop(o3.em, "or", o3.bit, w5.bit);
  return emit_zext_i1(o4.em, o4.bit);
}

// Lower an array builtin (int_array_empty / int_array_push) to inline IR.
fn llvm_array_builtin(em: Emit, mir: Mir, node: Int) -> EmitVal {
  let callee: String = mir.me_text[node];
  let astart: Int = mir.me_a[node];
  let elem: String = array_builtin_elem(callee);
  let elemll: String = llvm_ty(em.tcx, elem);
  let stride: Int = elem_stride(elem);
  if !array_builtin_is_push(callee) {
    let mut e: Emit = em;
    let ra: Int = e.reg;
    e.reg = e.reg + 1;
    let agg0: String = llvm_reg_name(ra);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, agg0);
    e.out = string_concat(e.out, " = insertvalue %zarr undef, i64 0, 0\n");
    let rb: Int = e.reg;
    e.reg = e.reg + 1;
    let agg1: String = llvm_reg_name(rb);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, agg1);
    e.out = string_concat(e.out, " = insertvalue %zarr ");
    e.out = string_concat(e.out, agg0);
    e.out = string_concat(e.out, ", ptr null, 1\n");
    return EmitVal { em: e, vref: agg1 };
  }
  // *_array_push(arr, x): malloc((len+1)*stride), copy old, append x. The source
  // array is read (not mutated), so no defensive copy of `arr` is needed.
  let arr: EmitVal = llvm_expr(em, mir, mir.mchild_list[astart]);
  let xv: EmitVal = llvm_expr(arr.em, mir, mir.mchild_list[astart + 1]);
  let mut e: Emit = xv.em;
  let rl: Int = e.reg;
  e.reg = e.reg + 1;
  let len: String = llvm_reg_name(rl);
  let rs: Int = e.reg;
  e.reg = e.reg + 1;
  let src: String = llvm_reg_name(rs);
  let rnl: Int = e.reg;
  e.reg = e.reg + 1;
  let nlen: String = llvm_reg_name(rnl);
  let rob: Int = e.reg;
  e.reg = e.reg + 1;
  let obytes: String = llvm_reg_name(rob);
  let rnb: Int = e.reg;
  e.reg = e.reg + 1;
  let nbytes: String = llvm_reg_name(rnb);
  let rbuf: Int = e.reg;
  e.reg = e.reg + 1;
  let buf: String = llvm_reg_name(rbuf);
  let rep: Int = e.reg;
  e.reg = e.reg + 1;
  let endp: String = llvm_reg_name(rep);
  let r0: Int = e.reg;
  e.reg = e.reg + 1;
  let agg0: String = llvm_reg_name(r0);
  let r1: Int = e.reg;
  e.reg = e.reg + 1;
  let agg1: String = llvm_reg_name(r1);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, len);
  e.out = string_concat(e.out, " = extractvalue %zarr ");
  e.out = string_concat(e.out, arr.vref);
  e.out = string_concat(e.out, ", 0\n  ");
  e.out = string_concat(e.out, src);
  e.out = string_concat(e.out, " = extractvalue %zarr ");
  e.out = string_concat(e.out, arr.vref);
  e.out = string_concat(e.out, ", 1\n  ");
  e.out = string_concat(e.out, nlen);
  e.out = string_concat(e.out, " = add i64 ");
  e.out = string_concat(e.out, len);
  e.out = string_concat(e.out, ", 1\n  ");
  e.out = string_concat(e.out, obytes);
  e.out = string_concat(e.out, " = mul i64 ");
  e.out = string_concat(e.out, len);
  e.out = string_concat(e.out, ", ");
  e.out = string_concat(e.out, int_to_string(stride));
  e.out = string_concat(e.out, "\n  ");
  e.out = string_concat(e.out, nbytes);
  e.out = string_concat(e.out, " = mul i64 ");
  e.out = string_concat(e.out, nlen);
  e.out = string_concat(e.out, ", ");
  e.out = string_concat(e.out, int_to_string(stride));
  e.out = string_concat(e.out, "\n  ");
  e.out = string_concat(e.out, buf);
  e.out = string_concat(e.out, " = call ptr @malloc(i64 ");
  e.out = string_concat(e.out, nbytes);
  e.out = string_concat(e.out, ")\n  call ptr @memcpy(ptr ");
  e.out = string_concat(e.out, buf);
  e.out = string_concat(e.out, ", ptr ");
  e.out = string_concat(e.out, src);
  e.out = string_concat(e.out, ", i64 ");
  e.out = string_concat(e.out, obytes);
  e.out = string_concat(e.out, ")\n  ");
  e.out = string_concat(e.out, endp);
  e.out = string_concat(e.out, " = getelementptr ");
  e.out = string_concat(e.out, elemll);
  e.out = string_concat(e.out, ", ptr ");
  e.out = string_concat(e.out, buf);
  e.out = string_concat(e.out, ", i64 ");
  e.out = string_concat(e.out, len);
  e.out = string_concat(e.out, "\n  store ");
  e.out = string_concat(e.out, elemll);
  e.out = string_concat(e.out, " ");
  e.out = string_concat(e.out, xv.vref);
  e.out = string_concat(e.out, ", ptr ");
  e.out = string_concat(e.out, endp);
  e.out = string_concat(e.out, "\n  ");
  e.out = string_concat(e.out, agg0);
  e.out = string_concat(e.out, " = insertvalue %zarr undef, i64 ");
  e.out = string_concat(e.out, nlen);
  e.out = string_concat(e.out, ", 0\n  ");
  e.out = string_concat(e.out, agg1);
  e.out = string_concat(e.out, " = insertvalue %zarr ");
  e.out = string_concat(e.out, agg0);
  e.out = string_concat(e.out, ", ptr ");
  e.out = string_concat(e.out, buf);
  e.out = string_concat(e.out, ", 1\n");
  return EmitVal { em: e, vref: agg1 };
}

// Deep-copy an array value: malloc(len*stride) + memcpy, returning a fresh
// {len, buf}. (String elements copy their {len,ptr} only — the byte buffers are
// immutable and safely shared.)
fn emit_array_copy(em: Emit, vref: String, stride: Int) -> EmitVal {
  let mut e: Emit = em;
  let rl: Int = e.reg;
  e.reg = e.reg + 1;
  let len: String = llvm_reg_name(rl);
  let rs: Int = e.reg;
  e.reg = e.reg + 1;
  let src: String = llvm_reg_name(rs);
  let rb: Int = e.reg;
  e.reg = e.reg + 1;
  let bytes: String = llvm_reg_name(rb);
  let rbuf: Int = e.reg;
  e.reg = e.reg + 1;
  let buf: String = llvm_reg_name(rbuf);
  let r0: Int = e.reg;
  e.reg = e.reg + 1;
  let agg0: String = llvm_reg_name(r0);
  let r1: Int = e.reg;
  e.reg = e.reg + 1;
  let agg1: String = llvm_reg_name(r1);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, len);
  e.out = string_concat(e.out, " = extractvalue %zarr ");
  e.out = string_concat(e.out, vref);
  e.out = string_concat(e.out, ", 0\n  ");
  e.out = string_concat(e.out, src);
  e.out = string_concat(e.out, " = extractvalue %zarr ");
  e.out = string_concat(e.out, vref);
  e.out = string_concat(e.out, ", 1\n  ");
  e.out = string_concat(e.out, bytes);
  e.out = string_concat(e.out, " = mul i64 ");
  e.out = string_concat(e.out, len);
  e.out = string_concat(e.out, ", ");
  e.out = string_concat(e.out, int_to_string(stride));
  e.out = string_concat(e.out, "\n  ");
  e.out = string_concat(e.out, buf);
  e.out = string_concat(e.out, " = call ptr @malloc(i64 ");
  e.out = string_concat(e.out, bytes);
  e.out = string_concat(e.out, ")\n  call ptr @memcpy(ptr ");
  e.out = string_concat(e.out, buf);
  e.out = string_concat(e.out, ", ptr ");
  e.out = string_concat(e.out, src);
  e.out = string_concat(e.out, ", i64 ");
  e.out = string_concat(e.out, bytes);
  e.out = string_concat(e.out, ")\n  ");
  e.out = string_concat(e.out, agg0);
  e.out = string_concat(e.out, " = insertvalue %zarr undef, i64 ");
  e.out = string_concat(e.out, len);
  e.out = string_concat(e.out, ", 0\n  ");
  e.out = string_concat(e.out, agg1);
  e.out = string_concat(e.out, " = insertvalue %zarr ");
  e.out = string_concat(e.out, agg0);
  e.out = string_concat(e.out, ", ptr ");
  e.out = string_concat(e.out, buf);
  e.out = string_concat(e.out, ", 1\n");
  return EmitVal { em: e, vref: agg1 };
}

// A fresh array (literal or array builtin result) already owns a private
// buffer, so a binding point need not copy it again.
fn is_fresh_array_expr(mir: Mir, node: Int) -> Bool {
  let k: Int = mir.me_kind[node];
  if k == mir_array_expr() {
    return true;
  }
  if k == mir_call_expr() {
    return is_array_builtin(mir.me_text[node]);
  }
  return false;
}

// Evaluate `node` for a binding point (let / assign / call arg): deep-copy an
// array value unless it is already fresh, so each owner is independent (value
// semantics). Scalars and structs pass through (structs copy via load/store).
fn emit_bind(em: Emit, mir: Mir, node: Int) -> EmitVal {
  let ty: String = type_of_expr(em.tcx, mir, node);
  let v: EmitVal = llvm_expr(em, mir, node);
  if is_array_type(ty) {
    if is_fresh_array_expr(mir, node) {
      return v;
    }
    return emit_array_copy(v.em, v.vref, elem_stride(array_elem_type(ty)));
  }
  return v;
}

fn llvm_open_block(em: Emit, id: Int) -> Emit {
  let mut e: Emit = em;
  e.out = string_concat(e.out, llvm_label_name(id));
  e.out = string_concat(e.out, ":\n");
  e.term = 0;
  return e;
}

fn llvm_branch(em: Emit, id: Int) -> Emit {
  let mut e: Emit = em;
  e.out = string_concat(e.out, "  br label %");
  e.out = string_concat(e.out, llvm_label_name(id));
  e.out = string_concat(e.out, "\n");
  e.term = 1;
  return e;
}

// Emit `<reg> = icmp ne i64 <vref>, 0` and return the i1 register name, ready
// for a conditional branch.
struct EmitBit {
  em: Emit,
  bit: String,
}

fn llvm_cond_bit(em: Emit, vref: String) -> EmitBit {
  let mut e: Emit = em;
  let r: Int = e.reg;
  e.reg = e.reg + 1;
  let rn: String = llvm_reg_name(r);
  e.out = string_concat(e.out, "  ");
  e.out = string_concat(e.out, rn);
  e.out = string_concat(e.out, " = icmp ne i64 ");
  e.out = string_concat(e.out, vref);
  e.out = string_concat(e.out, ", 0\n");
  return EmitBit { em: e, bit: rn };
}

// Resolve an assignment place to (pointer register, Zeta type). A local is its
// alloca slot; a field GEPs into its base (chains for nested fields).
fn resolve_place(em: Emit, mir: Mir, place: Int) -> PlaceRef {
  let k: Int = mir.mpl_kind[place];
  if k == mir_place_local() {
    let nm: String = mir.mpl_name[place];
    return PlaceRef { em: em, ptr: llvm_slot_ref(nm), ty: scope_type(em.tcx, nm) };
  }
  if k == mir_place_field() {
    let base: PlaceRef = resolve_place(em, mir, mir.mpl_base[place]);
    let mut e: Emit = base.em;
    let si: Int = find_struct(e.tcx, base.ty);
    let fidx: Int = struct_field_index(e.tcx, si, mir.mpl_name[place]);
    let fty: String = struct_field_type_at(e.tcx, si, fidx);
    let r: Int = e.reg;
    e.reg = e.reg + 1;
    let rn: String = llvm_reg_name(r);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, rn);
    e.out = string_concat(e.out, " = getelementptr %");
    e.out = string_concat(e.out, base.ty);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, base.ptr);
    e.out = string_concat(e.out, ", i32 0, i32 ");
    e.out = string_concat(e.out, int_to_string(fidx));
    e.out = string_concat(e.out, "\n");
    return PlaceRef { em: e, ptr: rn, ty: fty };
  }
  if k == mir_place_index() {
    // arr[i] = v: load the array value, extract its data ptr, GEP the element.
    let base: PlaceRef = resolve_place(em, mir, mir.mpl_base[place]);
    let elem: String = array_elem_type(base.ty);
    let elemll: String = llvm_ty(base.em.tcx, elem);
    let mut e: Emit = base.em;
    let ra: Int = e.reg;
    e.reg = e.reg + 1;
    let arrval: String = llvm_reg_name(ra);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, arrval);
    e.out = string_concat(e.out, " = load %zarr, ptr ");
    e.out = string_concat(e.out, base.ptr);
    e.out = string_concat(e.out, "\n");
    let rd: Int = e.reg;
    e.reg = e.reg + 1;
    let data: String = llvm_reg_name(rd);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, data);
    e.out = string_concat(e.out, " = extractvalue %zarr ");
    e.out = string_concat(e.out, arrval);
    e.out = string_concat(e.out, ", 1\n");
    let idx: EmitVal = llvm_expr(e, mir, mir.mpl_index[place]);
    e = idx.em;
    let rp: Int = e.reg;
    e.reg = e.reg + 1;
    let p: String = llvm_reg_name(rp);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, p);
    e.out = string_concat(e.out, " = getelementptr ");
    e.out = string_concat(e.out, elemll);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, data);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, idx.vref);
    e.out = string_concat(e.out, "\n");
    return PlaceRef { em: e, ptr: p, ty: elem };
  }
  // unreachable in this slice.
  return PlaceRef { em: em, ptr: llvm_slot_ref(mir.mpl_name[place]), ty: "Int" };
}

// The i64 switch-case constant for a concrete match pattern (variant tag /
// int literal / bool 0-1).
fn pattern_case_const(tcx: Tcx, pat: String) -> Int {
  if string_starts_with(pat, "variant:") {
    return variant_tag(tcx, pattern_variant_enum(pat), pattern_variant_name(pat));
  }
  if string_starts_with(pat, "int:") {
    return decimal_to_int(string_byte_slice(pat, 4, string_len(pat) - 4));
  }
  if string_byte_slice(pat, 5, string_len(pat) - 5) == "true" {
    return 1;
  }
  return 0;
}

// Bind a match arm's pattern variable (if any) at the top of its block: a name
// pattern binds the whole scrutinee; a variant pattern binds its payload
// (Int/Bool from p0, String reconstructed from (p0, p1)).
fn emit_match_binding(em: Emit, mir: Mir, scrut: String, scrut_ty: String, pat: String) -> Emit {
  if string_starts_with(pat, "name:") {
    let mut e: Emit = em;
    e.out = string_concat(e.out, "  store ");
    e.out = string_concat(e.out, llvm_ty(e.tcx, scrut_ty));
    e.out = string_concat(e.out, " ");
    e.out = string_concat(e.out, scrut);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, llvm_slot_ref(pattern_binding(pat)));
    e.out = string_concat(e.out, "\n");
    return e;
  }
  if string_starts_with(pat, "variant:") {
    let bnd: String = pattern_binding(pat);
    if string_len(bnd) > 0 {
      let pty: String = variant_payload_type(em.tcx, pattern_variant_enum(pat), pattern_variant_name(pat));
      let mut e: Emit = em;
      let rp0: Int = e.reg;
      e.reg = e.reg + 1;
      let p0: String = llvm_reg_name(rp0);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, p0);
      e.out = string_concat(e.out, " = extractvalue %zenum ");
      e.out = string_concat(e.out, scrut);
      e.out = string_concat(e.out, ", 1\n");
      if pty == "String" {
        let rp1: Int = e.reg;
        e.reg = e.reg + 1;
        let p1: String = llvm_reg_name(rp1);
        e.out = string_concat(e.out, "  ");
        e.out = string_concat(e.out, p1);
        e.out = string_concat(e.out, " = extractvalue %zenum ");
        e.out = string_concat(e.out, scrut);
        e.out = string_concat(e.out, ", 2\n");
        let s: EmitVal = emit_make_zstr(e, p0, p1);
        e = s.em;
        e.out = string_concat(e.out, "  store %zstr ");
        e.out = string_concat(e.out, s.vref);
        e.out = string_concat(e.out, ", ptr ");
        e.out = string_concat(e.out, llvm_slot_ref(bnd));
        e.out = string_concat(e.out, "\n");
      } else {
        e.out = string_concat(e.out, "  store i64 ");
        e.out = string_concat(e.out, p0);
        e.out = string_concat(e.out, ", ptr ");
        e.out = string_concat(e.out, llvm_slot_ref(bnd));
        e.out = string_concat(e.out, "\n");
      }
      return e;
    }
  }
  return em;
}

fn llvm_stmt(em: Emit, mir: Mir, sidx: Int, brk: Int, cont: Int) -> Emit {
  let kind: Int = mir.ms_kind[sidx];
  if kind == mir_local_stmt() {
    let llty: String = llvm_ty(em.tcx, scope_type(em.tcx, mir.ms_name[sidx]));
    let v: EmitVal = emit_bind(em, mir, mir.ms_expr[sidx]);
    let mut e: Emit = v.em;
    e.out = string_concat(e.out, "  store ");
    e.out = string_concat(e.out, llty);
    e.out = string_concat(e.out, " ");
    e.out = string_concat(e.out, v.vref);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, llvm_slot_ref(mir.ms_name[sidx]));
    e.out = string_concat(e.out, "\n");
    return e;
  }
  if kind == mir_store_stmt() {
    let v: EmitVal = emit_bind(em, mir, mir.ms_expr[sidx]);
    let pr: PlaceRef = resolve_place(v.em, mir, mir.ms_place[sidx]);
    let mut e: Emit = pr.em;
    e.out = string_concat(e.out, "  store ");
    e.out = string_concat(e.out, llvm_ty(e.tcx, pr.ty));
    e.out = string_concat(e.out, " ");
    e.out = string_concat(e.out, v.vref);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, pr.ptr);
    e.out = string_concat(e.out, "\n");
    return e;
  }
  if kind == mir_return_stmt() {
    let mut e: Emit = em;
    if mir.ms_expr[sidx] >= 0 {
      let rty: String = llvm_ty(em.tcx, type_of_expr(em.tcx, mir, mir.ms_expr[sidx]));
      let v: EmitVal = llvm_expr(em, mir, mir.ms_expr[sidx]);
      e = v.em;
      e.out = string_concat(e.out, "  ret ");
      e.out = string_concat(e.out, rty);
      e.out = string_concat(e.out, " ");
      e.out = string_concat(e.out, v.vref);
      e.out = string_concat(e.out, "\n");
    } else {
      e.out = string_concat(e.out, "  ret void\n");
    }
    e.term = 1;
    return e;
  }
  if kind == mir_drop_stmt() {
    let v: EmitVal = llvm_expr(em, mir, mir.ms_expr[sidx]);
    return v.em;
  }
  if kind == mir_break_stmt() {
    return llvm_branch(em, brk);
  }
  if kind == mir_continue_stmt() {
    return llvm_branch(em, cont);
  }
  if kind == mir_if_stmt() {
    let cond: EmitVal = llvm_expr(em, mir, mir.ms_expr[sidx]);
    let cb: EmitBit = llvm_cond_bit(cond.em, cond.vref);
    let mut e: Emit = cb.em;
    let then_id: Int = e.block;
    e.block = e.block + 1;
    let else_id: Int = e.block;
    e.block = e.block + 1;
    let end_id: Int = e.block;
    e.block = e.block + 1;
    e.out = string_concat(e.out, "  br i1 ");
    e.out = string_concat(e.out, cb.bit);
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(then_id));
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(else_id));
    e.out = string_concat(e.out, "\n");
    e.term = 1;
    e = llvm_open_block(e, then_id);
    e = llvm_block(e, mir, mir.ms_then_start[sidx], mir.ms_then_count[sidx], brk, cont);
    let mut then_falls: Int = 0;
    if e.term == 0 {
      then_falls = 1;
      e = llvm_branch(e, end_id);
    }
    e = llvm_open_block(e, else_id);
    e = llvm_block(e, mir, mir.ms_else_start[sidx], mir.ms_else_count[sidx], brk, cont);
    let mut else_falls: Int = 0;
    if e.term == 0 {
      else_falls = 1;
      e = llvm_branch(e, end_id);
    }
    if then_falls == 1 || else_falls == 1 {
      e = llvm_open_block(e, end_id);
    } else {
      e.term = 1;
    }
    return e;
  }
  if kind == mir_while_stmt() {
    let mut e: Emit = em;
    let head_id: Int = e.block;
    e.block = e.block + 1;
    let body_id: Int = e.block;
    e.block = e.block + 1;
    let end_id: Int = e.block;
    e.block = e.block + 1;
    e = llvm_branch(e, head_id);
    e = llvm_open_block(e, head_id);
    let cond: EmitVal = llvm_expr(e, mir, mir.ms_expr[sidx]);
    let cb: EmitBit = llvm_cond_bit(cond.em, cond.vref);
    e = cb.em;
    e.out = string_concat(e.out, "  br i1 ");
    e.out = string_concat(e.out, cb.bit);
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(body_id));
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(end_id));
    e.out = string_concat(e.out, "\n");
    e.term = 1;
    e = llvm_open_block(e, body_id);
    e = llvm_block(e, mir, mir.ms_then_start[sidx], mir.ms_then_count[sidx], end_id, head_id);
    if e.term == 0 {
      e = llvm_branch(e, head_id);
    }
    e = llvm_open_block(e, end_id);
    return e;
  }
  if kind == mir_match_stmt() {
    // Switch on the scrutinee: an enum's tag, or an Int / Bool value itself.
    let sval: EmitVal = llvm_expr(em, mir, mir.ms_expr[sidx]);
    let scrut_ty: String = type_of_expr(em.tcx, mir, mir.ms_expr[sidx]);
    let mut e: Emit = sval.em;
    let mut switchval: String = sval.vref;
    if find_enum(e.tcx, scrut_ty) < e.tcx.men_name.len {
      let rt: Int = e.reg;
      e.reg = e.reg + 1;
      let tagr: String = llvm_reg_name(rt);
      e.out = string_concat(e.out, "  ");
      e.out = string_concat(e.out, tagr);
      e.out = string_concat(e.out, " = extractvalue %zenum ");
      e.out = string_concat(e.out, sval.vref);
      e.out = string_concat(e.out, ", 0\n");
      switchval = tagr;
    }
    let astart: Int = mir.ms_then_start[sidx];
    let acount: Int = mir.ms_then_count[sidx];
    // One block per arm, then the join block.
    let mut arm_ids: IntArray = int_array_empty();
    let mut ai: Int = 0;
    while ai < acount {
      arm_ids = int_array_push(arm_ids, e.block);
      e.block = e.block + 1;
      ai = ai + 1;
    }
    let end_id: Int = e.block;
    e.block = e.block + 1;
    // Cases for concrete patterns; first name / wildcard arm is the default.
    let mut cases: String = "";
    let mut has_default: Int = 0;
    let mut default_block: Int = 0;
    ai = 0;
    while ai < acount {
      let pat: String = mir.marm_pattern[astart + ai];
      if pat == "_" || string_starts_with(pat, "name:") {
        if has_default == 0 {
          has_default = 1;
          default_block = arm_ids[ai];
        }
      } else {
        cases = string_concat(cases, "    i64 ");
        cases = string_concat(cases, int_to_string(pattern_case_const(e.tcx, pat)));
        cases = string_concat(cases, ", label %");
        cases = string_concat(cases, llvm_label_name(arm_ids[ai]));
        cases = string_concat(cases, "\n");
      }
      ai = ai + 1;
    }
    let mut default_id: Int = 0;
    if has_default == 1 {
      default_id = default_block;
    } else {
      default_id = e.block;
      e.block = e.block + 1;
    }
    e.out = string_concat(e.out, "  switch i64 ");
    e.out = string_concat(e.out, switchval);
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(default_id));
    e.out = string_concat(e.out, " [\n");
    e.out = string_concat(e.out, cases);
    e.out = string_concat(e.out, "  ]\n");
    e.term = 1;
    // Exhaustive match without a catch-all → an unreachable default.
    if has_default == 0 {
      e = llvm_open_block(e, default_id);
      e.out = string_concat(e.out, "  unreachable\n");
      e.term = 1;
    }
    let mut any_fall: Int = 0;
    ai = 0;
    while ai < acount {
      e = llvm_open_block(e, arm_ids[ai]);
      e = emit_match_binding(e, mir, sval.vref, scrut_ty, mir.marm_pattern[astart + ai]);
      e = llvm_block(e, mir, mir.marm_body_start[astart + ai], mir.marm_body_count[astart + ai], brk, cont);
      if e.term == 0 {
        any_fall = 1;
        e = llvm_branch(e, end_id);
      }
      ai = ai + 1;
    }
    if any_fall == 1 {
      e = llvm_open_block(e, end_id);
    } else {
      e.term = 1;
    }
    return e;
  }
  if kind == mir_for_range_stmt() {
    // for i in start..end: store start into i's slot, eval end once, loop with
    // i < end; continue increments (the latch), break exits.
    let nm: String = mir.ms_name[sidx];
    let startv: EmitVal = llvm_expr(em, mir, mir.ms_expr[sidx]);
    let mut e: Emit = startv.em;
    e.out = string_concat(e.out, "  store i64 ");
    e.out = string_concat(e.out, startv.vref);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, llvm_slot_ref(nm));
    e.out = string_concat(e.out, "\n");
    let endv: EmitVal = llvm_expr(e, mir, mir.ms_expr2[sidx]);
    e = endv.em;
    let head_id: Int = e.block;
    e.block = e.block + 1;
    let body_id: Int = e.block;
    e.block = e.block + 1;
    let latch_id: Int = e.block;
    e.block = e.block + 1;
    let end_id: Int = e.block;
    e.block = e.block + 1;
    e = llvm_branch(e, head_id);
    e = llvm_open_block(e, head_id);
    let riv: Int = e.reg;
    e.reg = e.reg + 1;
    let iv: String = llvm_reg_name(riv);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, iv);
    e.out = string_concat(e.out, " = load i64, ptr ");
    e.out = string_concat(e.out, llvm_slot_ref(nm));
    e.out = string_concat(e.out, "\n");
    let rc: Int = e.reg;
    e.reg = e.reg + 1;
    let cc: String = llvm_reg_name(rc);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, cc);
    e.out = string_concat(e.out, " = icmp slt i64 ");
    e.out = string_concat(e.out, iv);
    e.out = string_concat(e.out, ", ");
    e.out = string_concat(e.out, endv.vref);
    e.out = string_concat(e.out, "\n  br i1 ");
    e.out = string_concat(e.out, cc);
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(body_id));
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(end_id));
    e.out = string_concat(e.out, "\n");
    e.term = 1;
    e = llvm_open_block(e, body_id);
    e = llvm_block(e, mir, mir.ms_then_start[sidx], mir.ms_then_count[sidx], end_id, latch_id);
    if e.term == 0 {
      e = llvm_branch(e, latch_id);
    }
    e = llvm_open_block(e, latch_id);
    let riv2: Int = e.reg;
    e.reg = e.reg + 1;
    let iv2: String = llvm_reg_name(riv2);
    let rn: Int = e.reg;
    e.reg = e.reg + 1;
    let nn: String = llvm_reg_name(rn);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, iv2);
    e.out = string_concat(e.out, " = load i64, ptr ");
    e.out = string_concat(e.out, llvm_slot_ref(nm));
    e.out = string_concat(e.out, "\n  ");
    e.out = string_concat(e.out, nn);
    e.out = string_concat(e.out, " = add i64 ");
    e.out = string_concat(e.out, iv2);
    e.out = string_concat(e.out, ", 1\n  store i64 ");
    e.out = string_concat(e.out, nn);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, llvm_slot_ref(nm));
    e.out = string_concat(e.out, "\n");
    e = llvm_branch(e, head_id);
    e = llvm_open_block(e, end_id);
    return e;
  }
  if kind == mir_for_in_stmt() {
    // for x in arr: index from 0 to len, binding x = data[i].
    let nm: String = mir.ms_name[sidx];
    let elemll: String = llvm_ty(em.tcx, array_elem_type(type_of_expr(em.tcx, mir, mir.ms_expr[sidx])));
    let arrv: EmitVal = llvm_expr(em, mir, mir.ms_expr[sidx]);
    let mut e: Emit = arrv.em;
    let rl: Int = e.reg;
    e.reg = e.reg + 1;
    let lenr: String = llvm_reg_name(rl);
    let rd: Int = e.reg;
    e.reg = e.reg + 1;
    let data: String = llvm_reg_name(rd);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, lenr);
    e.out = string_concat(e.out, " = extractvalue %zarr ");
    e.out = string_concat(e.out, arrv.vref);
    e.out = string_concat(e.out, ", 0\n  ");
    e.out = string_concat(e.out, data);
    e.out = string_concat(e.out, " = extractvalue %zarr ");
    e.out = string_concat(e.out, arrv.vref);
    e.out = string_concat(e.out, ", 1\n");
    // Reserve a block id purely to name a unique index slot (allocated inline).
    let fid: Int = e.block;
    e.block = e.block + 1;
    let idx: String = string_concat(string_concat("%fori", int_to_string(fid)), ".idx");
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, idx);
    e.out = string_concat(e.out, " = alloca i64\n  store i64 0, ptr ");
    e.out = string_concat(e.out, idx);
    e.out = string_concat(e.out, "\n");
    let head_id: Int = e.block;
    e.block = e.block + 1;
    let body_id: Int = e.block;
    e.block = e.block + 1;
    let latch_id: Int = e.block;
    e.block = e.block + 1;
    let end_id: Int = e.block;
    e.block = e.block + 1;
    e = llvm_branch(e, head_id);
    e = llvm_open_block(e, head_id);
    let ri: Int = e.reg;
    e.reg = e.reg + 1;
    let iv: String = llvm_reg_name(ri);
    let rc: Int = e.reg;
    e.reg = e.reg + 1;
    let cc: String = llvm_reg_name(rc);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, iv);
    e.out = string_concat(e.out, " = load i64, ptr ");
    e.out = string_concat(e.out, idx);
    e.out = string_concat(e.out, "\n  ");
    e.out = string_concat(e.out, cc);
    e.out = string_concat(e.out, " = icmp slt i64 ");
    e.out = string_concat(e.out, iv);
    e.out = string_concat(e.out, ", ");
    e.out = string_concat(e.out, lenr);
    e.out = string_concat(e.out, "\n  br i1 ");
    e.out = string_concat(e.out, cc);
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(body_id));
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(end_id));
    e.out = string_concat(e.out, "\n");
    e.term = 1;
    e = llvm_open_block(e, body_id);
    let rp: Int = e.reg;
    e.reg = e.reg + 1;
    let p: String = llvm_reg_name(rp);
    let rel: Int = e.reg;
    e.reg = e.reg + 1;
    let elem: String = llvm_reg_name(rel);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, p);
    e.out = string_concat(e.out, " = getelementptr ");
    e.out = string_concat(e.out, elemll);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, data);
    e.out = string_concat(e.out, ", i64 ");
    e.out = string_concat(e.out, iv);
    e.out = string_concat(e.out, "\n  ");
    e.out = string_concat(e.out, elem);
    e.out = string_concat(e.out, " = load ");
    e.out = string_concat(e.out, elemll);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, p);
    e.out = string_concat(e.out, "\n  store ");
    e.out = string_concat(e.out, elemll);
    e.out = string_concat(e.out, " ");
    e.out = string_concat(e.out, elem);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, llvm_slot_ref(nm));
    e.out = string_concat(e.out, "\n");
    e = llvm_block(e, mir, mir.ms_then_start[sidx], mir.ms_then_count[sidx], end_id, latch_id);
    if e.term == 0 {
      e = llvm_branch(e, latch_id);
    }
    e = llvm_open_block(e, latch_id);
    let ri2: Int = e.reg;
    e.reg = e.reg + 1;
    let iv2: String = llvm_reg_name(ri2);
    let rn: Int = e.reg;
    e.reg = e.reg + 1;
    let nn: String = llvm_reg_name(rn);
    e.out = string_concat(e.out, "  ");
    e.out = string_concat(e.out, iv2);
    e.out = string_concat(e.out, " = load i64, ptr ");
    e.out = string_concat(e.out, idx);
    e.out = string_concat(e.out, "\n  ");
    e.out = string_concat(e.out, nn);
    e.out = string_concat(e.out, " = add i64 ");
    e.out = string_concat(e.out, iv2);
    e.out = string_concat(e.out, ", 1\n  store i64 ");
    e.out = string_concat(e.out, nn);
    e.out = string_concat(e.out, ", ptr ");
    e.out = string_concat(e.out, idx);
    e.out = string_concat(e.out, "\n");
    e = llvm_branch(e, head_id);
    e = llvm_open_block(e, end_id);
    return e;
  }
  if kind == mir_for_c_stmt() {
    // for (init; cond; step): init once, loop on cond, continue runs step.
    let mut e: Emit = llvm_stmt(em, mir, mir.ms_init[sidx], 0, 0);
    let head_id: Int = e.block;
    e.block = e.block + 1;
    let body_id: Int = e.block;
    e.block = e.block + 1;
    let step_id: Int = e.block;
    e.block = e.block + 1;
    let end_id: Int = e.block;
    e.block = e.block + 1;
    e = llvm_branch(e, head_id);
    e = llvm_open_block(e, head_id);
    let cond: EmitVal = llvm_expr(e, mir, mir.ms_expr[sidx]);
    let cb: EmitBit = llvm_cond_bit(cond.em, cond.vref);
    e = cb.em;
    e.out = string_concat(e.out, "  br i1 ");
    e.out = string_concat(e.out, cb.bit);
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(body_id));
    e.out = string_concat(e.out, ", label %");
    e.out = string_concat(e.out, llvm_label_name(end_id));
    e.out = string_concat(e.out, "\n");
    e.term = 1;
    e = llvm_open_block(e, body_id);
    e = llvm_block(e, mir, mir.ms_then_start[sidx], mir.ms_then_count[sidx], end_id, step_id);
    if e.term == 0 {
      e = llvm_branch(e, step_id);
    }
    e = llvm_open_block(e, step_id);
    e = llvm_stmt(e, mir, mir.ms_step[sidx], 0, 0);
    e = llvm_branch(e, head_id);
    e = llvm_open_block(e, end_id);
    return e;
  }
  return em;
}

fn llvm_block(em: Emit, mir: Mir, start: Int, count: Int, brk: Int, cont: Int) -> Emit {
  let mut e: Emit = em;
  let mut i: Int = 0;
  while i < count {
    if e.term == 0 {
      e = llvm_stmt(e, mir, mir.mblock_list[start + i], brk, cont);
    }
    i = i + 1;
  }
  return e;
}

fn llvm_name_seen(names: StringArray, name: String) -> Bool {
  let mut i: Int = 0;
  while i < names.len {
    if names[i] == name {
      return true;
    }
    i = i + 1;
  }
  return false;
}

// Collect distinct local names declared anywhere in a block (recursing into
// if / while bodies) so all allocas can be hoisted to the entry block.
fn llvm_collect_locals(mir: Mir, start: Int, count: Int, names: StringArray) -> StringArray {
  let mut acc: StringArray = names;
  let mut i: Int = 0;
  while i < count {
    let s: Int = mir.mblock_list[start + i];
    let k: Int = mir.ms_kind[s];
    if k == mir_local_stmt() {
      if !llvm_name_seen(acc, mir.ms_name[s]) {
        acc = string_array_push(acc, mir.ms_name[s]);
      }
    }
    if k == mir_if_stmt() {
      acc = llvm_collect_locals(mir, mir.ms_then_start[s], mir.ms_then_count[s], acc);
      acc = llvm_collect_locals(mir, mir.ms_else_start[s], mir.ms_else_count[s], acc);
    }
    if k == mir_while_stmt() {
      acc = llvm_collect_locals(mir, mir.ms_then_start[s], mir.ms_then_count[s], acc);
    }
    if k == mir_match_stmt() {
      let astart: Int = mir.ms_then_start[s];
      let acount: Int = mir.ms_then_count[s];
      let mut ai: Int = 0;
      while ai < acount {
        let pat: String = mir.marm_pattern[astart + ai];
        let mut bnd: String = "";
        if string_starts_with(pat, "name:") {
          bnd = pattern_binding(pat);
        }
        if string_starts_with(pat, "variant:") {
          bnd = pattern_binding(pat);
        }
        if string_len(bnd) > 0 {
          if !llvm_name_seen(acc, bnd) {
            acc = string_array_push(acc, bnd);
          }
        }
        acc = llvm_collect_locals(mir, mir.marm_body_start[astart + ai], mir.marm_body_count[astart + ai], acc);
        ai = ai + 1;
      }
    }
    if k == mir_for_range_stmt() || k == mir_for_in_stmt() {
      if !llvm_name_seen(acc, mir.ms_name[s]) {
        acc = string_array_push(acc, mir.ms_name[s]);
      }
      acc = llvm_collect_locals(mir, mir.ms_then_start[s], mir.ms_then_count[s], acc);
    }
    if k == mir_for_c_stmt() {
      let init: Int = mir.ms_init[s];
      if mir.ms_kind[init] == mir_local_stmt() {
        if !llvm_name_seen(acc, mir.ms_name[init]) {
          acc = string_array_push(acc, mir.ms_name[init]);
        }
      }
      acc = llvm_collect_locals(mir, mir.ms_then_start[s], mir.ms_then_count[s], acc);
    }
    i = i + 1;
  }
  return acc;
}

fn llvm_emit_function(mir: Mir, g: Tcx, fi: Int, gcount_in: Int, globals_in: String) -> FnResult {
  let tcx: Tcx = tcx_with_scope(g, mir, fi);
  let mut retty: String = "void";
  if mir.mf_has_ret[fi] == 1 {
    retty = llvm_ty(tcx, mir.mf_ret[fi]);
  }
  let mut o: String = string_concat("", "define ");
  o = string_concat(o, retty);
  o = string_concat(o, " @z_");
  o = string_concat(o, mir.mf_name[fi]);
  o = string_concat(o, "(");
  let pstart: Int = mir.mf_param_start[fi];
  let pcount: Int = mir.mf_param_count[fi];
  let mut pi: Int = 0;
  while pi < pcount {
    if pi > 0 {
      o = string_concat(o, ", ");
    }
    o = string_concat(o, llvm_ty(tcx, mir.mp_type[pstart + pi]));
    o = string_concat(o, " %");
    o = string_concat(o, mir.mp_name[pstart + pi]);
    o = string_concat(o, ".arg");
    pi = pi + 1;
  }
  o = string_concat(o, ") {\n");
  // Entry block: alloca every param slot, then every distinct local slot.
  pi = 0;
  while pi < pcount {
    o = string_concat(o, "  ");
    o = string_concat(o, llvm_slot_ref(mir.mp_name[pstart + pi]));
    o = string_concat(o, " = alloca ");
    o = string_concat(o, llvm_ty(tcx, mir.mp_type[pstart + pi]));
    o = string_concat(o, "\n");
    pi = pi + 1;
  }
  let mut locals: StringArray = string_array_empty();
  locals = llvm_collect_locals(mir, mir.mf_body_start[fi], mir.mf_body_count[fi], locals);
  let mut li: Int = 0;
  while li < locals.len {
    o = string_concat(o, "  ");
    o = string_concat(o, llvm_slot_ref(locals[li]));
    o = string_concat(o, " = alloca ");
    o = string_concat(o, llvm_ty(tcx, scope_type(tcx, locals[li])));
    o = string_concat(o, "\n");
    li = li + 1;
  }
  // Store each incoming param value into its slot.
  pi = 0;
  while pi < pcount {
    o = string_concat(o, "  store ");
    o = string_concat(o, llvm_ty(tcx, mir.mp_type[pstart + pi]));
    o = string_concat(o, " %");
    o = string_concat(o, mir.mp_name[pstart + pi]);
    o = string_concat(o, ".arg, ptr ");
    o = string_concat(o, llvm_slot_ref(mir.mp_name[pstart + pi]));
    o = string_concat(o, "\n");
    pi = pi + 1;
  }
  // Body. break / continue targets default to 0 (never branched to outside a
  // loop; the verifier guarantees break / continue appear only inside one).
  let mut em: Emit = Emit { out: o, reg: 0, block: 0, term: 0, tcx: tcx, gcount: gcount_in, globals: globals_in };
  em = llvm_block(em, mir, mir.mf_body_start[fi], mir.mf_body_count[fi], 0, 0);
  let mut body: String = em.out;
  if em.term == 0 {
    if mir.mf_has_ret[fi] == 1 {
      if retty == "i64" {
        body = string_concat(body, "  ret i64 0\n");
      } else {
        body = string_concat(body, "  ret ");
        body = string_concat(body, retty);
        body = string_concat(body, " zeroinitializer\n");
      }
    } else {
      body = string_concat(body, "  ret void\n");
    }
  }
  body = string_concat(body, "}\n\n");
  return FnResult { body: body, gcount: em.gcount, globals: em.globals };
}

fn llvm_module_header() -> String {
  // Array / string {len, ptr} value types plus the libc helpers their lowering
  // calls. Unused declarations are dropped by clang.
  let mut out: String = "%zarr = type { i64, ptr }\n";
  out = string_concat(out, "%zstr = type { i64, ptr }\n");
  out = string_concat(out, "%zenum = type { i64, i64, ptr }\n");
  out = string_concat(out, "declare ptr @malloc(i64)\n");
  out = string_concat(out, "declare ptr @memcpy(ptr, ptr, i64)\n");
  out = string_concat(out, "declare i32 @memcmp(ptr, ptr, i64)\n");
  out = string_concat(out, "declare i32 @snprintf(ptr, i64, ptr, ...)\n");
  out = string_concat(out, "@.fmt.lld = private constant [5 x i8] c\"%lld\\00\"\n\n");
  return out;
}

fn llvm_emit_module(arena: Arena, mir: Mir) -> String {
  let g: Tcx = tcx_global(arena, mir);
  let mut bodies: String = "";
  let mut gcount: Int = 0;
  let mut globals: String = "";
  let mut f: Int = 0;
  while f < mir.mf_name.len {
    let fr: FnResult = llvm_emit_function(mir, g, f, gcount, globals);
    bodies = string_concat(bodies, fr.body);
    gcount = fr.gcount;
    globals = fr.globals;
    f = f + 1;
  }
  let mut out: String = llvm_module_header();
  out = llvm_emit_struct_defs(out, g);
  out = string_concat(out, globals);
  if string_len(globals) > 0 {
    out = string_concat(out, "\n");
  }
  out = string_concat(out, bodies);
  return out;
}

// Lower `source` (parse-only, no std external enums) and emit textual LLVM IR
// for the scalar subset. Mirrors `mir_dump_via_arena`'s pipeline.
export fn llvm_ir_via_arena(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut start_arena: Arena = arena_empty();
  start_arena.token_start = lex_starts(source);
  let parsed: ParseResult = parse_module(start_arena, kinds, texts, 0);
  let enums: EnumTable = enum_table_build(parsed.arena, false, false);
  let mut mir: Mir = mir_empty();
  mir = mir_enum_dump_table(parsed.arena, mir, false, false);
  mir = lower_module(parsed.arena, enums, mir);
  return llvm_emit_module(parsed.arena, mir);
}

export fn compile(source: String, mode: String) -> String {
  if mode == "ast-dump" {
    return dump_module_via_arena(source);
  }
  if mode == "resolve" {
    return resolve_report(source);
  }
  if mode == "typecheck" {
    return typecheck_report(source);
  }
  if mode == "mir-dump" {
    return mir_dump_pipeline_via_arena(source);
  }
  if mode == "run" {
    return run_main_via_arena(source);
  }
  if mode == "llvm" {
    return llvm_ir_via_arena(source);
  }
  return string_concat("ZETAC_UNKNOWN_MODE ", mode);
}
