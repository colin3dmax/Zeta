  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut out: String = "Module\n";
  let mut index: Int = 0;
  let mut depth: Int = 0;
  while index < kinds.len {
    let kind: Int = kinds[index];
    if depth == 0 && kind == token_module() {
      out = append_rust_module_decl_dump(out, kinds, texts, index);
    }
    if depth == 0 && kind == token_import() {
      out = append_rust_import_dump(out, kinds, texts, index, false);
    }
    if depth == 0 && kind == token_export() && index + 1 < kinds.len {
      let target: Int = kinds[index + 1];
      if target == token_import() {
        out = append_rust_import_dump(out, kinds, texts, index + 1, true);
      }
      if target == token_struct() {
        out = append_rust_struct_dump(out, kinds, texts, index + 1, true);
      }
      if target == token_enum() {
        out = append_rust_enum_dump(out, kinds, texts, index + 1, true);
      }
      if target == token_fn() {
        out = append_rust_fn_dump(out, kinds, texts, index + 1, true);
      }
      index = index + 1;
    }
    if depth == 0 && kind == token_struct() {
      out = append_rust_struct_dump(out, kinds, texts, index, false);
    }
    if depth == 0 && kind == token_enum() {
      out = append_rust_enum_dump(out, kinds, texts, index, false);
    }
    if depth == 0 && kind == token_fn() {
      out = append_rust_fn_dump(out, kinds, texts, index, false);
    }
    if kind == token_lbrace() {
      depth = depth + 1;
    }
    if kind == token_rbrace() && depth > 0 {
      depth = depth - 1;
    }
    index = index + 1;
  }
  return out;
}

fn parse_module_score(kinds: IntArray) -> Int {
  let mut index: Int = 0;
  let mut functions: Int = 0;
  let mut lets: Int = 0;
  let mut returns: Int = 0;
  while index < kinds.len {
    if kinds[index] == token_fn() {
      functions = functions + 1;
    }
    if kinds[index] == token_let() {
      lets = lets + 1;
    }
    if kinds[index] == token_return() {
      returns = returns + 1;
    }
    index = index + 1;
  }
  return functions * 100 + lets * 10 + returns;
}

fn count_token(kinds: IntArray, token: Int) -> Int {
  let mut index: Int = 0;
  let mut count: Int = 0;
  while index < kinds.len {
    if kinds[index] == token {
      count = count + 1;
    }
    index = index + 1;
  }
  return count;
}

fn append_import_dump(out: String, kinds: IntArray, index: Int, exported: Bool) -> String {
  let mut next: String = string_concat(out, "  import segments=");
  next = string_concat(next, int_to_string(count_import_path_segments_at(kinds, index)));
  next = string_concat(next, " alias=");
  next = string_concat(next, bool_text(import_has_alias_at(kinds, index)));
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(exported));
  next = string_concat(next, "\n");
  return next;
}

fn append_named_import_dump(
  out: String,
  kinds: IntArray,
  texts: StringArray,
  index: Int,
  exported: Bool
) -> String {
  let mut next: String = string_concat(out, "  import path=");
  next = string_concat(next, path_text_at(kinds, texts, index));
  let alias: String = import_alias_text_at(kinds, texts, index);
  if alias != "" {
    next = string_concat(next, " alias=");
    next = string_concat(next, alias);
  }
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(exported));
  next = string_concat(next, "\n");
  return next;
}

fn append_named_decl_dump(out: String, item_kind: String, name: String, exported: Bool) -> String {
  let mut next: String = string_concat(out, "  ");
  next = string_concat(next, item_kind);
  next = string_concat(next, " name=");
  next = string_concat(next, name);
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(exported));
  next = string_concat(next, "\n");
  return next;
}

fn append_struct_signature_dump(
  out: String,
  kinds: IntArray,
  texts: StringArray,
  index: Int,
  exported: Bool
) -> String {
  let mut next: String = string_concat(out, "  struct name=");
  next = string_concat(next, ident_text_after(texts, index));
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(exported));
  next = string_concat(next, "\n");
  let mut scan: Int = index + 1;
  while scan < kinds.len && kinds[scan] != token_lbrace() {
    scan = scan + 1;
  }
  if scan < kinds.len {
    scan = scan + 1;
  }
  while scan + 2 < kinds.len && kinds[scan] != token_rbrace() {
    if kinds[scan] == token_ident() && kinds[scan + 1] == token_colon() {
      next = string_concat(next, "    field name=");
      next = string_concat(next, texts[scan]);
      next = string_concat(next, " type=");
      next = string_concat(next, texts[scan + 2]);
      next = string_concat(next, "\n");
      scan = scan + 2;
    }
    scan = scan + 1;
  }
  return next;
}

fn append_enum_signature_dump(
  out: String,
  kinds: IntArray,
  texts: StringArray,
  index: Int,
  exported: Bool
) -> String {
  let mut next: String = string_concat(out, "  enum name=");
  next = string_concat(next, ident_text_after(texts, index));
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(exported));
  next = string_concat(next, "\n");
  let mut scan: Int = index + 1;
  while scan < kinds.len && kinds[scan] != token_lbrace() {
    scan = scan + 1;
  }
  if scan < kinds.len {
    scan = scan + 1;
  }
  while scan < kinds.len && kinds[scan] != token_rbrace() {
    if kinds[scan] == token_ident() {
      next = string_concat(next, "    variant name=");
      next = string_concat(next, texts[scan]);
      if scan + 2 < kinds.len && kinds[scan + 1] == token_lparen() && kinds[scan + 2] == token_ident() {
        next = string_concat(next, " payload=");
        next = string_concat(next, texts[scan + 2]);
        scan = scan + 3;
      }
      next = string_concat(next, "\n");
    }
    scan = scan + 1;
  }
  return next;
}

fn append_fn_signature_dump(
  out: String,
  kinds: IntArray,
  texts: StringArray,
  index: Int,
  exported: Bool
) -> String {
  let mut next: String = string_concat(out, "  fn name=");
  next = string_concat(next, ident_text_after(texts, index));
  next = string_concat(next, " exported=");
  next = string_concat(next, bool_text(exported));
  next = string_concat(next, "\n");
  next = append_param_lines_at(next, kinds, texts, index);
  let return_type: String = return_type_text_at(kinds, texts, index);
  next = string_concat(next, "    return type=");
  next = string_concat(next, return_type);
  next = string_concat(next, "\n");
  return next;
}

fn append_rust_module_decl_dump(out: String, kinds: IntArray, texts: StringArray, index: Int) -> String {
  let mut next: String = string_concat(out, "  ModuleDecl name=");
  next = string_concat(next, path_text_at(kinds, texts, index));
  next = string_concat(next, "\n");
  return next;
}

fn append_rust_import_dump(
  out: String,
  kinds: IntArray,
  texts: StringArray,
  index: Int,
  exported: Bool
