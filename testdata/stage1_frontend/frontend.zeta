module stage1.frontend;
import std.core;

export fn ast_dump_score(source: String) -> Int {
  let kinds: IntArray = lex_kinds(source);
  return parse_module_score(kinds);
}

export fn ast_dump_summary(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let mut out: String = "fn=";
  out = string_concat(out, int_to_string(count_token(kinds, token_fn())));
  out = string_concat(out, ";let=");
  out = string_concat(out, int_to_string(count_token(kinds, token_let())));
  out = string_concat(out, ";return=");
  out = string_concat(out, int_to_string(count_token(kinds, token_return())));
  return out;
}

