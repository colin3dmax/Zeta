export fn ast_dump_import_summary(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let mut out: String = "imports=";
  out = string_concat(out, int_to_string(count_top_level_token(kinds, token_import())));
  out = string_concat(out, ";aliased=");
  out = string_concat(out, int_to_string(count_top_level_import_aliases(kinds)));
  out = string_concat(out, ";exported=");
  out = string_concat(out, int_to_string(count_top_level_export_target(kinds, token_import())));
  out = string_concat(out, ";path_segments=");
  out = string_concat(out, int_to_string(count_top_level_import_path_segments(kinds)));
  return out;
}

export fn ast_dump_item_dump(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let mut out: String = "items\n";
  let mut index: Int = 0;
  let mut depth: Int = 0;
  while index < kinds.len {
    let kind: Int = kinds[index];
    if depth == 0 && kind == token_module() {
      out = string_concat(out, "  module\n");
    }
    if depth == 0 && kind == token_import() {
      out = append_import_dump(out, kinds, index, false);
    }
    if depth == 0 && kind == token_export() && index + 1 < kinds.len {
      let target: Int = kinds[index + 1];
      if target == token_import() {
        out = append_import_dump(out, kinds, index + 1, true);
      }
      if target == token_struct() {
        out = string_concat(out, "  struct exported=true\n");
      }
      if target == token_enum() {
        out = string_concat(out, "  enum exported=true\n");
      }
      if target == token_fn() {
        out = string_concat(out, "  fn exported=true\n");
      }
      index = index + 1;
    }
    if depth == 0 && kind == token_struct() {
      out = string_concat(out, "  struct exported=false\n");
    }
    if depth == 0 && kind == token_enum() {
      out = string_concat(out, "  enum exported=false\n");
    }
    if depth == 0 && kind == token_fn() {
      out = string_concat(out, "  fn exported=false\n");
    }
    if kind == token_lbrace() {
      depth = depth + 1;
    }
    if kind == token_rbrace() && depth > 0 {
      depth = depth - 1;
    }
    index = index + 1;
  }
  return out;
}

export fn ast_dump_named_item_dump(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut out: String = "items\n";
  let mut index: Int = 0;
  let mut depth: Int = 0;
  while index < kinds.len {
    let kind: Int = kinds[index];
    if depth == 0 && kind == token_module() {
      out = string_concat(out, "  module name=");
      out = string_concat(out, path_text_at(kinds, texts, index));
      out = string_concat(out, "\n");
    }
    if depth == 0 && kind == token_import() {
      out = append_named_import_dump(out, kinds, texts, index, false);
    }
    if depth == 0 && kind == token_export() && index + 1 < kinds.len {
      let target: Int = kinds[index + 1];
      if target == token_import() {
        out = append_named_import_dump(out, kinds, texts, index + 1, true);
      }
      if target == token_struct() {
        out = append_named_decl_dump(out, "struct", ident_text_after(texts, index + 1), true);
      }
      if target == token_enum() {
        out = append_named_decl_dump(out, "enum", ident_text_after(texts, index + 1), true);
      }
      if target == token_fn() {
        out = append_named_decl_dump(out, "fn", ident_text_after(texts, index + 1), true);
      }
      index = index + 1;
    }
    if depth == 0 && kind == token_struct() {
      out = append_named_decl_dump(out, "struct", ident_text_after(texts, index), false);
    }
    if depth == 0 && kind == token_enum() {
      out = append_named_decl_dump(out, "enum", ident_text_after(texts, index), false);
    }
    if depth == 0 && kind == token_fn() {
      out = append_named_decl_dump(out, "fn", ident_text_after(texts, index), false);
    }
    if kind == token_lbrace() {
      depth = depth + 1;
    }
    if kind == token_rbrace() && depth > 0 {
      depth = depth - 1;
    }
    index = index + 1;
  }
  return out;
}

export fn ast_dump_signature_dump(source: String) -> String {
  let kinds: IntArray = lex_kinds(source);
  let texts: StringArray = lex_texts(source);
  let mut out: String = "signatures\n";
  let mut index: Int = 0;
  let mut depth: Int = 0;
  while index < kinds.len {
    let kind: Int = kinds[index];
    if depth == 0 && kind == token_export() && index + 1 < kinds.len {
      let target: Int = kinds[index + 1];
      if target == token_struct() {
        out = append_struct_signature_dump(out, kinds, texts, index + 1, true);
      }
      if target == token_enum() {
        out = append_enum_signature_dump(out, kinds, texts, index + 1, true);
      }
      if target == token_fn() {
        out = append_fn_signature_dump(out, kinds, texts, index + 1, true);
      }
      index = index + 1;
    }
    if depth == 0 && kind == token_struct() {
      out = append_struct_signature_dump(out, kinds, texts, index, false);
    }
    if depth == 0 && kind == token_enum() {
      out = append_enum_signature_dump(out, kinds, texts, index, false);
    }
    if depth == 0 && kind == token_fn() {
      out = append_fn_signature_dump(out, kinds, texts, index, false);
    }
    if kind == token_lbrace() {
      depth = depth + 1;
    }
    if kind == token_rbrace() && depth > 0 {
      depth = depth - 1;
    }
    index = index + 1;
  }
  return out;
}

