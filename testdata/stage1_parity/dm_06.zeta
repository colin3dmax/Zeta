module probe.dm06;
fn f(x: Int) -> Int {
  if x > 0 {
    while x < 10 {
      match x {
        5 -> { return 50; }
        _ -> { return x; }
      }
      return 1;
    }
    return 2;
  } else {
    match x {
      0 -> { return 0; }
      _ -> { return 3; }
    }
    return 4;
  }
  return x;
}
