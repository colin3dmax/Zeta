module probe.dm08;
fn f(s: String) -> Int {
  match s {
    "a" -> {
      match flag {
        true -> { return 1; }
        false -> {
          match s {
            "b" -> { return 2; }
            _ -> { return 3; }
          }
          return 4;
        }
      }
      return 5;
    }
    _ -> { return 0; }
  }
  return 0;
}
