module probe.dc20;
fn six_level_else(n: Int) -> Int {
  let mut r: Int = 0;
  if n == 0 {
    r = 0;
  } else {
    if n == 1 {
      r = 1;
    } else {
      if n == 2 {
        r = 2;
      } else {
        if n == 3 {
          r = 3;
        } else {
          if n == 4 {
            r = 4;
          } else {
            if n == 5 {
              r = 5;
            } else {
              r = 6;
            }
          }
        }
      }
    }
  }
  return r;
}
