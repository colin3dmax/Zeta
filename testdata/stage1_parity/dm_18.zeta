module probe.dm18;
fn f(x: Int) -> Int {
  match x {
    0 -> {
      match build()[x] {
        1 -> { return 1; }
        _ -> {
          match grid()[x][0] {
            2 -> { return 2; }
            _ -> { return 3; }
          }
          return 4;
        }
      }
      return 5;
    }
    _ -> { return 0; }
  }
  return x;
}
