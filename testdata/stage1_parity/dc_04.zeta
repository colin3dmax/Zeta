module probe.dc04;
fn while_if_while_if(n: Int) -> Int {
  let mut i: Int = 0;
  let mut acc: Int = 0;
  while i < n {
    if i < n {
      let mut j: Int = 0;
      while j < i {
        if j == 0 {
          acc = acc + 1;
        } else {
          acc = acc + j;
        }
        j = j + 1;
      }
    } else {
      acc = acc - 1;
    }
    i = i + 1;
  }
  return acc;
}
