module probe.dm24;
fn f(x: Int) -> Int {
  match x {
    0 -> {
      if x > 1 {
        match x {
          2 -> {
            while x < 9 {
              match x {
                3 -> { return 3; }
                _ -> { return x; }
              }
              return 7;
            }
            return 8;
          }
          _ -> { return 6; }
        }
        return 5;
      } else {
        return 4;
      }
      return 1;
    }
    _ -> { return 0; }
  }
  return x;
}
