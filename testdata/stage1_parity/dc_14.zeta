module probe.dc14;
fn five_deep(a: Int, b: Int, c: Int, d: Int, e: Int) -> Int {
  let mut r: Int = 0;
  if a > 0 {
    if b > 0 {
      if c > 0 {
        if d > 0 {
          if e > 0 {
            r = 5;
          } else {
            r = 4;
          }
        } else {
          r = 3;
        }
      } else {
        r = 2;
      }
    } else {
      r = 1;
    }
  } else {
    r = 0;
  }
  return r;
}
