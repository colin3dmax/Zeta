module probe.dc10;
fn complex_cond_deep(a: Int, b: Int, c: Int) -> Int {
  let mut r: Int = 0;
  while a < b && b < c || a == c {
    if a < b && b < c {
      if a == 0 || b == 0 {
        r = r + 1;
      } else {
        r = r + 2;
      }
    } else {
      r = r - 1;
    }
    a = a + 1;
  }
  return r;
}
