enum Shape { Dot, Box(Int), }

fn f(x: Int, s: String, b: Bool, sh: Shape) -> Int {
  match x {
    1 -> {
      return 1;
    },
    n -> {
      return n;
    },
  }
  match s {
    "a\nb" -> {
      return 2;
    },
    _ -> {
      return 0;
    },
  }
  match b {
    true -> {
      return 3;
    },
    false -> {
      return 4;
    },
  }
  match sh {
    Shape.Dot -> {
      return 5;
    },
    Shape.Box(v) -> {
      return v;
    },
  }
  return 0;
}
